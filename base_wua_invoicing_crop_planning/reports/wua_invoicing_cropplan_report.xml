<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <report id="action_wua_irrigationcontract_report"
        string="Irrigation Contract"
        model="wua.cropplan"
        report_type="qweb-pdf"
        name="base_wua_invoicing_crop_planning.report_wua_invocing_cropplan"
        paperformat="base_wua_report.paperformat_wua_reports"/>

    <template id="report_wua_invocing_cropplan">
        <t t-call="report.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="base_wua_report.wua_external_layout">
                    <t t-call="base_wua_invoicing_crop_planning.report_wua_invocing_cropplan_document"/>
                </t>
            </t>
        </t>
    </template>

    <template id="report_wua_invocing_cropplan_document">
        <div class="page">
            <div name="section_header">
                <div name="title" style="font-size: 16;text-align: center;">
                    <strong>Irrigation Contract</strong>
                    <t t-if="o.state == 'draft'">
                        <span>( DRAFT )</span>
                    </t>
                </div>
                <div name="contract_num" style="text-align: right;">
                    <span>Contract number:</span>
                    <span t-esc="o.order_number + '/' + o.agriculturalseason_id.name.split('-')[0]"/>
                </div>
                <div name="agriculturalseason_id" style="text-align: right;">
                    <span t-field="o.agriculturalseason_id"/>
                </div>
            </div>
            <br/>
            <div name="section_master" class="row">
                <div><strong>Contracting from one side:</strong></div>
                <div name="company_id">
                    <t t-if="o.partner_id.company_id">
                    <span>&amp;emsp;</span>
                    <span t-field="o.partner_id.company_id.name"></span>
                    <span>as the organism in charge of the Watering Area operations.</span>
                    </t>
                </div>
                <br/>
                <div name="partner_id">
                    <strong>And from other side:</strong>
                    <div name="crop_planner_data">
                        <span>&amp;emsp;</span>
                        <span t-field="o.partner_id.name"/>
                        <span> as crop planner.</span>
                        <t t-if="o.partner_id.vat">
                            <div>VAT:</div>
                            <span t-field="o.partner_id.vat"></span>
                        
                        </t>
                        
                        <div>
                        
                        
                        </div>
                    
                    </div>
                </div>
                
            </div>
            <div name="section_detail" class="row" style="margin-left: 0px; margin-right: 0px;">
                <div name="detail_title" class="col-xs-12" style="font-size: 13;text-align: center;margin-top: 50px;margin-bottom: 30px;">
                    E N R O L L M E N T S
                </div>
                <table class="table table-condensed">
                    <thead>
                        <tr style="background-color: #e9e9e9">
                            <th class="text-left">Parcel</th>
                            <th class="text-center">Order</th>
                            <th class="text-left">Type</th>
                            <th class="text-left">Cultivation</th>
                            <th class="text-left">Variety</th>
                            <th class="text-left">Irrig. System</th>
                            <th class="text-left">Prod. Method</th>
                            <th class="text-right">Area</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="o.enrolledsubparcel_ids" t-as="l">
                            <td align="left"><span t-field="l.parcel_id"/></td>
                            <td align="center"><span t-field="l.order"/></td>
                            <td align="left"><span t-field="l.subparceltype_id"/></td>
                            <td align="left"><span t-field="l.cultivation_id"/></td>
                            <td align="left"><span t-field="l.cultivationvariety_id"/></td>
                            <td align="left"><span t-field="l.irrigationsystem_id"/></td>
                            <td align="left"><span t-field="l.productionmethod_id"/></td>
                            <td align="right"><span t-field="l.area_official"/></td>
                        </tr>
                    </tbody>
                </table>
                <div class="row" name="section_total">
                    <div class="col-xs-8"><![CDATA[&nbsp;]]></div>
                    <div class="col-xs-2 text-right">Total Area :</div>
                    <div class="col-xs-2 text-right"><span t-field="o.area_official" style="margin-right: 4px;"/></div>
                </div>
            </div>
        </div>
    </template>

</odoo>