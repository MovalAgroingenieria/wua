<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_reading_view_form" model="ir.ui.view">
        <field name="name">Readings (form view)</field>
        <field name="model">wua.reading</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation.wua_reading_view_form"/>
        <field name="arch" type="xml">
          <xpath expr="//field[@name='last_reading_value']"
                 position="after">
                <field name="watercosts_partner_id"/>
          </xpath>
        </field>
    </record>

</odoo>
