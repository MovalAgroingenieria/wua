#. module: base_wua_invoicing_separate_waterconnection_billing
#: code:addons/base_wua_invoicing_separate_waterconnection_billing/models/wua_waterconnection.py:223
#, python-format
msgid "Separate water connection billing: It is mandatory to enter a valid mandate of the only partner that pays the other costs."
msgstr "Facturació separada de tomes: És obligatori indicar un mandat validat que pertanyi a l'soci (únic) que es faci càrrec de les despeses diferents de l'aigua."

#. module: base_wua_invoicing_separate_waterconnection_billing
#: code:addons/base_wua_invoicing_separate_waterconnection_billing/models/wua_waterconnection.py:207
#, python-format
msgid "Separate water connection billing: It is mandatory to enter a valid mandate of the only partner that pays the water costs."
msgstr "Facturació separada de tomes: És obligatori indicar un manat validat que pertanyi a l'soci (únic) que es faci càrrec de les despeses d'aigua."

#. module: base_wua_invoicing_separate_waterconnection_billing
#: code:addons/base_wua_invoicing_separate_waterconnection_billing/models/account_banking_mandate.py:38
#, python-format
msgid "Separate water connection billing: The mandate must be a valid mandate, because there are some water connections associated with this mandate (other costs)."
msgstr "Facturació separada de tomes: El mandat ha de ser obligatòriament un mandat vàlid, ja que hi ha tomes associades a aquest mandat (facturació separada per altres despeses)."

#. module: base_wua_invoicing_separate_waterconnection_billing
#: code:addons/base_wua_invoicing_separate_waterconnection_billing/models/account_banking_mandate.py:26
#, python-format
msgid "Separate water connection billing: The mandate must be a valid mandate, because there are some water connections associated with this mandate (water costs)."
msgstr "Facturació separada de tomes: El mandat ha de ser obligatòriament un mandat vàlid, ja que hi ha tomes associades a aquest mandat (facturació separada per despeses d'aigua)."

#. module: base_wua_invoicing_separate_waterconnection_billing
#: code:addons/base_wua_invoicing_separate_waterconnection_billing/models/wua_waterconnection.py:192
#, python-format
msgid "Separate water connection billing: there can be no more one payer for the other costs."
msgstr "Facturació separada de tomes: No es permet que hi hagi més d'un soci a càrrec de despeses diferents de l'aigua."

#. module: base_wua_invoicing_separate_waterconnection_billing
#: code:addons/base_wua_invoicing_separate_waterconnection_billing/models/wua_waterconnection.py:183
#, python-format
msgid "Separate water connection billing: there can be no more one water payer."
msgstr "Facturació separada de tomes: No es permet que hi hagi més d'un soci a càrrec de les despeses d'aigua."

