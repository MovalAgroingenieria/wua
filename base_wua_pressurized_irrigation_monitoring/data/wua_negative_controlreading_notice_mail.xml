<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Definición de la plantilla de correo electrónico -->
        <record model="mail.template" id="email_template_negative_controlreading">
            <field name="name">Notificación de lectura de control negativa</field>
            <field name="model_id" ref="model_wua_negative_controlreading"/>
            <field name="subject">Lectura de control negativa creada - ${object.name}</field>
            <field name="email_from"></field>
            <field name="email_to"></field>
            <field name="lang"></field>
            <field name="auto_delete">True</field>
            <field name="body_html">
                <![CDATA[
                <p>Se ha creado una lectura de control negativa con los siguientes detalles:</p>
                <ul>
                    <li>Identificador del elemento: ${object.name}</li>
                    <li>Volumen: ${object.volume} m³</li>
                    <li>Diferencia con respecto al último consumo: ${object.controlpresconsumption_volume} m³</li>
                </ul>
                <p>Por favor, revise el registro y tome las medidas necesarias.</p>
                ]]>
            </field>
        </record>
    </data>
</odoo>
