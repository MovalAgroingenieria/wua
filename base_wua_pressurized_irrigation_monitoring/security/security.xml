<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="rule_wua_comparative_subparcel_presconsumption_group_wua_portal_user" model="ir.rule">
      <field name="name">Rule for Wua Portal User on subparcel comparative consumptions</field>
      <field name="model_id" ref="model_wua_comparative_subparcel_presconsumption"/>
      <field name="domain_force">
          ['|', ('partner_id','=',user.partner_id.id),
                ('partner_id.child_ids','=',user.partner_id.id)]
      </field>
      <field name="groups" eval="[(4, ref('base_wua.group_wua_portal_user'))]"/>
  </record>

  <record id="rule_wua_comparative_parcel_presconsumption_group_wua_portal_user" model="ir.rule">
      <field name="name">Rule for Wua Portal User on parcel comparative consumptions</field>
      <field name="model_id" ref="model_wua_comparative_parcel_presconsumption"/>
      <field name="domain_force">
          ['|', ('partner_id','=',user.partner_id.id),
                ('partner_id.child_ids','=',user.partner_id.id)]
      </field>
      <field name="groups" eval="[(4, ref('base_wua.group_wua_portal_user'))]"/>
  </record>

  <record id="rule_wua_comparative_partner_presconsumption_group_wua_portal_user" model="ir.rule">
      <field name="name">Rule for Wua Portal User on partner comparative consumptions</field>
      <field name="model_id" ref="model_wua_comparative_partner_presconsumption"/>
      <field name="domain_force">
          ['|', ('partner_id','=',user.partner_id.id),
                ('partner_id.child_ids','=',user.partner_id.id)]
      </field>
      <field name="groups" eval="[(4, ref('base_wua.group_wua_portal_user'))]"/>
  </record>

</odoo>
