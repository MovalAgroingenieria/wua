<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_comparative_parcel_presconsumption_view_tree" model="ir.ui.view">
        <field name="name">Parcels (tree view)</field>
        <field name="model">wua.comparative.parcel.presconsumption</field>
        <field name="arch" type="xml">
            <tree
             class="o_base_wua_pressurized_irrigation_monitoring_comparative_parcel_presconsumption_view_tree"
             create="false">
              <field name="controlperiod_id"/>
              <field name="parcel_id"/>
              <field name="hydraulicsector_id"/>
              <field name="partner_id"/>
              <field name="area_official"/>
              <field name="estimated_consumption"/>
              <field name="real_consumption"/>
              <field name="deviation"/>
            </tree>
        </field>
    </record>

    <record id="wua_comparative_parcel_presconsumption_view_search" model="ir.ui.view">
        <field name="name">Parcels (search view)</field>
        <field name="model">wua.comparative.parcel.presconsumption</field>
        <field name="arch" type="xml">
            <search>
              <field name="parcel_id"/>
              <field name="partner_id"/>
              <field name="hydraulicsector_id"/>
              <filter string="Active Agriculturalseason" name="agriculturalseasonactive"
               domain="[('agriculturalseason_id.active_agriculturalseason','=',True)]"/>
              <group expand="0" string="Group By">
                  <filter string="Agriculturalseason"
                   name="agriculturalseason"
                   context="{'group_by':'agriculturalseason_id'}"/>
                  <filter string="Controlperiod"
                   name="controlperiod"
                   context="{'group_by':'controlperiod_id'}"/>
                  <filter string="Hydraulicsector"
                   name="hydraulicsector"
                   context="{'group_by':'hydraulicsector_id'}"/>
                  <filter string="Irrigation Partner"
                   name="partner"
                   context="{'group_by':'partner_id'}"/>
              </group>
            </search>
        </field>
    </record>

    <record id="wua_comparative_parcel_presconsumption_action" model="ir.actions.act_window">
        <field name="name">Parcels</field>
        <field name="res_model">wua.comparative.parcel.presconsumption</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="wua_comparative_parcel_presconsumption_view_tree"/>
        <field name="search_view_id" ref="wua_comparative_parcel_presconsumption_view_search"/>
        <field name="context">{'search_default_agriculturalseasonactive': True}</field>
    </record>

    <menuitem id="wua_comparative_parcel_presconsumption_menu"
              name="Parcels"
              parent="base_wua_pressurized_irrigation_monitoring.monitoring_comparative_consumption"
              action="wua_comparative_parcel_presconsumption_action"
              sequence="3"
              groups="base_wua.group_wua_user"/>

</odoo>
