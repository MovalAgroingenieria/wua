<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_comparative_parcel_presconsumption_view_tree" model="ir.ui.view">
        <field name="name">Parcels (tree view)</field>
        <field name="model">wua.comparative.parcel.presconsumption</field>
        <field name="arch" type="xml">
            <tree
             class="o_base_wua_pressurized_irrigation_monitoring_comparative_parcel_presconsumption_view_tree"
             create="false">
              <field name="cadastral_reference_link" invisible="1"/>
              <field name="gis_viewer_link" invisible="1"/>
              <field name="controlperiod_id"/>
              <field name="parcel_id"/>
              <field name="hydraulicsector_id"/>
              <field name="partner_id"/>
              <field name="area_official"/>
              <button name="action_see_gis_viewer"
                      type="object" class="oe_stat_button"
                      string="GIS Viewer (zoom to parcel)"
                      icon="fa-map-marker"
                      attrs="{'invisible':
                              [('gis_viewer_link','=',False)]}"/>
              <button name="action_see_cadastral_report"
                      type="object" class="oe_stat_button"
                      string="Cadastral Report"
                      icon="fa-cubes"
                      attrs="{'invisible': [('cadastral_reference_link','=','')]}"/>
              <field name="estimated_consumption"/>
              <field name="real_consumption"/>
              <field name="deviation"/>
              <field name="consumption_category" invisible="1" />
              <button icon='fa-circle semaphore-green' readonly="1" attrs="{'invisible':[('consumption_category', '!=', 'A')]}"/>
              <button icon='fa-circle semaphore-yellow' readonly="1" attrs="{'invisible':[('consumption_category', '!=', 'B')]}"/>
              <button icon='fa-circle semaphore-red' readonly="1" attrs="{'invisible':[('consumption_category', '!=', 'C')]}"/>
            </tree>
        </field>
    </record>

    <record id="wua_comparative_parcel_presconsumption_view_search" model="ir.ui.view">
        <field name="name">Parcels (search view)</field>
        <field name="model">wua.comparative.parcel.presconsumption</field>
        <field name="arch" type="xml">
            <search>
              <field name="parcel_id"/>
              <field name="partner_id"/>
              <field name="hydraulicsector_id"/>
              <filter string="Active Agricultural Season" name="agriculturalseasonactive"
               domain="[('agriculturalseason_id.active_agriculturalseason','=',True)]"/>
              <separator/>
              <filter string="Correct Irrigation" name="category_a"
               domain="[('consumption_category','=','a')]"/>
              <filter string="Acceptable Irrigation" name="category_b"
               domain="[('consumption_category','=','b')]"/>
              <filter string="Unacceptable Irrigation" name="category_c"
               domain="[('consumption_category','=','c')]"/>
              <group expand="0" string="Group By">
                  <filter string="Agricultural Season"
                   name="agriculturalseason"
                   context="{'group_by':'agriculturalseason_id'}"/>
                  <filter string="Control Period"
                   name="controlperiod"
                   context="{'group_by':'controlperiod_id'}"/>
                  <filter string="Hydraulic Sector"
                   name="hydraulicsector"
                   context="{'group_by':'hydraulicsector_id'}"/>
                  <filter string="Irrigation Partner"
                   name="partner"
                   context="{'group_by':'partner_id'}"/>
                  <filter string="Consumption Category"
                   name="consumption_category"
                   context="{'group_by':'consumption_category'}"/>
              </group>
            </search>
        </field>
    </record>

    <record id="wua_comparative_parcel_presconsumption_action" model="ir.actions.act_window">
        <field name="name">Parcels</field>
        <field name="res_model">wua.comparative.parcel.presconsumption</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="wua_comparative_parcel_presconsumption_view_tree"/>
        <field name="search_view_id" ref="wua_comparative_parcel_presconsumption_view_search"/>
        <field name="context">{'search_default_agriculturalseasonactive': True,
                               'search_default_controlperiod': True}</field>
    </record>

    <menuitem id="wua_comparative_parcel_presconsumption_menu"
              name="Parcels"
              parent="base_wua_pressurized_irrigation_monitoring.monitoring_comparative_consumption"
              action="wua_comparative_parcel_presconsumption_action"
              sequence="3"
              groups="base_wua.group_wua_user,base_wua.group_wua_portal_user"/>

</odoo>
