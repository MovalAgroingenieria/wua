<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_comparative_cultivation_presconsumption_view_tree" model="ir.ui.view">
        <field name="name">Cultivations (tree view)</field>
        <field name="model">wua.comparative.cultivation.presconsumption</field>
        <field name="arch" type="xml">
            <tree
             class="o_base_wua_pressurized_irrigation_monitoring_comparative_cultivation_presconsumption_view_tree"
             create="false">
              <field name="controlperiod_id"/>
              <field name="cultivation_id"/>
              <field name="estimated_consumption"/>
              <field name="real_consumption"/>
              <field name="deviation"/>
              <field name="deviation_percentage" string="(%)"/>
              <field name="consumption_category" invisible="1" />
              <button icon='fa-circle semaphore-green' readonly="1" attrs="{'invisible':[('consumption_category', '!=', 'A')]}"/>
              <button icon='fa-circle semaphore-yellow' readonly="1" attrs="{'invisible':[('consumption_category', '!=', 'B')]}"/>
              <button icon='fa-circle semaphore-red' readonly="1" attrs="{'invisible':[('consumption_category', '!=', 'C')]}"/>
            </tree>
        </field>
    </record>

    <record id="wua_comparative_cultivation_presconsumption_view_search" model="ir.ui.view">
        <field name="name">Cultivations (search view)</field>
        <field name="model">wua.comparative.cultivation.presconsumption</field>
        <field name="arch" type="xml">
            <search>
              <field name="cultivation_id"/>
              <field name="agriculturalseason_id"/>
              <field name="controlperiod_id"/>
              <filter string="Active Agricultural Season" name="agriculturalseasonactive"
               domain="[('agriculturalseason_id.active_agriculturalseason','=',True)]"/>
              <separator/>
              <filter string="Correct Irrigation" name="category_a"
               domain="[('consumption_category','=','a')]"/>
              <filter string="Acceptable Irrigation" name="category_b"
               domain="[('consumption_category','=','b')]"/>
              <filter string="Unacceptable Irrigation" name="category_c"
               domain="[('consumption_category','=','c')]"/>
              <separator/>
              <filter string="Current Controlperiod"
                    name="current_controlperiod"
                    domain="[('controlperiod_id.is_the_current', '=', True)]"/>
              <separator/>
              <group expand="0" string="Group By">
                  <filter string="Agricultural Season"
                   name="agriculturalseason"
                   context="{'group_by':'agriculturalseason_id'}"/>
                  <filter string="Control Period"
                   name="controlperiod"
                   context="{'group_by':'controlperiod_id'}"/>
                  <filter string="Consumption Category"
                   name="consumption_category"
                   context="{'group_by':'consumption_category'}"/>
              </group>
            </search>
        </field>
    </record>

    <record id="wua_comparative_cultivation_presconsumption_action" model="ir.actions.act_window">
        <field name="name">Cultivations (agregated comparative consumptions)</field>
        <field name="res_model">wua.comparative.cultivation.presconsumption</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="wua_comparative_cultivation_presconsumption_view_tree"/>
        <field name="search_view_id" ref="wua_comparative_cultivation_presconsumption_view_search"/>
        <field name="context">{'search_default_current_controlperiod': True}</field>
    </record>

    <menuitem id="wua_comparative_cultivation_presconsumption_menu"
              name="Cultivations"
              parent="base_wua_pressurized_irrigation_monitoring.monitoring_comparative_consumption"
              action="wua_comparative_cultivation_presconsumption_action"
              sequence="2"
              groups="base_wua.group_wua_user"/>

</odoo>
