<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_comparative_subparcel_presconsumption_view_form" model="ir.ui.view">
        <field name="name">Subparcels (form view)</field>
        <field name="model">wua.comparative.subparcel.presconsumption</field>
        <field name="arch" type="xml">
            <form duplicate="0" create="false" delete="false">
              <sheet>
                  <group name="master_data">
                      <group name="master_data_left">
                          <field name="parcel_id" readonly="1"/>
                          <field name="subparcel_id" readonly="1"/>
                          <field name="cultivation_id" readonly="1"/>
                          <field name="cultivationvariety_id" readonly="1"/>
                          <field name="tree_development" readonly="1"/>
                          <field name="shaded_percentage" readonly="1"/>
                          <field name="soil_type" readonly="1"/>
                          <field name="organic_material_percentage" readonly="1"/>
                          <field name="orientation" readonly="1"/>
                          <field name="drippers_number" readonly="1"/>
                          <field name="drippers_nomial_flow" readonly="1"/>
                          <field name="tree_lateral_number" readonly="1"/>
                          <field name="plantation_year" readonly="1"/>
                          <field name="tree_distance" readonly="1"/>
                          <field name="row_distance" readonly="1"/>
                          <field name="tree_drippers_number" readonly="1"/>
                      </group>
                      <group name="master_data_right">
                          <field name="partner_id" readonly="1"/>
                          <field name="hydraulicsector_id" readonly="1"/>
                          <field name="area_official" readonly="1"/>
                          <field name="cadastral_reference" readonly="1"/>
                          <field name="area_perc" readonly="1"/>
                          <field name="productionmethod_id" readonly="1"/>
                          <field name="irrigationsystem_id" readonly="1"/>
                          <field name="updated_in_remotecontrol" readonly="1"/>
                          <field name="cultivation_age" readonly="1"/>
                          <field name="theoretical_consumption" readonly="1"/>
                          <field name="regularization"/>
                          <field name="estimated_consumption" readonly="1"/>
                          <field name="real_consumption" readonly="1"/>
                          <field name="deviation" readonly="1"/>

                      </group>
                  </group>
                  <group name="slave_data">
                      <notebook name="slave_data_notebook">
                          <page name="notes_page" string="Notes">
                              <field name="notes"/>
                          </page>
                      </notebook>
                  </group>
              </sheet>
            </form>
        </field>
    </record>

    <record id="wua_comparative_subparcel_presconsumption_view_tree" model="ir.ui.view">
        <field name="name">Subparcels (tree view)</field>
        <field name="model">wua.comparative.subparcel.presconsumption</field>
        <field name="arch" type="xml">
            <tree
             class="o_base_wua_pressurized_irrigation_monitoring_comparative_subparcel_presconsumption_view_tree"
             create="false">
              <field name="controlperiod_id"/>
              <field name="parcel_id"/>
              <field name="subparcel_id"/>
              <field name="hydraulicsector_id"/>
              <field name="partner_id"/>
              <field name="area_official"/>
              <field name="cultivation_id"/>
              <field name="estimated_consumption"/>
              <field name="real_consumption"/>
              <field name="deviation"/>
            </tree>
        </field>
    </record>

    <record id="wua_comparative_subparcel_presconsumption_view_search" model="ir.ui.view">
        <field name="name">Subparcels (search view)</field>
        <field name="model">wua.comparative.subparcel.presconsumption</field>
        <field name="arch" type="xml">
            <search>
              <field name="parcel_id"/>
              <field name="partner_id"/>
              <field name="cultivation_id"/>
              <field name="hydraulicsector_id"/>
              <filter string="Active Agriculturalseason" name="agriculturalseasonactive"
               domain="[('agriculturalseason_id.active_agriculturalseason','=',True)]"/>
              <group expand="0" string="Group By">
                  <filter string="Agriculturalseason"
                   name="agriculturalseason"
                   context="{'group_by':'agriculturalseason_id'}"/>
                  <filter string="Controlperiod"
                   name="controlperiod"
                   context="{'group_by':'controlperiod_id'}"/>
                  <filter string="Cultivation"
                   name="cultivation"
                   context="{'group_by':'cultivation_id'}"/>
                  <filter string="Tree Development"
                   name="treedevelopment"
                   context="{'group_by':'tree_development'}"/>
                  <filter string="Soil Type"
                   name="soiltype"
                   context="{'group_by':'soil_type'}"/>
                  <filter string="Hydraulicsector"
                   name="hydraulicsector"
                   context="{'group_by':'hydraulicsector_id'}"/>
                  <filter string="Irrigation Partner"
                   name="partner"
                   context="{'group_by':'partner_id'}"/>
                  <filter string="Parcel"
                   name="parcel"
                   context="{'group_by':'parcel_id'}"/>
              </group>
            </search>
        </field>
    </record>

    <record id="wua_comparative_subparcel_presconsumption_view_graphic" model="ir.ui.view">
        <field name="name">Subparcels (graph view)</field>
        <field name="model">wua.comparative.subparcel.presconsumption</field>
        <field name="arch" type="xml">
            <graph string="Subparcel Presconsumptions" type="pie">
                <field name="cultivation_id"/>
                <field name="real_consumption" type='measure'/>
            </graph>
        </field>
    </record>

    <record id="wua_comparative_subparcel_presconsumption_view_pivot" model="ir.ui.view">
        <field name="name">Subparcels (pivot view)</field>
        <field name="model">wua.comparative.subparcel.presconsumption</field>
        <field name="arch" type="xml">
            <pivot string="Agregated Values" display_quantity="true">
              <field name="cultivation_id"/>
              <field name="real_consumption" type='measure'/>
            </pivot>
        </field>
    </record>

    <record id="wua_comparative_subparcel_presconsumption_action" model="ir.actions.act_window">
        <field name="name">Subparcels</field>
        <field name="res_model">wua.comparative.subparcel.presconsumption</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form,graph,pivot</field>
        <field name="view_id" ref="wua_comparative_subparcel_presconsumption_view_tree"/>
        <field name="search_view_id" ref="wua_comparative_subparcel_presconsumption_view_search"/>
        <field name="context">{'search_default_agriculturalseasonactive': True,
                               'graph_mode':'pie'}</field>
    </record>

    <menuitem id="wua_comparative_subparcel_presconsumption_menu"
              name="Subparcels"
              parent="base_wua_pressurized_irrigation_monitoring.monitoring_comparative_consumption"
              action="wua_comparative_subparcel_presconsumption_action"
              sequence="4"
              groups="base_wua.group_wua_user"/>

</odoo>
