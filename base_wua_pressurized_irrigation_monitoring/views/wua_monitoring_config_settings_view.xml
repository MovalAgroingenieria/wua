<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_monitoring_config_settings_view_form" model="ir.ui.view">
        <field name="name">Parameters</field>
        <field name="model">wua.monitoring.configuration</field>
        <field name="arch" type="xml">
            <form string="Monitoring Settings (sets)"
                  class="oe_form_configuration">
                <header>
                    <button string="Apply" type="object" name="execute"
                            class="oe_highlight"/>
                    <button string="Cancel" type="object" name="cancel"
                            class="oe_link"/>
                </header>
                <group name="monitoring_values"
                       string="Monitoring Values">
                    <field name="control_periodicity" widget="radio"/>
                    <field name="uniformity_irrigation_application"/>
                    <field name="max_deviation_categ_01"/>
                    <field name="max_deviation_categ_02"/>
                </group>
                <group name="gis_settings"
                       string="GIS Settings">
                    <field name="url_gis_viewer_subparcel_param"/>
                </group>
                <group name="incoming_mails"
                       string="Incoming Mails (agroclimatic data)">
                    <field name="incoming_mail_email_from"/>
                    <field name="incoming_mail_subject"/>
                    <field name="incoming_mail_only_emails_to_admin"/>
                    <field name="incoming_mail_col_finaldate"/>
                    <field name="incoming_mail_col_et0"/>
                    <field name="incoming_mail_col_pe"/>
                </group>
                <group name="reports_config" string="Reports configuration">
                    <field name="monitoring_informative_clauses"/>
                </group>
            </form>
        </field>
    </record>

    <record id="wua_monitoring_configuration_action"
            model="ir.actions.act_window">
        <field name="name">Configure Monitoring</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">wua.monitoring.configuration</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
    </record>

    <menuitem id="wua_monitoring_configuration_menu"
              name="Monitoring Parameters"
              parent="base_wua_pressurized_irrigation_monitoring.monitoring_configuration_menu"
              action="wua_monitoring_configuration_action"
              sequence="1"
              groups="base.group_system"/>

</odoo>