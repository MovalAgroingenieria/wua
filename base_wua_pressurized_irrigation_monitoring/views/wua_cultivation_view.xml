<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_cultivation_comparative_presconsumption_action" model="ir.actions.server">
        <field name="name">Cultivations</field>
        <field name="model_id" ref="base_wua_pressurized_irrigation_monitoring.model_wua_cultivation"/>
        <field name="code">action = env["wua.cultivation"].get_wua_cultivation_comparative_presconsumption_action()</field>
    </record>

    <record id="wua_cultivation_view_form" model="ir.ui.view">
        <field name="name">Cultivations (form view)</field>
        <field name="model">wua.cultivation</field>
        <field name="inherit_id"
               ref="base_wua.wua_cultivation_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='description']" position="after">
                <field name="monitoring"/>
                <field name="lower_age_middle"/>
                <field name="upper_age_middle"/>
            </xpath>
            <xpath expr="//div[@name='buttons']" position="inside">
                <button name="%(wua_cultivation_comparative_presconsumption_action)d"
                        type="action"
                        class="oe_stat_button"
                        icon="fa-monitoring-compare"
                        groups="base_wua.group_wua_user">
                        <div class="o_form_field o_stat_info">
                            <span class="o_stat_text">
                                Comp. Consumptions
                            </span>
                        </div>
                </button>
                <button name="action_get_cultivation_kc"
                        type="object" class="oe_stat_button"
                        icon="fa-times-circle"
                        attrs="{'invisible': [('monitoring','!=',True)]}">
                    <div class="o_form_field o_stat_info">
                        <span class="o_stat_text">Kc-Values</span>
                    </div>
                </button>
            </xpath>
            <xpath expr="//group[@name='slave_data']" position="before">
                <div style="width: 96%; margin:0 auto;">
                    <field name="comparative_consumptions_graph"
                           widget="bokeh_chart" nolabel="1"/>
                </div>
            </xpath>
        </field>
    </record>

    <record id="wua_cultivation_view_tree" model="ir.ui.view">
        <field name="name">Cultivations (tree view)</field>
        <field name="model">wua.cultivation</field>
        <field name="inherit_id"
               ref="base_wua.wua_cultivation_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="class">o_base_wua_pressurized_irrigation_cultivation_view_tree</attribute>
            </xpath>
            <xpath expr="//field[@name='description']" position="after">
                <field name="monitoring"/>
            </xpath>
        </field>
    </record>

    <record id="wua_cultivation_view_search" model="ir.ui.view">
        <field name="name">Cultivations (search view)</field>
        <field name="model">wua.cultivation</field>
        <field name="inherit_id"
               ref="base_wua.wua_cultivation_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='description']" position="after">
                <filter string="Monitoring: Yes" name="monitoring_yes"
                 domain="[('monitoring','=',True)]"/>
                <filter string="Monitoring: No" name="monitoring_no"
                 domain="[('monitoring','=',False)]"/>
            </xpath>
        </field>
    </record>

</odoo>