<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_irrigationdose_view_tree" model="ir.ui.view">
        <field name="name">Irrigation dose (tree view)</field>
        <field name="model">wua.irrigationdose</field>
        <field name="arch" type="xml">
            <tree class="o_base_wua_pressurized_irrigation_monitoring_irrigationdose_view_tree"
                editable="bottom">
                <field name="cultivation_id" invisible="1"/>
                <field name="soiltype_id"/>
                <field name="age_category"/>
                <field name="minimum_irrigation_dose"/>
            </tree>
        </field>
    </record>

</odoo>
