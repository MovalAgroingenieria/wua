<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_soiltype_view_form" model="ir.ui.view">
        <field name="name">Soil Type (form view)</field>
        <field name="model">wua.soiltype</field>
        <field name="arch" type="xml">
            <form duplicate="0">
              <header>
              </header>
              <sheet>
                    <div name="buttons" class="oe_button_box">
                        <button name="action_see_subparcels"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-list"
                                groups="base_wua.group_wua_user">
                                <div class="o_form_field o_stat_info">
                                    <span class="o_stat_value">
                                        <field name="number_of_subparcels"/>
                                    </span>
                                    <span class="o_stat_text">Subparcels</span>
                                </div>
                        </button>
                    </div>
                    <group name="master_data">
                        <group name="master_data_left">
                            <field name="name"/>
                        </group>
                        <group name="master_data_right">
                        </group>
                    </group>
                    <group name="slave_data">
                        <notebook name="slave_data_notebook">
                            <page name="notes_page" string="Notes">
                               <field name="notes"/>
                            </page>
                        </notebook>
                  </group>
              </sheet>
            </form>
        </field>
    </record>

    <record id="wua_soiltype_view_tree" model="ir.ui.view">
        <field name="name">Soil Type (tree view)</field>
        <field name="model">wua.soiltype</field>
        <field name="arch" type="xml">
            <tree class="o_base_wua_pressurized_irrigation_monitoring_soiltype_view_tree">
                <field name="name"/>
                <field name="number_of_subparcels"/>
            </tree>
        </field>
    </record>

    <record id="wua_soiltype_view_search" model="ir.ui.view">
        <field name="name">Soil Type (search view)</field>
        <field name="model">wua.soiltype</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
            </search>
        </field>
    </record>


    <record id="wua_soiltype_action" model="ir.actions.act_window">
        <field name="name">Soil Types</field>
        <field name="res_model">wua.soiltype</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids"
         eval="[(5, 0),
                (0, 0, {'view_mode': 'tree',
                        'view_id': ref('wua_soiltype_view_tree')}),
                (0, 0, {'view_mode': 'form',
                        'view_id': ref('wua_soiltype_view_form')})]"/>
        <field name="search_view_id" ref="wua_soiltype_view_search"/>
    </record>

    <menuitem id="soiltype_menu"
              name="Soil Types"
              parent="base_wua.base_wua_census_configuration_menu"
              sequence="9"
              action="wua_soiltype_action"/>

</odoo>
