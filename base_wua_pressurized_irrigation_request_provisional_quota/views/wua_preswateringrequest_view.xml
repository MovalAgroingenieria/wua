<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="wua_preswateringrequest_view_form" model="ir.ui.view">
        <field name="name">Pres Watering Requests (form view)</field>
        <field name="model">wua.preswateringrequest</field>
        <field name="inherit_id" ref="base_wua_pressurized_irrigation_request.wua_preswateringrequest_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="attrs">{'readonly': [('id', '!=', False)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='initial_date']" position="attributes">
                <attribute name="attrs">{'readonly': [('id', '!=', False)]}</attribute>
            </xpath>
            <xpath expr="//group[@name='master_data_right']"
                   position="inside">
                <div attrs="{'invisible': [('html_quota_balance','=',False)]}"
                     >
                    <br/>
                    <field name="html_quota_balance" nolabel="1"/>
                </div>
            </xpath>
        </field>
    </record>

</odoo>