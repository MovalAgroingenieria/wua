<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_infrastructure_config_settings_view_form" model="ir.ui.view">
        <field name="name">Parameters</field>
        <field name="model">wua.infrastructure.configuration</field>
        <field name="inherit_id" ref="base_wua_infrastructure.wua_infrastructure_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[1]" position="after">
                 <group string="Reservoirs">
                    <field name="measurements_in_height"/>
                    <field name="to_vol_coef_a" style="width:100px" attrs="{'invisible':[('measurements_in_height','=',False)]}"/>
                    <field name="to_vol_coef_b" style="width:100px" attrs="{'invisible':[('measurements_in_height','=',False)]}"/>
                    <field name="to_vol_coef_c" style="width:100px" attrs="{'invisible':[('measurements_in_height','=',False)]}"/>
                </group>
            </xpath>
            <xpath expr="//field[@name='url_gis_viewer_irrigationditch_param']" position="after">
                 <field name="url_gis_viewer_reservoir_param"/>
            </xpath>
        </field>
    </record>

</odoo>
