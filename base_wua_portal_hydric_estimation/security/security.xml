<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="0">

        <record id="rule_wua_cropunit_group_portal" model="ir.rule">
            <field name="name">Rule for portal user on crop units</field>
            <field name="model_id" ref="base_wua_hydric_estimation.model_wua_cropunit"/>
            <field name="domain_force">
                ['|', ('partner_id', '=', user.partner_id.id), ('partner_id', 'parent_of', user.partner_id.id)]
            </field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        </record>

        <record id="rule_wua_hydricneed_group_portal" model="ir.rule">
            <field name="name">Rule for portal user on hydric needs</field>
            <field name="model_id" ref="base_wua_hydric_estimation.model_wua_hydricneed"/>
            <field name="domain_force">
                ['|', ('partner_id', '=', user.partner_id.id), ('partner_id', 'parent_of', user.partner_id.id)]
            </field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        </record>

    </data>

</odoo>