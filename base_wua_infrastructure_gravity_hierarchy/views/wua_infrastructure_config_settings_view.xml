<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_infrastructure_config_settings_view_form" model="ir.ui.view">
        <field name="name">Parameters</field>
        <field name="model">wua.infrastructure.configuration</field>
        <field name="inherit_id" ref="base_wua_infrastructure.wua_infrastructure_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[1]" position="after">
                 <group string="Hierarchical Gravity">
                    <field name="flowstopper_on_parcels"/>
                    <field name="max_levels_gravity_irrigation" style="width:100px"/>
                    <field name="max_levels_gravity_drainage" style="width:100px"/>
                </group>
            </xpath>
            <xpath expr="//field[@name='url_gis_viewer_irrigationditch_param']" position="after">
                 <field name="url_gis_viewer_drainageditch_param"/>
            </xpath>
        </field>
    </record>

</odoo>
