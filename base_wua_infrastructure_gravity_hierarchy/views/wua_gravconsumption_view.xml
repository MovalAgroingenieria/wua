<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_gravconsumption_view_search" model="ir.ui.view">
        <field name="name">Gravity Consumptions (search view)</field>
        <field name="model">wua.gravconsumption</field>
        <field name="inherit_id"
               ref="base_wua_gravity_irrigation.wua_gravconsumption_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='irrigationditch']" position="before">
                <filter string="Main irrigation ditch"
                 name="main_irrigationditch"
                 context="{'group_by':'main_irrigationditch_id'}"/>
            </xpath>
        </field>
    </record>

    <record id="base_wua_gravity_irrigation.wua_gravconsumption_action"
            model="ir.actions.act_window">
        <field name="context">{'search_default_executed': 1,
                               'search_default_agriculturalseason': 1,
                               'search_default_irrigationditch': 0,
                               'search_default_main_irrigationditch': 1,
                               'search_default_wateringperiod': 1}
        </field>
    </record>

</odoo>