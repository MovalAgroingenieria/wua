<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form view -->
    <record id="wua_parcel_view_form" model="ir.ui.view">
        <field name="name">Parcels Gravity hierarchy (form view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id" ref="base_wua_infrastructure.wua_parcel_view_form"/>
        <field name="arch" type="xml">
            <!-- Change irrigationditch_id by irrigationditch_direct_id -->
            <xpath expr="//field[@name='irrigationditch_id']" position="replace">
                <field name="irrigationditch_direct_id" colspan="4"/>
            </xpath>
            <xpath expr="//field[@name='gis_viewer_link']" position="after">
                <field name="flowstopper_on_parcels" invisible="1"/>
                <field name="flowdivider_id_domain" invisible="1"/>
            </xpath>
            <!-- Add drainage ditch -->
            <xpath expr="//field[@name='gravityfed_irrigation_right']" position="after">
                <field name="flowdivider_id" colspan="4"
                    attrs="{'invisible':
                        [('flowstopper_on_parcels','!=', True)]}"
                    domain="flowdivider_id_domain"/>
                <div colspan="4" attrs="{'invisible':
                        [('flowstopper_on_parcels','!=', True)]}"></div>
                <field name="drainageditch_id" colspan="4"/>
                <div colspan="4"></div>
            </xpath>

        </field>
    </record>

    <!-- Search view -->
    <record id="wua_parcel_view_search" model="ir.ui.view">
        <field name="name">Parcels Gravity hierarchy (search view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id" ref="base_wua_infrastructure.wua_parcel_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='irrigationditch_id']" position="after">
                <field name="drainageditch_id"/>
                <field name="flowdivider_id"/>
                <field name="path"/>
                <field name="drain_path"/>
            </xpath>
            <xpath expr="//filter[@name='irrigationworker']" position="after">
                <filter string="Irrigation Full name" name="path" context="{'group_by':'path'}"/>
                <filter string="Drainage full name" name="drain_path" context="{'group_by':'drain_path'}"/>
                <filter string="Ditch level 1" name="ditchlevel1" context="{'group_by':'irrigationditch_01_id'}"/>
                <filter string="Drainage ditch level 1" name="drainageditchlevel1" context="{'group_by':'drainageditch_01_id'}"/>
            </xpath>

        </field>
    </record>

</odoo>