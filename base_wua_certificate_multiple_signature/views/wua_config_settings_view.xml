<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_config_settings_view_form" model="ir.ui.view">
        <field name="name">Parameters</field>
        <field name="model">wua.configuration</field>
        <field name="inherit_id" ref="base_wua_certificate.wua_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='max_pending_certificates']" position="after">
                <field name="show_sign"
                       string="Show signature"/>
                <field name="page_of_signature"
                       style="width:100px"
                       attrs="{'invisible':[('show_sign','=',False)]}"/>
                <field name="llx_for_signature"
                       style="width:100px"
                       attrs="{'invisible':[('show_sign','=',False)]}"/>
                <field name="lly_for_signature"
                       style="width:100px"
                       attrs="{'invisible':[('show_sign','=',False)]}"/>
                <field name="urx_for_signature"
                       style="width:100px"
                       attrs="{'invisible':[('show_sign','=',False)]}"/>
                <field name="ury_for_signature"
                       style="width:100px"
                       attrs="{'invisible':[('show_sign','=',False)]}"/>
                <field name="max_signatures"
                       style="width:100px"
                       attrs="{'invisible':[('show_sign','=',False)]}"/>
                <field name="column_spacing"
                       style="width:100px"
                       attrs="{'invisible':[('show_sign','=',False)]}"/>
                <field name="fit_image"
                       style="width:100px"
                       attrs="{'invisible':[('show_sign','=',False)]}"/>
            </xpath>
        </field>
    </record>

</odoo>