<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_company_form" model="ir.ui.view">
        <field name="name">Add PDF report certificates list (with signer)</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base_wua_certificate.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='employee_as_secretary_id']"
                   position="attributes">
                <attribute name="string">Signing Supervisor</attribute>
            </xpath>
        </field>
    </record>

</odoo>