<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="portal_my_quotas_hours"
                  inherit_id="base_wua_portal_quota_management_with_provisional_quota.portal_my_quotas_management_with_provisional_quotas"
                name="Portal My Quotas - Conditional Hours Table">
            <xpath expr="//th[@id='provisional_extra_consumption_th']" position="attributes">
                <attribute name="t-if">not show_hours_portal</attribute>
            </xpath>
            <xpath expr="//th[@id='provisional_balance_th']" position="attributes">
                <attribute name="t-if">not show_hours_portal</attribute>
            </xpath>
            <xpath expr="//th[@id='available_th']" position="after">
                    <th t-if="show_hours_portal">Provisional Extra Consumption (h)</th>
                    <th t-if="show_hours_portal">Provisional Balance (h)</th>
            </xpath>
            <xpath expr="//td[@id='provisional_extra_consumption_td']" position="attributes">
                <attribute name="t-if">not show_hours_portal</attribute>
            </xpath>
            <xpath expr="//td[@id='provisional_balance_td']" position="attributes">
                <attribute name="t-if">not show_hours_portal</attribute>
            </xpath>
            <xpath expr="//td[@id='available_td']" position="after">
                <td t-if="show_hours_portal">
                    <t t-esc="quota.provisional_extra_consumption_hours"/>
                </td>
                <td t-if="show_hours_portal">
                    <t t-esc="quota.provisional_balance_hours"/>
                </td>
            </xpath>
        </template>
    </data>
</odoo>
