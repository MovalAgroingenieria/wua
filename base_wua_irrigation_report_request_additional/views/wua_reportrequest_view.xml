<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_reportrequest_view_form" model="ir.ui.view">
        <field name="name">Report Requests (form view)</field>
        <field name="model">wua.reportrequest</field>
        <field name="inherit_id" ref="base_wua_irrigation_report_request.wua_reportrequest_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='master_data']" position="before">
                <div name="buttons" class="oe_button_box">
                    <button name="action_get_mapped_irrigationreport_ids" type="object"
                        class="oe_stat_button" icon="fa-moval-file-irrigation"
                        attrs="{'invisible':[('num_mapped_irrigationreport_ids','=',0)]}">
                        <div class="o_form_field o_stat_info">
                            <span class="o_stat_value">
                                <field name="num_mapped_irrigationreport_ids"/>
                            </span>
                            <span class="o_stat_text">
                                Irrigation reports
                            </span>
                        </div>
                    </button>
                </div>
            </xpath>
        </field>
    </record>

</odoo>
