<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_irrigationreport_view_form" model="ir.ui.view">
        <field name="name">Irrigation Reports (form view)</field>
        <field name="model">wua.irrigationreport</field>
        <field name="inherit_id" ref="base_wua_irrigation_report.wua_irrigationreport_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='reportrequest_id']" position="before">
                <field name="source_reportrequest_id"
                    domain="[('state','=','validated'),('partner_id','=',partner_id),
                        ('of_active_agriculturalseason', '=', True)]"
                    attrs="{'invisible':[('mapped_to_reportrequest','=',True)]}"/>
            </xpath>
        </field>
    </record>

     <record id="wua_irrigationreport_view_search" model="ir.ui.view">
        <field name="name">Irrigation Reports (search view)</field>
        <field name="model">wua.irrigationreport</field>
        <field name="inherit_id" ref="base_wua_irrigation_report.wua_irrigationreport_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='employee_id']" position="after">
                <field name="source_reportrequest_id"/>
            </xpath>
            <xpath expr="//filter[@name='employee_id']" position="after">
                <filter name="source_reportrequest" string="Source Report Request"
                    context="{'group_by':'source_reportrequest_id'}"/>
            </xpath>
        </field>
    </record>

     <record id="wua_irrigationreport_view_search_inherit_reportrequest" model="ir.ui.view">
        <field name="name">Irrigation Reports (search view)</field>
        <field name="model">wua.irrigationreport</field>
        <field name="inherit_id" ref="base_wua_irrigation_report_request.wua_irrigationreport_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='mapped_to_report_request_true']" position="replace">
                <filter name="mapped_to_source_request_true" string="Mapped to source request: Yes"
                        domain="[('mapped_to_source_reportrequest_id','=',True)]"/>
            </xpath>
            <xpath expr="//filter[@name='mapped_to_report_request_false']" position="replace">
                <filter name="mapped_to_source_request_false" string="Mapped to source request: No"
                        domain="[('mapped_to_source_reportrequest_id','=',False)]"/>
            </xpath>
        </field>
    </record>

</odoo>
