<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_flowmeter_view_form" model="ir.ui.view">
        <field name="name">Flowmeters (form view)</field>
        <field name="model">wua.flowmeter</field>
        <field name="inherit_id" ref="base_wua_infrastructure_primary.wua_flowmeter_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='flow_direction']" position="after">
                <field name="flowmeter_salz_id"/>
                <field name="flowmeter_salz_gid"/>
            </xpath>
        </field>
    </record>

</odoo>