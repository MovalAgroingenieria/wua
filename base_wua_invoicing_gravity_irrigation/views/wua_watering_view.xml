<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_watering_view_form" model="ir.ui.view">
        <field name="name">Waterings (form view)</field>
        <field name="model">wua.watering</field>
        <field name="inherit_id"
               ref="base_wua_gravity_irrigation.wua_watering_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='publishable']"
             position="after">
                <field name="product_id"
                 domain="[('categ_id.productcategory_code','=',8)]"
                 attrs="{'readonly':[('initialized', '=', True)]}"/>
            </xpath>
        </field>
    </record>

    <record id="wua_watering_view_search" model="ir.ui.view">
        <field name="name">Waterings (search view)</field>
        <field name="model">wua.watering</field>
        <field name="inherit_id"
               ref="base_wua_gravity_irrigation.wua_watering_view_search"/>        
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='wateringperiod']" position="after">
                <filter string="Water Type" name="product"
                 context="{'group_by':'product_id'}"/>
            </xpath>
        </field>
    </record>

</odoo>