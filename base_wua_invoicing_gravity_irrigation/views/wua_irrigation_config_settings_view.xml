<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_irrigation_config_settings_view_form" model="ir.ui.view">
        <field name="name">Parameters</field>
        <field name="model">wua.irrigation.configuration</field>
        <field name="inherit_id"
               ref="wua_structure_irrigation.wua_irrigation_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='default_distribute_extra_volume']"
                   position="after">
                <field name="default_gravity_product_id" style="width:200px"
                       domain="[('categ_id.productcategory_code','=',8)]"/>
                <field name="default_set_product_id_for_wateringrequest"/>
                <field name="overprice_with_irrigation_worker"
                       style="width:100px"/>
            </xpath>
        </field>
    </record>

</odoo>
