<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="rule_res_file_group_portal" model="ir.rule">
            <field name="name">Rule for Portal User on file</field>
            <field name="model_id" ref="crm_filemgmt.model_res_file"/>
            <field name="domain_force">[
                '|',
                    ('partnerlink_ids.partner_id', '=', user.partner_id.id),
                    ('partnerlink_ids.partner_id', 'parent_of', user.partner_id.id)
                ]
            </field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        </record>
    </data>
</odoo>
