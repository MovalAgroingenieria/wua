<odoo>
    <data>
        <template id="portal_my_files" name="My Files">
            <t t-call="website.layout">
                <t t-call="base_wua_portal.portal_wua_navbar"/>
                <div id="wrap">
                    <div class="container mb64">
                        <div class="col-md-12">
                            <h3 class="page-header">Your Files</h3>
                            <t t-if="not files">
                                <p>There are currently no files for your account.</p>
                            </t>
                            <t t-if="files">
                                <form action="/my/files" method="get" class="mb-3">
                                    <div class="row">
                                        <div class="col-md-2">
                                            <select id="search_field" name="search_field" class="form-control">
                                                <option value="filename" t-att-selected="'filename' == search_field">Filename</option>
                                                <option value="description" t-att-selected="'description' == search_field">Description</option>
                                            </select>
                                        </div>
                                        <div class="col-md-8">
                                            <input type="text" name="search" class="form-control" placeholder="Search files..." t-att-value="search_query or ''"/>
                                        </div>
                                        <div class="col-md-2">
                                            <button type="submit" class="btn btn-primary btn-block">Search</button>
                                        </div>
                                    </div>
                                </form>
                                <table class="table table-hover o_my_status_table">
                                    <thead>
                                        <tr class="active">
                                            <th>Date File</th>
                                            <th>Category</th>
                                            <th>Filename</th>
                                            <th>Stage</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="files" t-as="file">
                                            <tr>
                                                <td>
                                                    <t t-esc="file.date_file"/>
                                                </td>
                                                <td>
                                                    <t t-esc="file.category_id.name"/>
                                                </td>
                                                <td>
                                                <t t-if="file.category_report_id">
                                                    <a t-att-href="'/my/files/' + str(file.id) + '/report'">
                                                        <t t-esc="file.name"/>
                                                    </a>
                                                    </t>
                                                <t t-else="">
                                                    <t t-esc="file.name"/>
                                                </t>
                                                </td>
                                                <td>
                                                    <t t-esc="file.stage_id.name"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                                <div t-if="pager" class="o_portal_pager text-center">
                                    <t t-call="website.pager"/>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>
            </t>
        </template>
        <template id="portal_my_registries" name="My Registries">
            <t t-call="website.layout">
            <t t-call="base_wua_portal.portal_wua_navbar"/>
            <div id="wrap">
                <div class="container mb64">
                <div class="col-md-12">
                    <h3 class="page-header">Your Registries</h3>
                    <t t-if="not registries">
                    <p>There are currently no registries for your account.</p>
                    </t>
                    <t t-if="registries">
                    <form action="/my/registries" method="get" class="mb-3">
                        <div class="row">
                            <div class="col-md-2">
                                <select id="search_field" name="search_field" class="form-control">
                                <option value="name" t-att-selected="'name' == search_field">Name</option>
                                <option value="date" t-att-selected="'date' == search_field">Date</option>
                                </select>
                            </div>
                            <div class="col-md-8">
                                <input type="text" name="search" class="form-control" placeholder="Search registries..." t-att-value="search_query or ''"/>
                            </div>
                            <div class="col-md-2">
                                <button type="submit" class="btn btn-primary btn-block">Search</button>
                            </div>
                        </div>
                    </form>
                    <table class="table table-hover o_my_status_table">
                        <thead>
                        <tr class="active">
                            <th style="width: 20%;">Date</th>
                            <th style="width: 20%;">Type</th>
                            <th style="width: 20%;">Number</th>
                            <th style="width: 40%;">Subject</th>
                        </tr>
                        </thead>
                        <tbody>
                        <t t-foreach="registries" t-as="registry">
                            <tr>
                            <td>
                                <t t-esc="registry.date"/>
                            </td>
                            <td>
                                <t t-if="registry.move == 'in'"><span>In</span></t>
                                <t t-elif="registry.move == 'out'"><span>Out</span></t>
                            </td>
                            <td>
                                <t t-esc="registry.number"/>
                            </td>
                            <td>
                                <a t-att-href="'/my/registries/' + str(registry.id) + '/report'">
                                    <t t-esc="registry.name"/>
                                </a>
                            </td>
                            </tr>
                        </t>
                        </tbody>
                    </table>
                    <div t-if="pager" class="o_portal_pager text-center">
                        <t t-call="website.pager"/>
                    </div>
                    </t>
                </div>
                </div>
            </div>
            </t>
        </template>
    </data>
</odoo>