<odoo>
    <data>
        <template id="portal_my_home_menu_wua" name="Portal layout : wua menu entries" inherit_id="base_wua_portal.portal_my_home_menu_wua" priority="925">
            <xpath expr="//ul[contains(@class,'o_portal_submenu')]" position="inside">
                <li style="order: 14;">
                    <a href="/my/files">Files</a>
                </li>
                <li style="order: 15;">
                    <a href="/my/registries">Registries</a>
                </li>
            </xpath>
        </template>
        <template id="portal_my_files" name="My Files">
            <t t-call="website.layout">
                <div class="container mt16">
                    <div class="navbar navbar-default">
                        <div class="navbar-header">
                            <button type="button" class="navbar-toggle" data-toggle="collapse" data-target="#oe-help-navbar-collapse">
                                <span class="sr-only">Toggle navigation</span>
                                <span class="icon-bar"></span>
                                <span class="icon-bar"></span>
                            </button>
                            <a class="navbar-brand" href="/my/home">My Account</a>
                        </div>
                        <div class="collapse navbar-collapse" id="oe-help-navbar-collapse">
                            <ul class="nav navbar-nav o_portal_submenu">
                                <li><a href="/my/invoices">Invoices</a></li>
                                <li><a href="/my/parcels">Parcels</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div id="wrap">
                    <div class="container mb64">
                        <div class="col-md-12">
                            <h3 class="page-header">Your Files</h3>
                            <t t-if="not files">
                                <p>There are currently no files for your account.</p>
                            </t>
                            <t t-if="files">
                                <form action="/my/files" method="get" class="mb-3">
                                    <div class="row">
                                        <div class="col-md-2">
                                            <select id="search_field" name="search_field" class="form-control">
                                                <option value="filename" t-att-selected="'filename' == search_field">Filename</option>
                                                <option value="description" t-att-selected="'description' == search_field">Description</option>
                                            </select>
                                        </div>
                                        <div class="col-md-8">
                                            <input type="text" name="search" class="form-control" placeholder="Search files..." t-att-value="search_query or ''"/>
                                        </div>
                                        <div class="col-md-2">
                                            <button type="submit" class="btn btn-primary btn-block">Search</button>
                                        </div>
                                    </div>
                                </form>
                                <table class="table table-hover o_my_status_table">
                                    <thead>
                                        <tr class="active">
                                            <th>Date File</th>
                                            <th>Category</th>
                                            <th>Filename</th>
                                            <th>Stage</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="files" t-as="file">
                                            <tr>
                                                <td>
                                                    <t t-esc="file.date_file"/>
                                                </td>
                                                <td>
                                                    <t t-esc="file.category_id.name"/>
                                                </td>
                                                <td>
                                                    <a t-att-href="'/my/files/' + str(file.id) + '/report'">
                                                        <t t-esc="file.name"/>
                                                    </a>
                                                </td>
                                                <td>
                                                    <t t-esc="file.stage_id.name"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                                <div t-if="pager" class="o_portal_pager text-center">
                                    <t t-call="website.pager"/>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>
            </t>
        </template>
        <template id="portal_my_registries" name="My Registries">
            <t t-call="website.layout">
            <div class="container mt16">
                <div class="navbar navbar-default">
                <div class="navbar-header">
                    <button type="button" class="navbar-toggle" data-toggle="collapse" data-target="#oe-help-navbar-collapse">
                    <span class="sr-only">Toggle navigation</span>
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                    </button>
                    <a class="navbar-brand" href="/my/home">My Account</a>
                </div>
                <div class="collapse navbar-collapse" id="oe-help-navbar-collapse">
                    <ul class="nav navbar-nav o_portal_submenu">
                    <li><a href="/my/invoices">Invoices</a></li>
                    <li><a href="/my/parcels">Parcels</a></li>
                    </ul>
                </div>
                </div>
            </div>
            <div id="wrap">
                <div class="container mb64">
                <div class="col-md-12">
                    <h3 class="page-header">Your Registries</h3>
                    <t t-if="not registries">
                    <p>There are currently no registries for your account.</p>
                    </t>
                    <t t-if="registries">
                    <form action="/my/registries" method="get" class="mb-3">
                        <div class="row">
                            <div class="col-md-2">
                                <select id="search_field" name="search_field" class="form-control">
                                <option value="name" t-att-selected="'name' == search_field">Name</option>
                                <option value="date" t-att-selected="'date' == search_field">Date</option>
                                <option value="state" t-att-selected="'state' == search_field">State</option>
                                </select>
                            </div>
                            <div class="col-md-8">
                                <input type="text" name="search" class="form-control" placeholder="Search registries..." t-att-value="search_query or ''"/>
                            </div>
                            <div class="col-md-2">
                                <button type="submit" class="btn btn-primary btn-block">Search</button>
                            </div>
                        </div>
                    </form>
                    <table class="table table-hover o_my_status_table">
                        <thead>
                        <tr class="active">
                            <th>Name</th>
                            <th>Date</th>
                            <th>State</th>
                        </tr>
                        </thead>
                        <tbody>
                        <t t-foreach="registries" t-as="registry">
                            <tr>
                            <td>
                                <a t-att-href="'/my/registries/' + str(registry.id) + '/report'">
                                <t t-esc="registry.name"/>
                                </a>
                            </td>
                            <td>
                                <t t-esc="registry.date"/>
                            </td>
                            <td>
                                <t t-esc="registry.state"/>
                            </td>
                            </tr>
                        </t>
                        </tbody>
                    </table>
                    <div t-if="pager" class="o_portal_pager text-center">
                        <t t-call="website.pager"/>
                    </div>
                    </t>
                </div>
                </div>
            </div>
            </t>
        </template>
    </data>
</odoo>