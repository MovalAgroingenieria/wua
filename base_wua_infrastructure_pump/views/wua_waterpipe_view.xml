<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_waterpipe_view_form" model="ir.ui.view">
        <field name="name">Water pipe (form view)</field>
        <field name="model">wua.waterpipe</field>
        <field name="inherit_id" ref="base_wua_infrastructure_pressurized_hierarchy.wua_waterpipe_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_get_parcels']" position="after">
                <button name="action_see_pumpgroups"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-moval-pumpgroup">
                    <div class="o_form_field o_stat_info">
                        <span class="o_stat_text">
                            Pumpgroups
                        </span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
