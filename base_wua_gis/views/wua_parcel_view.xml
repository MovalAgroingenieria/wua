<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_parcel_view_form" model="ir.ui.view">
        <field name="name">Parcels (form view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id" ref="base_wua.wua_parcel_view_form"/>        
        <field name="arch" type="xml">
            <xpath expr="//group[@name='slave_data']" position="after">
                <templates>
                    <t t-name="gisviewer">
                         <field name="with_gis_parcel" invisible="1"/>
                         <field name="parcel_gis_preview_in_form" invisible="1"/>
                         <div id="gisviewer_parcel"
                              attrs="{'invisible':['|', '|', ('with_gis_parcel','=',False), ('html_gisviewer_frame', '=', False), ('parcel_gis_preview_in_form', '!=', True)]}">
                             <field name="html_gisviewer_frame" widget="html"/>
                         </div>
                    </t>
                </templates>            
            </xpath>
            <xpath expr="//page[@name='aerial_img']" position="after">
                <page name="gis_preview" string="GIS Preview"
                      attrs="{'invisible':['|', '|', ('with_gis_parcel','=',False), ('html_gisviewer_frame_bis', '=', False), ('parcel_gis_preview_in_form', '=', True)]}">
                    <field name="html_gisviewer_frame_bis" widget="html" style="margin-top:15px;"/>
                </page>
            </xpath>
        </field>
    </record>

</odoo>