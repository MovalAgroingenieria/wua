<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_invoicing_config_settings_view_form" model="ir.ui.view">
        <field name="name">Parameters</field>
        <field name="model">wua.invoicing.configuration</field>
        <field name="inherit_id"
               ref="base_wua_invoicing.wua_invoicing_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@string='Invoicing Area']"
                   position="after">
                <group name="params_categ_13"
                    string="Invoicing of quotas">
                  <field name="invoicing_of_negative_balance" widget="checkbox"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
