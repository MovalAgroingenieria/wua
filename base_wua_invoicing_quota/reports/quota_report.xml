<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="quota_report_document" inherit_id="base_wua_quota_management.quota_report_document">
        <xpath expr="//tr[@name='tr_empty_0']" position="replace">
            <tr name="tr_sum_price_subtotal">
                <td><span>Invoiced Amount</span></td>
                <td class="text-right">
                    <span t-field="o.sum_price_subtotal" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                </td>
            </tr>
        </xpath>
    </template>

</odoo>
