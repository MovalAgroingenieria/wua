<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_invoiceset_line_tankconsumption_view_tree" model="ir.ui.view" >
        <field name="name">Invoice-set line for tank consumptions (tree view)</field>
        <field name="model">wua.invoiceset.line.tankconsumption</field>
        <field name="arch" type="xml">
            <tree create="false" edit="false" delete="false" export="false"
                class="o_base_wua_invoicing_invoiceset_view_tree">
                <field name="selected" invisible="1"/>
                <field name="tankconsumption_id"/>
                <button type="object" class="oe_read_only" icon="fa-check-circle" attrs="{'invisible': [('selected','=',False)]}"/>
                <field name="tank_id"/>
                <field name="hydraulicsector_id"/>
                <field name="initial_time"/>
                <field name="end_time"/>
                <field name="volume_request"/>
                <field name="volume_real"/>
            </tree>
        </field>
    </record>

    <record id="wua_invoiceset_line_tankconsumption_view_search" model="ir.ui.view" >
        <field name="name">Invoice-set line for tank consumptions (search view)</field>
        <field name="model">wua.invoiceset.line.tankconsumption</field>
        <field name="arch" type="xml">
            <search>
                <field name="tankconsumption_id"/>
                <field name="tank_id"/>
                <field name="hydraulicsector_id"/>
                <filter string="Selected" name="selected" domain="[('selected','=',True)]"/>
                <filter string="Not Selected" name="notselected" domain="[('selected','!=',True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Is selected (marked)" name="isselected" context="{'group_by':'selected'}"/>
                    <filter string="Hydraulic Sector" name="hydraulic_sector" context="{'group_by':'hydraulicsector_id'}"/>
                    <filter string="Tank" name="tank" context="{'group_by':'tank_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="wua_add_tankconsumption_to_invoiceset" model="ir.actions.server">
        <field name="name">Add to invoice set</field>
        <field name="model_id" ref="model_wua_invoiceset_line_tankconsumption"/>
        <field name="state">code</field>
        <field name="code">
            if context.get('active_ids'):
                action = env['wua.invoiceset.line.tankconsumption'].browse(context['active_ids']).add_to_invoiceset()
        </field>
    </record>
    
    <record id="wua_action_add_tankconsumption_to_invoiceset" model="ir.values">
        <field name="name">Add tank consumption to invoice set</field>
        <field name="model">wua.invoiceset.line.tankconsumption</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('wua_add_tankconsumption_to_invoiceset'))"/>
    </record>

    <record id="wua_remove_tankconsumption_to_invoiceset" model="ir.actions.server">
        <field name="name">Remove from invoice set</field>
        <field name="model_id" ref="model_wua_invoiceset_line_tankconsumption"/>
        <field name="state">code</field>
        <field name="code">
            if context.get('active_ids'):
                action = env['wua.invoiceset.line.tankconsumption'].browse(context['active_ids']).remove_from_invoiceset()
        </field>
    </record>
    
    <record id="wua_action_remove_tankconsumption_to_invoiceset" model="ir.values">
        <field name="name">Remove tank consumption from invoice set</field>
        <field name="model">wua.invoiceset.line.tankconsumption</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('wua_remove_tankconsumption_to_invoiceset'))"/>
    </record>

</odoo>