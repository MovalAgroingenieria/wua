<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_irrigationsrequest_view_form" model="ir.ui.view">
        <field name="name">Irrigations Requests (form view)</field>
        <field name="model">wua.irrigationsrequest</field>
        <field name="inherit_id"
               ref="base_wua_irrigations_request.wua_irrigationsrequest_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='area_official']"
                   position="after">
                <div attrs="{'invisible': [('html_quota_balance','=',False)]}"
                     colspan="2">
                    <br/>
                    <field name="html_quota_balance" nolabel="1"/>
                </div>
            </xpath>
        </field>
    </record>

</odoo>