<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="wua_parcel_report_document" inherit_id="base_wua.wua_parcel_report_document">
        <xpath expr="//tr[@name='tr_code']" position="after">
            <tr name="tr_extra_code">
                <td><span>Extra code:</span></td>
                <td class="text-right"><span t-field="o.extra_code"/></td>
            </tr>
        </xpath>
    </template>

</odoo>
