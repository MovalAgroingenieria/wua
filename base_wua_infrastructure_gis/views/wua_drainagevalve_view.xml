<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_drainagevalve_view_form" model="ir.ui.view">
        <field name="name">Draingevalves (form view)</field>
        <field name="model">wua.drainagevalve</field>
        <field name="inherit_id" ref="base_wua_infrastructure.wua_drainagevalve_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='slave_data']" position="after">
                <templates>
                    <t t-name="gisviewer">
                         <field name="with_gis_drainagevalve" invisible="1"/>
                         <div id="gisviewer_drainagevalve"
                              attrs="{'invisible':
                                      [('with_gis_drainagevalve','=',False)]}">
                             <field name="html_gisviewer_frame" widget="html"/>
                         </div>
                    </t>
                </templates>
            </xpath>
        </field>
    </record>

</odoo>