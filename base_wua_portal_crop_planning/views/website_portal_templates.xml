<odoo>
    <data>
        <template id="portal_my_home_menu_wua" name="Portal layout : wua menu entries" inherit_id="base_wua_portal.portal_my_home_menu_wua" priority="925">
            <xpath expr="//ul[contains(@class,'o_portal_submenu')]" position="inside">
                <li style="order: 16;">
                    <a href="/my/enrolledsubparcels">Inscriptions</a>
                </li>
            </xpath>
        </template>
        <template id="portal_my_home_wua" inherit_id="base_wua_portal.portal_my_home_wua" name="Hide Quotes and Orders">
            <xpath expr="//div[contains(@class,'o_my_home_content')]" position="inside">
                <h3 class="page-header" style="order: 16;">
                    <a href="/my/enrolledsubparcels">
                        <i class="fa fa-fw fa-comments"></i>
                        Your inscriptions
                        <small class="ml8">
                            <t t-if="enrolledsubparcels_count">
                                <span class='badge pull-right'><t t-esc="enrolledsubparcels_count"/></span>
                            </t>
                        </small>
                    </a>
                </h3>
            </xpath>
        </template>
        <template id="portal_my_enrolledsubparcels" name="My Inscriptions">
            <t t-call="website.layout">
                <div class="container mt16">
                    <div class="navbar navbar-default">
                        <div class="navbar-header">
                            <button type="button" class="navbar-toggle" data-toggle="collapse" data-target="#oe-help-navbar-collapse">
                                <span class="sr-only">Toggle navigation</span>
                                <span class="icon-bar"></span>
                                <span class="icon-bar"></span>
                            </button>
                            <a class="navbar-brand" href="/my/home">My Account</a>
                        </div>
                        <div class="collapse navbar-collapse" id="oe-help-navbar-collapse">
                            <ul class="nav navbar-nav o_portal_submenu">
                                <li><a href="/my/invoices">Invoices</a></li>
                                <li><a href="/my/parcels">Parcels</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div id="wrap">
                    <div class="container mb64">
                        <div class="col-md-12">
                            <h3 class="page-header">Your Inscriptions</h3>
                            <t t-if="not enrolledsubparcels">
                                <p>There are currently no inscriptions for your account.</p>
                            </t>
                            <t t-if="enrolledsubparcels">
                                <form action="/my/enrolledsubparcels" method="get" class="mb-3">
                                    <div class="row">
                                        <div class="col-md-2">
                                            <select id="search_field" name="search_field" class="form-control">
                                                <option value="parcel_id" t-att-selected="'parcel_id' == search_field">Parcel</option>
                                                <option value="subparcel_code" t-att-selected="'subparcel_code' == search_field">Subparcel Code</option>
                                                <option value="cropplan_id" t-att-selected="'cropplan_id' == search_field">Crop Plan</option>
                                                <option value="subparceltype_id" t-att-selected="'subparceltype_id' == search_field">Subparcel Type</option>
                                                <option value="area_official" t-att-selected="'area_official' == search_field">Official Area</option>
                                                <option value="cultivation_id" t-att-selected="'cultivation_id' == search_field">Cultivation</option>
                                                <option value="cultivationvariety_id" t-att-selected="'cultivationvariety_id' == search_field">Cultivation Variety</option>
                                                <option value="irrigationsystem_id" t-att-selected="'irrigationsystem_id' == search_field">Irrigation System</option>
                                                <option value="productionmethod_id" t-att-selected="'productionmethod_id' == search_field">Production Method</option>
                                                <option value="profile" t-att-selected="'profile' == search_field">Profile</option>
                                            </select>
                                        </div>
                                        <div class="col-md-8">
                                            <input type="text" name="search" class="form-control" placeholder="Search enrolledsubparcels..." t-att-value="search_query or ''"/>
                                        </div>
                                        <div class="col-md-2">
                                            <button type="submit" class="btn btn-primary btn-block">Search</button>
                                        </div>
                                    </div>
                                </form>
                                <table class="table table-hover o_my_status_table">
                                    <thead>
                                        <tr class="active">
                                            <th>Parcel</th>
                                            <th>Subparcel Code</th>
                                            <th>Crop Plan</th>
                                            <th>Subparcel Type</th>
                                            <th>Official Area</th>
                                            <th>Cultivation</th>
                                            <th>Cultivation Variety</th>
                                            <th>Irrigation System</th>
                                            <th>Production Method</th>
                                            <th>Profile</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="enrolledsubparcels" t-as="enrolledsubparcel">
                                            <tr>
                                                <td><span t-field="enrolledsubparcel.parcel_id"/></td>
                                                <td><span t-field="enrolledsubparcel.subparcel_code"/></td>
                                                <td><span t-field="enrolledsubparcel.cropplan_id"/></td>
                                                <td><span t-field="enrolledsubparcel.subparceltype_id"/></td>
                                                <td><span t-field="enrolledsubparcel.area_official"/></td>
                                                <td><span t-field="enrolledsubparcel.cultivation_id"/></td>
                                                <td><span t-field="enrolledsubparcel.cultivationvariety_id"/></td>
                                                <td><span t-field="enrolledsubparcel.irrigationsystem_id"/></td>
                                                <td><span t-field="enrolledsubparcel.productionmethod_id"/></td>
                                                <td><span t-field="enrolledsubparcel.profile"/></td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                                <div t-if="pager" class="o_portal_pager text-center">
                                    <t t-call="website.pager"/>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>
            </t>
        </template>
    </data>
</odoo>