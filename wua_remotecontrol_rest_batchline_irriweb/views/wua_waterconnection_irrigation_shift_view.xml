<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_waterconnection_irrigation_shift_view_form" model="ir.ui.view">
        <field name="name">Irrigation Shift (form view)</field>
        <field name="model">wua.waterconnection.irrigation.shift</field>
        <field name="inherit_id" ref="base_wua_pressurized_irrigation.wua_waterconnection_irrigation_shift_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='description']" position="after">
                <field name="batchline_id"/>
            </xpath>
        </field>
    </record>
</odoo>
