<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_invoice_pivot" model="ir.ui.view">
        <field name="name">Invoices (pivot view)</field>
        <field name="model">account.invoice</field>
        <field name="inherit_id" ref="base_wua_invoicing.view_invoice_pivot"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_untaxed_categ06']" position="after">
                <field name="amount_untaxed_categ16" type="measure"/>
                <field name="amount_untaxed_categ17" type="measure"/>
                <field name="amount_untaxed_categ18" type="measure"/>
            </xpath>
        </field>
    </record>

    <record id="invoice_tree" model="ir.ui.view">
        <field name="name">Invoices (tree view)</field>
        <field name="model">account.invoice</field>
        <field name="inherit_id" ref="base_wua_invoicing.invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoiceset_id']" position="after">
                <field name="number_of_variable_surcharges" invisible="1"/>
                <field name="number_of_fixed_surcharges" invisible="1"/>
                <field name="number_of_total_variable_surcharges" invisible="1"/>
            </xpath>
        </field>
    </record>

</odoo>