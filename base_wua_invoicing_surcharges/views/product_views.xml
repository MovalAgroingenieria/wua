<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_template_form_view" model="ir.ui.view">
        <field name="name">Products (form view)</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="base_wua_invoicing.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='parcel_area_to_be_invoiced']" position="after">
                <field name="only_open_invoices" attrs="{
                'invisible': [('productcategory_code','not in', [16,17,18])]}"/>
            </xpath>
        </field>
    </record>

</odoo>