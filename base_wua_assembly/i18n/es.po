#: code:addons/base_wua_assembly/models/wua_delegationvote.py:32
#, python-format
msgid "<div style=\"text-align: justify;\">Mr. <b>{{ grantor.name }}</b> with Community Member No. <b>{{ grantor.partner_code }}</b>, by virtue of the provisions of the perminent articles of the Statutes of the {{ assembly.president_id.company_id.name }}, <b>AUTHORIZE</b>:<br><br>Mr. <b>{{ receiver.name }}</b> to represent him at the {{ assembly.issue }} of this Water Association Community, which will take place on the next {{ assembly_day }} of {{ assembly_month }} of {{ assembly_year }}.<br><br><div style=\"text-align: center;\"><br>The Authorized&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; The Communard<br><br><br><br><br>VAT {{ receiver.vat }}&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; VAT {{ grantor.vat }}<br><br><b>THE COMMUNITY SECRETARY</b><br><br><br><br>VAT {{ assembly.secretary_id.vat }}<br></div></div>"
msgstr "<div style=\"text-align: justify;\">D. <b>{{ grantor.name }}</b> con Nº de comunero <b>{{ grantor.partner_code }}</b>, en virtud de los artículos pertinenetes de los Estatutos de la {{ assembly.president_id.company_id.name }}, <b>AUTORIZA</b>:<br><br>D. <b>{{ receiver.name }}</b> para que le represente en la {{ assembly.issue }} de esta Comunidad de Regantes, que tendrá lugar el próximo {{ assembly_day }} de {{ assembly_month }} de {{ assembly_year }}.<br><br><div style=\"text-align: center;\"><br>El Autorizado&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; El Comunero<br><br><br><br><br>NIF {{ receiver.vat }}&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; NIF {{ grantor.vat }}<br><br><b>Vº Bº<br>EL SECRETARIO DE LA COMUNIDAD</b><br><br><br><br>NIF {{ assembly.secretary_id.vat }}<br></div></div>"

#. module: base_wua_assembly
#: code:addons/base_wua_assembly/models/wua_representation.py:32
#, python-format
msgid "<div style=\"text-align: justify;\">Mr. <b>{{ partner.name }}</b> with Community Member No. <b>{{ partner.partner_code }}</b>, by virtue of the provisions of the perminent articles of the Statutes of the {{ assembly.president_id.company_id.name }}, <b>AUTHORIZE</b>:<br><br>Mr. <b>{{ agent.name }}</b> to represent him at the {{ assembly.issue }} of this Water Association Community, which will take place on the next {{ assembly_day }} of {{ assembly_month }} of {{ assembly_year }}.<br><br><div style=\"text-align: center;\"><br>The Authorized&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;The Communard<br><br><br><br><br>VAT {{ agent.vat_wua_legalrep }}&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;VAT {{ partner.vat }}<br><br><b>THE COMMUNITY SECRETARY</b><br><br><br><br>VAT {{ assembly.secretary_id.vat }}<br></div></div>"
msgstr "<div style=\"text-align: justify;\">D. <b>{{ partner.name }}</b> con Nº de comunero <b>{{ partner.partner_code }}</b>, en virtud de los artículos pertinenetes de los Estatutos de la {{ assembly.president_id.company_id.name }}, <b>AUTORIZA</b>:<br><br>D. <b>{{ agent.name }}</b> para que le represente en la {{ assembly.issue }} de esta Comunidad de Regantes, que tendrá lugar el próximo {{ assembly_day }} de {{ assembly_month }} de {{ assembly_year }}.<br><br><div style=\"text-align: center;\"><br>El Autorizado&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; El comunero<br><br><br><br><br>NIF {{ agent.vat_wua_legalrep }}&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;NIF {{ partner.vat }}<br><br><b>Vº Bº<br>EL SECRETARIO DE LA COMUNIDAD</b><br><br><br><br>NIF {{ assembly.secretary_id.vat }}<br></div></div>"

#. module: base_wua_assembly
#: code:addons/base_wua_assembly/models/wua_delegationvote.py:64
#: code:addons/base_wua_assembly/models/wua_representation.py:65
#, python-format
msgid "<p><b>NOTE</b>: By virtue of the pertinent Statutes, the Authorizations must be submitted to the Irrigation Community, for its verification and legitimation by the Secretary of the Community. Failure to comply with this rule will invalidate any Authorization.</p>"
msgstr "<p><b>NOTA</b>: En virtud de los Estatutos pertinentes, las Autorizaciones deberán ser presentadas a la Comunidad de Regantes para su verificación y legitimación por el Secretario de la Comunidad. El incumplimiento de esta regla invalidará cualquier Autorización.</p>"

#. module: base_wua_assembly
#: code:addons/base_wua_assembly/models/wua_assembly.py:78
#, python-format
msgid "<p>{{ assembly.issue }} of the {{ assembly.president_id.company_id.name }}, which will take place on {{ assembly_month }} {{ assembly_day }}, at {{ assembly.street }} ({{ assembly.city }}, {{ assembly.state_id.name }}), at {{ assembly.first_hour_hhmm }}{% if assembly.second_hour %} in the first call, and at {{ assembly.second_hour_hhmm }} in second, {% else %},{% endif %} according to the following <b>AGENDA</b>:<br></p>"
msgstr "<p>{{ assembly.issue }} de la {{ assembly.president_id.company_id.name }}, que tendrá lugar el próximo día {{ assembly_day }} de {{ assembly_month }}, en {{ assembly.street }} ({{ assembly.city }}, {{ assembly.state_id.name }}), a las {{ assembly.first_hour_hhmm }} horas{% if assembly.second_hour %} en primera convocatoria, y a las {{ assembly.second_hour_hhmm }} en segunda, {% else %},{% endif %} de acuerdo con el siguiente <b>ORDEN DEL DÍA</b>:<br></p>"

