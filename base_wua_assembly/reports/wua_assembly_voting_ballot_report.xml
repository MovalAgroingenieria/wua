<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <report id="action_wua_assembly_voting_ballot"
            string="Assembly Voting Ballot"
            model="wua.assembly"
            report_type="qweb-pdf"
            name="base_wua_assembly.report_wua_assembly_voting_ballot"
            paperformat="base_wua_report.paperformat_wua_reports"
            groups="base_wua.group_wua_user"/>

    <template id="report_wua_assembly_voting_ballot">
        <t t-call="report.html_container">
            <t t-call="base_wua_report.wua_external_layout">
                <div class="page">
                    <t t-foreach="docs" t-as="o">
                        <t t-call="base_wua_assembly.report_wua_assembly_voting_ballot_document"/>
                        <p style="page-break-after:always;"></p>
                    </t>
                </div>
            </t>
        </t>
    </template>

    <template id="report_wua_assembly_voting_ballot_document">
        <t t-set="report_style" t-value="o.env['ir.values'].get_default('wua.configuration', 'reports_style')"/>
        <div name="section_master" style="display: table; width: 100%;">
            <div style="width: 100%; display: table-row; margin-bottom: 15px;">
                <div style="width: 25%; display: table-cell;">
                </div>
                <div style="width: 50%; display: table-cell;" class="text-center">
                    <h4 style="margin-top:0px; padding-top:0px;">
                        <strong>Agenda Voting Ballot of the</strong>
                        <strong><span t-field="o.issue"/></strong>
                    </h4>
                    <div>
                        <span t-field="o.assembly_date" t-options="{'format': 'dd/MM/YYYY'}"/>
                        <span>-</span>
                        <span t-field="o.city"/>,
                        <span t-field="o.state_id"/>
                    </div>
                </div>
                <div style="width: 25%; display: table-cell;" class="text-center">
                    <div style="border: 1px solid black; padding: 10px;">
                        <div style="background-color: #d3d3d3; padding: 5px; font-weight: bold;">
                            <span>N. Votes</span>
                        </div>
                        <div style="height: 50px; border: 1px solid black; margin-top: 10px;">
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div name="attendee_detail" style="margin-top:20px;">
            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                <t t-if="report_style == 'light'">
                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px; margin-bottom:20px;">
                        <div style="float: left; width: 32px; font-size: 1.2em;"><span class="fa fa-user"/></div>
                        <div style="float: left; display: inline;">
                            <strong>Attendee Or Representative</strong>
                        </div>
                    </div>
                </t>
                <t t-else="">
                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px; margin-bottom:20px;">
                        <div style="float: left; width: 32px; font-size: 1.2em;"><span class="fa fa-user"/></div>
                        <div style="float: left; display: inline;">
                            <strong>Attendee Or Representative</strong>
                        </div>
                    </div>
                </t>
                <div style="margin-top: 4px; margin-left: 18px;" name="attendee_text">
                    <div t-field="o.attendee_text_on_ballot"/>
                </div>
            </div>
        </div>
        <div name="section_detail" style="margin-top:20px;">
            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                <t t-if="report_style == 'light'">
                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px; margin-bottom:4px;">
                        <div style="float: left; width: 32px; font-size: 1.2em;"><span class="fa fa-list"/></div>
                        <div style="float: left; display: inline;">
                            <strong>Agendaitem to vote on the agenda</strong>
                        </div>
                    </div>
                </t>
                <t t-else="">
                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px; margin-bottom:4px;">
                        <div style="float: left; width: 32px; font-size: 1.2em;"><span class="fa fa-list"/></div>
                        <div style="float: left; display: inline;">
                            <strong>Agendaitem to vote on the agenda</strong>
                        </div>
                    </div>
                </t>
            </div>
            <div name="agenda_items" style="margin-top: 4px;">
                <t t-foreach="o.agendaitem_ids" t-as="agenda_item">
                    <t t-if="agenda_item.type_02_yes_or_no or agenda_item.type_03_options">
                        <div name="agendaitem_vote">
                            <h4>
                                <span t-field="agenda_item.number"/>
                                <span t-field="agenda_item.description"/>
                            </h4>
                        </div>
                        <br/>
                        <t t-if="agenda_item.type_02_yes_or_no">
                            <div style="display: table; width: 100%;">
                                <div name="agendaitem_yes_or_no_vote" style="width: 100%; display: table-row; margin-top: 15px; margin-bottom: 15px;">
                                    <div style="width: 33%; text-align: center; display: table-cell;">
                                        <strong>Yes</strong>
                                        <span class="fa fa-square-o" style="margin-left: 5px; font-size: 30px; color:grey;"/>
                                    </div>
                                    <div style="width: 33%; text-align: center; display: table-cell;">
                                        <strong>No</strong>
                                        <span class="fa fa-square-o" style="margin-left: 5px; font-size: 30px; color:grey;"/>
                                    </div>
                                    <div style="width: 33%; text-align: center; display: table-cell;">
                                        <strong>Abstention</strong>
                                        <span class="fa fa-square-o" style="margin-left: 5px; font-size: 30px; color:grey;"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                        <t t-if="agenda_item.type_03_options">
                            <div style="display: table; width: 100%; margin-left: 50px;">
                                <t t-set="option_index" t-value="0"/>
                                <t t-foreach="range(len(agenda_item.option_ids))" t-as="index">
                                    <t t-set="option" t-value="agenda_item.option_ids[index]"/>
                                    <t t-if="index % 2 == 0">
                                        <div style="width: 100%; display: table-row; margin-top: 15px; margin-bottom: 15px;">
                                            <div style="width: 50%; text-align: left; display: table-cell; margin-left: 50px;">
                                                <span class="fa fa-square-o" style="margin-left: 5px; font-size: 30px; color:grey;"/>
                                                <strong t-field="option.option"/>
                                            </div>
                                            <t t-if="index + 1 &lt; len(agenda_item.option_ids)">
                                                <t t-set="next_option" t-value="agenda_item.option_ids[index + 1]"/>
                                                <div style="width: 50%; text-align: left; display: table-cell; margin-left: 50px;">
                                                    <span class="fa fa-square-o" style="margin-left: 5px; font-size: 30px; color:grey;"/>
                                                    <strong t-field="next_option.option"/>
                                                </div>
                                            </t>
                                        </div>
                                    </t>
                                </t>
                            </div>
                        </t>
                        <br/>
                    </t>
                </t>
            </div>
        </div>
    </template>

</odoo>