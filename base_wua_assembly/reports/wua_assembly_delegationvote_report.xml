<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <report
        id="wua_assembly_delegationvote_report"
        string="Delegation vote (Template)"
        model="wua.assembly"
        report_type="qweb-pdf"
        file="base_wua_assembly.wua_assembly_delegationvote_report_document"
        name="base_wua_assembly.wua_assembly_delegationvote_report_document"
        paperformat="base_wua_assembly.paperformat_wua_delegationvote_report"/>

    <template id="wua_assembly_delegationvote_internal_layout" inherit_id="report.internal_layout">
        <xpath expr="//div[@class='header']" position="attributes">
            <attribute name="t-att-style">"display: none"</attribute>
        </xpath>
    </template>

    <template id="wua_assembly_delegationvote_report_document">
        <t t-call="report.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="base_wua_assembly.wua_assembly_delegationvote_internal_layout">
                    <div class="page">
                        <!-- Vars -->
                        <t t-set="report_style" t-value="o.env['ir.values'].get_default('wua.configuration', 'reports_style')"/>
                        <t t-set="company" t-value="o.secretary_id.company_id.sudo()"></t>

                        <div name="header_main_copy" style="margin-bottom: 12px;">
                            <div class="row">
                                <div class="col-xs-2 text-center">
                                    <img t-if="company.logo" t-att-src="'data:image/png;base64,%s' % company.logo"
                                         style="max-height: 80px; max-width: 90px;"/>
                                </div>
                                <div class="col-xs-10" style="margin-bottom: 6px;">
                                    <div name="company_address">
                                        <t t-if="company.name">
                                            <li style="list-style:none;">
                                                <strong><span t-field="company.name"/></strong>
                                                 <t t-if="company.vat">
                                                    <t t-set="mod_vat" t-value="company.vat[2:]"/>
                                                    <span>(TIN: <span t-esc="mod_vat"/>)</span>
                                                </t>
                                            </li>
                                        </t>
                                        <t t-if="company.street or company.street2">
                                            <li style="list-style:none;">
                                                <span t-field="company.street"/>
                                                <t t-if="company.street2">
                                                    <span t-field="company.street2"/>
                                                </t>
                                                <t t-if="company.city">
                                                    <span t-field="company.city"/>
                                                </t>
                                                <t t-if="company.zip">
                                                    <span t-field="company.zip"/>
                                                </t>
                                                <t t-if="company.state_id">
                                                    <span t-field="company.state_id"/>
                                                </t>
                                                <t t-if="company.country_id">
                                                    <span t-field="company.country_id"/>
                                                </t>
                                            </li>
                                        </t>
                                        <t t-if="company.partner_id">
                                            <li style="list-style:none; margin-left: 2px; width: 100%;">
                                                <t t-if="company.partner_id.email or company.partner_id.phone">
                                                    <span class="fa fa-envelope theme-report-color" style="display: inline;">
                                                        <t t-set="email" t-value="company.sudo().partner_id.email"/>
                                                        <a style="color: black;" href="mailto:email">
                                                            <span style="font-size: 13px;" t-esc="email"/>
                                                         </a>
                                                    </span>
                                                    <t t-if="company.partner_id.phone">
                                                        <span class="fa fa-phone theme-report-color" style="display: inline;">
                                                            <t t-set="phone" t-value="company.sudo().partner_id.phone"/>
                                                            <a style="color: black;" href="callto:phone">
                                                                <span style="font-size: 13px;" t-esc="phone"/>
                                                            </a>
                                                        </span><br/>
                                                    </t>
                                                </t>
                                                <t t-if="company.partner_id.website">
                                                    <span class="fa fa-globe theme-report-color" style="display: inline;">
                                                        <t t-set="website" t-value="company.sudo().partner_id.website"/>
                                                        <a class="theme-report-color" href="website">
                                                            <span style="font-size: 13px;" t-esc="website"/>
                                                        </a>
                                                    </span>
                                                </t>
                                            </li>
                                        </t>
                                    </div>
                                </div>
                            </div>
                            <div class="row zero_min_height">
                                <div class="col-xs-12">
                                    <div style="border-bottom: 1px solid black;"/>
                                </div>
                            </div>
                        </div>

                        <div name="delegationvote_main_text">
                            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;" name="secction_title">
                                <t t-if="report_style == 'light'">
                                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;"><span class="fa fa-check-square-o"/></div>
                                        <div style="float: left; display: inline;"><strong>Delegation&amp;nbsp;vote</strong></div>
                                   </div>
                                </t>
                                <t t-else="">
                                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;"><span class="fa fa-check-square-o"/></div>
                                        <div style="float: left; display: inline;"><strong>Delegation&amp;nbsp;vote</strong></div>
                                    </div>
                                </t>
                            </div>
                            <div style="margin-top: 4px;" name="main_text">
                                <div t-field="o.rendered_delegation_vote_main_text"/>
                            </div>
                        </div>
                        <br/>
                        <div class="row zero_min_height">
                            <div class="col-xs-12">
                                <div style="border-bottom: 1px solid black;"/>
                            </div>
                        </div>
                        <div t-field="o.rendered_delegation_vote_footer_text" name="footer_text"/>

                        <div name="cutting_line" style="margin-top: 20px;margin-bottom: 8px; width: 100%;" class="text-center">
                            <span class="fa fa-cut"/>
                            <span style="color: lightgrey;">
                                -------------------------------------------------------------------
                                            &amp;nbsp;Copy for Community&amp;nbsp;
                                -------------------------------------------------------------------
                            </span>
                        </div>

                        <div name="header_community_copy" style="margin-bottom: 12px;">
                            <div class="row">
                                <div class="col-xs-2 text-center">
                                    <img t-if="company.logo" t-att-src="'data:image/png;base64,%s' % company.logo"
                                         style="max-height: 80px; max-width: 90px;"/>
                                </div>
                                <div class="col-xs-10" style="margin-bottom: 6px;">
                                    <div name="company_address">
                                        <t t-if="company.name">
                                            <li style="list-style:none;">
                                                <strong><span t-field="company.name"/></strong>
                                                 <t t-if="company.vat">
                                                    <t t-set="mod_vat" t-value="company.vat[2:]"/>
                                                    <span>(TIN: <span t-esc="mod_vat"/>)</span>
                                                </t>
                                            </li>
                                        </t>
                                        <t t-if="company.street or company.street2">
                                            <li style="list-style:none;">
                                                <span t-field="company.street"/>
                                                <t t-if="company.street2">
                                                    <span t-field="company.street2"/>
                                                </t>
                                                <t t-if="company.city">
                                                    <span t-field="company.city"/>
                                                </t>
                                                <t t-if="company.zip">
                                                    <span t-field="company.zip"/>
                                                </t>
                                                <t t-if="company.state_id">
                                                    <span t-field="company.state_id"/>
                                                </t>
                                                <t t-if="company.country_id">
                                                    <span t-field="company.country_id"/>
                                                </t>
                                            </li>
                                        </t>
                                        <t t-if="company.partner_id">
                                            <li style="list-style:none; margin-left: 2px; width: 100%;">
                                                <t t-if="company.partner_id.email or company.partner_id.phone">
                                                    <span class="fa fa-envelope theme-report-color" style="display: inline;">
                                                        <t t-set="email" t-value="company.sudo().partner_id.email"/>
                                                        <a style="color: black;" href="mailto:email">
                                                            <span style="font-size: 13px;" t-esc="email"/>
                                                         </a>
                                                    </span>
                                                    <t t-if="company.partner_id.phone">
                                                        <span class="fa fa-phone theme-report-color" style="display: inline;">
                                                            <t t-set="phone" t-value="company.sudo().partner_id.phone"/>
                                                            <a style="color: black;" href="callto:phone">
                                                                <span style="font-size: 13px;" t-esc="phone"/>
                                                            </a>
                                                        </span><br/>
                                                    </t>
                                                </t>
                                                <t t-if="company.partner_id.website">
                                                    <span class="fa fa-globe theme-report-color" style="display: inline;">
                                                        <t t-set="website" t-value="company.sudo().partner_id.website"/>
                                                        <a class="theme-report-color" href="website">
                                                            <span style="font-size: 13px;" t-esc="website"/>
                                                        </a>
                                                    </span>
                                                </t>
                                            </li>
                                        </t>
                                    </div>
                                </div>
                            </div>
                            <div class="row zero_min_height">
                                <div class="col-xs-12">
                                    <div style="border-bottom: 1px solid black;"/>
                                </div>
                            </div>
                        </div>

                        <div name="delegationvote_main_text_community_copy">
                            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;" name="secction_title">
                                <t t-if="report_style == 'light'">
                                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;"><span class="fa fa-check-square-o"/></div>
                                        <div style="float: left; display: inline;"><strong>Delegation&amp;nbsp;vote</strong></div>
                                   </div>
                                </t>
                                <t t-else="">
                                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;"><span class="fa fa-check-square-o"/></div>
                                        <div style="float: left; display: inline;"><strong>Delegation&amp;nbsp;vote</strong></div>
                                    </div>
                                </t>
                            </div>
                            <div style="margin-top: 4px;" name="main_text_community_copy">
                                <div t-field="o.rendered_delegation_vote_main_text"/>
                            </div>
                        </div>
                        <br/>
                        <div class="row zero_min_height">
                            <div class="col-xs-12">
                                <div style="border-bottom: 1px solid black;"/>
                            </div>
                        </div>
                        <div t-field="o.rendered_delegation_vote_footer_text" name="footer_text"/>

                    </div><!-- end page -->
                </t>
            </t>
        </t>
    </template>

</odoo>
