<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <report id="action_wua_attendance_individual_call_report"
            string="Assembly Attendance Call"
            model="wua.attendance"
            report_type="qweb-pdf"
            name="base_wua_assembly.wua_attendance_individual_call_report"
            paperformat="base_wua_report.paperformat_wua_reports"
            groups="base_wua.group_wua_user"/>

    <template id="wua_attendance_individual_call_report">
        <t t-call="report.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="base_wua_assembly.wua_attendance_individual_call_report_document"/>
            </t>
        </t>
    </template>

    <template id="wua_attendance_individual_call_report_document">

        <t t-call="base_wua_report.wua_external_layout">
            <div class="page">

                <!-- Vars -->
                <t t-set="report_style" t-value="request.env['ir.values'].get_default('wua.configuration', 'reports_style')"/>

                <!-- Title -->
                <div name="title" class="text-center">
                    <h4 style="margin-top:0px; padding-top:0px;">
                        <strong>Assembly citation</strong>
                    </h4>
                    <div name="assembly_name">
                        <span>[</span><span t-field="o.assembly_id.issue"/><span>]</span>
                    </div>
                </div>

                <div name="wua_partner_data">
                    <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                        <t t-if="report_style == 'light'">
                            <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                <div style="float: left; width: 32px;"><span class="fa fa-user"/></div>
                                <div style="float: left; display: inline;"><strong>Participant</strong></div>
                            </div>
                        </t>
                        <t t-else="">
                            <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                <div style="float: left; width: 32px;"><span class="fa fa-user"/></div>
                                <div style="float: left; display: inline;"><strong>Participant</strong></div>
                            </div>
                        </t>
                    </div>

                    <div class="row" style="margin-top: 4px;">
                        <div class="col-xs-12" style="display: table;">
                            <div style="width: 50%; display: table-cell;">
                                <table name="partner_vote_data" style="width:90%;">
                                    <tbody>
                                        <tr name="tr_name_and_vat">
                                            <td>
                                                <t t-if="o.partner_id.name">
                                                    <span t-field="o.partner_id.name"/> [<span t-field="o.partner_id.partner_code"/>]
                                                </t>
                                            </td>
                                            <td class="text-right">
                                                <t t-if="o.partner_id.vat">
                                                    <span t-field="o.partner_id.vat"/>
                                                </t>
                                            </td>
                                        </tr>
                                        <tr name="tr_votes_owned">
                                            <td><span>Votes owned:</span></td>
                                            <td class="text-right">
                                                <t t-if="o.votes_owned">
                                                    <span t-field="o.votes_owned"/>
                                                </t>
                                            </td>
                                        </tr>
                                        <tr name="tr_votes_delegation">
                                            <td><span>Votes delegation:</span></td>
                                            <td class="text-right">
                                                <t t-if="o.votes_delegation">
                                                    <span t-field="o.votes_delegation"/>
                                                </t>
                                                <t t-else=""><span>0</span></t>
                                            </td>
                                        </tr>
                                        <tr name="tr_votes_total">
                                            <td><span>Votes total:</span></td>
                                            <td class="text-right">
                                                <t t-if="o.votes_total">
                                                    <span t-field="o.votes_total"/>
                                                </t>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <div style="display: table-cell; padding-left: 32px;">
                                <t t-if="o.partner_id.name">
                                    <strong><span t-field="o.partner_id.name"/></strong>
                                    <br/>
                                </t>
                                <t t-if="o.partner_id.street_type_show or o.partner_id.street or o.partner_id.street_num or o.partner_id.street2">
                                    <t t-if="o.partner_id.street_type_show"><span t-field="o.partner_id.street_type_show"/></t>
                                    <t t-if="o.partner_id.street"><span t-field="o.partner_id.street"/></t>
                                    <t t-if="o.partner_id.street_num"><span t-field="o.partner_id.street_num"/></t>
                                    <t t-if="o.partner_id.street2"><span t-field="o.partner_id.street2"/></t>
                                    <br/>
                                </t>
                                <t t-if="o.partner_id.city or o.partner_id.zip">
                                    <t t-if="o.partner_id.city"><span t-field="o.partner_id.city"/></t>
                                    <t t-if="o.partner_id.zip"><span>-&amp;nbsp;</span><span t-field="o.partner_id.zip"/></t>
                                    <br/>
                                </t>
                                <t t-if="o.partner_id.state_id or o.partner_id.country_id">
                                    <t t-if="o.partner_id.state_id"><span t-field="o.partner_id.state_id"/></t>
                                    <t t-if="o.partner_id.country_id"><span>-&amp;nbsp;</span><span t-field="o.partner_id.country_id"></span></t>
                                    <br/>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>

                <div name="assembly_data">
                    <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                        <t t-if="report_style == 'light'">
                            <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                <div style="float: left; width: 32px;"><span class="fa fa-gavel"/></div>
                                <div style="float: left; display: inline;"><strong>Assembly</strong></div>
                            </div>
                        </t>
                        <t t-else="">
                            <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                <div style="float: left; width: 32px;"><span class="fa fa-gavel"/></div>
                                <div style="float: left; display: inline;"><strong>Assembly</strong></div>
                            </div>
                        </t>
                    </div>
                    <div class="row" style="margin-top: 4px;">
                        <div class="col-xs-12" style="display: table;">
                            <div style="display: table-cell; min-width:320px;">
                                <table name="assembly_main_data" style="width:90%;">
                                    <tbody>
                                        <tr name="tr_assembly_date">
                                            <td><span>Date:</span></td>
                                            <td class="text-right">
                                                <t t-if="o.assembly_id.assembly_date">
                                                    <span t-field="o.assembly_id.assembly_date"/>
                                                </t>
                                            </td>
                                        </tr>
                                        <tr name="tr_first_hour">
                                            <td><span>First hour:</span></td>
                                            <td class="text-right">
                                                <t t-if="o.assembly_id.first_hour">
                                                    <t t-esc="'%02d:%02d' % (int(o.assembly_id.first_hour), o.assembly_id.first_hour % 1 * 60)" />
                                                </t>
                                            </td>
                                        </tr>
                                        <tr name="tr_second_hour">
                                            <td><span>Second hour:</span></td>
                                            <td class="text-right">
                                                <t t-if="o.assembly_id.second_hour">
                                                    <t t-esc="'%02d:%02d' % (int(o.assembly_id.second_hour), o.assembly_id.second_hour % 1 * 60)" />
                                                </t>
                                            </td>
                                        </tr>
                                        <tr name="tr_number_of_agendaitems">
                                            <td><span>Num. agendaitems:</span></td>
                                            <td class="text-right">
                                                <span t-field="o.assembly_id.number_of_agendaitems"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <div style="display: table-cell; padding-left: 40px;">
                                <div style="margin-bottom:8px;">Place of celebration:</div>
                                <div name="address" style="margin-left: 16px;">
                                    <t t-if="o.assembly_id.street"><span t-field="o.assembly_id.street"/></t><br/>
                                    <t t-if="o.assembly_id.city"><span t-field="o.assembly_id.city"/></t>
                                    <t t-if="o.assembly_id.state_id">
                                        <span> - </span>
                                        <span t-field="o.assembly_id.state_id"/>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div name="citation_data">
                    <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                        <t t-if="report_style == 'light'">
                            <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                <div style="float: left; width: 32px;"><span class="fa fa-file-text-o"/></div>
                                <div style="float: left; display: inline;"><strong>Citation</strong></div>
                            </div>
                        </t>
                        <t t-else="">
                            <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                <div style="float: left; width: 32px;"><span class="fa fa-file-text-o"/></div>
                                <div style="float: left; display: inline;"><strong>Citation</strong></div>
                            </div>
                        </t>
                    </div>
                    <div name="publication_text" style="margin-top: 4px;">
                        <t t-if="o.assembly_id.rendered_publication_text">
                            <span t-field="o.assembly_id.rendered_publication_text"></span>
                        </t>
                    </div>
                </div>

                <div name="agendaitem_data">
                    <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                        <t t-if="report_style == 'light'">
                            <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                <div style="float: left; width: 32px;"><span class="fa fa-list-ol"/></div>
                                <div style="float: left; display: inline;"><strong>Agenda&amp;nbsp;items</strong></div>
                            </div>
                        </t>
                        <t t-else="">
                            <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                <div style="float: left; width: 32px;"><span class="fa fa-list-ol"/></div>
                                <div style="float: left; display: inline;"><strong>Agenda&amp;nbsp;items</strong></div>
                            </div>
                        </t>
                    </div>
                    <div style="margin-top: 4px;">
                        <t t-if="o.assembly_id.agendaitem_ids">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th name="th_number" class="text-center" width="4%"/>
                                        <th name="th_description" width="82%">Description</th>
                                        <th name="th_type" width="14%">Type</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="o.assembly_id.agendaitem_ids" t-as="item"
                                        style="page-break-before: always; page-break-after: auto; page-break-inside: avoid;">
                                        <td name="td_number" class="text-center"><span t-field="item.number"/></td>
                                        <td name="th_description"><span t-field="item.description"/></td>
                                        <td name="th_type"><span t-field="item.type"/></td>
                                    </tr>
                                </tbody>
                            </table>
                        </t>
                    </div>
                </div>

                <div name="approved_data" style="margin-top: 32px; page-break-inside: avoid;">
                    <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                        <t t-if="report_style == 'light'">
                            <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                <div style="float: left; width: 32px;"><span class="fa fa-check-square-o"/></div>
                                <div style="float: left; display: inline;"><strong>Approved</strong></div>
                            </div>
                        </t>
                        <t t-else="">
                            <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                <div style="float: left; width: 32px;"><span class="fa fa-check-square-o"/></div>
                                <div style="float: left; display: inline;"><strong>Approved</strong></div>
                            </div>
                        </t>
                    </div>
                    <div name="current_date_n_place" class="text-right">
                        <t t-if="request.env.user.company_id.city">
                            <span t-esc="request.env.user.company_id.city"/>,
                        </t>
                        <t t-else=""/>
                        <span t-field="o.assembly_id.date_now" t-options="{'format': 'dd MMMM YYYY'}"/>
                    </div>
                    <div name="signatures" class="row" style="border: 1px solid lightgrey; margin: 2px 1px; page-break-inside: avoid;">
                        <div class="col-xs-12" style="display: table;">
                            <div style="border-right: 1px solid lightgrey; width: 50%; display: table-cell;">
                                <p style="margin-left: -8px; margin-top: 2px; margin-bottom: 0px;">
                                    <span><b>THE PRESIDENT</b></span>
                                </p>
                                <t t-if="o.assembly_id.president_id.signature_image">
                                    <div class="text-center">
                                        <img style="max-width: 380px;" t-attf-src="data:image/*;base64,{{o.assembly_id.president_id.signature_image}}"/>
                                    </div>
                                </t>
                                <t t-else="">
                                    <p>&amp;nbsp;</p><p>&amp;nbsp;</p><p>&amp;nbsp;</p>
                                </t>
                                <p>
                                    <span>Sgd.:</span>
                                    <t t-if="o.assembly_id.president_id">
                                        <span t-field="o.assembly_id.president_id"/>
                                    </t>
                                </p>
                            </div>
                            <div style="width: 50%; display: table-cell; padding: 0px 8px;">
                                <p style="margin-top: 2px; margin-bottom: 0px">
                                    <span><b>THE SECRETARY</b></span>
                                </p>
                                <t t-if="o.assembly_id.secretary_id.signature_image">
                                    <div class="text-center">
                                        <img style="max-width: 380px;" t-attf-src="data:image/*;base64,{{o.assembly_id.secretary_id.signature_image}}"/>
                                    </div>
                                </t>
                                <t t-else="">
                                    <p>&amp;nbsp;</p><p>&amp;nbsp;</p><p>&amp;nbsp;</p>
                                </t>
                                <p>
                                    <span>Sgd.:</span>
                                    <t t-if="o.assembly_id.secretary_id">
                                        <span t-field="o.assembly_id.secretary_id"/>
                                    </t>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <t t-if="o.assembly_id.rendered_final_paragraph">
                    <div name="final_paragraph" style="margin-top: 32px;">
                        <span t-field="o.assembly_id.rendered_final_paragraph"></span>
                    </div>
                </t>
                <!-- Force new page -->
                <p style="page-break-after:always;"/>

            </div> <!-- En page -->

        </t>

    </template>

</odoo>