<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <report id="action_wua_assembly_attendance_with_delegationvote_report"
            string="Assembly Attendees (only presents, with delegated votes)"
            model="wua.assembly"
            report_type="qweb-pdf"
            name="base_wua_assembly.report_wua_assembly_attendance_with_delegationvote"
            paperformat="base_wua_report.paperformat_wua_reports"
            groups="base_wua.group_wua_user"/>

    <template id="report_wua_assembly_attendance_with_delegationvote">
        <t t-call="report.html_container">
            <t t-call="base_wua_report.wua_external_layout">
                <div class="page">
                    <t t-foreach="docs" t-as="o">
                        <t t-call="base_wua_assembly.report_wua_assembly_attendance_with_delegationvote_document"/>
                        <p style="page-break-after:always;"></p>
                    </t>
                </div>
            </t>
        </t>
    </template>

    <template id="report_wua_assembly_attendance_with_delegationvote_document">
        <t t-set="report_style" t-value="o.env['ir.values'].get_default('wua.configuration', 'reports_style')"/>
        <div name="section_master" class="text-center">
            <h4 style="margin-top:0px; padding-top:0px;">
                <strong><span t-field="o.issue"/></strong>
            </h4>
            <div>
                <span t-field="o.assembly_date" t-options="{'format': 'dd/MM/YYYY'}"/>
                <span>-</span>
                <span t-field="o.city"/>,
                <span t-field="o.state_id"/>
            </div>
            <div style="margin-top:20px">
                <span>(</span>
                <span>number of attendees:</span>
                <span t-field="o.number_of_attendances_with_signature"/>
                <span>, number of votes:</span>
                <span t-field="o.number_of_possible_votes"/>
                <span>)</span>
            </div>
        </div>
        <div name="section_detail" style="margin-top:20px;">
            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                <t t-if="report_style == 'light'">
                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px; margin-bottom:4px;">
                        <div style="float: left; width: 32px; font-size: 1.2em;"><span class="fa fa-list"/></div>
                        <div style="float: left; display: inline;">
                            <strong>Attendees List</strong>
                        </div>
                    </div>
                </t>
                <t t-else="">
                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px; margin-bottom:4px;">
                        <div style="float: left; width: 32px; font-size: 1.2em;"><span class="fa fa-list"/></div>
                        <div style="float: left; display: inline;">
                            <strong>Attendees List</strong>
                        </div>
                    </div>
                </t>
            </div>
            <small>
            <table class="table table-striped" style="width:100%;">
                <thead>
                    <th name="th_vat_participant">Attendee TIN</th>
                    <th name="th_participant_name">Attendee Name</th>
                    <th name="th_represented_partner">Represents...</th>
                    <th name="th_votes_total" class="text-center">Votes</th>
                    <th name="th_compressed_assignors">Delegated Votes</th>
                    <th name="th_attendance_signature" class="text-center">Attendee Signature</th>
                </thead>
                <t t-if="o.state == '03_in_progress' or o.state == '04_finished'">
                    <tbody>
                        <t t-foreach="o.attendance_ids.filtered(lambda x: x.present == True)" t-as="attendance">
                            <t t-if="attendance.potential_attendee">
                                <tr style="page-break-before: always; page-break-after: auto; page-break-inside: avoid;">
                                    <td name="td_vat_participant"><span t-field="attendance.vat_participant"/></td>
                                    <td name="td_participant_name"><span t-field="attendance.participant_name"/></td>
                                    <td name="td_represented_partner"><span t-field="attendance.represented_partner"/></td>
                                    <td name="td_votes_total" class="text-center"><span t-field="attendance.votes_total"/></td>
                                    <td name="td_compressed_assignors"><span t-field="attendance.compressed_assignors"/></td>
                                    <t t-if="attendance.attendance_signature">
                                        <td name="td_attendance_signature" class="text-center" style="max-width: 125px; max-height: 125px;"><span t-field="attendance.attendance_signature" t-field-options='{"widget": "image"}'/></td>
                                    </t>
                                    <t t-else="">
                                        <td name="td_attendance_signature_none" class="text-center"></td>
                                    </t>
                                </tr>
                            </t>
                        </t>
                    </tbody>
                </t>
            </table>
            </small>
        </div>
    </template>

</odoo>