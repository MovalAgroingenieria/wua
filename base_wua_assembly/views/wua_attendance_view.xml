<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_attendance_calls_particular_view_tree" model="ir.ui.view">
        <field name="name">Calls (tree view)</field>
        <field name="model">wua.attendance</field>
        <field name="arch" type="xml">
            <tree class="o_base_wua_assembly_attendance_calls_view_tree"
                  create="false" delete="false"
                  default_order="partner_id">
                <field name="partner_code"
                       string="Code"/>
                <field name="participant_name"/>
                <field name="votes_owned"
                       string="Votes"
                       sum="Total Votes"/>
            </tree>
        </field>
    </record>

    <record id="wua_attendance_calls_particular_view_search" model="ir.ui.view">
        <field name="name">Calls (search view)</field>
        <field name="model">wua.attendance</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_code"/>
                <field name="participant_name"/>
            </search>
        </field>
    </record>

    <record id="wua_attendance_activate_notes" model="ir.actions.server">
        <field name="name">Enter notes</field>
        <field name="model_id" ref="base_wua_assembly.model_wua_attendance"/>
        <field name="code">
            if context.get('active_id'):
                action = env['wua.attendance'].action_activate_notes(context['active_id'])
        </field>
    </record>

    <record id="wua_attendance_particular_view_form" model="ir.ui.view">
        <field name="name">Attendances (form view)</field>
        <field name="model">wua.attendance</field>
        <field name="arch" type="xml">
            <form create="0" edit="0" delete="0" duplicate="false">
                <field name="assembly_state" invisible="1"/>
                <field name="param_allow_notes_in_signature" invisible="1"/>
                <field name="param_add_qr_code_in_attendance" invisible="1"/>
                <field name="with_attendance_notes" invisible="1"/>
                <script>
                    $(document).ready(function(){
                    $(".btn.btn-primary.btn-sm.o_form_button_save").hide();
                    $(".btn.btn-default.btn-sm.o_form_button_cancel").hide();
                    $(".fa.fa-chevron-left.btn.btn-icon.o_pager_previous").hide();
                    $(".fa.fa-chevron-right.btn.btn-icon.o_pager_next").hide();
                    });
                </script>
                <group name="master_data_01">
                    <group name="master_data_01_left" col="1">
                        <div name="section_partner"
                             style="margin-top:-20px;">
                            <field name="participant_image" widget="image"
                                   class="oe_avatar" options="{'size': [90, 90]}"/>
                            <div name="section_participant_name"
                                 class="oe_title" style="margin-left:10px;">
                                <h1>
                                    <field name="participant_name"/>
                                </h1>
                            </div>
                        </div>
                    </group>
                    <group name="master_data_01_right" col="1">
                        <div name="section_votes_total_title"
                             style="margin-top:-20px;">
                             <field name="html_attendance_title" nolabel="1"/>
                        </div>
                    </group>
                </group>
                <group name="master_data_02">
                    <group name="master_data_02_left">
                        <field name="vat_participant"
                               string="Attendee TIN"/>
                        <field name="represented_partner"
                               string="Represented Partner"
                               attrs="{'invisible': [('represented_partner','=',False)]}"/>
                    </group>
                    <group name="master_data_02_right">
                        <field name="votes_owned"
                               string="Own Votes"
                               readonly="1"
                               attrs="{'invisible': [('votes_delegation','=',0)]}"/>
                        <field name="votes_delegation"
                               string="Delegated Votes"
                               readonly="1"
                               attrs="{'invisible': [('votes_delegation','=',0)]}"/>
                    </group>
                </group>
                <div name="button_activate_notes" colspan="2"
                     class="text-center" style="margin-top:12px;margin-bottom:10px;"
                     attrs="{'invisible': [('param_allow_notes_in_signature','=',False)]}">
                    <button name="%(wua_attendance_activate_notes)d" type="action"
                            string="Enter notes"
                            class="btn-primary"
                            attrs="{'invisible': ['|',('assembly_state','!=','03_in_progress'),('with_attendance_notes','=',True)]}"/>
                    <h4 attrs="{'invisible': [('with_attendance_notes','=',False)]}">ATTENDANCE NOTES</h4>
                    <field name="attendance_notes"
                           style="margin-top:10px;"
                           attrs="{'invisible': [('with_attendance_notes','=',False)]}"/>
                </div>
                <div class="mw-100 text-center" style="margin-bottom:20px">
                    <field name="attendance_signature" widget="signature"
                           nolabel="1"
                           attrs="{'invisible': [('assembly_state','=','04_finished'),('attendance_signature','=',False)]}"/>
                </div>
                <div width="100%" class="text-center"
                     attrs="{'invisible': [('assignors','=',False)]}">
                    <h3>PARTNERS WHO GIVE THEIR VOTE</h3>
                    <br/>
                    <field name="assignors"/>
                    <br/>
                </div>
                <footer style="text-align:center">
                     <button name="confirm_present_value" type="object"
                             string="C O N F I R M" class="btn-primary"
                             attrs="{'invisible': [('assembly_state','!=','03_in_progress')]}"
                             groups="base_wua.group_wua_manager"/>
                </footer>
            </form>
        </field>
    </record>

