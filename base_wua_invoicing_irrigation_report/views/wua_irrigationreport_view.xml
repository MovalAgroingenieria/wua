<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_irrigationreport_view_form" model="ir.ui.view">
        <field name="name">Irrigation Reports (form view)</field>
        <field name="model">wua.irrigationreport</field>
        <field name="inherit_id" ref="base_wua_irrigation_report.wua_irrigationreport_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='intake_id']" position="after">
                <field name="product_id"/>
            </xpath>
            <xpath expr="//field[@name='volume_real']" position="after">
                <field name="invoiced" invisible="1"/>
                <field name="price_unit"/>
                <field name="sum_price_subtotal" attrs="{'invisible': [('invoiced','=', False)]}"/>
                <field name="planned_import" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='initial_volume']" position="attributes">
                <attribute name="attrs">{'readonly':[('invoiced','=', True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='end_volume']" position="attributes">
                <attribute name="attrs">{'readonly':[('invoiced','=', True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='hours']" position="attributes">
                <attribute name="attrs">{'readonly':[('invoiced','=', True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='conversion_factor']" position="attributes">
                <attribute name="attrs">{'readonly':[('invoiced','=', True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='adjustement_volume']" position="attributes">
                <attribute name="attrs">{'readonly':[('invoiced','=', True)]}</attribute>
            </xpath>
            <xpath expr="//page[@name='signature_page']" position="after">
                <page name="invoicing_page" string="Invoicing" invisible="1">
                    <group name="irrigationreport_invoicing_data_group">
                        <group>
                            <field name="irrigationreport_payment_mode_id"
                                   string="Payment Mode"
                                   domain="[('payment_type','=','inbound')]"/>
                            <field name="irrigationreport_mandate_required" invisible="1"/>
                            <field name="irrigationreport_mandate_id"
                                   string="Direct Debit Mandate"
                                   attrs="{'invisible':
                                            [('irrigationreport_mandate_required',
                                            '=',False)]}"
                                   domain="[('state','=','valid'),
                                            ('partner_id','=',partner_id)]"
                                   context="{'reduced_name_get_for_bankingmandate':
                                            True}"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="wua_irrigationreport_view_tree" model="ir.ui.view">
        <field name="name">Irrigation Reports (tree view)</field>
        <field name="model">wua.irrigationreport</field>
        <field name="inherit_id" ref="base_wua_irrigation_report.wua_irrigationreport_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='intake_id']" position="after">
                <field name="product_id"/>
            </xpath>
            <xpath expr="//field[@name='volume_real']" position="after">
                <field name="price_unit"/>
                <field name="sum_price_subtotal"/>
                <field name="invoiced"/>
                <field name="planned_import" readonly="1" invisible="1"/>
            </xpath>
        </field>
    </record>

    <record id="wua_irrigationreport_view_tree_wizard" model="ir.ui.view">
        <field name="name">Irrigation Reports Wizard (tree view)</field>
        <field name="model">wua.irrigationreport</field>
        <field name="inherit_id" ref="base_wua_irrigation_report.wua_irrigationreport_view_tree_wizard"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='parcel_id']" position="after">
                <field name="product_id"/>
            </xpath>
        </field>
    </record>

    <record id="wua_irrigationreport_view_search" model="ir.ui.view">
        <field name="name">Irrigation Reports (search view)</field>
        <field name="model">wua.irrigationreport</field>
        <field name="inherit_id" ref="base_wua_irrigation_report.wua_irrigationreport_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="product_id"/>
            </xpath>
            <xpath expr="//group[@expand='0']" position="before">
                <separator/>
                <filter name="invoiced_yes" string="Invoiced: Yes"
                    domain="[('invoiced','=',True)]"/>
                <filter name="invoiced_no" string="Invoiced: No"
                    domain="[('invoiced','=',False)]"/>
            </xpath>
            <xpath expr="//filter[@name='intake']" position="after">
                <filter name="invoiced_gb" string="Water Type"
                    context="{'group_by':'product_id'}"/>
            </xpath>
        </field>
    </record>

</odoo>