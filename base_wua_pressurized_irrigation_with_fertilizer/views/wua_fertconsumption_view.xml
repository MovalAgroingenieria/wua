<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_fertconsumption_view_form" model="ir.ui.view">
        <field name="name">Consumptions (form view)</field>
        <field name="model">wua.fertconsumption</field>
        <field name="arch" type="xml">
            <form create="0" delete="0" duplicate="0">
                <sheet>
                    <group name="master_data">
                        <group name="master_data_left">
                            <field name="reading_initial_time" attrs="{'readonly':[('presconsumption_id','>',0)]}"/>
                            <field name="reading_end_time" attrs="{'readonly':[('presconsumption_id','>',0)]}"/>
                            <field name="amount"/>
                        </group>
                        <group name="master_data_right">
                            <field name="waterconnection_id" attrs="{'readonly':[('presconsumption_id','>',0)]}"/>
                            <field name="presconsumption_id"/>
                        </group>
                    </group>
                    <group name="slave_data">
                        <notebook name="slave_data_notebook">
                            <page name="notes_page" string="Notes">
                                <field name="notes"/>
                            </page>
                        </notebook>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="wua_fertconsumption_view_tree" model="ir.ui.view">
        <field name="name">Consumptions (tree view)</field>
        <field name="model">wua.fertconsumption</field>
        <field name="arch" type="xml">
            <tree class="o_base_wua_pressurized_irrigation_with_fertilizer_consumptions_view_tree">
                <field name="waterconnection_id"/>
                <field name="reading_initial_time"/>
                <field name="reading_end_time"/>
                <field name="amount"/>
                <field name="presconsumption_id"/>
            </tree>
        </field>
    </record>

    <record id="wua_fertconsumption_view_search" model="ir.ui.view">
        <field name="name">Consumptions (search view)</field>
        <field name="model">wua.fertconsumption</field>
        <field name="arch" type="xml">
            <search>
                <field name="waterconnection_id"/>
                <field name="irrigationshed_id"/>
                <field name="hydraulicsector_id"/>
                <field name="agriculturalseason_id"/>
                <filter string="Associated to a consumption: Yes" name="presconsumptionyes"
                 domain="[('with_presconsumption','=',True)]"/>
                <filter string="Associated to a consumption: No" name="presconsumptionno"
                 domain="[('with_presconsumption','=',False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Agricultural Season"
                     name="agriculturalseason"
                     context="{'group_by':'agriculturalseason_id'}"/>
                    <filter string="Hydraulic Sector"
                     name="hydraulicsector"
                     context="{'group_by':'hydraulicsector_id'}"/>
                    <filter string="Irrigation Shed"
                     name="irrigationshed"
                     context="{'group_by':'irrigationshed_id'}"/>
                    <filter string="Water Connection"
                     name="waterconnection"
                     context="{'group_by':'waterconnection_id'}"/>
                    <filter string="Date"
                     name="readingendtime"
                     context="{'group_by':'reading_end_time:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="wua_fertconsumption_view_graph" model="ir.ui.view">
        <field name="name">Consumptions (graph view)</field>
        <field name="model">wua.fertconsumption</field>
        <field name="arch" type="xml">
            <graph string="Pressure Consumptions" type="bar">
                <field name="hydraulicsector_id"/>
                <field name="amount" type='measure'/>
            </graph>
        </field>
    </record>

    <record id="wua_fertconsumption_view_pivot" model="ir.ui.view">
        <field name="name">Fertilizer Consumptions (pivot view)</field>
        <field name="model">wua.fertconsumption</field>
        <field name="arch" type="xml">
            <pivot string="Agregated Values" display_quantity="true">
                <field name="amount" type="measure"/>
                <field name="hydraulicsector_id"/>
            </pivot>
        </field>
    </record>

    <record id="wua_fertconsumption_action" model="ir.actions.act_window">
        <field name="name">Fertconsumption</field>
        <field name="res_model">wua.fertconsumption</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form,graph,pivot</field>
        <field name="view_id" ref="wua_fertconsumption_view_tree"/>
        <field name="search_view_id" ref="wua_fertconsumption_view_search"/>
        <field name="context">{'search_default_hydraulicsector': 0, 'search_default_readingendtime': 0}</field>
    </record>

    <menuitem id="wua_fertconsumption_menu"
              name="Uses of fertilizer"
              parent="wua_structure_irrigation.base_wua_pressurized_irrigation_menu"
              action="wua_fertconsumption_action"
              sequence="4"
              groups="base_wua.group_wua_user"/>

</odoo>
