<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_irrigation_config_settings_view_form_fertconsumption"
            model="ir.ui.view">
        <field name="name">Parameters - Fertilizer Consumption</field>
        <field name="model">wua.irrigation.configuration</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation.wua_irrigation_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='management_of_reading_type']"
                   position="after">
                <field name="allow_negative_fertconsumption"/>
            </xpath>
        </field>
    </record>

</odoo>
