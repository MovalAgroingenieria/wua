<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_hydricmovement_view_form" model="ir.ui.view">
        <field name="name">Hydric Movements (form view)</field>
        <field name="model">wua.hydricmovement</field>
        <field name="inherit_id" ref="base_wua_quota_management.wua_hydricmovement_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='accounting_volume']" position="replace">
                <field name="accounting_volume_vol_hours"/>
            </xpath>
            <xpath expr="//field[@name='balance']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='balance']" position="after">
                <field name="balance_vol_hours" attrs="{'invisible':[('balance','&lt;',0)]}"/>
            </xpath>
            <xpath expr="//field[@name='negative_balance']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='negative_balance']" position="after">
                <field name="negative_balance_vol_hours" style="color:red" attrs="{'invisible':[('balance','>=',0)]}"/>
            </xpath>
        </field>
    </record>

    <record id="wua_hydricmovement_view_tree" model="ir.ui.view">
        <field name="name">Hydric Movements (tree view)</field>
        <field name="model">wua.hydricmovement</field>
        <field name="inherit_id" ref="base_wua_quota_management.wua_hydricmovement_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='balance']" position="after">
                <field name="informative_amount_eur" class="oe_number"/>
                <field name="accounting_volume_hours"/>
                <field name="balance_hours"/>
            </xpath>
        </field>
    </record>

    <record id="wua_hydricmovement_of_quota_view_tree" model="ir.ui.view">
        <field name="name">Hydric Movements of a quota (tree view)</field>
        <field name="model">wua.hydricmovement</field>
        <field name="inherit_id" ref="base_wua_quota_management.wua_hydricmovement_of_quota_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='balance']" position="after">
                <field name="informative_amount_eur" class="oe_number"/>
                <field name="accounting_volume_hours"/>
                <field name="balance_hours"/>
            </xpath>
        </field>
    </record>

</odoo>