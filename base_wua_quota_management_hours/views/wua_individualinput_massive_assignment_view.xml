<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_individualinput_massive_assignmnet_view_form" model="ir.ui.view">
        <field name="name">Individual Input Massive Assignments (form view)</field>
        <field name="model">wua.individualinput.massive.assignment</field>
        <field name="inherit_id" ref="base_wua_quota_management.wua_individualinput_massive_assignmnet_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='effective_volume']" position="after">
                <field name="effective_volume_hours"/>
            </xpath>
        </field>
    </record>


</odoo>