<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_individualinput_view_form" model="ir.ui.view">
        <field name="name">Individual Inputs (form view)</field>
        <field name="model">wua.individualinput</field>
        <field name="inherit_id" ref="base_wua_quota_management.wua_individualinput_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='volume']" position="replace">
                <field name="volume_vol_hours" colspan="3" attrs="{'readonly':[('id','>',0)]}"/>
            </xpath>
            <xpath expr="//field[@name='effective_volume']" position="replace">
                <field name="effective_volume_vol_hours" colspan="3"/>
            </xpath>
            <xpath expr="//field[@name='quota_accumulated_input']" position="replace">
                <field name="quota_accumulated_input_vol_hours"/>
            </xpath>
            <xpath expr="//field[@name='quota_accumulated_consumption']" position="replace">
                <field name="quota_accumulated_consumption_vol_hours"/>
            </xpath>
            <xpath expr="//field[@name='quota_balance']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='quota_balance']" position="after">
                <field name="quota_balance_vol_hours" attrs="{'invisible':[('quota_balance','&lt;',0)]}"/>
            </xpath>
            <xpath expr="//field[@name='quota_negative_balance']" position="replace">
                <field name="quota_negative_balance_vol_hours" style="color:red" attrs="{'invisible':[('quota_balance','>=',0)]}"/>
            </xpath>
        </field>
    </record>

    <record id="wua_individualinput_view_tree" model="ir.ui.view">
        <field name="name">Individual Inputs (tree view)</field>
        <field name="model">wua.individualinput</field>
        <field name="inherit_id" ref="base_wua_quota_management.wua_individualinput_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='effective_volume']" position="after">
                <field name="effective_volume_hours"/>
            </xpath>
        </field>
    </record>

</odoo>