<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_quotas_config_settings_view_form" model="ir.ui.view">
        <field name="name">Parameters</field>
        <field name="model">wua.quotas.configuration</field>
        <field name="inherit_id" ref="base_wua_quota_management.wua_quotas_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group" position="after">
                <group string="Volume display">
                    <field name="volume_time_equivalence" style="width: 10%;" string="1 hour, in m³ (*)"/>
                    <field name="equivalence_hour_format"/>
                    <field name="hours_as_hhmm"/>
                </group>
                <div>
                    (*) The configuration of this parameter is done in Census/Configuration/Parameters.
                        It will be updated after saving.
                </div>
            </xpath>
        </field>
    </record>

</odoo>