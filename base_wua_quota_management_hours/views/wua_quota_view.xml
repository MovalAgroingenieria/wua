<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_quota_view_form" model="ir.ui.view">
        <field name="name">Quotas (form view)</field>
        <field name="model">wua.quota</field>
        <field name="inherit_id" ref="base_wua_quota_management.wua_quota_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='accumulated_input']" position="replace">
                <field name="accumulated_input_vol_hours"/>
            </xpath>
            <xpath expr="//field[@name='accumulated_consumption']" position="replace">
                <field name="accumulated_consumption_vol_hours"/>
            </xpath>
            <xpath expr="//field[@name='balance']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='balance']" position="after">
                <field name="balance_vol_hours" attrs="{'invisible':[('balance','&lt;',0)]}"/>
            </xpath>
            <xpath expr="//field[@name='negative_balance']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='negative_balance']" position="after">
                <field name="negative_balance_vol_hours" style="color:red" attrs="{'invisible':[('balance','>=',0)]}"/>
            </xpath>
            <xpath expr="//field[@name='average_daily_consumption']" position="replace">
                <field name="average_daily_consumption_vol_hours"/>
            </xpath>
            <xpath expr="//field[@name='estimated_consumption']" position="replace">
                <field name="estimated_consumption_vol_hours"/>
            </xpath>
            <xpath expr="//field[@name='estimated_balance']" position="replace">
                <field name="estimated_balance_vol_hours"/>
            </xpath>
        </field>
    </record>

    <record id="wua_quota_view_tree" model="ir.ui.view">
        <field name="name">Quotas (tree view)</field>
        <field name="model">wua.quota</field>
        <field name="inherit_id" ref="base_wua_quota_management.wua_quota_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='accumulated_input']" position="attributes">
                <attribute name="string">Inputs (m³)</attribute>
            </xpath>
            <xpath expr="//field[@name='accumulated_consumption']" position="attributes">
                <attribute name="string">Consumptions (m³)</attribute>
            </xpath>
            <xpath expr="//field[@name='balance']" position="attributes">
                <attribute name="string">Balance (m³)</attribute>
            </xpath>
            <xpath expr="//field[@name='balance']" position="after">
                <field name="accumulated_input_hours"/>
                <field name="accumulated_consumption_hours"/>
                <field name="balance_hours"/>
            </xpath>
        </field>
    </record>

    <record id="wua_quota_aggregatevalue_view_tree" model="ir.ui.view">
        <field name="name">Quotas Aggregate (tree view)</field>
        <field name="model">wua.quota.aggregatevalue</field>
        <field name="inherit_id" ref="base_wua_quota_management.wua_quota_aggregatevalue_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='accumulated_input']" position="attributes">
                <attribute name="string">Inputs (m³)</attribute>
            </xpath>
            <xpath expr="//field[@name='accumulated_consumption']" position="attributes">
                <attribute name="string">Consumptions (m³)</attribute>
            </xpath>
            <xpath expr="//field[@name='balance']" position="attributes">
                <attribute name="string">Balance (m³)</attribute>
            </xpath>
            <xpath expr="//field[@name='balance']" position="after">
                <field name="accumulated_input_hours"/>
                <field name="accumulated_consumption_hours"/>
                <field name="balance_hours"/>
            </xpath>
            <xpath expr="//field[@name='estimated_balance']" position="attributes">
                <attribute name="string">Estimated balance (m³)</attribute>
            </xpath>
            <xpath expr="//field[@name='estimated_balance']" position="after">
                <field name="estimated_balance_hours"/>
            </xpath>
        </field>
    </record>

</odoo>