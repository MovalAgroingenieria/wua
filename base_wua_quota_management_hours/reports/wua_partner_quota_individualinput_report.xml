<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="wua_partner_quota_individualinput_report_document" 
        inherit_id="base_wua_quota_management.wua_partner_quota_individualinput_report_document">

        <xpath expr="//td[@name='td_volume']" position="replace">
            <td name="td_volume" class="text-center">
                <span t-field="o.volume_vol_hours"/>
            </td>
        </xpath>

        <xpath expr="//td[@name='td_effective_volume']" position="replace">
            <td name="td_effective_volume" class="text-center">
                <span t-field="o.effective_volume_vol_hours"/>
            </td>
        </xpath>

        <xpath expr="//td[@name='td_inputs']" position="replace">
            <td name="td_inputs" class="text-center">
                <span t-field="o.quota_accumulated_input_vol_hours"/>
            </td>
        </xpath>

        <xpath expr="//td[@name='td_consumptions']" position="replace">
            <td name="td_consumptions" class="text-center">
                <span t-field="o.quota_accumulated_consumption_vol_hours"/>
            </td>
        </xpath>

        <xpath expr="//td[@name='td_balance']" position="replace">
            <td name="td_balance" class="text-center">
                <span t-field="o.quota_balance_vol_hours"/>
            </td>
        </xpath>

        <xpath expr="//tr[@name='tr_volume']" position="replace">
            <tr name="tr_volume">
                <td><span><strong>Volume:</strong></span></td>
                <td class="text-right">
                   <span t-field="o.volume_vol_hours"/>
                </td>
            </tr>
        </xpath>

        <xpath expr="//tr[@name='tr_effective_volume']" position="replace">
            <tr name="tr_effective_volume">
                <td><span><strong>Effective volume:</strong></span></td>
                <td class="text-right">
                   <span t-field="o.effective_volume_vol_hours"/>
                </td>
            </tr>
        </xpath>

    </template>

</odoo>
