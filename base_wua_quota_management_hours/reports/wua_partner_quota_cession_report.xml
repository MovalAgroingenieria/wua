<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="wua_partner_quota_cession_report_document"
        inherit_id="base_wua_quota_management.wua_partner_quota_cession_report_document">

        <xpath expr="//td[@name='td_volume']" position="replace">
            <td name="td_volume_vol_hours" class="text-center">
                <span t-field="o.volume_vol_hours"/>
            </td>
        </xpath>

        <xpath expr="//tr[@name='tr_volume']" position="replace">
            <tr name="tr_volume">
                <td><span><strong>Volume:</strong></span></td>
                <td class="text-right">
                   <span t-field="o.volume_vol_hours"/>
                </td>
            </tr>
        </xpath>

    </template>

</odoo>
