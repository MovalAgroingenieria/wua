<odoo>
    <data>
        <template id="assets_frontend" name="My Waterconnections Assets" inherit_id="website.assets_frontend">
            <xpath expr="." position="inside">
                <script type="text/javascript" src="/base_wua_portal_infrastructure/static/src/js/manage_columns.js"></script>
            </xpath>
        </template>
        <template id="portal_my_home_menu_wua" name="Portal layout : wua menu entries" inherit_id="base_wua_portal.portal_my_home_menu_wua" priority="925">
            <xpath expr="//ul[contains(@class,'o_portal_submenu')]" position="inside">
                <li style="order: 3;">
                    <a name="waterconnections_menu" href="/my/waterconnections">Water connections</a>
                </li>
            </xpath>
        </template>
        <template id="portal_my_home_wua" inherit_id="base_wua_portal.portal_my_home_wua" name="My Waterconnections Home">
            <xpath expr="//div[contains(@class,'o_my_home_content')]" position="inside">
                <h3 name="irrigationmanagement_home_header" class="page-header" style="order: 3;">
                    <a href="/my/irrigationmanagement">
                    <i class="fa fa-fw fa-moval-water-counter"></i>
                        Irrigation Management
                    </a>
                </h3>
            </xpath>
        </template>
    </data>
</odoo>