<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_res_notification_document" inherit_id="ncm_notifmgmt.report_res_notification_document">
        <xpath expr="//div[@name='section_rendered_fields']" position="before">
            <t t-set="show_address" t-value="not o.env['ir.values'].get_default('res.notif.config.settings', 'hide_address')"/>
            <t t-if="show_address">
                <div name="wua_partner_data">
                    <div class="row" style="font-size:14;">
                        <div name="wua_partner_data_frame" class="col-xs-12" style="display:table;margin-top:48px;margin-bottom:24px">
                            <div name="wua_partner_data_left" style="width:50%;display:table-cell;">
                            </div>
                            <div name="wua_partner_data_right" style="display:table-cell;padding-left:96px;">
                                <t t-if="o.partner_id.name">
                                    <strong><span t-field="o.partner_id.name"/></strong>
                                    <br/>
                                </t>
                                <t t-if="o.partner_id.street_type_show or o.partner_id.street or o.partner_id.street_num or o.partner_id.street2">
                                    <t t-if="o.partner_id.street_type_show"><span t-field="o.partner_id.street_type_show"/></t>
                                    <t t-if="o.partner_id.street"><span t-field="o.partner_id.street"/></t>
                                    <t t-if="o.partner_id.street_num"><span t-field="o.partner_id.street_num"/></t>
                                    <t t-if="o.partner_id.street2"><span t-field="o.partner_id.street2"/></t>
                                    <br/>
                                </t>
                                <t t-if="o.partner_id.city or o.partner_id.zip">
                                    <t t-if="o.partner_id.city"><span t-field="o.partner_id.city"/></t>
                                    <t t-if="o.partner_id.zip"><span>-&amp;nbsp;</span><span t-field="o.partner_id.zip"/></t>
                                    <br/>
                                </t>
                                <t t-if="o.partner_id.state_id or o.partner_id.country_id">
                                    <t t-if="o.partner_id.state_id"><span t-field="o.partner_id.state_id"/></t>
                                    <t t-if="o.partner_id.country_id"><span>-&amp;nbsp;</span><span t-field="o.partner_id.country_id"></span></t>
                                    <br/>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </xpath>
    </template>

    <template id="dynamic_template_caller">
        <t t-if="o.notificationset_id.notificationset_type_id.attach_report_id.report_name">
            <t name="dynamic_tamplate_caller_if_hook" t-if="o.notificationset_id.notificationset_type_id.attach_report_id.report_name == 'base_wua.wua_partner_report_document'">
                <t t-call="base_wua.wua_partner_report_document"/>
            </t>
            <t t-elif="o.notificationset_id.notificationset_type_id.attach_report_id.report_name == 'base_wua.wua_lessor_report_document'">
                <t t-call="base_wua.wua_lessor_report_document"/>
            </t>
            <t t-elif="o.notificationset_id.notificationset_type_id.attach_report_id.report_name == 'base_wua.wua_partner_report_document_consent'">
                <t t-call="base_wua.wua_partner_report_document_consent"/>
            </t>
            <t t-elif="o.notificationset_id.notificationset_type_id.attach_report_id.report_name == 'base_wua.wua_tenant_report_document'">
                <t t-call="base_wua.wua_tenant_report_document"/>
            </t>
        </t>
    </template>

    <record id="ncm_notifmgmt.action_res_notification_report" model="ir.actions.report.xml">
        <field name="paperformat_id" ref="base_wua_report.paperformat_wua_reports"/>
    </record>

    <template id="report_res_notification" inherit_id="ncm_notifmgmt.report_res_notification">
        <xpath expr="//t[@name='t_call_notification_external_lyout']" position="attributes">
            <attribute name='t-call'>base_wua_report.wua_external_layout</attribute>
        </xpath>

        <xpath expr="//t[@name='t_call_notification_external_lyout']" position="after">
            <!-- Store old_docs variable before calling new report, maybe not necessary but just in case -->
            <t t-set="old_docs" t-value="docs"/>
            <!-- Set new docs as partner_id (Maybe other value future) -->
            <t t-set="docs" t-value="o.partner_id"/>
            <!-- Call report attached report -->
            <t t-call="wua_ncm_notification.dynamic_template_caller"/>
            <!-- Restore old docs -->
            <t t-set="docs" t-value="old_docs"/>
        </xpath>
    </template>
</odoo>