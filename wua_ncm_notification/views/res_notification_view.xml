                <field name="file_id"
                       string="Associated File"/>
            </xpath>
            <xpath expr="//filter[@name='sent_no']" position="after">
                <group expand="0" string="Group By">
                    <filter string="Associated File"
                            name="grouped_file_id"
                     context="{'group_by':'file_id'}"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>