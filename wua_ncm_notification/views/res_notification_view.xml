    <record id="res_notification_view_search" model="ir.ui.view">
        <field name="name">res.notification.inherited.view.search</field>
        <field name="model">res.notification</field>
        <field name="inherit_id" ref="ncm_notifmgmt.res_notification_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
