<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">

        <record id="rule_res_notification_group_wua_portal_user" model="ir.rule">
            <field name="name">Rule for Wua Portal User on notifications</field>
            <field name="model_id" ref="ncm_notifmgmt.model_res_notification"/>
            <field name="domain_force">
                ['|', ('partner_id','=',user.partner_id.id),
                      ('partner_id.child_ids','=',user.partner_id.id)]
            </field>
            <field name="groups" eval="[(4, ref('base_wua.group_wua_portal_user'))]"/>
        </record>

    </data>

</odoo>