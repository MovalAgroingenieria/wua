<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_flowmeter_view_form" model="ir.ui.view">
        <field name="name">Flowmeter (form view)</field>
        <field name="model">wua.flowmeter</field>
        <field name="inherit_id"
               ref="base_wua_remotecontrol_rest_infrastructure.wua_flowmeter_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='telecontrol_rest_associated']" position="after">
                <field name="inelcom_flowmeter_type"
                    attrs="{'invisible':[('telecontrol_rest_associated', '!=', 'inelcom')],
                            'required': [('telecontrol_rest_associated', '=', 'inelcom')]}"/>
                <!-- Data needed when flowmeter on hydrant -->
                <field name="inelcom_id"
                    attrs="{'invisible':['|', ('telecontrol_rest_associated', '!=', 'inelcom'),
                                          ('inelcom_flowmeter_type', '!=', '01_hydrant')],
                            'required': [('telecontrol_rest_associated', '=', 'inelcom'),
                                         ('inelcom_flowmeter_type', '=', '01_hydrant')]}"/>
                <!-- Data needed when flowmeter on head -->
                <field name="inelcom_irrigation_head_id"
                    attrs="{'invisible':['|', ('telecontrol_rest_associated', '!=', 'inelcom'),
                                          ('inelcom_flowmeter_type', '!=', '02_head')],
                            'required': [('telecontrol_rest_associated', '=', 'inelcom'),
                                         ('inelcom_flowmeter_type', '=', '02_head')]}"/>
                <field name="inelcom_irrigation_head_location"
                    attrs="{'invisible':['|', ('telecontrol_rest_associated', '!=', 'inelcom'),
                                          ('inelcom_flowmeter_type', '!=', '02_head')],
                            'required': [('telecontrol_rest_associated', '=', 'inelcom'),
                                         ('inelcom_flowmeter_type', '=', '02_head')]}"/>
                <field name="inelcom_cumulative_reading_magnitude"
                    attrs="{'invisible':['|', ('telecontrol_rest_associated', '!=', 'inelcom'),
                                          ('inelcom_flowmeter_type', '!=', '02_head')],
                            }"/>
                <field name="inelcom_flow_magnitude"
                    attrs="{'invisible':['|', ('telecontrol_rest_associated', '!=', 'inelcom'),
                                          ('inelcom_flowmeter_type', '!=', '02_head')],
                            }"/>
            </xpath>
        </field>
    </record>

</odoo>