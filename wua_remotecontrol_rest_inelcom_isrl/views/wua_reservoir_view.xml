<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_reservoir_view_form" model="ir.ui.view">
        <field name="name">Reservoir (form view)</field>
        <field name="model">wua.reservoir</field>
        <field name="inherit_id"
               ref="base_wua_remotecontrol_rest_reservoir.wua_reservoir_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='telecontrol_associated']" position="after">
                <field name="inelcom_reservoir_type"
                    attrs="{'invisible':[('telecontrol_associated', '!=', 'inelcom')],
                            'required': [('telecontrol_associated', '=', 'inelcom')]}"/>
                <!-- Data needed when reservoir on hydrant -->
                <field name="inelcom_hydrant_analog"
                    attrs="{'invisible':['|', ('telecontrol_associated', '!=', 'inelcom'),
                                          ('inelcom_reservoir_type', '!=', '01_hydrant')],
                            'required': [('telecontrol_associated', '=', 'inelcom'),
                                         ('inelcom_reservoir_type', '=', '01_hydrant')]}"/>
                <field name="inelcom_id"
                    attrs="{'invisible':['|', ('telecontrol_associated', '!=', 'inelcom'),
                                          ('inelcom_reservoir_type', '!=', '01_hydrant')],
                            'required': [('telecontrol_associated', '=', 'inelcom'),
                                         ('inelcom_reservoir_type', '=', '01_hydrant')]}"/>
                <!-- Data needed when reservoir on head -->
                <field name="inelcom_irrigation_head_id"
                    attrs="{'invisible':['|', ('telecontrol_associated', '!=', 'inelcom'),
                                          ('inelcom_reservoir_type', '!=', '02_head')],
                            'required': [('telecontrol_associated', '=', 'inelcom'),
                                         ('inelcom_reservoir_type', '=', '02_head')]}"/>
                <field name="inelcom_irrigation_head_location"
                    attrs="{'invisible':['|', ('telecontrol_associated', '!=', 'inelcom'),
                                          ('inelcom_reservoir_type', '!=', '02_head')],
                            'required': [('telecontrol_associated', '=', 'inelcom'),
                                         ('inelcom_reservoir_type', '=', '02_head')]}"/>
                <field name="inelcom_cumulative_reading_magnitude"
                    attrs="{'invisible':['|', ('telecontrol_associated', '!=', 'inelcom'),
                                          ('inelcom_reservoir_type', '!=', '02_head')],
                            }"/>
            </xpath>
        </field>
    </record>

</odoo>