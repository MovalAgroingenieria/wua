<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_pressuresensor_view_form" model="ir.ui.view">
        <field name="name">Pressure Sensor (form view)</field>
        <field name="model">wua.pressuresensor</field>
        <field name="inherit_id"
               ref="base_wua_remotecontrol_rest.wua_pressuresensor_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='telecontrol_associated']" position="after">
                <field name="inelcom_pressuresensor_type"
                     attrs="{'invisible':[('telecontrol_associated', '!=', 'inelcom')],
                             'required': [('telecontrol_associated', '=', 'inelcom')]}"/>
                <field name="inelcom_hydrant_analog"
                       attrs="{'invisible':['|', ('telecontrol_associated', '!=', 'inelcom'),
                                          ('inelcom_pressuresensor_type', '!=', '01_hydrant')],
                             'required': [('telecontrol_associated', '=', 'inelcom'),
                                          ('inelcom_pressuresensor_type', '=', '01_hydrant')]}"/>
                <field name="inelcom_irrigation_head_id"
                       attrs="{'invisible':['|', ('telecontrol_associated', '!=', 'inelcom'),
                                          ('inelcom_pressuresensor_type', '!=', '02_head')],
                             'required': [('telecontrol_associated', '=', 'inelcom'),
                                          ('inelcom_pressuresensor_type', '=', '02_head')]}"/>
              <field name="inelcom_id"
                     attrs="{'invisible':[('telecontrol_associated', '!=', 'inelcom')],
                             'required': [('telecontrol_associated', '=', 'inelcom')]}"/>
            </xpath>
        </field>
    </record>

</odoo>