<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_irrigation_config_settings_view_form" model="ir.ui.view">
        <field name="name">Parameters</field>
        <field name="model">wua.irrigation.configuration</field>
        <field name="inherit_id"
               ref="base_wua_remotecontrol_rest.wua_irrigation_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='remote_control']"
                   position="after">
                <group name="remote_control_inelcom" string="Remote Control INELCOM"
                        attrs="{'invisible':[('enable_remotecontrol','=',False)],
                             'required': [('enable_remotecontrol', '=', True)]}">
                    <field name="url_remotecontrol_rest_inelcom"
                     attrs="{'invisible':[('enable_remotecontrol','=',False)],
                             'required': [('enable_remotecontrol', '=', True)]}"/>
                    <field name="url_remotecontrol_rest_username_inelcom"
                     attrs="{'invisible':[('enable_remotecontrol','=',False)],
                             'required': [('enable_remotecontrol', '=', True)]}"/>
                    <field name="url_remotecontrol_rest_password_inelcom"
                     attrs="{'invisible':[('enable_remotecontrol','=',False)],
                             'required': [('enable_remotecontrol', '=', True)]}"/>
                    <field name="irrigation_events_start_date"
                     attrs="{'invisible':[('enable_remotecontrol','=',False)],
                             'required': [('enable_remotecontrol', '=', True)]}"/>
                    <field name="automatic_census_synchronization_inelcom"
                     attrs="{'invisible':[('enable_remotecontrol','=',False)],
                             'required': [('enable_remotecontrol', '=', True)]}"/>
                    <field name="url_remotecontrol_application_inelcom"
                     attrs="{'invisible':[('enable_remotecontrol','=',False)]}"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="wua_remotecontrol_application_inelcom_action" model="ir.actions.server">
        <field name="name">Native Remote Control Application of INELCOM</field>
        <field name="model_id" ref="model_wua_reading"/>
        <field name="state">code</field>
        <field name="code">
            action = env['wua.reading'].run_remotecontrol_application_url_inelcom()
        </field>
    </record>

    <menuitem id="wua_remotecontrol_application_inelcom_menu"
              name="Native Remote Control INELCOM"
              parent="wua_structure_irrigation.base_wua_irrigation_configuration_menu"
              action="wua_remotecontrol_application_inelcom_action"
              sequence="3"/>

</odoo>
