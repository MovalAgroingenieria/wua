<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="wua_waterpipeflowreading_view_tree" model="ir.ui.view">
      <field name="name">Waterpipe Flowreading (tree view)</field>
      <field name="model">wua.waterpipeflowreading</field>
      <field name="arch" type="xml">
          <tree class="o_base_wua_waterpipe_measurement_waterpipeflowreading_view_tree">
            <field name="flowmeter_id"/>
            <field name="reading_time"/>
            <field name="volume"/>
            <field name="initialization_reading"/>
            <field name="instant_flow"/>
            <field name="is_last_reading"/>
            <field name="waterpipeconsumption_id"/>
            <field name="validated" string="Validated Waterpipe R."/>
          </tree>
      </field>
  </record>

  <record id="wua_waterpipeflowreading_view_form" model="ir.ui.view">
      <field name="name">Waterpipe Flowreading (form view)</field>
      <field name="model">wua.waterpipeflowreading</field>
      <field name="arch" type="xml">
        <form duplicate="0">
            <header>
                <button name="%(action_delete_waterpipe_flowmeter_readings)d"
                        type="action" string="Delete readings"
                        groups="base_wua.group_wua_manager"/>
            </header>
            <field name="id" invisible="1"/>
            <field name="reading_of_waterpipe" invisible="1"/>
            <field name="is_last_reading" invisible="1"/>
            <sheet>
                <div name="buttons" class="oe_button_box">
                    <img src="/base_wua_waterpipe_measurement/static/image/img_last.png"
                         hspace="2"
                         attrs="{'invisible':[('is_last_reading', '=', False)]}"/>
                </div>
                <group name="master_data">
                    <group name="master_data_left">
                      <field name="flowmeter_id"
                             attrs="{'readonly': [('id', '>', 0)]}"/>
                        <field name="volume"
                               attrs="{'readonly':
                                       [('id', '>', 0),
                                        ('is_last_reading', '!=', True)]}"/>
                        <field name="reading_time"
                               attrs="{'readonly': [('id', '>', 0)]}"/>
                        <field name="instant_flow"
                               attrs="{'readonly': [('id', '>', 0)]}"/>
                        <field name="initialization_reading"
                               attrs="{'readonly': [('id', '>', 0)]}"/>
                    </group>
                    <group name="master_data_right">
                        <field name="waterpipe_id" attrs="{'invisible': [('reading_of_waterpipe', '=', False)]}"/>
                        <field name="waterpipeconsumption_id" attrs="{'invisible': [('reading_of_waterpipe', '=', False)]}"/>
                        <field name="validated" readonly="1"/>
                    </group>
                </group>
                <group name="slave_data">
                    <notebook name="slave_data_notebook">
                        <page name="notes_page" string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </group>
            </sheet>
        </form>
      </field>
  </record>

  <record id="wua_waterpipeflowreading_view_search" model="ir.ui.view">
      <field name="name">Waterpipe Flowreading (search view)</field>
      <field name="model">wua.waterpipeflowreading</field>
      <field name="arch" type="xml">
          <search>
            <field string="Flowmeter" name="flowmeter_id"/>
            <field string="Waterpipe" name="waterpipe_id"/>
            <filter string="Initialization Reading" name="initreadingyes"
             domain="[('initialization_reading','=',True)]"/>
            <filter string="Normal Reading" name="initreadingno"
             domain="[('initialization_reading','=',False)]"/>
            <separator/>
            <filter string="Reading of waterpipe: Yes" name="readingwaterpipeyes"
              domain="[('reading_of_waterpipe','=',True)]"/>
            <filter string="Reading of waterpipe: No" name="readingwaterpipeno"
              domain="[('reading_of_waterpipe','=',False)]"/>
            <separator/>
            <filter string="Validated Reading: Yes" name="isvalidatedyes"
             domain="[('validated','=',True)]"/>
            <filter string="Validated Reading: No" name="isvalidatedno"
             domain="[('validated','=',False)]"/>
            <group expand="0" string="Group By">
                <filter string="Flowmeter"
                  name="flowmeter"
                  context="{'group_by':'flowmeter_id'}"/>
                <filter string="Waterpipe"
                  name="waterpipe"
                  context="{'group_by':'waterpipe_id'}"/>
              </group>
          </search>
      </field>
  </record>

  <record id="wua_validate_waterpipeflowreadings" model="ir.actions.server">
      <field name="name">Validate</field>
      <field name="model_id" ref="model_wua_waterpipeflowreading"/>
      <field name="state">code</field>
      <field name="code">
          if context.get('active_ids'):
              action = env['wua.waterpipeflowreading'].validate_waterpipeflowreadings(context['active_ids'])
      </field>
  </record>

  <record id="wua_action_validate_waterpipeflowreadings" model="ir.values">
      <field name="name">Validate</field>
      <field name="model">wua.waterpipeflowreading</field>
      <field name="key">action</field>
      <field name="key2">client_action_multi</field>
      <field name="value" eval="'ir.actions.server,' + str(ref('wua_validate_waterpipeflowreadings'))"/>
  </record>

  <record id="wua_cancel_waterpipeflowreadings" model="ir.actions.server">
      <field name="name">Cancel</field>
      <field name="model_id" ref="model_wua_waterpipeflowreading"/>
      <field name="state">code</field>
      <field name="code">
          if context.get('active_ids'):
              action = env['wua.waterpipeflowreading'].cancel_waterpipeflowreadings(context['active_ids'])
      </field>
  </record>

  <record id="wua_action_cancel_waterpipeflowreadings" model="ir.values">
      <field name="name">Cancel</field>
      <field name="model">wua.waterpipeflowreading</field>
      <field name="key">action</field>
      <field name="key2">client_action_multi</field>
      <field name="value" eval="'ir.actions.server,' + str(ref('wua_cancel_waterpipeflowreadings'))"/>
  </record>

  <record id="wua_waterpipeflowreading_action" model="ir.actions.act_window">
      <field name="name">Waterpipe Flowmeter Readings</field>
      <field name="res_model">wua.waterpipeflowreading</field>
      <field name="view_type">form</field>
      <field name="view_mode">tree,form</field>
      <field name="view_id" ref="wua_waterpipeflowreading_view_tree"/>
      <field name="search_view_id" ref="wua_waterpipeflowreading_view_search"/>
  </record>

  <menuitem
      name="Waterpipe Flow Meter Readings"
      id="wua_waterpipeflowreading_menu"
      parent="base_wua_irrigation_measurement.base_wua_irrigation_measurement_menu"
      sequence="4"
      action="wua_waterpipeflowreading_action"/>

</odoo>