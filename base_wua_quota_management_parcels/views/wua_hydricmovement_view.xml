<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_hydricmovement_view_form" model="ir.ui.view">
        <field name="name">Hydric Movements (form view)</field>
        <field name="model">wua.hydricmovement</field>
        <field name="inherit_id" ref="base_wua_quota_management.wua_hydricmovement_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='master_data']" position="before">
                <div class="oe_button_box" name="button_box">
                    <button name="action_get_hydric_movements_of_parcel"
                            type="object" class="oe_stat_button"
                            icon="fa-list-ol">
                        <div class="o_form_field o_stat_info">
                            <span class="o_stat_text">Hydric mov.</span>
                            <span class="o_stat_text">of parcel</span>
                        </div>
                    </button>
                </div>
            </xpath>
        </field>
    </record>

</odoo>