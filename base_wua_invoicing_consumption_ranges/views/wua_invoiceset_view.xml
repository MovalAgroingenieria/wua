<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_edit_invoiceset_line_view_tree" model="ir.ui.view" >
        <field name="name">Invoice-Set Lines</field>
        <field name="model">wua.invoiceset.line</field>
        <field name="inherit_id"
               ref="base_wua_invoicing.wua_edit_invoiceset_line_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']"
                   position="attributes">
                <attribute name="domain">
                    [('is_wua_product','=',True),
                     '|',('categ_id.productcategory_code','!=',7),
                         ('is_first_variant','=',True)]
                </attribute>
            </xpath>
        </field>    
    </record>
    
</odoo>
