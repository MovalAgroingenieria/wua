<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_irrigation_config_settings_view_form" model="ir.ui.view">
        <field name="name">Parameters</field>
        <field name="model">wua.irrigation.configuration</field>
        <field name="inherit_id"
               ref="base_wua_invoicing_pressurized_irrigation.wua_irrigation_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='default_pressure_product_id']"
                   position="attributes">
                <attribute name="domain">
                    [('categ_id.productcategory_code','=',7),
                     ('is_first_variant','=',True)]
                </attribute>                                        
            </xpath>
        </field>
    </record>

</odoo>