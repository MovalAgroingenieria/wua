<odoo>
    <record id="view_agriculturalseason_form" model="ir.ui.view">
        <field name="name">Agricultural season form view</field>
        <field name="model">wua.agriculturalseason</field>
        <field name="inherit_id" ref="base_wua_pressurized_irrigation.wua_agriculturalseason_view_form"/>
        <field name="arch" type="xml">
             <xpath expr="//button[@name='action_see_presconsumptions']"
                   position="after">
                    <button name="action_see_preswateringperiods"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-moval-file-irrigation"
                            groups="base_wua.group_wua_user"
                            attrs="{'invisible':[('number_of_preswateringperiods','=', 0)]}">
                            <div class="o_form_field o_stat_info">
                                <span class="o_stat_value">
                                    <field name="number_of_preswateringperiods"/>
                                </span>
                                <span class="o_stat_text">
                                    Watering Periods
                                </span>
                            </div>
                    </button>
            </xpath>
        </field>
    </record>
</odoo>