<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_waterconnection_view_form" model="ir.ui.view">
        <field name="name">Water Connections (form view)</field>
        <field name="model">wua.waterconnection</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation.wua_waterconnection_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_see_irrigation_events']"
                   position="after">
                <field name='number_of_presresconsumptions' invisible="1"/>
                <button name="action_see_presresconsumption"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-moval-intake-wall-consumption"
                        groups="base_wua.group_wua_user"
                        attrs="{'invisible':
                                [('number_of_presresconsumptions','&lt;=',0),]}">
                        <div class="o_form_field o_stat_info"><span class="o_stat_text">
                            Consumption
                        </span><span class="o_stat_text">
                            Requests
                        </span></div>
                </button>
            </xpath>
            <xpath expr="//field[@name='last_reading_consumption']" position="after">
                <field name="default_request_duration"/>
                <field name="default_request_initial_hour" widget="float_time"/>
            </xpath>
        </field>
    </record>


</odoo>
