<odoo>
    <record id="wua_presresconsumption_view_form" model="ir.ui.view">
        <field name="name">wua.presresconsumption.form</field>
        <field name="model">wua.presresconsumption</field>
        <field name="arch" type="xml">
            <form string="Presurized Watering Request" duplicate="0" create="0" edit="0" delete="0">
                <header>
                    <field name="state"
                    widget="statusbar"
                    statusbar_visible="01_proposed,02_granted,03_issued"/>
                </header>
                <group>
                    <group>
                        <field name="preswateringrequest_id" readonly="1"/>
                        <field name="preswateringperiod_id" readonly="1"/>
                        <field name="partner_id"/>
                        <field name="hydraulicsector_id"/>
                        <field name="waterpipe_id"/>
                        <field name="irrigationshed_id"/>
                        <field name="waterconnection_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="request_time"/>
                        <field name="total_affected_area_official_hec"/>
                        <field name="nominal_flow" readonly="1"/>
                        <field name="nominal_flow_ls" readonly="1"/>
                        <field name="nominal_flow_granted" readonly="1"/>
                        <field name="nominal_flow_ls_granted" readonly="1"/>
                        <field name="nominal_flow_issued" readonly="1"/>
                        <field name="nominal_flow_ls_issued" readonly="1"/>
                        <field name="watering_duration"/>
                        <field name="watering_volume"/>
                        <field name="watering_volume_granted"/>
                        <field name="watering_volume_issued"/>
                        <field name="initial_hour" widget="float_time" readonly="1"/>
                    </group>
                </group>
            </form>
        </field>
    </record>

    <record id="wua_presresconsumption_view_tree" model="ir.ui.view">
        <field name="name">wua.presresconsumption.tree</field>
        <field name="model">wua.presresconsumption</field>
        <field name="arch" type="xml">
            <tree string="Presurized Watering Requests" create="0" delete="0" duplicate="0">
                <field name="request_time"/>
                <field name="preswateringrequest_id" invisible="1"/>
                <field name="partner_id"/>
                <field name="preswateringperiod_id"/>
                <field name="waterconnection_id"/>
                <field name="total_affected_area_official_hec"/>
                <field name="nominal_flow"/>
                <field name="nominal_flow_ls"/>
                <field name="nominal_flow_granted"/>
                <field name="nominal_flow_ls_granted"/>
                <field name="nominal_flow_issued"/>
                <field name="nominal_flow_ls_issued"/>
                <field name="watering_duration"/>
                <field name="watering_volume" invisible="1"/>
                <field name="watering_volume_granted" invisible="1"/>
                <field name="watering_volume_issued" invisible="1"/>
                <field name="initial_hour" widget="float_time"/>
                <field name="preswatering_id"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="wua_presresconsumption_view_search" model="ir.ui.view">
        <field name="name">wua.presresconsumption.search</field>
        <field name="model">wua.presresconsumption</field>
        <field name="arch" type="xml">
            <search string="Search Presurized Watering Requests">
                <field name="partner_id"/>
                <field name="preswateringrequest_id"/>
                <field name="waterconnection_id"/>
                <filter string="Created by Farmer" name="is_portal_user"
                        domain="[('is_portal_user', '=', True)]"/>
                <separator/>
                <filter string="Proposed" name="proposed"
                        domain="[('state', '=', '01_proposed')]"/>
                <filter string="Granted" name="granted"
                        domain="[('state', '=', '02_granted')]"/>
                <filter string="Issued" name="issued"
                        domain="[('state', '=', '03_issued')]"/>
                <separator/>
                <filter string="Rejected" name="rejected"
                        domain="[('rejected', '=', '99_rejected')]"/>
                <group expand="0" string="Group By...">
                    <filter string="State"
                            name="group_by_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Water Connection"
                            name="group_by_waterconnection"
                            context="{'group_by': 'waterconnection_id'}"/>
                    <filter string="Campaign"
                            name="group_by_agriculturalseason"
                            context="{'group_by': 'agriculturalseason_id'}"/>
                    <filter string="Request"
                            name="group_by_preswateringrequest"
                            context="{'group_by': 'preswateringrequest_id'}"/>
                    <filter string="Period"
                            name="group_by_preswateringperiod"
                            context="{'group_by': 'preswateringperiod_id'}"/>
                    <filter string="Partner WUA"
                            name="group_by_partner"
                            context="{'group_by': 'partner_id'}"/>
                    <filter string="Preswatering"
                            name="group_by_preswatering"
                            context="{'group_by': 'preswatering_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="wua_presresconsumption_view_pivot" model="ir.ui.view">
        <field name="name">wua.presresconsumption.pivot</field>
        <field name="model">wua.presresconsumption</field>
        <field name="arch" type="xml">
            <pivot string="Agregated Values">
                <field name="total_affected_area_official_hec" type="measure"/>
                <field name="watering_duration" type="measure"/>
                <field name="watering_volume" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="wua_presresconsumption_view_calendar" model="ir.ui.view">
        <field name="name">Pres Watering Requests (calendar view)</field>
        <field name="model">wua.presresconsumption</field>
        <field name="arch" type="xml">
            <calendar create="0" edit="0" string="Presresconsumption"
                        color="partner_id"
                        date_start="request_time"
                        date_delay="watering_duration"
                        mode="month"
                        quick_add="false">
                    <field name="calendar_display_name"/>
            </calendar>
        </field>
    </record>

    <record id="wua_presresconsumption_action" model="ir.actions.act_window">
        <field name="name">Consumption Requests</field>
        <field name="res_model">wua.presresconsumption</field>
        <field name="view_mode">tree,pivot,calendar,form</field>
        <field name="view_id" ref="wua_presresconsumption_view_tree"/>
        <field name="target">current</field>
        <field name="context">{'search_default_group_by_agriculturalseason': 1,
                               'search_default_group_by_preswateringperiod': 1}</field>
    </record>

    <menuitem id="wua_presresconsumption_menu"
              name="Consumption Requests"
              parent="wua_structure_irrigation.base_wua_pressurized_irrigation_menu"
              action="wua_presresconsumption_action"
              sequence="22"/>

    <record id="wua_set_presresconsumption_as_selected" model="ir.actions.server">
        <field name="name">Select for calculation</field>
        <field name="model_id" ref="model_wua_presresconsumption"/>
        <field name="state">code</field>
        <field name="code">
            if context.get('active_ids'):
                action = env['wua.presresconsumption'].set_as_selected(context['active_ids'])
        </field>
    </record>

    <record id="wua_action_set_presresconsumption_as_selected" model="ir.values">
        <field name="name">Set presresconsumption as selected</field>
        <field name="model">wua.presresconsumption</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('wua_set_presresconsumption_as_selected'))"/>
    </record>

    <record id="wua_set_presresconsumption_as_unselected" model="ir.actions.server">
        <field name="name">Unselect for calculation</field>
        <field name="model_id" ref="model_wua_presresconsumption"/>
        <field name="state">code</field>
        <field name="code">
            if context.get('active_ids'):
                action = env['wua.presresconsumption'].set_as_unselected(context['active_ids'])
        </field>
    </record>

    <record id="wua_action_set_presresconsumption_as_unselected" model="ir.values">
        <field name="name">Set presresconsumption as unselected</field>
        <field name="model">wua.presresconsumption</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('wua_set_presresconsumption_as_unselected'))"/>
    </record>

</odoo>