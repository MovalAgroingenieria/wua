<odoo>

    <record id="view_wua_irrigation_config_settings_form" model="ir.ui.view">
        <field name="name">wua.irrigation.config.settings.form</field>
        <field name="model">wua.irrigation.configuration</field>
        <field name="inherit_id" ref="wua_structure_irrigation.wua_irrigation_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='pres_irrig']" position="after">
                <group string="Preswatering Requests">
                    <field name="lock_modification_hours"/>
                    <field name="default_irrigation_duration"/>
                    <field name="default_presresconsumption_initial_hour" widget="float_time"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>