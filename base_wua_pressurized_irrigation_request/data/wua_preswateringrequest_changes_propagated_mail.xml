<odoo>
    <data noupdate="1">
        <record id="email_template_preswateringrequest_update" model="mail.template">
            <field name="name">Preswatering Request Update Notification</field>
            <field name="model_id" ref="base_wua_pressurized_irrigation_request.model_wua_preswateringrequest"/>
            <field name="subject">Your Preswatering Request has been Updated</field>
            <field name="email_from">${(user.email or 'no-reply@yourdomain.com')|safe}</field>
            <field name="email_to">${object.partner_id.email|safe}</field>
            <field name="lang">es_ES</field>
            <field name="body_html">
                <![CDATA[

                    <p>Dear ${object.partner_id.name | safe},</p>
                    <p>Your watering request for the period has been updated. The following changes were applied:</p>

                    <table border="1" style="width: 100%; border-collapse: collapse; text-align: left;">
                        <thead>
                            <tr style="background-color: #f2f2f2;">
                                <th style="padding: 8px;">Water Connection</th>
                                <th style="padding: 8px;">Nominal Flow (l/s)</th>
                                <th style="padding: 8px;">Duration (h)</th>
                                <th style="padding: 8px;">Volume (m³)</th>
                            </tr>
                        </thead>
                        <tbody>
                            % for consumption in ctx['data']['consumptions']:
                                <tr>
                                    <td style="padding: 8px;">${consumption.get('water_connection', '-')}</td>
                                    <td style="padding: 8px;">${consumption.get('nominal_flow', '0.0')}</td>
                                    <td style="padding: 8px;">${consumption.get('watering_duration', '0')}</td>
                                    <td style="padding: 8px;">${consumption.get('watering_volume', '0.0')}</td>
                                </tr>
                            % endfor
                        </tbody>
                    </table>
                    <p>Thank you.</p>
                ]]>
            </field>
        </record>
    </data>
</odoo>
