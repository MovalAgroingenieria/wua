<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <report id="action_wua_preswateringrequest_report"
            string="Preswatering Request"
            model="wua.preswateringrequest"
            report_type="qweb-pdf"
            name="base_wua_pressurized_irrigation_request.report_wua_preswateringrequest"
            file="base_wua_pressurized_irrigation_request.report_wua_preswateringrequest"
            paperformat="base_wua_report.paperformat_wua_reports"/>

    <template id="report_wua_preswateringrequest">
        <t t-call="report.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="base_wua_report.wua_external_layout">
                    <t t-call="base_wua_pressurized_irrigation_request.report_wua_preswateringrequest_document"/>
                </t>
            </t>
        </t>
    </template>

    <template id="report_wua_preswateringrequest_document">
        <div class="page">

            <!-- Vars -->
            <t t-set="report_style" t-value="o.env['ir.values'].get_default('wua.configuration', 'reports_style')"/>
            <t t-set="flow_in_ls" t-value="o.env['ir.values'].get_default('wua.irrigation.configuration', 'preswateringrequest_flow_liters_per_second')"/>

            <!-- Title -->
            <div name="title" class="text-center">
                <h4><strong>Preswatering Request</strong></h4>
            </div>

            <!-- Partner (irrigator) data -->
            <div name="wua_irrigator_data">
                <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                    <t t-if="report_style == 'light'">
                        <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-user"/></div>
                            <div style="float: left; display: inline;"><strong>Irrigator</strong></div>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-user"/></div>
                            <div style="float: left; display: inline;"><strong>Irrigator</strong></div>
                        </div>
                    </t>
                </div>
                <div class="row" style="margin-top: 4px;">
                    <div class="col-xs-12" style="display: table;">
                        <div style="width: 50%; display: table-cell;">
                            <t t-if="o.partner_id.name">
                                <strong><span t-field="o.partner_id.name"/></strong>
                                <t t-if="o.partner_id.vat"><span>(NIF:&#160;<span t-field="o.partner_id.vat"/>)</span></t>
                                <br/>
                            </t>
                            <t t-if="o.partner_id.street or o.partner_id.city or o.partner_id.zip">
                                <t t-if="o.partner_id.street"><span t-field="o.partner_id.street"/><br/></t>
                                <t t-if="o.partner_id.city"><span t-field="o.partner_id.city"/>, </t>
                                <t t-if="o.partner_id.zip"><span t-field="o.partner_id.zip"/></t>
                                <br/>
                            </t>
                            <t t-if="o.partner_id.phone or o.partner_id.mobile">
                                <t t-if="o.partner_id.phone"><span t-field="o.partner_id.phone"/></t>
                                <t t-if="o.partner_id.mobile"><span>,&#160;<span t-field="o.partner_id.mobile"/></span></t>
                                <br/>
                            </t>
                            <t t-if="o.partner_id.email"><span t-field="o.partner_id.email"/><br/></t>
                        </div>
                        <div style="display: table-cell; padding-left: 32px;">
                            <table style="width:100%;">
                                <tbody>
                                    <tr>
                                        <td><span>Code:</span></td>
                                        <td class="text-right"><span t-field="o.name"/></td>
                                    </tr>
                                    <tr>
                                        <td><span>Period:</span></td>
                                        <td class="text-right"><span t-field="o.preswateringperiod_id"/></td>
                                    </tr>
                                    <tr>
                                        <td><span>Agricultural Season:</span></td>
                                        <td class="text-right"><span t-field="o.agriculturalseason_id"/></td>
                                    </tr>
                                    <tr>
                                        <td><span>Start Date:</span></td>
                                        <td class="text-right"><span t-field="o.initial_date"/></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Consumption Requests -->
            <div name="consumption_requests" style="margin-top: 20px;">
                <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                    <t t-if="report_style == 'light'">
                        <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-tint"/></div>
                            <div style="float: left; display: inline;"><strong>Consumption Requests</strong></div>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-tint"/></div>
                            <div style="float: left; display: inline;"><strong>Consumption Requests</strong></div>
                        </div>
                    </t>
                </div>
                <t t-if="o.presresconsumption_ids">
                    <table class="table table-condensed">
                        <thead>
                            <tr>
                                <th>Water Connection</th>
                                <th>Watering Duration (Hours)</th>
                                <t t-if="flow_in_ls">
                                    <th>Nominal Flow (l/s)</th>
                                </t>
                                <t t-else="">
                                    <th>Nominal Flow (m³/h)</th>
                                </t>
                                <th>Watering Volume (m³)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="o.presresconsumption_ids" t-as="consumption">
                                <tr>
                                    <td><span t-field="consumption.waterconnection_id.name"/></td>
                                    <td><span t-field="consumption.watering_duration"/></td>
                                    <t t-if="flow_in_ls">
                                        <td><span t-field="consumption.nominal_flow_ls"/></td>
                                    </t>
                                    <t t-else="">
                                        <td><span t-field="consumption.nominal_flow"/></td>
                                    </t>
                                    <td><span t-field="consumption.watering_volume"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>
            </div>

            <!-- Notes -->
            <t t-if="o.notes or o.notes_user">
                <div name="notes" style="margin-top: 20px;">
                    <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                        <t t-if="report_style == 'light'">
                            <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                <div style="float: left; width: 32px;"><span class="fa fa-sticky-note"/></div>
                                <div style="float: left; display: inline;"><strong>Notes</strong></div>
                            </div>
                        </t>
                        <t t-else="">
                            <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                <div style="float: left; width: 32px;"><span class="fa fa-sticky-note"/></div>
                                <div style="float: left; display: inline;"><strong>Notes</strong></div>
                            </div>
                        </t>
                    </div>
                    <div style="margin-top: 4px;">
                        <t t-if="o.notes"><p><span t-field="o.notes"/></p></t>
                        <t t-if="o.notes_user"><p><span t-field="o.notes_user"/></p></t>
                    </div>
                </div>
            </t>

            <!-- Conformity -->
            <div name="conformity" style="margin-top: 20px;">
                <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                    <t t-if="report_style == 'light'">
                        <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-check-square-o"/></div>
                            <div style="float: left; display: inline;"><strong>Conformity</strong></div>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-check-square-o"/></div>
                            <div style="float: left; display: inline;"><strong>Conformity</strong></div>
                        </div>
                    </t>
                </div>
                <div name="signature" class="row" style="border: 1px solid lightgrey; margin: 2px 1px;">
                    <div class="col-xs-12" style="display: table;">
                        <div style="border-right: 1px solid lightgrey; width: 50%; display: table-cell;">
                            <p style="margin-left: -8px; margin-top: 2px; margin-bottom: 0px;">
                                <span>Place and Date:</span>
                            </p>
                            <p class="text-center" style="margin-top: 4px;">
                                <span t-esc="o.env.user.company_id.city"/>
                                (<span t-esc="o.env.user.company_id.state_id.name"/>),
                                <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y')"/>
                            </p>
                        </div>
                        <div style="width: 50%; display: table-cell; padding: 0px 8px;">
                            <p style="margin-top: 2px; margin-bottom: 0px">
                                <span>Signature</span>
                            </p>
                            <t t-if="o.signature_image">
                                <div class="text-center">
                                    <img style="max-width: 380px;" t-attf-src="data:image/*;base64,{{o.signature_image}}"/>
                                </div>
                            </t>
                            <t t-else="">
                                <p>&#160;</p>
                                <p>&#160;</p>
                                <p>&#160;</p>
                            </t>
                        </div>
                    </div>
                </div>
            </div>

        </div><!-- end page -->
    </template>

</odoo>
