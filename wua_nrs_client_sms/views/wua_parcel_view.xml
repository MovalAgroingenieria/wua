<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="wua_parcel_view_form" model="ir.ui.view">
        <field name="name">Parcels (form view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id" ref="base_wua.wua_parcel_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='buttons']" position="inside">
                <button name="action_see_nrs_parcel" class="oe_stat_button" icon="fa-nrs-sms-registre"
                    type="object"  attrs="{'invisible': [('num_sms','=', 0)]}" help="SMS's that have been sent.">
                    <div class="o_form_field o_stat_info">
                        <span class="o_stat_value" style="display:inline;"><field name="num_sms"/></span>
                        <span class="o_stat_text" style="display:inline;"> SMS's</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

</odoo>