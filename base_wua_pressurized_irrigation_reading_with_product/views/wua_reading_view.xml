<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_reading_view_form" model="ir.ui.view">
        <field name="name">Readings (form view)</field>
        <field name="model">wua.reading</field>
        <field name="inherit_id"
               ref="base_wua_invoicing_pressurized_irrigation.wua_reading_view_form"/>
        <field name="arch" type="xml">
          <xpath expr="//field[@name='watermeter_id']"
                 position="after">
                <field name="product_id"
                       domain="[('categ_id.productcategory_code','=',7)]"
                       attrs="{'readonly': [('id', '>', 0)]}"/>
          </xpath>
        </field>
    </record>

    <record id="wua_reading_view_tree" model="ir.ui.view">
        <field name="name">Readings (tree view)</field>
        <field name="model">wua.reading</field>
        <field name="inherit_id" ref="base_wua_pressurized_irrigation.wua_reading_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='initialization_reading']" position="after">
                <field name="product_id" invisible="1"/>
            </xpath>
        </field>
    </record>

    <record id="wua_reading_view_search" model="ir.ui.view">
        <field name="name">Readings (search view)</field>
        <field name="model">wua.reading</field>
        <field name="inherit_id" ref="base_wua_pressurized_irrigation.wua_reading_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='hydraulicsector_id']" position="after">
                <field name="product_id"/>
            </xpath>
            <xpath expr="//filter[@name='waterconnection']" position="after">
                <filter string="Water Type"
                 name="productid"
                 context="{'group_by':'product_id'}"/>
            </xpath>
        </field>
    </record>

</odoo>
