<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_presconsumption_view_tree" model="ir.ui.view">
        <field name="name">Consumptions (tree view)</field>
        <field name="model">wua.presconsumption</field>
         <field name="inherit_id" ref="base_wua_pressurized_irrigation.wua_presconsumption_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='volume']" position="before">
                <field name="product_id" readonly="1"/>
            </xpath>
        </field>
    </record>

</odoo>
