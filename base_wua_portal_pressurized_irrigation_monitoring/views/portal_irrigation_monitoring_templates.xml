<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="portal_my_irrigation_monitoring" inherit_id="base_wua_portal_infrastructure.portal_my_irrigationmanagement" name="Add Control Readings Menu">
            <xpath expr="//div[@name='irrigation_menu']" position="inside">
                <h3 class="page-header" style="order: 9;">
                    <a href="/my/controlreadings">
                        <i class="fa fa-fw fa-tachometer"/>
                        Control Readings
                        <small class="ml8">
                            <t t-if="controlreadings_count">
                                <span class='badge pull-right'><t t-esc="controlreadings_count"/></span>
                            </t>
                        </small>
                    </a>
                </h3>
            </xpath>
        </template>
        <template id="waterconnections_followup" name="Portal layout : waterconnection entries" inherit_id="base_wua_portal_infrastructure.waterconnections_followup">
            <xpath expr="//div[contains(@name,'buttons')]" position="inside">
                <a t-att-href="'/my/controlreadings?search_field=waterconnection&amp;search=' + waterconnection.name" class="btn oe_stat_button">
                    <div class="fa fa-fw fa-list o_button_icon"></div>
                    <span>Control Readings</span>
                </a>
            </xpath>
        </template>
    </data>
</odoo>
