<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="rule_wua_reading_group_portal" model="ir.rule">
            <field name="name">Rule for Portal User on readings</field>
            <field name="model_id" ref="base_wua_pressurized_irrigation.model_wua_reading"/>
            <field name="domain_force">
                ['|',
                 ('waterconnection_id.irrigationpoint_ids.parcel_id.partnerlink_ids.partner_id','=',user.partner_id.id),
                 ('waterconnection_id.irrigationpoint_ids.parcel_id.partnerlink_ids.partner_id','parent_of',user.partner_id.id)]
            </field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        </record>
        <record id="rule_wua_presconsumption_group_portal" model="ir.rule">
            <field name="name">Rule for Portal User on presconsumptions</field>
            <field name="model_id" ref="base_wua_pressurized_irrigation.model_wua_presconsumption"/>
            <field name="domain_force">
                ['|',
                 ('waterconnection_id.irrigationpoint_ids.parcel_id.partnerlink_ids.partner_id','=',user.partner_id.id),
                 ('waterconnection_id.irrigationpoint_ids.parcel_id.partnerlink_ids.partner_id','parent_of',user.partner_id.id)]
            </field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        </record>
    </data>
</odoo>
