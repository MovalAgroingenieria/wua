<odoo>
    <data>
        <template id="portal_my_readings" name="My Readings">
            <t t-call="website.layout">
                <div class="container mt16">
                    <div class="navbar navbar-default">
                        <div class="navbar-header">
                            <button type="button" class="navbar-toggle" data-toggle="collapse" data-target="#oe-help-navbar-collapse">
                                <span class="sr-only">Toggle navigation</span>
                                <span class="icon-bar"></span>
                                <span class="icon-bar"></span>
                            </button>
                            <a class="navbar-brand" href="/my/home">
                                My Account
                            </a>
                        </div>
                        <div class="collapse navbar-collapse" id="oe-help-navbar-collapse">
                            <ul class="nav navbar-nav o_portal_submenu">
                            <li>
                                <a href="/my/invoices">Invoices</a>
                            </li>
                            <li>
                                <a href="/my/readings">Parcels</a>
                            </li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div id="wrap">
                    <div class="container mb64">
                        <div class="col-md-12">
                            <h3 class="page-header">Your Readings</h3>
                            <t t-if="not readings">
                                <p>There are currently no readings for your account.</p>
                            </t>

                            <t t-if="readings">
                                <form action="/my/readings" method="get" class="mb-3">
                                    <div class="row">
                                        <div class="col-md-2">
                                            <select id="search_field" name="search_field" class="form-control">
                                                <option value="waterconnection" t-att-selected="'waterconnection' == search_field">Water Connection</option>
                                                <option value="watermeter" t-att-selected="'watermeter' == search_field">Water Meter</option>
                                                <option value="reading_time" t-att-selected="'reading_time' == search_field">Date</option>
                                            </select>
                                        </div>
                                        <div class="col-md-8">
                                            <input type="text" name="search" class="form-control" placeholder="Search readings..." t-att-value="search_query or ''"/>
                                        </div>
                                        <div class="col-md-2">
                                            <button type="submit" class="btn btn-primary btn-block">Search</button>
                                        </div>
                                    </div>
                                </form>

                                <table class="table table-hover o_my_status_table">
                                    <thead>
                                        <tr class="active">
                                            <th>Watermeter</th>
                                            <th>Water Connection</th>
                                            <th>Reading Time</th>
                                            <th>Volume</th>
                                            <th>Initialization Reading</th>
                                            <th>Presconsumption Volume</th>
                                            <th>Presconsumption Volume Real</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="readings" t-as="reading">
                                            <tr>
                                                <td>
                                                    <t t-esc="reading.watermeter_id.name"/>
                                                </td>
                                                <td>
                                                    <a t-attf-href="/my/waterconnections/#{partner.waterconnectionlink_ids.filtered(lambda l: l.waterconnection_id == reading.waterconnection_id).id}">
                                                        <t t-esc="reading.waterconnection_id.name"/>
                                                    </a>
                                                </td>
                                                <td>
                                                    <t t-esc="reading.reading_time"/>
                                                </td>
                                                <td>
                                                    <t t-esc="reading.volume"/>
                                                </td>
                                                <td>
                                                    <input type="checkbox" t-att-checked="reading.initialization_reading" disabled="disabled"/>
                                                </td>
                                                <td>
                                                    <t t-esc="reading.presconsumption_volume"/>
                                                </td>
                                                <td>
                                                    <t t-esc="reading.presconsumption_volume_real"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>

                                <div t-if="pager" class="o_portal_pager text-center">
                                    <t t-call="website.pager"/>
                                </div>
                            </t>

                        </div>
                    </div>
                </div>
            </t>
        </template>
        <template id="portal_my_presconsumptions" name="My Presconsumptions">
            <t t-call="website.layout">
            <div class="container mt16">
                <div class="navbar navbar-default">
                <div class="navbar-header">
                    <button type="button" class="navbar-toggle" data-toggle="collapse" data-target="#oe-help-navbar-collapse">
                    <span class="sr-only">Toggle navigation</span>
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                    </button>
                    <a class="navbar-brand" href="/my/home">
                    My Account
                    </a>
                </div>
                <div class="collapse navbar-collapse" id="oe-help-navbar-collapse">
                    <ul class="nav navbar-nav o_portal_submenu">
                    <li>
                        <a href="/my/invoices">Invoices</a>
                    </li>
                    <li>
                        <a href="/my/parcels">Parcels</a>
                    </li>
                    </ul>
                </div>
                </div>
            </div>
            <div id="wrap">
                <div class="container mb64">
                <div class="col-md-12">
                    <h3 class="page-header">Your Presconsumptions</h3>
                    <t t-if="not presconsumptions">
                    <p>There are currently no presconsumptions for your account.</p>
                    </t>

                    <t t-if="presconsumptions">
                    <form action="/my/presconsumptions" method="get" class="mb-3">
                        <div class="row">
                        <div class="col-md-2">
                            <select id="search_field" name="search_field" class="form-control">
                                <option value="waterconnection" t-att-selected="'waterconnection' == search_field">Water Connection</option>
                                <option value="watermeter" t-att-selected="'watermeter' == search_field">Water Meter</option>
                                <option value="date" t-att-selected="'date' == search_field">Date</option>
                            </select>
                        </div>
                        <div class="col-md-8">
                            <input type="text" name="search" class="form-control" placeholder="Search presconsumptions..." t-att-value="search_query or ''"/>
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-primary btn-block">Search</button>
                        </div>
                        </div>
                    </form>

                    <table class="table table-hover o_my_status_table">
                        <thead>
                        <tr class="active">
                            <th>Water Connection</th>
                            <th>Reading Initial Time</th>
                            <th>Initial Lecture(m3)</th>
                            <th>Reading End Time</th>
                            <th>Final Lecture(m3)</th>
                            <th>Volume(m3)</th>
                            <th>Adjustment Volume(m3)</th>
                            <th>Volume Real(m3)</th>
                        </tr>
                        </thead>
                        <tbody>
                        <t t-foreach="presconsumptions" t-as="presconsumption">
                            <tr>
                                <td>
                                    <t t-esc="presconsumption.waterconnection_id.name"/>
                                </td>
                                <td>
                                    <t t-esc="presconsumption.reading_initial_time"/>
                                </td>
                                <td>
                                    <t t-esc="presconsumption.reading_end_time"/>
                                </td>
                                <td>
                                    <t t-esc="presconsumption.volume"/>
                                </td>
                                <td>
                                    <t t-esc="presconsumption.adjustement_volume"/>
                                </td>
                                <td>
                                    <t t-esc="presconsumption.volume_real"/>
                                </td>
                                <td>
                                    <t t-esc="presconsumption.initial_volume"/>
                                </td>
                                <td>
                                    <t t-esc="presconsumption.end_volume"/>
                                </td>
                            </tr>
                        </t>
                        </tbody>
                    </table>

                    <div t-if="pager" class="o_portal_pager text-center">
                        <t t-call="website.pager"/>
                    </div>
                    </t>

                </div>
                </div>
            </div>
            </t>
        </template>
        <template id="portal_my_irrigationevents" name="My Irrigation Events">
            <t t-call="website.layout">
            <div class="container mt16">
                <div class="navbar navbar-default">
                <div class="navbar-header">
                    <button type="button" class="navbar-toggle" data-toggle="collapse" data-target="#oe-help-navbar-collapse">
                    <span class="sr-only">Toggle navigation</span>
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                    </button>
                    <a class="navbar-brand" href="/my/home">
                    My Account
                    </a>
                </div>
                <div class="collapse navbar-collapse" id="oe-help-navbar-collapse">
                    <ul class="nav navbar-nav o_portal_submenu">
                    <li>
                        <a href="/my/invoices">Invoices</a>
                    </li>
                    <li>
                        <a href="/my/parcels">Parcels</a>
                    </li>
                    </ul>
                </div>
                </div>
            </div>
            <div id="wrap">
                <div class="container mb64">
                <div class="col-md-12">
                    <h3 class="page-header">Your irrigationevents</h3>
                    <t t-if="not irrigationevents">
                    <p>There are currently no irrigationevents for your account.</p>
                    </t>

                    <t t-if="irrigationevents">
                    <form action="/my/irrigationevents" method="get" class="mb-3">
                        <div class="row">
                        <div class="col-md-2">
                            <select id="search_field" name="search_field" class="form-control">
                                <option value="waterconnection" t-att-selected="'waterconnection' == search_field">Water Connection</option>
                                <option value="date" t-att-selected="'date' == search_field">Date</option>
                            </select>
                        </div>
                        <div class="col-md-8">
                            <input type="text" name="search" class="form-control" placeholder="Search irrigationevents..." t-att-value="search_query or ''"/>
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-primary btn-block">Search</button>
                        </div>
                        </div>
                    </form>

                    <table class="table table-hover o_my_status_table">
                        <thead>
                        <tr class="active">
                            <th>Water connection</th>
                            <th>Initial irrigation date</th>
                            <th>End irrigation date</th>
                            <th>Volume (m3)</th>
                            <th>Duration</th>
                            <th>Irrigation flow(m3/h)</th>
                            <th>Specific flow rate per surface (m3/hg/h)</th>
                        </tr>
                        </thead>
                        <tbody>
                        <t t-foreach="irrigationevents" t-as="irrigationevent">
                            <tr>
                                <td>
                                    <t t-esc="irrigationevent.waterconnection_id.name"/>
                                </td>
                                <td>
                                    <t t-esc="irrigationevent.irrigation_start_date"/>
                                </td>
                                <td>
                                    <t t-esc="irrigationevent.irrigation_end_date"/>
                                </td>
                                <td>
                                    <t t-esc="irrigationevent.irrigation_volume"/>
                                </td>
                                <td>
                                    <t t-esc="('%d:%02d' % (int(irrigationevent.irrigation_duration), round((irrigationevent.irrigation_duration % 1) * 60)))"/>                                </td>
                                <td>
                                    <t t-esc="irrigationevent.irrigation_flow"/>
                                </td>
                                <td>
                                    <t t-esc="irrigationevent.irrigation_flow_per_surface"/>
                                </td>
                            </tr>
                        </t>
                        </tbody>
                    </table>

                    <div t-if="pager" class="o_portal_pager text-center">
                        <t t-call="website.pager"/>
                    </div>
                    </t>

                </div>
                </div>
            </div>
            </t>
        </template>
        <template id="readings_followup" name="Reading">
            <t t-call="website.layout">
                <div id="wrap">
                    <div class="container">
                        <div class="oe_structure">
                            <div class="row">
                                <div class="col-sm-4">
                                    <ol class="breadcrumb mt8">
                                        <li><a href="/my/home"><i class="fa fa-home"/></a></li>
                                        <li>
                                            <a t-attf-href="/my/readings">
                                                <t>My Readings</t>
                                            </a>
                                        </li>
                                    </ol>
                                </div>
                            </div>
                            <div id="optional_placeholder"></div>
                            <div class="panel panel-default">
                                <div class="panel-heading">
                                    <div class="row">
                                        <div class="col-md-8">
                                            <h4>
                                                <t>Reading</t>
                                                <span t-esc="reading.name"/>
                                            </h4>
                                        </div>
                                    </div>
                                </div>
                                <div class="panel-body">
                                    <div class="row">
                                        <div class="col-md-4 d-flex flex-column justify-content-between"></div>
                                    </div>
                                    <hr/>

                                    <ul name="tabs_titles" class="nav nav-tabs" role="tablist">
                                        <li class="active"><a href="#parcels" role="tab" data-toggle="tab">Parcels</a></li>
                                        <li><a href="#partnerlinks" role="tab" data-toggle="tab"></a></li>
                                    </ul>

                                    <div name="tabs_content" class="tab-content">
                                        <div class="tab-pane active" id="parcels">
                                            <table class="table table-hover">
                                                <thead>
                                                    <tr>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                </tbody>
                                            </table>
                                        </div>
                                        <div class="tab-pane" id="partnerlinks">
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </template>
        <template id="waterconnections_followup" name="Portal layout : waterconnection entries" inherit_id="base_wua_portal_infrastructure.waterconnections_followup">
            <xpath expr="//div[contains(@name,'buttons')]" position="inside">
                <a t-att-href="'/my/readings?search_field=waterconnection&amp;search=' + waterconnection.name" class="btn oe_stat_button">
                    <div class="fa fa-fw fa-list o_button_icon"></div>
                    <span>Readings</span>
                </a>
                <a t-att-href="'/my/presconsumptions?search_field=waterconnection&amp;search=' + waterconnection.name" class="btn oe_stat_button">
                    <div class="fa fa-fw fa-list o_button_icon"></div>
                    <span>Consumptions</span>
                </a>
                <a t-att-href="'/my/irrigationevents?search_field=waterconnection&amp;search=' + waterconnection.name" class="btn oe_stat_button">
                    <div class="fa fa-fw fa-list o_button_icon"></div>
                    <span>Irrigation Events</span>
                </a>
            </xpath>
            <xpath expr="//ul[@name='tabs_titles']" position="inside">
                <li><a href="#irrigation_shifts" role="tab" data-toggle="tab">Irrigation Shifts</a></li>
            </xpath>

            <xpath expr="//div[@name='tabs_content']" position="inside">
                <div class="tab-pane" id="irrigation_shifts">
                    <h4>Irrigation Shifts</h4>
                    <t t-if="not waterconnection.irrigation_shift_ids">
                        <p>There are currently no irrigation shifts for this water connection.</p>
                    </t>
                    <t t-if="waterconnection.irrigation_shift_ids">
                        <table class="table table-hover">
                            <thead>
                                <tr class="active">
                                    <th>Irrigation Shift</th>
                                    <th>Description</th>
                                    <th>Notes</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="waterconnection.irrigation_shift_ids" t-as="shift">
                                    <tr>
                                        <td><t t-esc="shift.irrigation_shift_id.name"/></td>
                                        <td><t t-esc="shift.description"/></td>
                                        <td><t t-esc="shift.notes"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>
                </div>
            </xpath>
        </template>
    </data>
</odoo>