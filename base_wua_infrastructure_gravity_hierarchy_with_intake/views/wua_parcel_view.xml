<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_parcel_view_form" model="ir.ui.view">
        <field name="name">Parcels (form view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id" ref="base_wua_infrastructure_gravity_hierarchy.wua_parcel_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='drainageditch_id']" position="before">
                <field name="intake_id" colspan="8"/>
            </xpath>
        </field>
    </record>

    <record id="wua_parcel_view_search" model="ir.ui.view">
        <field name="name">Parcels (search view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id" ref="base_wua_infrastructure_gravity_hierarchy.wua_parcel_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='irrigationditch_id']" position="after">
                <field name="intake_id"/>
            </xpath>
            <xpath expr="//filter[@name='irrigationditch']" position="after">
                <filter string="Intake" name="intake"
                 context="{'group_by':'intake_id'}"/>
            </xpath>
        </field>
    </record>

</odoo>