<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_wua_wateringrequest_document" inherit_id="base_wua_gravity_irrigation.report_wua_wateringrequest_document">
        <xpath expr="//div[@name='wua_irrigator_data']" position="replace">

            <!-- Partner (irrigator) and agent data -->
            <div name="wua_irrigator_data">
                <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                        <t t-if="o.with_agent">
                            <div style="float: left; width: 32px;"><span class="fa fa-users"/></div>
                            <div style="float: left; display: inline;"><strong>Irrigator and agent</strong></div>
                        </t>
                        <t t-else="">
                            <div style="float: left; width: 32px;"><span class="fa fa-user"/></div>
                            <div style="float: left; display: inline;"><strong>Irrigator</strong></div>
                        </t>
                    </div>
                </div>
                <!-- Irrigator -->
                <div class="row" style="margin-top: 4px;">
                    <div class="col-xs-12" style="display: table;">
                        <div style="width: 60%; display: table-cell;">
                            <t t-if="o.partner_id.name">
                                <strong><span t-field="o.partner_id.name"/></strong>
                                <t t-if="o.partner_id.vat"><span>(NIF:&amp;nbsp;<span t-field="o.partner_id.vat"/>)</span></t>
                                <br/>
                            </t>
                            <t t-if="o.partner_id.street_type_show or o.partner_id.street or o.street_num or o.partner_id.street2">
                                <t t-if="o.partner_id.street_type_show"><span t-field="o.partner_id.street_type_show"/></t>
                                <t t-if="o.partner_id.street"><span t-field="o.partner_id.street"/></t>
                                <t t-if="o.partner_id.street_num"><span t-field="o.partner_id.street_num"/></t>
                                <t t-if="o.partner_id.street2"><span t-field="o.partner_id.street2"/></t>
                                <br/>
                            </t>
                            <t t-if="o.partner_id.city or o.partner_id.zip">
                                <t t-if="o.partner_id.city"><span t-field="o.partner_id.city"/></t>
                                <t t-if="o.partner_id.zip"><span>-&amp;nbsp;</span><span t-field="o.partner_id.zip"/></t>
                                <br/>
                            </t>
                            <t t-if="o.partner_id.state_id or o.partner_id.country_id">
                                <t t-if="o.partner_id.state_id"><span t-field="o.partner_id.state_id"/></t>
                                <t t-if="o.partner_id.country_id"><span>-&amp;nbsp;</span><span t-field="o.partner_id.country_id"></span></t>
                                <br/>
                            </t>
                            <t t-if="o.partner_id.phones or o.partner_id.phone or o.partner_id.mobile">
                                <t t-if="o.partner_id.phones"><span t-field="o.partner_id.phones"/></t>
                                <t t-else="">
                                    <t t-if="o.partner_id.phone"><span t-field="o.partner_id.phone"/></t>
                                    <t t-if="o.partner_id.mobile"><span t-field="o.partner_id.mobile"/></t>
                                </t>
                                <br/>
                            </t>
                            <t t-if="o.partner_id.email"><span t-field="o.partner_id.email"/><br/></t>
                        </div>
                        <div style="width: 40%; display: table-cell; padding: 0px 32px;">
                            <div>&amp;nbsp;</div>
                            <t t-if="o.partner_id.partnerlink_ids">
                                <t t-set="measurement_unit" t-value="o.partner_id.partnerlink_ids[0].parcel_id._compute_area_measurement_name()"/>
                            </t>
                            <table>
                                <tbody>
                                    <tr>
                                        <td><span>Wua partner code:</span></td>
                                        <td class="text-right" style="padding: 0 0 0 90px;">
                                           <t t-if="o.partner_id.partner_code">
                                               <t t-set="partner_code" t-value="str(o.partner_id.partner_code)"/>
                                           </t>
                                           <span t-esc="partner_code"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><span>Number of requests:</span></td>
                                        <td class="text-right">
                                           <t t-if="o.partner_id.number_of_requests">
                                               <t t-set="number_of_requests" t-value="str(o.partner_id.number_of_requests)"/>
                                           </t>
                                           <span t-esc="number_of_requests"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><span>Number of gravity consumptions:</span></td>
                                        <td class="text-right">
                                           <t t-if="o.partner_id.number_of_gravconsumptions">
                                               <t t-set="number_of_gravconsumptions" t-value="str(o.partner_id.number_of_gravconsumptions)"/>
                                           </t>
                                           <span t-esc="number_of_gravconsumptions"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <!-- Agent -->
                <t t-if="o.with_agent">
                    <t t-set="agent_id" t-value="o.sudo().agent_id"/>
                    <hr style="margin: 4 0px;"/>
                    <div class="row" style="margin-top: 4px;">
                        <div class="col-xs-12" style="display: table;">
                            <div style="width: 60%; display: table-cell;">
                                <t t-if="agent_id.name">
                                    <strong><span t-field="agent_id.name"/></strong>
                                    <t t-if="agent_id.vat"><span>(NIF:&amp;nbsp;<span t-field="agent_id.vat"/>)</span></t>
                                    <br/>
                                </t>
                                <t t-if="agent_id.street_type_show or agent_id.street or o.street_num or agent_id.street2">
                                    <t t-if="agent_id.street_type_show"><span t-field="agent_id.street_type_show"/></t>
                                    <t t-if="agent_id.street"><span t-field="agent_id.street"/></t>
                                    <t t-if="agent_id.street_num"><span t-field="agent_id.street_num"/></t>
                                    <t t-if="agent_id.street2"><span t-field="agent_id.street2"/></t>
                                    <br/>
                                </t>
                                <t t-if="agent_id.city or agent_id.zip">
                                    <t t-if="agent_id.city"><span t-field="agent_id.city"/></t>
                                    <t t-if="agent_id.zip"><span>-&amp;nbsp;</span><span t-field="agent_id.zip"/></t>
                                    <br/>
                                </t>
                                <t t-if="agent_id.state_id or agent_id.country_id">
                                    <t t-if="agent_id.state_id"><span t-field="agent_id.state_id"/></t>
                                    <t t-if="agent_id.country_id"><span>-&amp;nbsp;</span><span t-field="agent_id.country_id"></span></t>
                                    <br/>
                                </t>
                                <t t-if="agent_id.phones or agent_id.phone or agent_id.mobile">
                                    <t t-if="agent_id.phones"><span t-field="agent_id.phones"/></t>
                                    <t t-else="">
                                        <t t-if="agent_id.phone"><span t-field="agent_id.phone"/></t>
                                        <t t-if="agent_id.mobile"><span t-field="agent_id.mobile"/></t>
                                    </t>
                                    <br/>
                                </t>
                                <t t-if="agent_id.email"><span t-field="agent_id.email"/><br/></t>
                            </div>
                            <div style="width: 40%; display: table-cell; padding: 0px 32px;">
                                <div>&amp;nbsp;</div>
                                <table>
                                    <tbody>
                                        <tr>
                                            <td><span>Wua partner code:</span></td>
                                            <td class="text-right" style="padding: 0 0 0 124px;">
                                               <t t-if="agent_id.partner_code">
                                                   <t t-set="partner_code" t-value="str(agent_id.partner_code)"/>
                                               </t>
                                               <span t-esc="partner_code"/>
                                            </td>
                                        </tr>
                                        <tr name="tr_is_agent">
                                            <td><span>Is agent:</span></td>
                                            <td class="text-right">
                                                <t t-if="agent_id.is_agent"><span class="fa fa-check"/></t>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </t>
            </div>
        </xpath>

        <xpath expr="//th[@name='th_subparcel']" position="replace">
            <th name="th_idbancal" class="text-center">Id. Bancal</th>
        </xpath>
        <xpath expr="//td[@name='td_subparcel']" position="replace">
            <td name="td_subparcel" align="center">
                <t t-if="l.subparcel_id.id_bancal">
                    <t t-set="id_bancal" t-value="str(l.subparcel_id.id_bancal)"/>
                    <span t-esc="id_bancal"/>
                </t>
            </td>
        </xpath>

        <xpath expr="//div[@name='conformity']" position="after">
            <div class="row">
                <div class="col-xs-12 text-center" name="to_president" style="margin-top: 2px;">
                    <b>Sr. Presidente de la Comunidad de Regantes de las Aguas Reguladas por el Embalse del Argos</b>
                </div>
            </div>

            <!-- Irrigation rules -->
            <p style="page-break-after:always;"></p>
            <div class="row" name="section_norms" style="margin-top: 0px;">
                <div class="col-xs-12 text-justify">
                    <span><b>NORMAS GENERALES SOBRE RIEGO</b></span>
                    <hr style="margin-top: 0px; margin-bottom: 8px;"/>
                    <span style="font-size: 13px;">
                        Que en la Junta General de 24 de marzo de 2017 se aprobó entre otros asuntos: el sistema de reparto general de agua según los 11 sectores existentes de riego tradicional, así como el procedimiento de cálculo de los turnos de riego para cada entande, todo ello en virtud de las obligaciones, competencias y funciones de la Comunidad de Regantes establecidas en la Ley y en las Ordenanzas de la Comunidad, de ordenación y distribución de las aguas, estableciendo los turnos o tandas de riego del modo más conveniente, velando por la seguridad del aprovechamiento y la conservación de presas, acequias y demás obras comunes, con potestad de sancionar a aquellos partícipes que infrinjan las ordenanzas.
                    </span>
                    <span style="font-size: 13px;"><br/><br/>Que la Junta General de 24/03/2018 establece como
                    </span>
                    <span style="font-family: verdana;font-size: 13px;font-weight:bold;">requisito necesario para poder regar con el sistema de riego tradicional, la obligatoriedad de petición previa de agua, para cada periodo de riego o tanda, según el Sistema de Entandamiento implantado.
                    </span>
                    <span style="font-size: 13px;"><br/><br/>
                        Que cada regante es el responsable de administrar su dotación, pudiendo gastar su cupo de agua en los entandamientos que considere oportuno y con la distribución de tiempo que precise. No pudiendo gastar más agua de la que le corresponde según el reparto aprobado en la correspondiente Junta General (ver acuerdos en apartado de transparencia de la web de <a href="http://crargos.org/index.php/transparencia/">CR-ARGOS</a>).
                    </span>
                    <span style="font-size: 13px;"><br/><br/>
                        Que las peticiones de agua hay que registrarlas con tres semanas de antelación: en soporte papel según modelo normalizado en la oficina de CR-ARGOS; o bien a través de sede electrónica del regate (aplicación web puesta a disposición de todos los regantes), indicando: Sector de Riego Tradicional, Bancal, duración del riego (en minutos), Periodo de Riego (tanda)...
                    </span>
                    <span style="font-size: 13px;"><br/><br/>
                        Que el regante puede consultar los periodos de riego abiertos (periodos o tandas de riego en los que puede registrar solicitudes de riego) en la oficia de la Comunidad y en la web de <a href="http://crargos.org/index.php/periodos-de-riego-previstos/">CR-ARGOS</a>; o bien directamente en el <a href="https://gis.crargos.org/crargos/visor/">visor de CR-ARGOS</a> en el apartado de entanades.
                    </span>
                    <span style="font-size: 13px;"><br/><br/>
                        Que los datos de consumo se publican con cada entandamiento (tablón de anuncios físico y web, así como en la aplicación web de entandamiento). El regante será el responsable de conocer la dotación total consumida y la dotación restante a lo largo de la campaña de riego. Estos datos de consumo también están accesibles a través de la sede electrónica del regante.
                    </span>
                    <span style="font-size: 13px;"><br/><br/>
                        Que el desconocimiento de las normas de funcionamiento no le exime de su cumplimiento, entre dichas normas destacan las siguientes:
                    </span>
                    <span style="font-size: 13px; margin-left: 10px;"><br/>
                        - El Regante sólo puede tomar el agua por los tablachos o tomas de la red de riego tradicional; y no está permitido tomar agua por
                    </span>
                    <span style="font-size: 13px; margin-left: 18px;"><br/>
                          cualquier otro sistema de toma no contemplado en las ordenanzas.
                    </span>
                    <span style="font-size: 13px; margin-left: 10px;"><br/>
                        - El Regante no puede tomar el agua cuando no sea su turno.
                    </span>
                    <span style="font-size: 13px; margin-left: 10px;"><br/>
                        - El Regante no puede dejar pasar el agua cuando es su turno.
                    </span>
                    <span style="font-size: 13px; margin-left: 10px;"><br/>
                        - El Regante no puede usar el agua durante más tiempo del asignado.
                    </span>
                    <span style="font-size: 13px; margin-left: 10px;"><br/>
                        - El Regante no puede dejar escurrir el agua por las colas de los ramales o brazales de riego.
                    </span>
                    <span style="font-size: 13px; font-weight:bold;"><br/><br/>
                        Que el regante está obligado a informarse y conocer para cada entande o riego: cuándo es su turno de riego, durante cuánto tiempo puede regar y, en su caso, cuándo debe cortar el agua en el inicio del brazal o ramal de riego.
                    </span>
                </div>
            </div>
        </xpath>

    </template>

    <!-- base_wua_irrigation_with_quota -->
    <template id="report_wua_wateringrequest_with_quota_document" inherit_id="base_wua_gravity_irrigation_with_quota.report_wua_wateringrequest_document">
        <xpath expr="//span[@t-field='o.html_quota_balance']" position="after">
            <t t-if="o.html_quota_balance">
                <div style="font-size: 10px; padding: 0 74px; padding-top: 4px;" class="text-left">
                    El saldo reflejado es un valor provisional que se verá modificado tras la configuración final
                    del entande de riego, donde se aplicará la repercusión del volumen extra desembalsado.
                </div>
            </t>
        </xpath>
    </template>

</odoo>
