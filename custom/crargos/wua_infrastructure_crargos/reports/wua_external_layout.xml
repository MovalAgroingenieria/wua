<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Header modification for argos -->
    <template id="external_layout_header_argos" inherit_id="base_wua_report.external_layout_header">

        <xpath expr="//div[@class='header']" position="replace">
            <t t-set="company" t-value="company.sudo()"/>
            <t t-if="docs and docs[0]._name == 'wua.wateringrequest'">
                <div class="header">
                    <div class="row not-last-page">
                        <div class="col-xs-6">
                            <img t-if="company.logo" t-att-src="'data:image/png;base64,%s' % company.logo"
                                 style="max-width: 322px; margin-top: 4px;"/>
                        </div>
                        <div class="col-xs-6" name="part3" style="margin-bottom: 6px;">
                            <div name="company_address">
                                <t t-if="company.vat">
                                    <!-- The two first chars are sliced -->
                                    <t t-set="mod_vat" t-value="company.vat[2:]"/>
                                    <li class="text-right" style="list-style:none;">TIN: <span t-esc="mod_vat"/></li>
                                </t>
                                <t t-if="company.street or company.street2">
                                    <li class="text-right" style="list-style:none;">
                                        <span t-field="company.street"/>
                                        <t t-if="company.street2">
                                            <span t-field="company.street"/>
                                        </t>
                                        <t t-if="company.city">
                                            <span t-field="company.city"/>
                                        </t>
                                        <t t-if="company.zip">
                                            <span t-field="company.zip"/>
                                        </t>
                                        <t t-if="company.state_id">
                                            <span t-field="company.state_id"/>
                                        </t>
                                        <t t-if="company.country_id">
                                            <span t-field="company.country_id"/>
                                        </t>
                                    </li>
                                </t>
                                <t t-if="company.partner_id">
                                    <li class="text-right" style="list-style:none; margin-left: 2px; width: 100%;">
                                        <t t-if="company.partner_id.email">
                                            <span class="fa fa-envelope theme-report-color" style="display: inline;">
                                                <t t-set="email" t-value="company.partner_id.email"/>
                                                <a style="color: black;" href="mailto:email">
                                                    <span style="font-size: 13px;" t-esc="email"/>
                                                 </a>
                                            </span><br/>
                                        </t>
                                        <t t-if="company.partner_id.website">
                                            <span class="fa fa-globe theme-report-color" style="display: inline;">
                                                <t t-set="website" t-value="company.partner_id.website"/>
                                                <a class="theme-report-color" href="website">
                                                    <span style="font-size: 13px;" t-esc="website"/>
                                                </a>
                                            </span><br/>
                                        </t>
                                        <t t-if="company.partner_id.phone">
                                             <span class="fa fa-phone theme-report-color" style="display: inline;">
                                                <t t-set="phone" t-value="company.partner_id.phone"/>
                                                <a style="color: black;" href="callto:phone">
                                                    <span style="font-size: 13px;" t-esc="phone"/>
                                                </a>
                                            </span><br/>
                                        </t>
                                    </li>
                                </t>
                            </div>
                        </div>
                    </div>
                    <!-- separator line -->
                    <div class="row zero_min_height not-last-page">
                        <div class="col-xs-12">
                            <div style="border-bottom: 1px solid black;"/>
                        </div>
                    </div>
                </div>
            </t>
            <t t-else="">
                <div class="header">
                    <div class="row">
                        <div class="col-xs-6">
                            <img t-if="company.logo" t-att-src="'data:image/png;base64,%s' % company.logo"
                                 style="max-width: 322px; margin-top: 4px;"/>
                        </div>
                        <div class="col-xs-6" name="part3" style="margin-bottom: 6px;">
                            <div name="company_address">
                                <t t-if="company.vat">
                                    <!-- The two first chars are sliced -->
                                    <t t-set="mod_vat" t-value="company.vat[2:]"/>
                                    <li class="text-right" style="list-style:none;">TIN: <span t-esc="mod_vat"/></li>
                                </t>
                                <t t-if="company.street or company.street2">
                                    <li class="text-right" style="list-style:none;">
                                        <span t-field="company.street"/>
                                        <t t-if="company.street2">
                                            <span t-field="company.street"/>
                                        </t>
                                        <t t-if="company.city">
                                            <span t-field="company.city"/>
                                        </t>
                                        <t t-if="company.zip">
                                            <span t-field="company.zip"/>
                                        </t>
                                        <t t-if="company.state_id">
                                            <span t-field="company.state_id"/>
                                        </t>
                                        <t t-if="company.country_id">
                                            <span t-field="company.country_id"/>
                                        </t>
                                    </li>
                                </t>
                                <t t-if="company.partner_id">
                                    <li class="text-right" style="list-style:none; margin-left: 2px; width: 100%;">
                                        <t t-if="company.partner_id.email">
                                            <span class="fa fa-envelope theme-report-color" style="display: inline;">
                                                <t t-set="email" t-value="company.partner_id.email"/>
                                                <a style="color: black;" href="mailto:email">
                                                    <span style="font-size: 13px;" t-esc="email"/>
                                                 </a>
                                            </span><br/>
                                        </t>
                                        <t t-if="company.partner_id.website">
                                            <span class="fa fa-globe theme-report-color" style="display: inline;">
                                                <t t-set="website" t-value="company.partner_id.website"/>
                                                <a class="theme-report-color" href="website">
                                                    <span style="font-size: 13px;" t-esc="website"/>
                                                </a>
                                            </span><br/>
                                        </t>
                                        <t t-if="company.partner_id.phone">
                                             <span class="fa fa-phone theme-report-color" style="display: inline;">
                                                <t t-set="phone" t-value="company.partner_id.phone"/>
                                                <a style="color: black;" href="callto:phone">
                                                    <span style="font-size: 13px;" t-esc="phone"/>
                                                </a>
                                            </span><br/>
                                        </t>
                                    </li>
                                </t>
                            </div>
                        </div>
                    </div>
                    <!-- separator line -->
                    <div class="row zero_min_height">
                        <div class="col-xs-12">
                            <div style="border-bottom: 1px solid black;"/>
                        </div>
                    </div>
                </div>
            </t>
        </xpath>

    </template>


    <template id="external_layout_footer_argos_conditional" inherit_id="base_wua_report.external_layout_footer">

        <xpath expr="//div[@style='border-top: 1px solid black;']" position="replace">
            <t t-if="docs and docs[0]._name == 'wua.wateringrequest'">
                <div style="border-top: 1px solid black;" class="not-last-page">
                    <!-- Company custom footer -->
                    <t t-if="company.custom_footer">
                        <div style="font-size: 8px; margin-top: 2px;text-align: left;">
                            <span t-raw="company.rml_footer"/>
                            <t t-if="company.company_registry">
                                <br/>
                                <span t-field="company.company_registry"/>
                            </t>
                        </div>
                    </t>
                    <div class="first-page" style="font-size: 10px; margin-top: 2px;">
                        <div>
                            <span class="fa fa-eye"/>
                            <span><b>Servicio de vigilancia del agua</b></span>
                            <span><i>(ver normas de riego en el reverso)</i></span>
                        </div>
                        <div>
                            <div style="padding-left: 12px;padding-right: 40px; display: inline;">
                                <span>JOSÉ PÉREZ -</span>
                                <span>608 120 089</span>
                            </div>
                            <div style="padding-right: 40px; display: inline;">
                                <span>JUAN MARTÍNEZ -</span>
                                <span>682 321 926</span>
                            </div>
                            <div style="display: inline;">
                                <span>TELF. GUARDIA -</span>
                                <span>638 912 427</span>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
            <t t-else="">
                <div style="border-top: 1px solid black;">
                    <!-- Company custom footer -->
                    <t t-if="company.custom_footer">
                        <div style="font-size: 8px; margin-top: 2px;text-align: left;">
                            <span t-raw="company.rml_footer"/>
                            <t t-if="company.company_registry">
                                <br/>
                                <span t-field="company.company_registry"/>
                            </t>
                        </div>
                    </t>
                    <!-- Details by document -->
                   <div class="text-right" name="details_by_document">
                       <!-- Details according document type -->
                       <t t-if="docs and docs[0]._name == 'account.invoice' and o.number">
                           <span t-field="o.number" style="font-size: 8px;"/>
                           <span style="font-size: 8px;">&amp;nbsp;&amp;nbsp;</span>
                       </t>
                       <t t-if="docs and docs[0]._name == 'credit.control.communication' and doc.partner_id.name">
                           <span t-field="doc.partner_id.name" style="font-size: 8px;"/>
                           <t t-if="doc.partner_id.partner_code">
                               <span style="font-size: 8px;">[</span><span t-field="doc.partner_id.partner_code" style="font-size: 8px;"/><span style="font-size: 8px;">]</span>
                           </t>
                           <span style="font-size: 8px;">&amp;nbsp;&amp;nbsp;</span>
                       </t>
                       <!-- Page numbers -->
                       <div name="page_numbers" style="display: inline;">
                           <span class="page" style="font-size: 8px;"/>
                           <span style="font-size: 8px;">/</span>
                           <span class="topage" style="font-size: 8px;"/>
                       </div>
                   </div>
                </div>
            </t>
        </xpath>

    </template>

</odoo>