<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_wateringrequest_view_form" model="ir.ui.view">
        <field name="name">Watering Requests (form view)</field>
        <field name="model">wua.wateringrequest</field>
        <field name="inherit_id"
               ref="base_wua_gravity_irrigation.wua_wateringrequest_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="agent_id"
                       options="{'no_quick_create':True,
                                 'no_create_edit':True}"
                       domain="[('is_agent', '=', True)]"
                       attrs="{'readonly':
                               ['|',('is_open','=',False),('id','>',0)]}"
                       groups="base_wua.group_wua_user"/>
            </xpath>
            <xpath expr="//field[@name='subparcel_id']" position="attributes">
                <attribute name='domain'>[('partner_id', '=', parent.partner_id),
                                          ('irrigationgate_id', '!=', False),
                                          ('parcel_id.gravityfed_irrigation_right', '=', True),
                                          ('parcel_id.with_watering_shift', '=', True),
                                          ('irrigationditch_id', '=?', parent.irrigationditch_id),
                                          ('parcel_id.agent_id', '=?', parent.agent_id)]</attribute>
            </xpath> 
        </field>
    </record>

    <record id="wua_wateringrequest_view_tree" model="ir.ui.view">
        <field name="name">Watering Requests (tree view)</field>
        <field name="model">wua.wateringrequest</field>
        <field name="inherit_id"
               ref="base_wua_gravity_irrigation.wua_wateringrequest_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="with_agent"/>
            </xpath> 
        </field>
    </record>

    <record id="wua_wateringrequest_view_search" model="ir.ui.view">
        <field name="name">Watering Requests (search view)</field>
        <field name="model">wua.wateringrequest</field>
        <field name="inherit_id"
               ref="base_wua_gravity_irrigation.wua_wateringrequest_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='agriculturalseason_id']" position="after">
                <field name="agent_id"/>
            </xpath>
            <xpath expr="//filter[@name='stateexecuted']" position="after">
                <separator/>
                <filter string="Agent: Yes" name="with_agent_1"
                 domain="[('with_agent','=',True)]"/>
                <filter string="Agent: No" name="with_agent_0"
                 domain="[('with_agent','=',False)]"/>                
            </xpath>
            <xpath expr="//filter[@name='user']" position="after">
                <filter string="Agent" name="agent"
                    context="{'group_by':'agent_id'}"/>
            </xpath>
        </field>
    </record>

</odoo>