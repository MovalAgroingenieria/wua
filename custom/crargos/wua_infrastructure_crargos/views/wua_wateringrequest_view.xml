<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form" model="ir.ui.view">
        <field name="name">Partners (form view)</field>
        <field name="model">res.partner</field>
        <field name="inherit_id"
               ref="base_wua_gravity_irrigation.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='number_of_votes']"
                   position="after">
                <field name="is_agent"/>
            </xpath>
        </field>
    </record>

    <record id="wua_wateringrequest_view_form" model="ir.ui.view">
        <field name="name">Watering Requests (form view)</field>
        <field name="model">wua.wateringrequest</field>
        <field name="inherit_id"
               ref="base_wua_gravity_irrigation.view_partner_form"/>
        <field name="arch" type="xml">
        </field>
    </record>

</odoo>