<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_edit_parcel_subparcel_view_tree" model="ir.ui.view">
        <field name="name">Subparcels</field>
        <field name="model">wua.parcel.subparcel</field>
        <field name="inherit_id" ref="base_wua_infrastructure.wua_edit_parcel_subparcel_view_tree"/>        
        <field name="arch" type="xml">
            <xpath expr="//field[@name='pos_str']" position="after">
                <field name="id_bancal"/>
            </xpath>        
        </field>
    </record>
    
    <record id="wua_parcel_subparcel_view_form" model="ir.ui.view">
        <field name="name">Subparcels (form view)</field>
        <field name="model">wua.parcel.subparcel</field>
        <field name="inherit_id" ref="base_wua.wua_parcel_subparcel_view_form"/>        
        <field name="arch" type="xml">
            <xpath expr="//field[@name='subparcel_code']" position="after">
                <field name="id_bancal"/>
            </xpath>        
        </field>
    </record>

    <record id="wua_parcel_subparcel_view_tree" model="ir.ui.view">
        <field name="name">Subparcels (tree view)</field>
        <field name="model">wua.parcel.subparcel</field>
        <field name="inherit_id" ref="base_wua.wua_parcel_subparcel_view_tree"/>        
        <field name="arch" type="xml">
            <xpath expr="//field[@name='subparcel_code']" position="after">
                <field name="id_bancal"/>
            </xpath>        
        </field>
    </record>

    <record id="wua_parcel_subparcel_view_search" model="ir.ui.view">
        <field name="name">Subparcels (search view)</field>
        <field name="model">wua.parcel.subparcel</field>
        <field name="inherit_id" ref="base_wua.wua_parcel_subparcel_view_search"/>        
        <field name="arch" type="xml">
            <xpath expr="//field[@name='parcel_id']" position="after">
                <field name="id_bancal"/>
            </xpath>        
        </field>
    </record>

    <record id="wua_technical_parcel_subparcel_view_tree" model="ir.ui.view">
        <field name="name">Subparcels (tree view)</field>
        <field name="model">wua.parcel.subparcel</field>
        <field name="inherit_id" ref="base_wua.wua_technical_parcel_subparcel_view_tree"/>        
        <field name="arch" type="xml">
            <xpath expr="//field[@name='subparcel_code']" position="after">
                <field name="id_bancal"/>
            </xpath>        
        </field>
    </record>

    <record id="wua_parcel_partnerlink_view_tree" model="ir.ui.view">
        <field name="name">Partner Links (tree view)</field>
        <field name="model">wua.parcel.partnerlink</field>
        <field name="inherit_id" ref="base_wua.wua_parcel_partnerlink_view_tree"/>        
        <field name="arch" type="xml">
            <xpath expr="//field[@name='area_official_other_costs_net']" position="after">
                <field name="rurallocation"/>                
                <field name="pressurized_irrigation_right"/>
                <field name="gravityfed_irrigation_right"/>
            </xpath>        
        </field>
    </record>


</odoo>