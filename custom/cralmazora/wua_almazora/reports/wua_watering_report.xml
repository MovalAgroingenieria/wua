<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="paperformat_portrait_standard_watering"
            model="report.paperformat">
        <field name="name">European A4 Portrait</field>
        <field name="default" eval="True"/>
        <field name="format">A4</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">33</field>
        <field name="margin_bottom">20</field>
        <field name="margin_left">9</field>
        <field name="margin_right">9</field>
        <field name="header_line" eval="False" />
        <field name="header_spacing">22</field>
        <field name="dpi">96</field>
    </record>

    <report id="action_wua_watering_report"
            string="Watering"
            model="wua.watering"
            report_type="qweb-pdf"
            name="wua_almazora.report_wua_watering"
            paperformat="paperformat_portrait_standard_watering"
            groups="base_wua.group_wua_user"/>

    <template id="report_wua_watering">
        <t t-call="report.html_container">
            <t t-call="wua_almazora.report_wua_watering_external_layout">
                <div class="page">
                    <t t-foreach="docs" t-as="o">
                        <t t-call="wua_almazora.report_wua_watering_document"/>
                        <p style="page-break-after:always;"></p>
                    </t>
                </div>
            </t>
        </t>
    </template>

    <template id="report_wua_watering_document">
        <div style="font-family: dejavusansmono;font-size: 9;">
            <style type="text/css">
            <![CDATA[
            @font-face {
                font-family: 'verdana';
                src: local('Verdana');
            }
            @font-face {
                font-family: 'dejavusansmono';
                src: local('DejaVu Sans Mono');
            }
            ]]>
            </style>
            <div class="row" name="section_master">
                <div class="col-xs-6" style="font-family: verdana;font-size: 14;">
                    <span t-field="o.irrigationditch_id.name"/>
                </div>
                <div class="col-xs-6 text-right" style="font-family: verdana;font-size: 12;">
                    <span t-field="o.wateringperiod_id"/>
                </div>
            </div>
            <div class="row" name="section_detail" style="margin-top: 20px;margin-left: 0px; margin-right: 0px;">
                <table class="table table-condensed">
                    <thead>
                        <tr style="background-color: #e9e9e9">
                            <th class="text-left">Land Parcel</th>
                            <th class="text-right">Area</th>
                            <th class="text-left">Partner</th>
                            <th class="text-left">Worker</th>
                            <th class="text-right">Gross Amount</th>
                            <th class="text-right">Parcel Net</th>
                            <th class="text-right">Worker Net</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="o.gravconsumption_ids" t-as="l">
                            <td align="left"><span t-field="l.parcel_id"/></td>
                            <td align="right"><span t-field="l.area_official"/></td>
                            <td align="left"><span t-field="l.partner_id.name"/></td>
                            <td align="left"><span t-field="l.employee_id.name"/></td>
                            <td align="right"><span t-field="l.gross_amount"/></td>
                            <td align="right"><span t-field="l.net_parcel_amount"/></td>
                            <td align="right"><span t-field="l.net_worker_amount"/></td>
                        </tr>
                    </tbody>
                </table>
                <div class="row" name="section_total">
                    <div class="col-xs-8"><![CDATA[&nbsp;]]></div>
                    <div class="col-xs-2">Total Area :</div>
                    <div class="col-xs-2 text-right"><span t-esc="'{0:.4f}'.format(sum(l.area_official for l in o.gravconsumption_ids)).replace('.',',')"/></div><br/><br/>
                    <div class="col-xs-8"><![CDATA[&nbsp;]]></div>
                    <div class="col-xs-2">Net Parcel :</div>
                    <div class="col-xs-2 text-right"><span t-esc="'{0:.2f}'.format(sum(l.net_parcel_amount for l in o.gravconsumption_ids)).replace('.',',')"/></div>
                    <div class="col-xs-8"><![CDATA[&nbsp;]]></div>
                    <div class="col-xs-2">Net Worker :</div>
                    <div class="col-xs-2 text-right"><span t-esc="'{0:.2f}'.format(sum(l.net_worker_amount for l in o.gravconsumption_ids)).replace('.',',')"/></div>
                    <div class="col-xs-8"><![CDATA[&nbsp;]]></div>
                    <div class="col-xs-2">Total Gross :</div>
                    <div class="col-xs-2 text-right"><span t-esc="'{0:.2f}'.format(sum(l.gross_amount for l in o.gravconsumption_ids)).replace('.',',')"/></div>
                </div>
            </div>
        </div>
    </template>

    <template id="report_wua_watering_external_layout">
        <!-- Multicompany -->
        <t t-if="not o and doc">
            <t t-set="o" t-value="doc"/>
        </t>
        <t t-if="o and 'company_id' in o">
            <t t-set="company" t-value="o.company_id"></t>
        </t>
        <t t-if="not o or not 'company_id' in o">
            <t t-set="company" t-value="res_company"></t>
        </t>

        <t t-call="wua_almazora.report_wua_watering_external_layout_header" />
        <t t-raw="0" />
        <t t-call="wua_almazora.report_wua_watering_external_layout_footer" />
    </template>

    <template id="report_wua_watering_external_layout_header">
        <div class="header" name="header_content" style="font-family: verdana;font-size: 12;">
            <style type="text/css">
            <![CDATA[
            @font-face {
                font-family: 'verdana';
                src: local('Verdana');
            }
            ]]>
            </style>
            <div name="logo_title_header" class="row">
                <t t-if="company.logo">
                    <div class="col-xs-1">
                        <img t-att-src="'data:image/png;base64,%s' % company.logo" style="max-height: 50px;"/>
                    </div>
                    <div class="col-xs-7" style="margin-top:30px;">
                        <span t-field="company.name"/>
                    </div>
                </t>
                <t t-else="">
                    <div class="col-xs-8" style="margin-top:30px;">
                        <span t-field="company.name"/>
                    </div>
                </t>
                <div class="col-xs-4 text-right" style="margin-top:30px;">
                    <span>WATERING REPORT</span>
                </div>
            </div>
            <div class="row zero_min_height">
                <div class="col-xs-12">
                    <div style="border-bottom: 1px solid black;"></div>
                </div>
            </div>
        </div>
    </template>

    <template id="report_wua_watering_external_layout_footer">
        <div class="footer" name="footer_content" style="font-family: verdana;font-size: 10;">
            <style type="text/css">
            <![CDATA[
            @font-face {
                font-family: 'verdana';
                src: local('Verdana');
            }
            ]]>
            </style>
            <div class="row" name="pagination">
                <div class="col-xs-12 text-center" name="pages" style="margin-top:15px;">
                    <span class="page"/> / <span class="topage"/>
                </div>
            </div>
        </div>
    </template>

</odoo>
