<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Modification in wua partner report (base_wua) -->
    <template id="wua_partner_report_document" inherit_id="base_wua.wua_partner_report_document">
        <!-- Make parcel column wider -->
        <xpath expr="//th[1]" position="attributes">
            <attribute name="t-att-style">"width: 15%;"</attribute>
        </xpath>
    </template>

    <!-- Modification in wua partner report (base_wua_infrastructure) -->
    <template id="wua_partner_infrastructure_report_document"
        inherit_id="base_wua_infrastructure.wua_partner_infrastructure_report_document">
        <!-- Add intake notes column -->
        <xpath expr="//th[@name='pression_hidraulicsector']" position="after">
            <th name="notes">Notes</th>
        </xpath>
        <xpath expr="//td[@name='pression_hidraulicsector']" position="after">
            <td name="notes"><span t-field="ip.waterconnection_id.notes"/></td>
        </xpath>
    </template> 

</odoo>