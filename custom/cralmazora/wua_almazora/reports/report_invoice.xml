<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Modification account wua report invoice -->
    <template id="wua_report_invoice_document_almazora" inherit_id="account.report_invoice_document">

        <!-- Adapt columns width -->
        <xpath expr="//col[@name='product']" position="attributes">
            <attribute name="width">22%</attribute>
        </xpath>
        <xpath expr="//col[@name='description']" position="attributes">
            <attribute name="width">38%</attribute>
        </xpath>
        <xpath expr="//col[@name='quantity']" position="attributes">
            <attribute name="width">15%</attribute>
        </xpath>
        <xpath expr="//col[@name='price']" position="attributes">
            <attribute name="width">16%</attribute>
        </xpath>
        <xpath expr="//col[@name='amount']" position="attributes">
            <attribute name="width">10%</attribute>
        </xpath>

        <!-- Delete monetary widget to adapt decimal positions in price -->
        <xpath expr="//td[@name='price']" position="replace">
            <td name="price" class="text-right">
                <span t-field="l.price_unit"/>
                <span> € /</span>
                <span t-field="l.uom_id" groups="product.group_uom"/>
            </td>
        </xpath>

        <!-- Do not show taxes column -->
        <xpath expr="//th[@name='taxes']" position="attributes">
            <attribute name="class">hidden</attribute>
        </xpath>
        <xpath expr="//td[@name='taxes']" position="attributes">
            <attribute name="class">hidden</attribute>
        </xpath>

    </template>

    <template id="account_invoice_report_due_list.report_invoice_document" inherit_id="account.report_invoice_document">
        <xpath expr='//tr[@name="tr_due_date"]' position="attributes">
            <attribute name="t-att-class">'hidden' if o.multi_due else ''</attribute>
        </xpath>
        <xpath expr="//span[@t-field='o.payment_term_id.note']" position="after">
            <div class="row" t-if="o.multi_due">
                <div class="col-xs-6">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Date Due</th>
                                <th class="text-right">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="o.get_multi_due_list()" t-as="due_tuple">
                                <td>
                                    <span t-esc="due_tuple[0]" t-esc-options="{'widget': 'date'}"/>
                                </td>
                                <td class="text-right">
                                    <span t-esc="due_tuple[1]"
                                          t-esc-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </xpath>
    </template>

</odoo>
