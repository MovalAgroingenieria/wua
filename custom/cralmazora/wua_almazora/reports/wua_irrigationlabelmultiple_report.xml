<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="paperformat_portrait_standard_irrigationlabel"
            model="report.paperformat">
        <field name="name">European A4 Portrait</field>
        <field name="default" eval="True"/>
        <field name="format">A4</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">18</field>
        <field name="margin_bottom">4</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line" eval="False" />
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <report id="action_wua_irrigationlabel_report"
            string="Irrigation Label"
            model="wua.parcel"
            report_type="qweb-pdf"
            name="wua_almazora.report_wua_irrigationlabel"
            paperformat="paperformat_portrait_standard_irrigationlabel"
            groups="base_wua.group_wua_user"/>

    <template id="report_wua_irrigationlabel">
        <t t-call="report.html_container">
            <div class="page" style="font-family: verdana;
                 font-size: 11; margin-left: 6px; margin-right: 6px">
                <style type="text/css">
                <![CDATA[
                @font-face {
                    font-family: 'lucidasansregular';
                    src: local('Lucida Sans');
                }
                @font-face {
                    font-family: 'verdana';
                    src: local('Verdana');
                }
                @font-face {
                    font-family: 'dejavusansmono';
                    src: local('DejaVu Sans Mono');
                }
                ]]>
                </style>
                <t t-set="i" t-value="0"/>
                <t t-set="wua_name" t-value="res_company.name.upper()"/>
                <t t-set="docs" t-value=
                   "docs.filtered(lambda x: x.gross_amount > 0)"/>
                <t t-foreach="docs" t-as="o">
                    <t t-set="i" t-value="i+1"/>
                    <t t-if="i % 2 == 1">
                        <div class="row">
                            <div class="col-xs-6 text-center"
                                 style="font-weight:bold;">
                                <span t-esc="wua_name"/>
                            </div>
                            <t t-if="i &lt; len(docs)">                            
                                <div class="col-xs-6 text-center"
                                     style="font-weight:bold;">
                                    <span t-esc="wua_name"/><br/><br/>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="col-xs-6"><![CDATA[&nbsp;]]></div>
                                <br/><br/>
                            </t>
                            <div class="col-xs-2">
                                YEAR :
                            </div>
                            <div class="col-xs-4">
                                <span t-esc="o.get_year()"/>
                            </div>
                            <t t-if="i &lt; len(docs)">
                                <div class="col-xs-2">
                                    YEAR :
                                </div>
                                <div class="col-xs-4">
                                    <span t-esc="o.get_year()"/><br/><br/>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="col-xs-6"><![CDATA[&nbsp;]]></div>
                                <br/><br/>
                            </t>
                            <div class="col-xs-2">
                                IRRIG. D. :
                            </div>
                            <div class="col-xs-4">
                                <span t-field="o.irrigationditch_id.name"/>
                            </div>
                            <t t-if="i &lt; len(docs)">
                                <div class="col-xs-2">
                                    IRRIG. D. :
                                </div>
                                <div class="col-xs-4">
                                    <span t-esc=
                                     "o.next_parcel_label(docs, i,
                                                          'irrigationditch')"/>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="col-xs-6"><![CDATA[&nbsp;]]></div>
                            </t>
                            <div class="col-xs-2">
                                PARCEL :
                            </div>
                            <div class="col-xs-4">
                                <span t-field="o.name"/>
                            </div>
                            <t t-if="i &lt; len(docs)">
                                <div class="col-xs-2">
                                    PARCEL :
                                </div>
                                <div class="col-xs-4">
                                    <span t-esc=
                                     "o.next_parcel_label(docs, i, 'name')"/>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="col-xs-6"><![CDATA[&nbsp;]]></div>
                            </t>
                            <div class="col-xs-2">
                                CAD.REF. :
                            </div>
                            <div class="col-xs-4">
                                <span t-field="o.cadastral_reference"/>
                            </div>
                            <t t-if="i &lt; len(docs)">
                                <div class="col-xs-2">
                                    CAD.REF. :
                                </div>
                                <div class="col-xs-4">
                                    <span t-esc=
                                     "o.next_parcel_label(docs, i,
                                                          'cadastralref')"/>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="col-xs-6"><![CDATA[&nbsp;]]></div>
                            </t>
                            <div class="col-xs-2">
                                AREA :
                            </div>
                            <div class="col-xs-4">
                                <span t-esc=
                                 "'{:0.2f}'.format(o.area_official)"/>
                                <span t-esc="o.get_area_measurement_name()"/>
                            </div>
                            <t t-if="i &lt; len(docs)">
                                <div class="col-xs-2">
                                    AREA :
                                </div>
                                <div class="col-xs-4">
                                    <span t-esc=
                                     "o.next_parcel_label(docs, i,
                                                          'area')"/>
                                    <span t-esc=
                                     "o.get_area_measurement_name()"/>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="col-xs-6"><![CDATA[&nbsp;]]></div>
                            </t>
                            <div class="col-xs-2">
                                AMOUNT :
                            </div>
                            <div class="col-xs-4">
                                <span t-esc=
                                 "'{:0.2f}'.format(o.gross_amount)"/>
                                <span t-field=
                                 "res_company.currency_id.symbol"/>
                            </div>
                            <t t-if="i &lt; len(docs)">
                                <div class="col-xs-2">
                                    AMOUNT :
                                </div>
                                <div class="col-xs-4">
                                    <span t-esc=
                                     "o.next_parcel_label(docs, i,
                                                          'grossamount')"/>
                                    <span t-field=
                                     "res_company.currency_id.symbol"/>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="col-xs-6"><![CDATA[&nbsp;]]></div>
                            </t>
                            <div class="col-xs-12"><![CDATA[&nbsp;]]><br/><br/></div>
                        </div>
                    </t>
                    <t t-if="i % 12 == 0">
                        <p style="page-break-after:always;"></p>
                    </t>
                </t>
            </div>
        </t>
    </template>

</odoo>