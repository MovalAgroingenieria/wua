<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_parcel_view_tree" model="ir.ui.view">
        <field name="name">Parcels (tree view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id"
               ref="base_wua.wua_parcel_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='number_of_subparcels']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='number_of_subparcels']"
                   position="before">
                <field name="waterconnection_id"/>
            </xpath>
        </field>
    </record>

    <record id="wua_parcel_view_search" model="ir.ui.view">
        <field name="name">Parcels (search view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id"
               ref="base_wua_infrastructure.wua_parcel_view_search"/>        
        <field name="arch" type="xml">
            <xpath expr="//field[@name='hydraulicsector_id']"
                   position="before">
                <field name="waterconnection_id"/>
            </xpath>
            <xpath expr="//filter[@name='hydraulicsector']" position="after">
                <filter string="Water Connection" name="waterconnection"
                 context="{'group_by':'waterconnection_id'}"/>
            </xpath>
        </field>
    </record>

    <record id="wua_parcel_view_form" model="ir.ui.view">
        <field name="name">Parcels (form view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id" ref="base_wua_infrastructure.wua_parcel_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='employee_id']" position="after">
                <field name="gross_amount" colspan="8"
                 attrs="{'invisible':[('with_irrigation_worker','=', False)]}"/>
                <field name="net_parcel_amount" colspan="4"
                 attrs="{'invisible':[('with_irrigation_worker','=', False)]}"/>
                <field name="net_worker_amount" colspan="4"
                 attrs="{'invisible':[('with_irrigation_worker','=', False)]}"/>
            </xpath>

            <!-- Add watering schedule tab -->
            <xpath expr="//page[@name='aerial_img']" position="before">
                <page name="watering_schedule" string="Watering Schedule"
                       groups="base_wua.group_wua_user,base_wua.group_wua_portal_user">
                     <field name="watering_notes"/>
                 </page>
            </xpath>

        </field>
    </record>

</odoo>