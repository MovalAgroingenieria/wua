<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_irrigationreport_view_form" model="ir.ui.view">
        <field name="name">Irrigation Report (form view)</field>
        <field name="model">wua.irrigationreport</field>
        <field name="inherit_id"
               ref="base_wua_irrigation_report.wua_irrigationreport_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='parcel_id']"
                   position="attributes">
                <attribute name="context">{'show_extra_and_rurallocation': True}</attribute>
            </xpath>
        </field>
    </record>

</odoo>
