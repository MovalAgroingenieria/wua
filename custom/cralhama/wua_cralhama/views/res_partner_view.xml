<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form" model="ir.ui.view">
        <field name="name">Partners (form view)</field>
        <field name="model">res.partner</field>
        <field name="inherit_id"
               ref="base_wua_gravity_irrigation.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_see_watering_requests']"
                   position="attributes">
              <attribute name="groups">base_wua.group_wua_user</attribute>
            </xpath>
            <xpath expr="//button[@name='action_see_gravity_consumptions']"
                   position="attributes">
              <attribute name="groups">base_wua.group_wua_user</attribute>
            </xpath>

        </field>
    </record>

    <record id="view_partner_form_mail" model="ir.ui.view">
        <field name="name">Partners (form view)</field>
        <field name="model">res.partner</field>
        <field name="inherit_id"
               ref="mail_tracking.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='%(mail_tracking.action_view_mail_tracking_email)d']"
                   position="attributes">
              <attribute name="groups">base_wua.group_wua_user</attribute>
            </xpath>

        </field>
    </record>

</odoo>
