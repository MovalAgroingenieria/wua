<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_wua_irrigationreport_document"
        inherit_id="base_wua_irrigation_report.report_wua_irrigationreport_document">

        <xpath expr="//tr[@name='report_number']" position="replace">
            <tr name="delivery_note_str">
                 <td><span>Delivery Note</span></td>
                 <t t-if="o.delivery_note_str">
                     <td class="text-right">
                         <strong><span t-field="o.delivery_note_str"/></strong>
                     </td>
                 </t>
            </tr>
        </xpath>

    </template>

</odoo>