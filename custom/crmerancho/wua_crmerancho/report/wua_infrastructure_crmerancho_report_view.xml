<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_parcel_partnerlink_view_pivot" model="ir.ui.view">
        <field name="name">Partner links (pivot view)</field>
        <field name="model">wua.parcel.partnerlink</field>
        <field name="arch" type="xml">
            <pivot string="Partner links">
                <field name="hydraulicsector_id" type="col"/>
                <field name="area_official_net" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="wua_parcel_partnerlink_view_search" model="ir.ui.view">
        <field name="name">Partner links (search view)</field>
        <field name="model">wua.parcel.partnerlink</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <filter string="Owner" name="owner"
                 domain="[('profile','=','O')]"/>
                <filter string="Lessee" name="lessee"
                 domain="[('profile','=','L')]"/>
                <filter string="Payer" name="payer"
                 domain="[('profile','=','P')]"/>
                <separator/>                
                <filter string="Infrastructure: None" name="hydraulic_infrastructure_type_0"
                 domain="[('hydraulic_infrastructure_type','=',False)]"/>
                <filter string="Infrastructure: Pressurized Irrigation" name="hydraulic_infrastructure_type_1"
                 domain="[('hydraulic_infrastructure_type','=',1)]"/>
                <filter string="Infrastructure: Gravity Irrigation" name="hydraulic_infrastructure_type_2"
                 domain="[('hydraulic_infrastructure_type','=',2)]"/>
                <filter string="Infrastructure: Pressurized and Gravity Irrigation" name="hydraulic_infrastructure_type_3"
                 domain="[('hydraulic_infrastructure_type','=',3)]"/>
                <separator/>
                <filter string="Water Right: Pressurized Irrigation" name="pressurizedirrigation"
                 domain="[('pressurized_irrigation_right','=',True)]"/>
                <filter string="Water Right: Gravity Irrigation" name="gravityfedirrigation"
                 domain="[('gravityfed_irrigation_right','=',True)]"/>
                 <group expand="0" string="Group By">
                    <filter string="Hydraulic Sector" name="hydraulicsector"
                     context="{'group_by':'hydraulicsector_id'}"/>
                    <filter string="Irrigation Ditch" name="irrigationditch"
                     context="{'group_by':'irrigationditch_id'}"/>
                    <filter string="Partner" name="partner"
                     context="{'group_by':'partner_id'}"/>
                 </group>
            </search>
        </field>
    </record>

    <record id="wua_partnerlink_report_action" model="ir.actions.act_window">
        <field name="name">Partners (summary)</field>
        <field name="res_model">wua.parcel.partnerlink</field>
        <field name="view_mode">pivot</field>
        <field name="search_view_id" ref="wua_parcel_partnerlink_view_search"/>
        <field name="context">{
            'search_default_owner':1,
            'search_default_partner':1,
        }</field>
    </record>

    <menuitem id="wua_reports_menu"
              name="Reports"
              parent="base_wua.base_wua_census_menu"
              sequence="1000"/>
              
    <menuitem id="wua_reports_partnerlinks_menu"
              name="Partners (summary)"
              parent="wua_reports_menu"
              action="wua_partnerlink_report_action"
              sequence="1"
              groups="base_wua.group_wua_manager"/>              

</odoo>