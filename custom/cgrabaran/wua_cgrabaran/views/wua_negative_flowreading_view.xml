<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_negative_flowreading_view_tree" model="ir.ui.view">
        <field name="name">Negative Flowreadings (tree view)</field>
        <field name="model">wua.negative.flowreading</field>
        <field name="arch" type="xml">
            <tree
             class="o_wua_cgrabaran_negative_readings_view_tree">
                <field name="flowmeter_id"/>
                <field name="intake_id"/>
                <field name="reading_time"/>
                <field name="volume"/>
                <field name="intakeconsumption_volume" string="Cons. Value (m3)"/>
            </tree>
        </field>
    </record>

    <record id="wua_negative_flowreading_view_search" model="ir.ui.view">
        <field name="name">Negative Flowreadings (search view)</field>
        <field name="model">wua.negative.flowreading</field>
        <field name="arch" type="xml">
            <search>
                <field name="flowmeter_id"/>
                <field name="intake_id"/>
                <group expand="0" string="Group By">
                    <filter string="Intake"
                     name="intake"
                     context="{'group_by':'intake_id'}"/>
                    <filter string="Flow Meter"
                     name="flowmeter"
                     context="{'group_by':'flowmeter_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="wua_negative_flowreading_action" model="ir.actions.act_window">
        <field name="name">Negative Flowreadings</field>
        <field name="res_model">wua.negative.flowreading</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="wua_negative_flowreading_view_tree"/>
        <field name="search_view_id" ref="wua_negative_flowreading_view_search"/>
    </record>

    <menuitem id="wua_negative_flowreading_menu"
              name="Negative Flowreadings"
              parent="base_wua_irrigation_measurement.base_wua_irrigation_measurement_menu"
              action="wua_negative_flowreading_action"
              sequence="4"
              groups="base_wua.group_wua_user"/>

</odoo>
