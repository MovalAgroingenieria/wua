<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_flowreading_view_form" model="ir.ui.view">
        <field name="name">Flowreadings (form view)</field>
        <field name="model">wua.flowreading</field>
        <field name="inherit_id" ref="base_wua_irrigation_measurement.wua_flowreading_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='intake_id']" position="attributes">
              <attribute name="attrs">{'readonly': [('initialization_reading', '=', True)],
                                       'invisible': [('reading_of_intake', '=', False)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='initialization_reading']" position="after">
              <field name="is_toll"/>
            </xpath>
        </field>
    </record>

    <record id="wua_flowreading_view_tree" model="ir.ui.view">
        <field name="name">Flowreadings (tree view)</field>
        <field name="model">wua.flowreading</field>
        <field name="inherit_id" ref="base_wua_irrigation_measurement.wua_flowreading_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='intakeconsumption_id']" position="after">
                <field name="from_import" string="Man."/>
                <field name="validated" string="Valid"/>
                <field name="is_toll" string="Toll"/>
            </xpath>
        </field>
    </record>

    <record id="wua_flowreading_view_search" model="ir.ui.view">
        <field name="name">Flowreadings (search view)</field>
        <field name="model">wua.flowreading</field>
        <field name="inherit_id" ref="base_wua_irrigation_measurement.wua_flowreading_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='initreadingno']" position="after">
                <separator/>
                <filter string="Manual Introduction: Yes" name="fromimportyes"
                 domain="[('from_import','=',True)]"/>
                <filter string="Manual Introduction: No (from remote control)" name="fromimportno"
                 domain="[('from_import','=',False)]"/>
                <separator/>
                <filter string="Validated: Yes" name="isvalidatedyes"
                 domain="[('validated','=',True)]"/>
                <filter string="Validated: No" name="isvalidatedno"
                 domain="[('validated','=',False)]"/>
                 <separator/>
                <filter string="Toll: Yes" name="istollyes"
                 domain="[('is_toll','=',True)]"/>
                <filter string="Toll: No" name="istollno"
                 domain="[('is_toll','=',False)]"/>
            </xpath>
        </field>
    </record>

    <record id="wua_validate_flowreadings" model="ir.actions.server">
        <field name="name">Validate</field>
        <field name="model_id" ref="model_wua_flowreading"/>
        <field name="state">code</field>
        <field name="code">
            if context.get('active_ids'):
                action = env['wua.flowreading'].validate_flowreadings(context['active_ids'])
        </field>
    </record>

    <record id="wua_action_validate_flowreadings" model="ir.values">
        <field name="name">Validate</field>
        <field name="model">wua.flowreading</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('wua_validate_flowreadings'))"/>
    </record>

    <record id="wua_cancel_flowreadings" model="ir.actions.server">
        <field name="name">Cancel</field>
        <field name="model_id" ref="model_wua_flowreading"/>
        <field name="state">code</field>
        <field name="code">
            if context.get('active_ids'):
                action = env['wua.flowreading'].cancel_flowreadings(context['active_ids'])
        </field>
    </record>

    <record id="wua_action_cancel_flowreadings" model="ir.values">
        <field name="name">Cancel</field>
        <field name="model">wua.flowreading</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('wua_cancel_flowreadings'))"/>
    </record>

</odoo>
