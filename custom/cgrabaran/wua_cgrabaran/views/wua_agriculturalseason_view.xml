<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_agriculturalseason_view_form" model="ir.ui.view">
        <field name="name">Agriculturalseason (form view)</field>
        <field name="model">wua.agriculturalseason</field>
        <field name="inherit_id"
        ref="base_wua_irrigation_measurement.wua_agriculturalseason_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_see_intakeconsumptions']" position="after">
                <button name="action_see_sum_intakeconsumption_invoicing"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-list-alt "
                        groups="base_wua.group_wua_user"
                        attrs="{'invisible':[('id', '=', False)]}">
                        <div class="o_form_field o_stat_info">
                            <span class="o_stat_text">Consumptions</span>
                            <span class="o_stat_text">balance</span>
                        </div>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
