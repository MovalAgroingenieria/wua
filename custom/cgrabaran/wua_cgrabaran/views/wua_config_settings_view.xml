<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_config_settings_view_form" model="ir.ui.view">
        <field name="name">Parameters</field>
        <field name="model">wua.configuration</field>
        <field name="inherit_id" ref="base_wua.wua_config_settings_view_form"/>
        <field name="arch" type="xml">
          <xpath expr="//group[@name='polling_system_group']" position="before">
            <group string="Companies">
                <field name="company_01" style="width:200px;"/>
                <field name="company_02" style="width:200px;"/>
                <field name="company_03" style="width:200px;"/>
                <field name="company_01_abv" style="width:200px;"/>
                <field name="company_02_abv" style="width:200px;"/>
                <field name="company_03_abv" style="width:200px;"/>
            </group>
            <group string="Polling System Company 1" name="polling_system_group_company_01">
                <field name="polling_system_type_company_01" widget="radio"/>
                <field name="polling_system_interval_company_01" style="width:100px"
                 attrs="{'invisible':[('polling_system_type_company_01','!=',2)]}"/>
                <field name="polling_system_rounding_type_company_01" widget="radio"
                 attrs="{'invisible':[('polling_system_type_company_01','!=',2)]}"/>
                <field name="polling_system_intervals_company_01" style="width:100%%"
                 attrs="{'invisible':[('polling_system_type_company_01','!=',3)]}"/>
            </group>
            <group string="Polling System Company 2" name="polling_system_group_company_02">
                <field name="polling_system_type_company_02" widget="radio"/>
                <field name="polling_system_interval_company_02" style="width:100px"
                 attrs="{'invisible':[('polling_system_type_company_02','!=',2)]}"/>
                <field name="polling_system_rounding_type_company_02" widget="radio"
                 attrs="{'invisible':[('polling_system_type_company_02','!=',2)]}"/>
                <field name="polling_system_intervals_company_02" style="width:100%%"
                 attrs="{'invisible':[('polling_system_type_company_02','!=',3)]}"/>
            </group>
            <group string="Polling System Company 3" name="polling_system_group_company_03">
                <field name="polling_system_type_company_03" widget="radio"/>
                <field name="polling_system_interval_company_03" style="width:100px"
                 attrs="{'invisible':[('polling_system_type_company_03','!=',2)]}"/>
                <field name="polling_system_rounding_type_company_03" widget="radio"
                 attrs="{'invisible':[('polling_system_type_company_03','!=',2)]}"/>
                <field name="polling_system_intervals_company_03" style="width:100%%"
                 attrs="{'invisible':[('polling_system_type_company_03','!=',3)]}"/>
            </group>
          </xpath>
          <xpath expr="//group[@name='polling_system_group']" position="attributes">
            <attribute name="attrs">{'invisible': True}</attribute>
          </xpath>


        </field>
    </record>

</odoo>
