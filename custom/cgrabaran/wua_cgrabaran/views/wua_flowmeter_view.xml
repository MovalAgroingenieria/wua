<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="wua_flowmeter_view_form" model="ir.ui.view">
      <field name="name">Flowmeter (form view)</field>
      <field name="model">wua.flowmeter</field>
      <field name="inherit_id" ref="base_wua_irrigation_measurement.wua_flowmeter_view_form"/>
      <field name="arch" type="xml">
        <xpath expr="//field[@name='nominal_water_flow']" position="after">
          <field name="scada_remote_code"></field>
          <field name="scada_identifier"></field>
          <field name="scada_info_type"></field>
        </xpath>
      </field>
  </record>
</odoo>
