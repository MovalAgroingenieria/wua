<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_sum_intakeconsumption_invoicing_view_tree" model="ir.ui.view">
        <field name="name">Consumption balance (tree view)</field>
        <field name="model">wua.sum.intakeconsumption.invoicing</field>
        <field name="arch" type="xml">
            <tree create="0" delete="0" duplicate="0"
                class="o_wua_cgrabaran_wua_sum_intakeconsumption_invoicing_view_tree">
                <field name="month" invisible="1"/>
                <field name="month_year_name"/>
                <field name="sum_intakeconsumption_company_01" string="Intake" sum="Total"/>
                <field name="sum_invoicing_company_01" string="Invoicing" sum="Total"/>
                <field name="difference_intakeconsumption_invoicing_company_01" string="Difference" sum="Total"/>
                <field name="sum_intakeconsumption_company_02" string="Intake" sum="Total"/>
                <field name="sum_invoicing_company_02" string="Invoicing" sum="Total"/>
                <field name="difference_intakeconsumption_invoicing_company_02" string="Difference" sum="Total"/>
                <field name="sum_intakeconsumption_company_03" string="Intake" sum="Total"/>
                <field name="sum_invoicing_company_03" string="Invoicing" sum="Total"/>
                <field name="difference_intakeconsumption_invoicing_company_03" string="Difference" sum="Total"/>
          </tree>
      </field>
    </record>

    <record id="wua_intakeconsumption_balance_view_form" model="ir.ui.view">
        <field name="name">Intakeconsumption Balance (form view)</field>
        <field name="model">wua.intakeconsumption.balance</field>
        <field name="arch" type="xml">
            <form duplicate="0">
                <sheet>
                    <div name="buttons" class="oe_button_box">
                        <button name="action_see_sum_intakeconsumption_invoicing"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-list-alt "
                            groups="base_wua.group_wua_user"
                            attrs="{'invisible':[('id', '=', False)]}">
                            <div class="o_form_field o_stat_info">
                                <span class="o_stat_text">Consumptions</span>
                                <span class="o_stat_text">balance</span>
                            </div>
                        </button>
                    </div>
                    <field name='id' invisible="True"/>
                    <group name="master_data">
                        <group name="master_data_left">
                            <field name="balance_type"
                                 attrs="{'readonly': [('id', '>', 0)]}"/>
                            <field name="agriculturalseason_id"
                                attrs="{'invisible':[('balance_type', '!=', 'C')],
                                        'readonly': [('id', '>', 0)]}"/>
                            <field name="date_range_id"
                                attrs="{'invisible': [('balance_type', '!=', 'R')],
                                        'readonly': [('id', '>', 0)]}"/>
                            <field name="description"/>
                        </group>
                        <group name="master_data_right">
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="wua_intakeconsumption_balance_view_tree" model="ir.ui.view">
        <field name="name">Intakeconsumption Balance (tree view)</field>
        <field name="model">wua.intakeconsumption.balance</field>
        <field name="arch" type="xml">
            <tree class="o_wua_cgrabaran_intakeconsumption_balance_view_tree">
                <field name="description"/>
            </tree>
        </field>
    </record>

    <record id="wua_intakeconsumption_balance_view_search" model="ir.ui.view">
        <field name="name">Intakeconsumption Balance (search view)</field>
        <field name="model">wua.intakeconsumption.balance</field>
        <field name="arch" type="xml">
            <search>
                <field name="description"/>
            </search>
        </field>
    </record>

    <record id="wua_intakeconsumption_balance_action" model="ir.actions.act_window">
        <field name="name">Intakeconsumption Balance</field>
        <field name="res_model">wua.intakeconsumption.balance</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids"
         eval="[(5, 0),
                (0, 0, {'view_mode': 'tree', 'view_id': ref('wua_intakeconsumption_balance_view_tree')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('wua_intakeconsumption_balance_view_form')})]"/>
        <field name="search_view_id"
         ref="wua_intakeconsumption_balance_view_search"/>
    </record>


    <menuitem id="wua_intakeconsumption_balance_menu"
              name="Intakeconsumption Balance"
              parent="base_wua_irrigation_measurement.base_wua_irrigation_measurement_menu"
              action="wua_intakeconsumption_balance_action"
              sequence="1"
              groups="base_wua.group_wua_user"/>

</odoo>
