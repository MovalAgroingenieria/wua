<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_presconsumption_view_tree" model="ir.ui.view">
        <field name="name">Consumptions (tree view)</field>
        <field name="model">wua.presconsumption</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation.wua_presconsumption_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='waterconnection_id']" position="before">
                <field name="company_id"/>
            </xpath>
        </field>
    </record>

    <record id="wua_presconsumption_view_search" model="ir.ui.view">
        <field name="name">Consumptions (search view)</field>
        <field name="model">wua.presconsumption</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation.wua_presconsumption_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='withadjustement']" position="after">
                <separator/>            
                <filter string="Mapped to a company: Yes"
                 name="mapped_to_company_yes"
                 domain="[('is_mapped_to_company','=', True)]"/>
                <filter string="Mapped to a company: No"
                 name="mapped_to_company_no"
                 domain="[('is_mapped_to_company','=', False)]"/>
            </xpath>
            <xpath expr="//filter[@name='agriculturalseason']" position="after">
                <filter string="Company"
                 name="company"
                 context="{'group_by':'company_id'}"/>
            </xpath>            
        </field>
    </record>

</odoo>