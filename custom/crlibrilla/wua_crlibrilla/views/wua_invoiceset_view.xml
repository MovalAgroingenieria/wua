<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="wua_invoiceset_line_gravconsumption_view_tree" model="ir.ui.view" >
      <field name="name">Invoice-set line for gravity consumptions (tree view)</field>
      <field name="model">wua.invoiceset.line.gravconsumption</field>
      <field name="inherit_id"
             ref="base_wua_invoicing_gravity_irrigation.wua_invoiceset_line_gravconsumption_view_tree"/>
      <field name="arch" type="xml">
        <xpath expr="//field[@name='watering_duration']" position="replace">
          <field name="watering_duration" invisible="1"/>
          <field name="watering_duration_dechours" />
        </xpath>
      </field>
  </record>

</odoo>
