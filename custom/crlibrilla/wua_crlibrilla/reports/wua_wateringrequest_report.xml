<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_wua_wateringrequest_document" inherit_id="base_wua_gravity_irrigation.report_wua_wateringrequest_document">
        <xpath expr="//th[@name='th_duration']" position="replace">
            <th name="th_duration" class="text-right">Duration (hours)</th>
        </xpath>
        <xpath expr="//td[@name='td_duration']" position="replace">
            <td name="td_duration" align="right">
                <t t-if="l.watering_duration">
                    <t t-set="watering_duration_hours" t-value="request.env['wua.watering'].minutes_to_dec_hours(l.watering_duration)"/>
                    <span t-esc="watering_duration_hours"/>
                </t>
            </td>
        </xpath>
    </template>

</odoo>
