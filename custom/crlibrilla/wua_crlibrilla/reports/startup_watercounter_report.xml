<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Start up watercounter report (droplist menu) -->
    <report
        id="start_up_watercounter_report"
        string="Start up watercounter"
        model="res.partner"
        report_type="qweb-pdf"
        file="wua_crlibrilla.start_up_watercounter_report_document"
        name="wua_crlibrilla.start_up_watercounter_report_document"
        paperformat="base_wua_report.paperformat_wua_reports"
        groups="base_wua.group_wua_user"/>

    <!-- tart up watercounter report  -->
    <template id="start_up_watercounter_report_document">
        <t t-call="report.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="base_wua_report.wua_external_layout">
                    <div class="page">

                        <!-- Vars -->
                        <t t-set="report_style" t-value="request.env['ir.values'].get_default('wua.configuration', 'reports_style')"/>
                        <t t-set="partnerlinks_as_owner" t-value="request.env['wua.parcel.partnerlink'].search([('partner_id', '=', o.id),('profile', '=', 'O')])"/>
                        <t t-set="measurement_unit" t-value="partnerlinks_as_owner[0].parcel_id._compute_area_measurement_name()"/>

                        <div name="section_header">
                            <div name="title" style="font-size: 16;text-align: center;">
                                <strong>REQUEST START-UP WATERCOUNTER</strong>
                            </div>
                        </div>

                        <!-- Partner data -->
                        <div name="wua_partner_data">
                            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                <t t-if="report_style == 'light'">
                                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;"><span class="fa fa-user"/></div>
                                        <div style="float: left; display: inline;"><strong>Partner</strong></div>
                                   </div>
                                </t>
                                <t t-else="">
                                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;"><span class="fa fa-user"/></div>
                                        <div style="float: left; display: inline;"><strong>Partner</strong></div>
                                    </div>
                                </t>
                            </div>
                            <div class="row" style="margin-top: 4px;">
                                <div class="col-xs-12" style="display: table;">
                                    <div style="width: 50%; display: table-cell;">
                                        <t t-if="o.name">
                                            <strong><span t-field="o.name"/></strong>
                                            <t t-if="o.vat"><span>(NIF:&amp;nbsp;<span t-field="o.vat"/>)</span></t>
                                        <br/>
                                        </t>
                                        <t t-if="o.street_type_show or o.street or o.street_num or o.street2">
                                            <t t-if="o.street_type_show"><span t-field="o.street_type_show"/></t>
                                            <t t-if="o.street"><span t-field="o.street"/></t>
                                            <t t-if="o.street_num"><span t-field="o.street_num"/></t>
                                            <t t-if="o.street2"><span t-field="o.street2"/></t>
                                            <br/>
                                        </t>
                                        <t t-if="o.city or o.zip">
                                            <t t-if="o.city"><span t-field="o.city"/></t>
                                            <t t-if="o.zip"><span>-&amp;nbsp;</span><span t-field="o.zip"/></t>
                                            <br/>
                                        </t>
                                        <t t-if="o.state_id or o.country_id">
                                            <t t-if="o.state_id"><span t-field="o.state_id"/></t>
                                            <t t-if="o.country_id"><span>-&amp;nbsp;</span><span t-field="o.country_id"></span></t>
                                            <br/>
                                        </t>
                                        <t t-if="o.phones or o.phone or o.mobile">
                                            <t t-if="o.phones"><span t-field="o.phones"/></t>
                                            <t t-else="">
                                                <t t-if="o.phone"><span t-field="o.phone"/></t>
                                                <t t-if="o.mobile"><span t-field="o.mobile"/></t>
                                            </t>
                                            <br/>
                                        </t>
                                        <t t-if="o.email"><span t-field="o.email"/><br/></t>
                                    </div>
                                    <div style="display: table-cell; padding-left: 32px;">
                                        <div>&amp;nbsp;</div>
                                        <table style="width: 100%;">
                                            <tbody>
                                                <tr>
                                                    <td><span>Wua partner code:</span></td>
                                                    <td class="text-right">
                                                        <t t-set="partner_code" t-value="str(o.partner_code)"/>
                                                        <span t-esc="partner_code"/>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td><span>Number of available parcels:</span></td>
                                                    <td class="text-right">
                                                        <t t-if="partnerlinks_as_owner">
                                                            <t t-set="num_available_parcels" t-value="len(partnerlinks_as_owner)"/>
                                                            <span t-esc="num_available_parcels"/>
                                                        </t>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Available parcels -->
                        <div name="wua_partnerlinks_ids" style="margin-top: 20px;">
                            <t t-if="partnerlinks_as_owner">
                                <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                    <t t-if="report_style == 'light'">
                                        <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                            <div style="float: left; width: 32px;"><span class="fa fa-moval-parcel"/></div>
                                            <div style="float: left; display: inline;"><strong>Parcels&amp;nbsp;selection</strong></div>
                                       </div>
                                    </t>
                                    <t t-else="">
                                        <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                            <div style="float: left; width: 32px;"><span class="fa fa-moval-parcel"/></div>
                                            <div style="float: left; display: inline;"><strong>Parcels&amp;nbsp;selection</strong></div>
                                        </div>
                                    </t>
                                </div>
                                <div name="request_text" style="margin-top: 2px;">
                                    List of available parcels. In the last column you can select the parcel or parcels for which
                                    you are requesting the start-up of the water counter.
                                </div>
                                <table class="table table-striped" style="margin-top: 4px;">
                                    <thead>
                                        <tr>
                                            <th width="2%" class="text-center"></th>
                                            <th width="18%" class="text-center">Parcel</th>
                                            <th width="18%" class="text-center" name="th_cadastral_reference_name">Cadastral ref.</th>
                                            <th width="19%" class="text-center" name="th_rurallocation_id">Rural location</th>
                                            <th width="23%" class="text-center" name="th_hydraulicsector_id">Hydraulic sector</th>
                                            <th width="11%" class="text-right">Area (<t t-esc="measurement_unit"/>)</th>
                                            <th width="9%" class="text-center" name="th_selection">Selection</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="partnerlinks_as_owner" t-as="p" style="page-break-inside: avoid;">
                                            <td class="text-center"><span style="color:grey; font-size:1.4em;" class="fa fa-moval-water-counter"/></td>
                                            <td class="text-center"><span t-field="p.parcel_id"/></td>
                                            <td class="text-center" name="td_cadastral_reference_name"><span t-field="p.parcel_id.cadastral_reference"/></td>
                                            <td class="text-center" name="td_rurallocation_id" ><span t-field="p.parcel_id.rurallocation_id"/></td>
                                            <td class="text-center" name="td_hydraulicsector_id" ><span t-field="p.parcel_id.hydraulicsector_id"/></td>
                                            <td class="text-right"><span t-field="p.area_official"/></td>
                                            <td class="text-center" name="td_selection"><span class="fa fa-square-o"/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </t>
                        </div>

                        <!-- Installation data -->
                        <div name="installation_data" style="margin-top: 20px; page-break-inside: avoid;">
                            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                <t t-if="report_style == 'light'">
                                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;"><span class="fa fa-wrench"/></div>
                                        <div style="float: left; display: inline;"><strong>Installation&amp;nbsp;notes</strong></div>
                                   </div>
                                </t>
                                <t t-else="">
                                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;"><span class="fa fa-wrench"/></div>
                                        <div style="float: left; display: inline;"><strong>Installation&amp;nbsp;notes</strong></div>
                                    </div>
                                </t>
                            </div>
                            <div name="instalation_text" style="margin-top: 2px;">
                                Fill in the following fields to make the water counter installation process easier.
                            </div>
                            <div style="display: table-cell; margin-top: 8px;">
                                <table style="border-spacing: 6px; border-collapse: separate; empty-cells: show;">
                                    <tbody>
                                        <tr>
                                            <td style="padding: 6px 0px;"><span><strong>Mobile for SMS notifications</strong></span></td>
                                            <td/>
                                            <td style="background-color:#F5F5F5;border-radius: 0.25em;"></td>
                                        </tr>
                                        <tr>
                                            <td style="padding: 6px 0px;"><span><strong>Installer contact</strong></span></td>
                                            <td/>
                                            <td style="background-color:#F5F5F5;border-radius: 0.25em;"></td>
                                        </tr>
                                        <tr>
                                            <td style="padding: 12px 0px;"><span><strong>Observations</strong></span></td>
                                            <td/>
                                            <td style="background-color:#F5F5F5;border-radius: 0.25em;">
                                                &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                                &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                                &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                                &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                                &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                                &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                                &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                                &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                                &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                                &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Request data -->
                        <div name="request_data" style="margin-top: 20px; page-break-inside: avoid;">
                            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                <t t-if="report_style == 'light'">
                                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;"><span class="fa fa-pencil-square-o"/></div>
                                        <div style="float: left; display: inline;"><strong>Start-up&amp;nbsp;request</strong></div>
                                   </div>
                                </t>
                                <t t-else="">
                                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;"><span class="fa fa-pencil-square-o"/></div>
                                        <div style="float: left; display: inline;"><strong>Start-up&amp;nbsp;request</strong></div>
                                    </div>
                                </t>
                            </div>
                            <div name="request_square" style="margin-top: 2px;">
                                Mr./Mrs. <span t-field="o.name"/> with VAT <span t-field="o.vat"/> as a community member up to date
                                with payments and with the drip irrigation infrastructure for the above parcels, <b>I REQUEST</b> to the
                                <span t-field="o.company_id"/> to start-up and activate the drip water counters
                                for parcels marked in the previous table.<br/><br/>
                                And for the record, I sign this document in <span t-field="o.company_id.city"/> on
                                 <span t-field="partnerlinks_as_owner[0].parcel_id.date_now" t-field-options='{"format": "dd MMMM yyyy"}'/>.
                                <br/><br/>
                                <div class="text-right">
                                    <div style="margin-right: 240px;">Signed</div><br/>
                                    <div style="margin-left: 620px; border-bottom: solid lightgrey 1px; max-width:160px;"/>
                                </div>
                            </div>
                        </div>

                        <!-- Force new page -->
                        <p style="page-break-after:always;"/>

                        <!-- Watercounter data -->
                        <div name="counter_data">
                            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                <t t-if="report_style == 'light'">
                                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;"><span class="fa fa-moval-water-counter"/></div>
                                        <div style="float: left; display: inline;"><strong>Watercounters&amp;nbsp;data</strong></div>
                                   </div>
                                </t>
                                <t t-else="">
                                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;"><span class="fa fa-moval-water-counter"/></div>
                                        <div style="float: left; display: inline;"><strong>Watercounters&amp;nbsp;data</strong></div>
                                    </div>
                                </t>
                            </div>
                            <div name="instalation_text"  style="margin-top: 2px; margin-bottom:12px;">
                                Data to be filled by Water User Assotiation.
                            </div>
                            <t t-set="num_watercounters" t-value="1"/>
                            <t t-foreach="num_watercounters" t-as="i">
                                <div style="margin-bottom: 12px;">
                                    <div style="display: table-cell; border: solid lightgrey 1px; padding: 4px;">
                                        <table style="border-spacing: 6px; border-collapse: separate; empty-cells: show;">
                                            <tbody>
                                                <tr>
                                                    <td class="text-center"><span class="fa fa-moval-water-counter" style="color:grey; font-size: 150%;"/></td>
                                                    <td/>
                                                    <td>
                                                    </td>
                                                    <td class="text-right" style="padding: 6px 0px;"><span><strong>Water connection</strong></span></td>
                                                    <td/>
                                                    <td style="background-color:#F5F5F5;border-radius: 0.25em;">
                                                        &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                                        &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                                        &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                                    </td>
                                                    <td class="text-right" style="padding: 6px 0px;"><span><strong>Serial number</strong></span></td>
                                                    <td/>
                                                    <td style="background-color:#F5F5F5;border-radius: 0.25em;">
                                                        &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                                        &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                                        &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                                    </td>
                                                    <td class="text-right" style="padding: 6px 0px;"><span><strong>Caliber</strong></span></td>
                                                    <td/>
                                                    <td style="background-color:#F5F5F5;border-radius: 0.25em;">
                                                        &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                                        &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                                        &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td class="text-center"><span class="fa fa-history" style="color:grey; font-size: 150%;"/></td>
                                                    <td/>
                                                    <td></td>
                                                    <td colspan="4" class="text-right" style="padding: 6px 0px;"><span><strong>Start-up date</strong></span></td>
                                                    <td/>
                                                    <td style="background-color:#F5F5F5;border-radius: 0.25em;"></td>
                                                    <td class="text-right" style="padding: 6px 0px;"><span><strong>Initial Reading</strong></span></td>
                                                    <td/>
                                                    <td style="background-color:#F5F5F5;border-radius: 0.25em;"></td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </t>
                        </div>

                        <!-- Conformity -->
                        <div name="conformity" style="margin-top: 20px; page-break-inside: avoid;">
                            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                <t t-if="report_style == 'light'">
                                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;"><span class="fa fa-check-square-o"/></div>
                                        <div style="float: left; display: inline;"><strong>Start-up&amp;nbsp;conformity</strong></div>
                                   </div>
                                </t>
                                <t t-else="">
                                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;"><span class="fa fa-check-square-o"/></div>
                                        <div style="float: left; display: inline;"><strong>Start-up&amp;nbsp;conformity</strong></div>
                                    </div>
                                </t>
                            </div>
                            <div name="conformity_square" style="margin-top: 2px;">
                                Mr./Mrs.
                                <span style="background-color:#F5F5F5;border-radius: 0.25em;">
                                    &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                    &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                    &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                    &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                    &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                    &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                    &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                </span>
                                with VAT
                                <span style="background-color:#F5F5F5;border-radius: 0.25em;">
                                    &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                    &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                    &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                    &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                </span>,
                                as
                                <span style="background-color:#F5F5F5;border-radius: 0.25em;">
                                    &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                    &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                    &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                    &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                </span>
                                certify that the <span t-field="o.company_id"/> has carried out the commissioning of the water counter or counters marked above,
                                with the necessary tests and verifications, leaving the installation in full operation.<br/><br/>
                                <div class="text-right" style="margin-right:12px;">
                                    <span t-field="o.company_id.city"/>
                                    on
                                    <span style="background-color:#F5F5F5;border-radius: 0.25em;">
                                        &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                    </span>
                                    of
                                    <span style="background-color:#F5F5F5;border-radius: 0.25em;">
                                        &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                        &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                    </span>
                                    of
                                    <span style="background-color:#F5F5F5;border-radius: 0.25em;">
                                        &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;
                                    </span>
                                </div>
                                <br/><br/>
                                <div class="text-right">
                                    <div style="margin-right: 240px;">Signed</div><br/>
                                    <div style="margin-left: 620px; border-bottom: solid lightgrey 1px; max-width:160px;"/>
                                </div>
                            </div>
                        </div>

                    </div><!-- end page -->
                </t>
            </t>
        </t>
    </template>

</odoo>
