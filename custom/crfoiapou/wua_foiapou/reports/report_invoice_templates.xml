<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_invoice_document" inherit_id="base_wua_invoicing_consumption_ranges.report_invoice_document">
        <xpath expr="//p[@style='page-break-after:always;']" position="replace"/>
        <xpath expr="//div[@name='consumptions']" position="replace"/>
        <xpath expr="//div[@name='threshold']" position="replace"/>
        <xpath expr="//p[@t-if='o.payment_term_id']" position="before">
            <t t-set="with_presconsumptions" t-value="False"/>
            <t t-foreach="o.invoice_line_ids" t-as="l">
                <t t-if="l.categ_id.productcategory_code == 7">
                    <t t-set="with_presconsumptions" t-value="True"/>
                </t>
            </t>
            <t t-if="with_presconsumptions">
                <t t-set="consumptions"
                   t-value="o._get_presconsumptions_from_lines(o.invoice_line_ids)"/>
                <t t-if="consumptions">
                 <p style="page-break-after:always;"></p>
                    <div name="consumptions">
                    <table class="table table-condensed">
                        <caption>WATER CONSUMPTION FOR WATERMETER</caption>
                        <thead>
                            <tr>
                                <th>Water Connection</th>
                                <th>Water Meter</th>
                                <th>Initial time</th>
                                <th>Final time</th>
                                <th class="text-right">Initial Reading</th>
                                <th class="text-right">Final Reading</th>
                                <th class="text-right">Real Vol. (m<sup>3</sup>)</th>
                            </tr>
                        </thead>
                        <tbody class="invoice_tbody">
                            <t t-set="qty" t-value="0"/>
                            <tr t-foreach="consumptions" t-as="c">
                                <t t-set="reading_initial_time"
                                 t-value="context_timestamp(
                                     datetime.datetime.strptime(
                                     c['reading_initial_time'],'%Y-%m-%d %H:%M:%S')).
                                     strftime('%d/%m/%y')"/>
                                <t t-set="reading_end_time"
                                 t-value="context_timestamp(
                                     datetime.datetime.strptime(
                                     c['reading_end_time'],'%Y-%m-%d %H:%M:%S')).
                                     strftime('%d/%m/%y')"/>
                                <td>
                                    <span t-esc="c['waterconnection']"/>
                                </td>
                                <td>
                                    <span t-esc="c['watermeter']"/>
                                </td>
                                <td>
                                    <span t-esc="reading_initial_time"/>
                                </td>
                                <td>
                                    <span t-esc="reading_end_time"/>
                                </td>
                                <td class="text-center">
                                    <span t-esc="'{:,.0f}'.format(round(c['initial_volume'])).replace(',','.')"/>
                                </td>
                                <td class="text-center">
                                    <span t-esc="'{:,.0f}'.format(round(c['end_volume'])).replace(',','.')"/>
                                </td>
                                <td class="text-center">
                                    <span t-esc="'{:,.0f}'.format(round(c['volume_real'])).replace(',','.')"/>
                                </td>
                                <t t-set="qty" t-value="qty + float(round(c['volume_real']))"/>
                            </tr>                            
                            <tr>
                                <td colspan="7" class="text-center">
                                   <span>Total water consumption (m<sup>3</sup>):</span>
                                </td>
                                <td class="text-center">
                                   <span t-esc="'{:,.0f}'.format(qty).replace(',','.')"></span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                    </div>
                </t>
            </t>
            <div name="threshold">
            <t t-set="daily_quota_data"
               t-value="o._get_daily_quota_data(o.invoice_line_ids)"/>
            <t t-if="daily_quota_data['quota_day'] > 0">
                <table class="table table-condensed">
                    <caption>ASSIGNED QUOTA AND CONSUMPTION EXCESS CALCULUS</caption>
                    <thead>
                        <tr>
                            <th class="text-center">Daily Quota (m<sup>3</sup>/hg and day)</th>
                            <th class="text-center">Total Area/hg</th>
                            <th class="text-center">Invoicing Days</th>
                            <th class="text-center">Assigned Quota (m<sup>3</sup>)</th>
                            <th class="text-center">Total Consumption (m<sup>3</sup>)</th>
                            <th class="text-center">Extra Consumption (m<sup>3</sup>)</th>
                        </tr>
                    </thead>
                    <tbody class="invoice_tbody">
                        <tr>
                            <td class="text-center">
                                <span t-esc=
                                "'{:,.2f}'.format(daily_quota_data['quota_day']).replace('.','%').replace(',','.').replace('%',',')"/>
                            </td>
                            <td class="text-center">
                                <span t-esc=
                                "'{:,.4f}'.format(daily_quota_data['total_area']).replace('.','%').replace(',','.').replace('%',',')"/>
                            </td>
                            <td class="text-center">
                                <span t-esc="daily_quota_data['days']"/>
                            </td>
                            <td class="text-center">
                                <span t-esc=
                                "'{:,.3f}'.format(daily_quota_data['threshold']).replace('.','%').replace(',','.').replace('%',',')"/>
                            </td>
                            <td class="text-center">
                                <span t-esc=
                                "'{:,.3f}'.format(daily_quota_data['total_consumption']).replace('.','%').replace(',','.').replace('%',',')"/>
                            </td>
                            <td class="text-center">
                                <span t-esc=
                                "'{:,.3f}'.format(daily_quota_data['extra_consumption']).replace('.','%').replace(',','.').replace('%',',')"/>
                            </td>
                        </tr>
                    </tbody>                    
                </table>
            </t>            
            </div>
        </xpath>  
        <xpath expr="//div[@name='consumptions']/table/thead/tr/th[2]" position="after">
            <th>Rural Location</th>
        </xpath>
        <xpath expr="//div[@name='consumptions']/table/tbody/tr[1]/td[2]" position="after">
            <td>
                <span t-esc="c['rural_location']"/>
            </td>           
        </xpath>
    </template>
  <!--  <record model="ir.ui.view" id="wua_foiapou.report_invoice_document">
        <field name="priority" eval="15"/>
     </record> -->

<template id="wua_report_invoice_document" inherit_id="account_wua.wua_report_invoice_document">
 <xpath expr="//table[@class='table']" position="replace">
        <table class="table">
        <caption>INVOICING APPORTIONMENT FOR CONSUMPTION TRANCHE</caption>
                <col width="30%"/>
                <col width="20%"/>
                <col width="15%"/>
                <col width="12%"/>
                <col width="12%"/>
                <col width="11%"/>
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Description</th>
                        <th class="hidden">Source Document</th>
                        <th class="text-right">Quantity</th>
                        <th class="text-right">Price</th>
                        <th t-if="display_discount" class="text-right">Disc.(%)</th>
                        <th>Taxes</th>
                        <th class="text-right">Amount</th>
                    </tr>
                </thead>
                <tbody class="invoice_tbody">
                    <tr t-foreach="o.invoice_line_ids" t-as="l">
                        <td><span t-field="l.product_id"/></td>
                        <td><span t-field="l.name"/></td>
                        <td class="hidden"><span t-field="l.origin"/></td>
                        <td class="text-right">
                            <span t-field="l.quantity"/>
                            <span t-field="l.uom_id" groups="product.group_uom"/>
                        </td>
                        <td class="text-right">
                            <span t-field="l.price_unit" t-options='{"widget": "monetary", "display_currency": l.currency_id}'/>
                            <span>/</span>
                            <span t-field="l.uom_id" groups="product.group_uom"/>
                        </td>
                        <td t-if="display_discount" class="text-right">
                            <span t-field="l.discount"/>
                        </td>
                        <td>
                            <!-- Change tax column from tax description to tax name (see below) -->
                            <span t-esc="', '.join(map(lambda x: (x.name), l.invoice_line_tax_ids))"/>
                        </td>
                        <td class="text-right">
                            <span t-field="l.price_subtotal" 
                                t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                        </td>
                    </tr>
                  
                </tbody>
            </table>    
 </xpath>
        <xpath expr="//t[@t-if='o.payment_mode_id']" position="replace">
            <t t-if="o.payment_mode_id">
                <p>
                    <span><strong>Payment mode:&amp;nbsp;</strong></span>
                    <span t-field="o.payment_mode_id"/>
                </p>
                <p>
                    <t t-if="'bancari' not in o.payment_mode_id.name">
                        <span><strong>Bank account:&amp;nbsp;</strong></span>
                        <t t-if="o.payment_mode_id.fixed_journal_id.bank_id.name">
                            <span t-field="o.payment_mode_id.fixed_journal_id.bank_id.name"/>
                        </t>
                        <t t-if="o.payment_mode_id.fixed_journal_id.bank_id.bic">
                            <span>&amp;nbsp;-&amp;nbsp;</span>
                            <span t-field="o.payment_mode_id.fixed_journal_id.bank_id.bic"/>
                        </t>
                        <t t-if="o.payment_mode_id.fixed_journal_id.bank_acc_number">
                            <span>&amp;nbsp;-&amp;nbsp;</span>
                            <span t-field="o.payment_mode_id.fixed_journal_id.bank_acc_number"/>
                        </t>
                    </t>
                    <t t-else="">
                        <span><strong>Bank account:&amp;nbsp;</strong></span>
                        <t t-if="o.mandate_id.partner_bank_id.bank_name">
                            <span t-field="o.mandate_id.partner_bank_id.bank_name"/>
                        </t>
                        <t t-if="o.mandate_id.partner_bank_id.bank_bic">
                            <span>&amp;nbsp;-&amp;nbsp;</span>
                            <span t-field="o.mandate_id.partner_bank_id.bank_bic"/>
                        </t>
                        <t t-if="o.mandate_id.partner_bank_id.acc_number">
                            <span>&amp;nbsp;-&amp;nbsp;</span>
                            <t t-set="anonymous_acc_number" t-value="o.mandate_id.partner_bank_id.acc_number[:24] + ' XXXX'"/>
                            <span t-esc="anonymous_acc_number"/>
                        </t>
                    </t>
                </p>
            </t>
        </xpath>
</template>
</odoo>
