<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="external_layout_header_foiapou" inherit_id="base_wua_report.external_layout_header">
        <xpath expr="//div[@class='col-xs-9']" position="attributes">
            <attribute name="class">col-xs-6</attribute>
        </xpath>
        <xpath expr="//div[@name='part3']" position="replace">
            <div class="col-xs-4" name="part3">
                <t t-if="docs and docs[0]._name == 'wua.comparative.partner.presconsumption'">
                    <img src="/wua_crfoiapou/static/images/logo_goinnowater.png"
                        style="max-width: 220px; margin-top:10px;"/>
                </t>
            </div>
        </xpath>
    </template>

</odoo>