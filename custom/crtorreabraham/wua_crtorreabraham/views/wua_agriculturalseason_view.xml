<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_agriculturalseason_view_form" model="ir.ui.view">
        <field name="name">Agricultural Seasons (form view)</field>
        <field name="model">wua.agriculturalseason</field>
        <field name="inherit_id" ref="base_wua_pressurized_irrigation.wua_agriculturalseason_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='notes_page']" position="after">
                 <page name="general_irrigation_rules" string="General Irrigation Rules">
                     <field name="general_irrigation_rules"/>
                     <hr/>
                     <span>(*) This field will be added to Irragation Contract Report</span>
                 </page>
            </xpath>
        </field>
    </record>

</odoo>