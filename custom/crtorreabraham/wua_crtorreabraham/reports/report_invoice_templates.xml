<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_invoice_document" inherit_id="account.report_invoice_document">
        <xpath expr="//col[@name='product']" position="attributes">
          <attribute name="t-att-style">"display: none"</attribute>
        </xpath>
        <xpath expr="//th[@name='product']" position="attributes">
          <attribute name="t-att-style">"display: none"</attribute>
        </xpath>
        <xpath expr="//td[@name='product']" position="attributes">
          <attribute name="t-att-style">"display: none"</attribute>
        </xpath>
        <xpath expr="//col[@name='taxes']" position="attributes">
          <attribute name="t-att-style">"display: none"</attribute>
        </xpath>
        <xpath expr="//th[@name='taxes']" position="attributes">
          <attribute name="t-att-style">"display: none"</attribute>
        </xpath>
        <xpath expr="//td[@name='taxes']" position="attributes">
          <attribute name="t-att-style">"display: none"</attribute>
        </xpath>

        <xpath expr="//col[@name='description']" position="attributes">
          <attribute name="t-att-style">"width: 50%"</attribute>
        </xpath>
        <xpath expr="//col[@name='quantity']" position="attributes">
          <attribute name="t-att-style">"width: 17%"</attribute>
        </xpath>
        <xpath expr="//td[@name='price']" position="replace">
          <td name="price" class="text-right" width="14%">
              <span style="display: none;" t-field="l.price_unit" t-options='{"widget": "monetary", "display_currency": l.currency_id}'/>
              <span t-esc="l.env['wua.parcel'].transform_float_to_locale(l.price_unit, 4) + ' ' + l.currency_id.symbol"/>
              <span>/</span>
              <span t-field="l.uom_id" groups="product.group_uom"/>
          </td>
        </xpath>

    </template>

    <!-- Irrigation settlement document -->
    <template id="report_irrigation_settlement_document" inherit_id="account.report_invoice_document" primary="True">
        <xpath expr="//div[@name='product_resume_table']" position="attributes">
            <attribute name="t-att-style">"display: none"</attribute>
        </xpath>

        <xpath expr="//div[@name='payment_data']" position="after">
            <!-- Presconcumptions -->
            <t t-set="presconsumptions" t-value="o.sudo()._get_partner_presconsumptions(o.partner_id.id)"/>
            <t t-if="presconsumptions">
                <div name="presconsumptions">
                    <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                        <t t-if="report_style == 'light'">
                            <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                <div style="float: left; width: 32px;"><span class="fa fa-moval-irrigation"/></div>
                                <div style="float: left; display: inline;"><strong>Consumptions</strong></div>
                           </div>
                        </t>
                        <t t-else="">
                            <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                <div style="float: left; width: 32px;"><span class="fa fa-moval-irrigation"/></div>
                                <div style="float: left; display: inline;"><strong>Consumptions</strong></div>
                            </div>
                        </t>
                    </div>
                    <div class="row" style="margin: 4 8px;">
                        <table class="table table-condensed">
                            <thead>
                                <tr>
                                    <th>Water Connection</th>
                                    <th class="text-center">Initial time</th>
                                    <th class="text-center">Final time</th>
                                    <th class="text-right">Initial Reading</th>
                                    <th class="text-right">Final Reading</th>
                                    <th class="text-right">Gross Vol. (m³)</th>
                                    <th class="text-right">Adjust. (m³)</th>
                                    <th class="text-right">Real Vol. (m³)</th>
                                </tr>
                            </thead>
                            <tbody class="invoice_tbody">
                                <tr t-foreach="presconsumptions" t-as="pc">
                                    <td><span t-esc="pc['waterconnection']"/></td>
                                    <td class="text-center"><span t-esc="pc['reading_initial_time']"/></td>
                                    <td class="text-center"><span t-esc="pc['reading_end_time']"/></td>
                                    <td class="text-right">
                                        <span t-esc="request.env['wua.parcel'].transform_float_to_locale(pc['initial_volume'], 0)"/>
                                    </td>
                                    <td class="text-right">
                                        <span t-esc="request.env['wua.parcel'].transform_float_to_locale(pc['end_volume'], 0)"/>
                                    </td>
                                    <td class="text-right">
                                        <span t-esc="request.env['wua.parcel'].transform_float_to_locale(pc['volume'], 0)"/>
                                    </td>
                                    <td class="text-right">
                                        <span t-esc="request.env['wua.parcel'].transform_float_to_locale(pc['adjustement_volume'], 0)"/>
                                    </td>
                                    <td class="text-right">
                                        <span t-esc="request.env['wua.parcel'].transform_float_to_locale(pc['volume_real'], 0)"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </t>
            <!-- Contracted volumes -->
            <t t-set="contracted_volumes" t-value="o.sudo()._get_partner_other_hydricmovements(o.partner_id.id)"/>
            <t t-if="contracted_volumes">
                <div name="contracted_volumes">
                    <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                        <t t-if="report_style == 'light'">
                            <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                <div style="float: left; width: 32px;"><span class="fa fa-moval-quotas"/></div>
                                <div style="float: left; display: inline;"><strong>Contracted&amp;nbsp;volumes</strong></div>
                           </div>
                        </t>
                        <t t-else="">
                            <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                <div style="float: left; width: 32px;"><span class="fa fa-moval-quotas"/></div>
                                <div style="float: left; display: inline;"><strong>Contracted&amp;nbsp;volumes</strong></div>
                            </div>
                        </t>
                    </div>
                    <div class="row" style="margin: 4 8px;">
                        <table class="table table-condensed">
                            <thead>
                                <tr>
                                    <th>Water type</th>
                                    <th>Description</th>
                                    <th class="text-right">Volume (m³)</th>
                                </tr>
                            </thead>
                            <tbody class="invoice_tbody">
                                <t t-set="total_accounting_volume" t-value="0.0"/>
                                <tr t-foreach="contracted_volumes" t-as="cv">
                                    <td><span t-esc="cv['superproduct']"/></td>
                                    <td><span t-esc="cv['description']"/></td>
                                    <td class="text-right">
                                        <span t-esc="request.env['wua.parcel'].transform_float_to_locale(cv['accounting_volume'], 0)"/>
                                        <t t-set="total_accounting_volume" t-value="total_accounting_volume + float(cv['accounting_volume'])"/>
                                    </td>
                                </tr>
                                <tr>
                                   <td></td>
                                   <td></td>
                                   <td name="td_total_accounting_volume" class="text-right">
                                       <strong><span t-esc="request.env['wua.parcel'].transform_float_to_locale(total_accounting_volume, 0)"/></strong>
                                   </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </t>
        </xpath>
    </template>

    <!-- Irrigation settlement report -->
    <template id="report_irrigation_settlement">
        <t t-call="report.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="wua_crtorreabraham.report_irrigation_settlement_document" t-lang="o.partner_id.lang"/>
            </t>
        </t>
    </template>

    <!-- Irrigation settlement menuitem -->
    <report id="irrigation_settlements"
            model="account.invoice"
            string="Irrigation settlement"
            report_type="qweb-pdf"
            name="wua_crtorreabraham.report_irrigation_settlement"
            file="wua_crtorreabraham.report_irrigation_settlement"
            attachment_use="False"
            attachment="(object.state in ('open','paid')) and ('IR'+(object.number or '').replace('/','')+'.pdf')"/>

</odoo>
