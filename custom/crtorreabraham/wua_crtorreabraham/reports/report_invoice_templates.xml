<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_invoice_document" inherit_id="account_wua.wua_report_invoice_document">
        <xpath expr="//col[@name='product']" position="attributes">
          <attribute name="t-att-style">"display: none"</attribute>
        </xpath>
        <xpath expr="//th[@name='product']" position="attributes">
          <attribute name="t-att-style">"display: none"</attribute>
        </xpath>
        <xpath expr="//td[@name='product']" position="attributes">
          <attribute name="t-att-style">"display: none"</attribute>
        </xpath>
        <xpath expr="//col[@name='taxes']" position="attributes">
          <attribute name="t-att-style">"display: none"</attribute>
        </xpath>
        <xpath expr="//th[@name='taxes']" position="attributes">
          <attribute name="t-att-style">"display: none"</attribute>
        </xpath>
        <xpath expr="//td[@name='taxes']" position="attributes">
          <attribute name="t-att-style">"display: none"</attribute>
        </xpath>

        <xpath expr="//col[@name='quantity']" position="attributes">
          <attribute name="t-att-style">"width: 17%"</attribute>
        </xpath>
        <xpath expr="//col[@name='price']" position="attributes">
          <attribute name="t-att-style">"width: 14%"</attribute>
        </xpath>
    </template>

</odoo>
