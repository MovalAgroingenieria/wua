<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <report id="action_wua_irrigationcontract_report"
        string="Irrigation Contract"
        model="wua.cropplan"
        report_type="qweb-pdf"
        name="wua_crtorreabraham.wua_irrigationcontract_report"
        paperformat="base_wua_report.paperformat_wua_reports"/>

    <template id="wua_irrigationcontract_report">
        <t t-call="report.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="base_wua_report.wua_external_layout">
                    <t t-call="wua_crtorreabraham.wua_irrigationcontract_document"/>
                </t>
            </t>
        </t>
    </template>

    <template id="wua_irrigationcontract_document">
        <div class="page">

            <div name="section_title">
                <div name="contract_num" style="text-align: right;">
                    <span>Contract number:</span>
                    <strong>
                        <span t-esc="o.order_number + '/' + o.agriculturalseason_id.name.split('-')[0]"/>
                    </strong>
                </div>
                <div name="agriculturalseason_id" style="text-align: right;">
                    <span t-field="o.agriculturalseason_id"/>
                </div>
                <div name="title" style="font-size: 16;text-align: center;">
                    <strong>Irrigation Contract</strong>
                    <t t-if="o.state == 'draft'">
                        <span>( DRAFT )</span>
                    </t>
                </div>
            </div>

            <div name="section_parts">
                <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                    <t t-if="report_style == 'light'">
                        <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-user"/></div>
                            <div style="float: left; display: inline;"><strong>Partner</strong></div>
                       </div>
                    </t>
                    <t t-else="">
                        <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-user"/></div>
                            <div style="float: left; display: inline;"><strong>Partner</strong></div>
                        </div>
                    </t>
                </div>
            </div>
            <div name="contract_parts" class="row">
                <div style="margin-left: 10px;"><strong>Contracting from one side as the organism in charge of the Watering Area operations:</strong></div>
                <div name="company_id">
                    <t t-if="o.partner_id.company_id">
                        <span t-field="o.partner_id.company_id.name" style="margin-left: 40px;"/>
                    </t>
                </div>
                <br/>
                <div name="partner_id">
                    <div style="margin-left: 10px;"><strong>And from other side as crop planner:</strong></div>
                    <div name="crop_planner_data">
                        <table border="0" style="margin-left: 40px;">
                            <tr>
                                <td><strong>Name</strong></td>
                                <td style="padding-left: 10px;">
                                    <span t-field="o.partner_id.name" class="text-left"/>
                                </td>
                            </tr>
                            <tr>
                                <td><strong>VAT</strong></td>
                                <td style="padding-left: 10px;">
                                    <span t-field="o.partner_id.vat" class="text-left"/>
                                </td>
                            </tr>
                            <tr>
                                <td><strong>Address</strong></td>
                                <td style="padding-left: 10px;">
                                    <t t-if="o.partner_id.street or o.partner_id.street2">
                                        <span t-field="o.partner_id.street"/>
                                        <t t-if="o.partner_id.street2">
                                            <span t-field="o.partner_id.street"/>
                                        </t>
                                    </t>
                                    <t t-if="o.partner_id.city">
                                        <span t-field="o.partner_id.city"/>
                                    </t>
                                    <t t-if="o.partner_id.zip">
                                        <span> - </span>
                                        <span t-field="o.partner_id.zip"/>
                                    </t>
                                    <t t-if="o.partner_id.state_id">
                                        <span t-field="o.partner_id.state_id"/>
                                    </t>
                                    <t t-if="o.partner_id.country_id">
                                        <span t-esc="('(' + o.partner_id.country_id.name + ')')"/>
                                    </t>
                                </td>
                            </tr>
                            <tr>
                                <td><strong>Payment mode</strong></td>
                                <td style="padding-left: 10px;">
                                    <t t-if="o.partner_id.customer_payment_mode_id">
                                        <span t-field="o.partner_id.customer_payment_mode_id.name"/>
                                     </t>
                                </td>
                            </tr>
                            <t t-if="(o.partner_id.customer_payment_mode_id and 'bancari' in o.partner_id.customer_payment_mode_id.name)">
                                <tr>
                                    <td><strong>Bank account</strong></td>
                                    <t t-if="o.partner_id.bank_ids">
                                        <td style="padding-left: 10px;">
                                            <span t-esc="o.partner_id.bank_ids[0].acc_number"/>
                                            <span t-esc="'(' + o.partner_id.bank_ids[0].bank_name + ')'"/>
                                        </td>
                                    </t>
                                </tr>
                            </t>
                        </table>
                    </div>
                </div>
            </div>

            <div name="section_detail_enrollments" style="margin-top: 20px;">
                <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                    <t t-if="report_style == 'light'">
                        <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-list-ul"/></div>
                            <div style="float: left; display: inline;"><strong>Enrollments</strong></div>
                       </div>
                    </t>
                    <t t-else="">
                        <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-list-ul"/></div>
                            <div style="float: left; display: inline;"><strong>Enrollments</strong></div>
                        </div>
                    </t>
                </div>
                <div class="row" style="margin: 0 8px;">
                    <table class="table table-condensed">
                        <thead>
                            <tr>
                                <th class="text-left">Parcel</th>
                                <th class="text-left">Profile</th>
                                <th class="text-left">Type</th>
                                <th class="text-left">Cultivation</th>
                                <th class="text-center">Waterconnection</th>
                                <th class="text-right">Last reading (m³)</th>
                                <th class="text-right">Area
                                    <t t-set="area_unit" t-value="o.get_area_unit()"></t>
                                    <span t-esc="('(' + area_unit + ')')"></span>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="o.enrolledsubparcel_ids" t-as="l" style="page-break-inside: avoid;">
                                <td align="left"><span t-field="l.parcel_id"/></td>
                                <td align="left"><span t-field="l.profile"/></td>
                                <td align="left"><span t-field="l.subparceltype_id"/></td>
                                <td align="left"><span t-field="l.cultivation_id"/></td>
                                <td align="center"><span t-field="l.parcel_id.irrigationpointwc_ids[0].waterconnection_id.name"/></td>
                                <td align="right">
                                    <span t-esc="request.env['wua.parcel'].transform_float_to_locale(l.parcel_id.irrigationpointwc_ids[0].waterconnection_id.last_reading_value, 0)"/>
                                </td>
                                <td align="right"><span t-field="l.area_official"/></td>
                            </tr>
                             <tr>
                                <td></td><td></td><td></td><td></td><td></td><td></td>
                                <td align="right">
                                    <strong><span>Total:</span></strong>
                                    <span t-field="o.area_official"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div name="section_detail_hydricmovement">
                <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                    <t t-if="report_style == 'light'">
                        <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-moval-quotas"/></div>
                            <div style="float: left; display: inline;"><strong>Contracted&amp;nbsp;volumes</strong></div>
                       </div>
                    </t>
                    <t t-else="">
                        <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-moval-quotas"/></div>
                            <div style="float: left; display: inline;"><strong>Contracted&amp;nbsp;volumes</strong></div>
                        </div>
                    </t>
                </div>
                <div class="row" style="margin: 4 8px;">
                    <table class="table table-condensed">
                        <thead>
                            <tr>
                                <th>Water type</th>
                                <th>Description</th>
                                <th class="text-right" style="width: 18%">Volume (m³)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="hydric_movements" t-value="o._get_hydricmovements(o.partner_id.id)"/>
                            <t t-set="total_accounting_volume" t-value="0.0"/>
                            <t t-if="hydric_movements">
                                <tr t-foreach="hydric_movements" t-as="h" style="page-break-inside: avoid;">
                                    <td><span t-field="h.superproduct_id.name"/></td>
                                    <td><span t-field="h.description"/></td>
                                    <td align="right">
                                        <span t-field="h.accounting_volume"/>
                                        <t t-set="total_accounting_volume" t-value="total_accounting_volume + h.accounting_volume"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td></td><td></td>
                                    <td align="right">
                                        <strong><span>Balance:</span><span> </span></strong><span t-esc="request.env['wua.parcel'].transform_float_to_locale(total_accounting_volume, 2)"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </div>
            <p style="page-break-before:always;"/>

            <!-- General irrigation rules -->
            <t t-if="o.agriculturalseason_id.general_irrigation_rules">
                <div style="margin-left: 30px;">
                    <span t-field="o.agriculturalseason_id.general_irrigation_rules"/>
                </div>
            </t>

        </div>
    </template>

</odoo>

