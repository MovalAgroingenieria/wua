<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Hide data we dont want -->
    <template id="wua_partner_report_document" inherit_id="base_wua.wua_partner_report_document">
      <xpath expr="//tr[@name='tr_number_of_votes']" position="attributes">
        <attribute name="t-att-style">"display: none"</attribute>
      </xpath>
      <xpath expr="//th[@name='th_profile_name']" position="attributes">
        <attribute name="t-att-style">"display: none"</attribute>
      </xpath>
      <xpath expr="//th[@name='th_irrigation_partner_name']" position="attributes">
        <attribute name="t-att-style">"display: none"</attribute>
      </xpath>
      <xpath expr="//th[@name='th_water_name']" position="attributes">
        <attribute name="t-att-style">"display: none"</attribute>
      </xpath>
      <xpath expr="//th[@name='th_costs_name']" position="attributes">
        <attribute name="t-att-style">"display: none"</attribute>
      </xpath>
      <xpath expr="//td[@name='td_profile_name']" position="attributes">
        <attribute name="t-att-style">"display: none"</attribute>
      </xpath>
      <xpath expr="//td[@name='td_irrigation_partner_name']" position="attributes">
        <attribute name="t-att-style">"display: none"</attribute>
      </xpath>
      <xpath expr="//td[@name='td_water_name']" position="attributes">
        <attribute name="t-att-style">"display: none"</attribute>
      </xpath>
      <xpath expr="//td[@name='td_costs_name']" position="attributes">
        <attribute name="t-att-style">"display: none"</attribute>
      </xpath>
      <!-- Add new data-->
      <xpath expr="//tr[@name='tr_number_of_votes']" position="after">
        <tr name="number-of-share-line">
            <td><span>Number of share:</span></td>
            <td class="text-right"><span t-field="o.share"/></td>
        </tr>
      </xpath>
      <xpath expr="//th[@name='th_cadastral_reference_name']" position="after">
        <th class="text-center" name="th_cadastral_polygon_name">Polygon</th>
        <th class="text-center" name="th_cadastral_parcel_name">Parcel</th>
      </xpath>
      <xpath expr="//th[@name='th_ownership_name']" position="after">
        <th name="th_area_official_net_name" class="text-center">Area % Ownerhsip (<t t-esc="measurement_unit"/>)</th>
      </xpath>
      <xpath expr="//td[@name='td_cadastral_reference_name']" position="after">
        <td name="td_cadastral_polygon_name" class="text-center"><span t-field="p.parcel_id.cadastral_polygon"/></td>
        <td name="td_cadastral_parcel_name" class="text-center"><span t-field="p.parcel_id.cadastral_parcel"/></td>
      </xpath>
      <xpath expr="//td[@name='td_ownership_name']" position="after">
        <td name="td_area_official_net_name" class="text-center"><span t-field="p.area_official_net"/></td>
      </xpath>
    </template>

</odoo>
