<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_watertransfer_view_search" model="ir.ui.view">
        <field name="name">Water Transfers (search view)</field>
        <field name="model">wua.watertransfer</field>
        <field name="inherit_id" ref="base_wua_quota_management_water_transfer.wua_watertransfer_view_search"/>
        <field name="arch" type="xml">
          <xpath expr="//filter[@name='grouped_partner']" position="after">
              <separator/>
              <filter string="Invoiced" name="invoiced"
                   domain="[('invoiced','=',True)]"/>
              <filter string="Not invoiced" name="notinvoiced"
                   domain="[('invoiced','=',False)]"/>
          </xpath>
        </field>
    </record>

    <record id="wua_watertransfer_view_form" model="ir.ui.view">
        <field name="name">Water Transfers (form view)</field>
        <field name="model">wua.watertransfer</field>
        <field name="inherit_id" ref="base_wua_quota_management_water_transfer.wua_watertransfer_view_form"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="product_id" colspan="4"/>
            </field>
        </field>
    </record>

</odoo>
