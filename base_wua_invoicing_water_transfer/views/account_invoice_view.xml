<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_invoice_pivot" model="ir.ui.view">
        <field name="name">Invoices (pivot view)</field>
        <field name="model">account.invoice</field>
        <field name="inherit_id" ref="base_wua_invoicing.view_invoice_pivot"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_untaxed_categ06']" position="after">
                <field name="amount_untaxed_categ21" type="measure"/>
            </xpath>
        </field>
    </record>

</odoo>