<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_waterconnection_view_form_regaber" model="ir.ui.view">
        <field name="name">wua.waterconnection.form.regaber</field>
        <field name="model">wua.waterconnection</field>
        <field name="inherit_id"
               ref="base_wua_remotecontrol_rest.wua_waterconnection_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='telecontrol_associated']"
                   position="after">
                <field name="regaber_tree_node_id"
                       attrs="{'invisible': [('telecontrol_associated', '!=', 'regaber')],
                               'required': [('telecontrol_associated', '=', 'regaber')]}"/>
                <field name="regaber_device_type"
                       attrs="{'invisible': [('telecontrol_associated', '!=', 'regaber')],
                               'required': [('telecontrol_associated', '=', 'regaber')]}"/>
            </xpath>
        </field>
    </record>

</odoo>
