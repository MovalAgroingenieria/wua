<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_vegetationindex_config_settings_view_form" model="ir.ui.view">
        <field name="name">Parameters</field>
        <field name="model">wua.vegetationindex.configuration</field>
        <field name="inherit_id"
            ref="wua_remotesensing_sentinelhub_ndvi.wua_vegetationindex_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='ndvi_configuration_group']" position="after">
                <group string="Grafana NDVI configuration" name="grafana_ndvi_configuration_group"
                       attrs="{'invisible':[('enable_remotesensing','=',False)]}">
                    <field name="grafana_host" style="width:300px"
                           attrs="{'required':[('enable_remotesensing','=',True)]}"/>
                    <field name="dashboard_id" style="width:300px"
                           attrs="{'required':[('enable_remotesensing','=',True)]}"/>
                    <field name="dashboard_url" style="width:300px"
                           attrs="{'required':[('enable_remotesensing','=',True)]}"/>
                    <field name="panel_id" style="width:300px"
                           attrs="{'required':[('enable_remotesensing','=',True)]}"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>