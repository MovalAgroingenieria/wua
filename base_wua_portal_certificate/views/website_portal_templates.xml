<odoo>
    <data>
        <template id="portal_my_home_menu_wua" name="Portal layout : wua menu entries" inherit_id="base_wua_portal_infrastructure.portal_my_home_menu_wua" priority="925">
            <xpath expr="//li/a[@name='parcels_menu']" position="after">
                <li>
                    <a href="/my/certificates">Certificates</a>
                </li>
            </xpath>
        </template>
        <template id="portal_my_home_wua" inherit_id="base_wua_portal_infrastructure.portal_my_home_wua" name="Hide Quotes and Orders">
            <xpath expr="//div[contains(@class,'o_my_home_content')]" position="inside">
                <h3 class="page-header" style="order: 13;">
                    <a href="/my/certificates">
                        <i class="fa fa-fw fa-certificate"/>
                        Your Certificates
                        <small class="ml8">
                            <t t-if="certificates_count">
                                <span class='badge pull-right'><t t-esc="certificates_count"/></span>
                            </t>
                            <t t-if="not certificates_count">
                                There are currently no certificates for your account.
                            </t>
                        </small>
                    </a>
                </h3>
            </xpath>
        </template>
        <template id="portal_my_certificates" name="My Certificates">
            <t t-call="website.layout">
                <div class="container mt16">
                    <div class="navbar navbar-default">
                        <div class="navbar-header">
                            <button type="button" class="navbar-toggle" data-toggle="collapse" data-target="#oe-help-navbar-collapse">
                                <span class="sr-only">Toggle navigation</span>
                                <span class="icon-bar"></span>
                                <span class="icon-bar"></span>
                            </button>
                            <a class="navbar-brand" href="/my/home">
                                My Account
                            </a>
                        </div>
                        <div class="collapse navbar-collapse" id="oe-help-navbar-collapse">
                            <ul class="nav navbar-nav o_portal_submenu">
                            <li>
                                <a href="/my/invoices">Invoices</a>
                            </li>
                            <li>
                                <a href="/my/certificates">Parcels</a>
                            </li>
                            <li>
                                <a href="/my/certificates">Certificates</a>
                            </li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div id="wrap">
                    <div class="container mb64">
                        <div class="col-md-12">
                            <h3 class="page-header">Your Certificates</h3>
                            <t t-if="can_request_certificate">
                                    <a href="#" class="btn btn-success pull-left" data-toggle="modal" data-target="#requestCertificateModal" style="margin-bottom: 20px;">
                                        <i class="fa fa-plus"></i> Request New Certificate
                                    </a>
                            </t>
                        </div>
                        <div class="col-md-12">
                            <t t-if="not certificates">
                                <p>There are currently no certificates for your account.</p>
                            </t>

                            <t t-if="certificates">
                                <form action="/my/certificates" method="get" class="mb-3">
                                    <div class="row">
                                        <div class="col-md-2">
                                            <select id="search_field" name="search_field" class="form-control">
                                                <option value="name" t-att-selected="'name' == search_field">Name</option>
                                                <option value="certificatetype_id" t-att-selected="'certificatetype_id' == search_field">Certificate Type</option>
                                                <option value="date_of_issue" t-att-selected="'date_of_issue' == search_field">Date of Issue</option>
                                                <option value="state" t-att-selected="'state' == search_field">State</option>
                                            </select>
                                        </div>
                                        <div class="col-md-8">
                                            <input type="text" name="search" class="form-control" placeholder="Search certificates..." t-att-value="search_query or ''"/>
                                        </div>
                                        <div class="col-md-2">
                                            <button type="submit" class="btn btn-primary btn-block">Search</button>
                                        </div>
                                    </div>
                                </form>
                                <table class="table table-hover o_my_status_table">
                                    <thead>
                                        <tr class="active">
                                            <th>Name</th>
                                            <th>Certificate Type</th>
                                            <th>Date of Issue</th>
                                            <th>State</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="certificates" t-as="certificate">
                                            <tr t-att-class="'text-danger' if certificate.state == '01_draft' else ''">
                                                <td>
                                                    <t t-if="certificate.state != '01_draft'">
                                                        <a t-att-href="'/my/certificate/%d/report' % certificate.id" target="_blank">
                                                            <t t-esc="certificate.name"/>
                                                        </a>
                                                    </t>
                                                    <t t-else="">
                                                        <t t-esc="certificate.name"/>
                                                    </t>
                                                </td>
                                                <td>
                                                    <t t-esc="certificate.certificatetype_id.name"/>
                                                </td>
                                                <td>
                                                    <t t-esc="certificate.date_of_issue"/>
                                                </td>
                                                <td>
                                                    <t t-if="certificate.state == '01_draft'">Pending</t>
                                                    <t t-if="certificate.state == '02_validated'">Validated</t>
                                                    <t t-if="certificate.state not in ['01_draft', '02_validated']">
                                                        <t t-esc="certificate.state"/>
                                                    </t>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>

                                <div t-if="pager" class="o_portal_pager text-center">
                                    <t t-call="website.pager"/>
                                </div>
                            </t>

                        </div>
                    </div>
                </div>
            </t>
            <div class="modal fade" id="requestCertificateModal" tabindex="-1" role="dialog" aria-labelledby="requestCertificateModalLabel">
                <div class="modal-dialog" role="document">
                    <div class="modal-content">
                    <form id="request-certificate-form">
                        <div class="modal-header">
                            <h4 class="modal-title" id="requestCertificateModalLabel">Request a Certificate</h4>
                            <div>
                                <button type="button" class="close" data-dismiss="modal" aria-label="Close" style="margin-top: -25px;">
                                    <span aria-hidden="true">x</span>
                                </button>
                            </div>
                        </div>
                        <div class="modal-body" >
                            <div class="form-group" >
                                <label for="certificate-type">Certificate Type</label>
                                <select class="form-control" id="certificate-type" name="certificatetype_id" required="required">
                                <t t-foreach="certificate_types" t-as="ct">
                                    <option t-att-value="ct.id"><t t-esc="ct.name"/></option>
                                </t>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="notes">Notes</label>
                                <textarea class="form-control" name="notes" id="notes"></textarea>
                            </div>
                        </div>
                            <div class="modal-footer">
                            <button type="submit" class="btn btn-primary">Submit</button>
                            <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                            </div>
                    </form>
                    </div>
                </div>
            </div>
            <script type="text/javascript">
                $(document).ready(function () {
                    $('#request-certificate-form').on('submit', function (e) {
                        e.preventDefault();
                        var $form = $(this);
                        var data = {
                            certificatetype_id: $('#certificate-type').val(),
                            notes: $('#notes').val(),
                        };

                        $.ajax({
                            url: '/my/certificate/request',
                            type: 'POST',
                            data: data,
                            success: function (response) {
                                $('#requestCertificateModal').modal('hide');
                                location.reload();
                            },
                            error: function (err) {
                                alert('Error while submitting the certificate request.');
                            }
                        });
                    });
                });
            </script>

        </template>
    </data>
</odoo>