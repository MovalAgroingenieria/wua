<odoo>
    <data>
        <template id="portal_my_home_wua" inherit_id="base_wua_portal.portal_my_home_wua" name="Certificates in My Account">
            <xpath expr="//div[contains(@class,'o_my_home_content')]" position="inside">
                <h3 class="page-header" style="order: 13;">
                    <a href="/my/certificates">
                        <i class="fa fa-fw fa-certificate"/>
                        Your Certificates
                        <small class="ml8">
                            <t t-if="certificates_count">
                                <span class='badge pull-right'><t t-esc="certificates_count"/></span>
                            </t>
                        </small>
                    </a>
                </h3>
            </xpath>
        </template>

        <!-- Override parcels link to point to certificates instead -->
        <template id="portal_wua_navbar_certificate" inherit_id="base_wua_portal.portal_wua_navbar">
            <xpath expr="//li[@name='navbar_parcels']" position="after">
                <li name="navbar_certificates"><a href="/my/certificates">Certificates</a></li>
            </xpath>
        </template>

        <template id="portal_my_certificates" name="My Certificates">
            <t t-call="website.layout">
                <t t-call="base_wua_portal.portal_wua_navbar"/>
                <div id="wrap">
                    <div class="container mb64">
                        <div class="col-md-12">
                            <h3 class="page-header">Your Certificates</h3>
                            <t t-if="can_request_certificate">
                                    <a href="#" class="btn btn-success pull-left" data-toggle="modal" data-target="#requestCertificateModal" style="margin-bottom: 20px;">
                                        <i class="fa fa-plus"></i> Request New Certificate
                                    </a>
                            </t>
                        </div>
                        <div class="col-md-12">
                            <t t-if="not certificates">
                                <p>There are currently no certificates for your account.</p>
                            </t>

                            <t t-if="certificates">
                                <form action="/my/certificates" method="get" class="mb-3 certificate-search-form">
                                    <div class="row">
                                        <div class="col-md-2">
                                            <select id="search_field" name="search_field" class="form-control">
                                                <option value="name" t-att-selected="'selected' if search_field == 'name' else None">Name</option>
                                                <option value="certificatetype_id" t-att-selected="'selected' if search_field == 'certificatetype_id' else None">Certificate Type</option>
                                                <option value="date_of_issue" t-att-selected="'selected' if search_field == 'date_of_issue' else None">Date of Issue</option>
                                                <option value="state" t-att-selected="'selected' if search_field == 'state' else None">State</option>
                                            </select>
                                        </div>

                                        <div class="col-md-8">
                                            <input type="text"
                                                name="search"
                                                class="form-control"
                                                placeholder="Search certificates..."
                                                t-att-value="search_query or ''"/>
                                        </div>

                                        <div class="col-md-2">
                                            <button type="submit" class="btn btn-primary btn-block">
                                                Search
                                            </button>
                                        </div>
                                    </div>
                                </form>

                                <table class="table table-hover o_my_status_table certificate-table">
                                    <thead>
                                        <tr class="active">
                                            <th>Name</th>
                                            <th>Certificate Type</th>
                                            <th>Date of Issue</th>
                                            <th>State</th>
                                        </tr>
                                    </thead>

                                    <tbody>
                                        <t t-foreach="certificates" t-as="certificate">
                                            <tr t-att-class="
                                                'certificate-row certificate-row-draft' if certificate.state == '01_draft'
                                                else 'certificate-row certificate-row-validated' if certificate.state == '02_validated'
                                                else 'certificate-row certificate-row-other'
                                            ">
                                                <td>
                                                    <t t-if="certificate.state != '01_draft'">
                                                        <a t-att-href="'/my/certificate/%d/report' % certificate.id"
                                                        target="_blank"
                                                        class="certificate-report-link">
                                                            <t t-esc="certificate.name"/>
                                                        </a>
                                                    </t>
                                                    <t t-else="">
                                                        <span class="certificate-name">
                                                            <t t-esc="certificate.name"/>
                                                        </span>
                                                    </t>
                                                </td>

                                                <td>
                                                    <t t-esc="certificate.certificatetype_id.name"/>
                                                </td>

                                                <td>
                                                    <t t-esc="certificate.date_of_issue"/>
                                                </td>

                                                <td>
                                                    <span t-att-class="
                                                        'certificate-state certificate-state-draft' if certificate.state == '01_draft'
                                                        else 'certificate-state certificate-state-validated' if certificate.state == '02_validated'
                                                        else 'certificate-state certificate-state-other'
                                                    ">
                                                        <t t-if="certificate.state == '01_draft'">Pending</t>
                                                        <t t-if="certificate.state == '02_validated'">Validated</t>
                                                        <t t-if="certificate.state not in ['01_draft', '02_validated']">
                                                            <t t-esc="certificate.state"/>
                                                        </t>
                                                    </span>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>

                                <div t-if="pager" class="o_portal_pager text-center">
                                    <t t-call="website.pager"/>
                                </div>
                            </t>

                        </div>
                    </div>
                </div>
            </t>
            <div class="modal fade" id="requestCertificateModal" tabindex="-1" role="dialog" aria-labelledby="requestCertificateModalLabel">
                <div class="modal-dialog" role="document">
                    <div class="modal-content">
                    <form id="request-certificate-form">
                        <div class="modal-header">
                            <h4 class="modal-title" id="requestCertificateModalLabel">Request a Certificate</h4>
                            <div>
                                <button type="button" class="close" data-dismiss="modal" aria-label="Close" style="margin-top: -25px;">
                                    <span aria-hidden="true">x</span>
                                </button>
                            </div>
                        </div>
                        <div class="modal-body" >
                            <div class="form-group" >
                                <label for="certificate-type">Certificate Type</label>
                                <select class="form-control" id="certificate-type" name="certificatetype_id" required="required">
                                <t t-foreach="certificate_types" t-as="ct">
                                    <option t-att-value="ct.id"><t t-esc="ct.name"/></option>
                                </t>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="notes">Notes</label>
                                <textarea class="form-control" name="notes" id="notes"></textarea>
                            </div>
                        </div>
                            <div class="modal-footer">
                            <button type="submit" class="btn btn-primary">Submit</button>
                            <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                            </div>
                    </form>
                    </div>
                </div>
            </div>
            <script type="text/javascript">
                $(document).ready(function () {
                    $('#request-certificate-form').on('submit', function (e) {
                        e.preventDefault();
                        var $form = $(this);
                        var data = {
                            certificatetype_id: $('#certificate-type').val(),
                            notes: $('#notes').val(),
                        };

                        $.ajax({
                            url: '/my/certificate/request',
                            type: 'POST',
                            data: data,
                            success: function (response) {
                                $('#requestCertificateModal').modal('hide');
                                location.reload();
                            },
                            error: function (err) {
                                alert('Error while submitting the certificate request.');
                            }
                        });
                    });
                });
            </script>

        </template>
    </data>
</odoo>