#. module: base_wua_invoicing_separate_parcel_billing
#: code:addons/base_wua_invoicing_separate_parcel_billing/models/wua_parcel.py:243
#, python-format
msgid "Separate parcel billing: It is mandatory to enter a valid mandate of the only partner that pays the other costs."
msgstr "Facturación separada de parcelas: Es obligatorio indicar un mandato validado que pertenezca al socio (único) que se haga cargo de los gastos diferentes del agua."

#. module: base_wua_invoicing_separate_parcel_billing
#: code:addons/base_wua_invoicing_separate_parcel_billing/models/wua_parcel.py:227
#, python-format
msgid "Separate parcel billing: It is mandatory to enter a valid mandate of the only partner that pays the water costs."
msgstr "Facturación separada de parcelas: Es obligatorio indicar un mandado validado que pertenezca al socio (único) que se haga cargo de los gastos de agua."

#. module: base_wua_invoicing_separate_parcel_billing
#: code:addons/base_wua_invoicing_separate_parcel_billing/models/account_banking_mandate.py:37
#, python-format
msgid "Separate parcel billing: The mandate must be a valid mandate, because there are some parcels associated with this mandate (other costs)."
msgstr "Facturación separada de parcelas: El mandato debe ser obligatoriamente un mandato válido, ya que hay parcelas asociadas a este mandato (facturación separada por otros gastos)."

#. module: base_wua_invoicing_separate_parcel_billing
#: code:addons/base_wua_invoicing_separate_parcel_billing/models/account_banking_mandate.py:26
#, python-format
msgid "Separate parcel billing: The mandate must be a valid mandate, because there are some parcels associated with this mandate (water costs)."
msgstr "Facturación separada de parcelas: El mandato debe ser obligatoriamente un mandato válido, ya que hay parcelas asociadas a este mandato (facturación separada por gastos de agua)."

#. module: base_wua_invoicing_separate_parcel_billing
#: code:addons/base_wua_invoicing_separate_parcel_billing/models/wua_parcel.py:213
#, python-format
msgid "Separate parcel billing: there can be no more one payer for the other costs."
msgstr "Facturación separada de parcelas: No se permite que haya más de un socio a cargo de gastos distintos del agua."

#. module: base_wua_invoicing_separate_parcel_billing
#: code:addons/base_wua_invoicing_separate_parcel_billing/models/wua_parcel.py:204
#, python-format
msgid "Separate parcel billing: there can be no more one water payer."
msgstr "Facturación separada de parcelas: No se permite que haya más de un socio a cargo de los gastos de agua."

