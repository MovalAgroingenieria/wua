#. module: base_wua_invoicing_separate_parcel_billing
#: code:addons/base_wua_invoicing_separate_parcel_billing/models/wua_parcel.py:207
#, python-format
msgid "Separate parcel billing: It is mandatory to enter a valid mandate of the only partner that pays the other costs."
msgstr "Facturació separada de parcel·les: És obligatori indicar un mandat validat que pertanyi al soci (únic) que es faci càrrec de les despeses diferents de l'aigua."

#. module: base_wua_invoicing_separate_parcel_billing
#: code:addons/base_wua_invoicing_separate_parcel_billing/models/wua_parcel.py:192
#, python-format
msgid "Separate parcel billing: It is mandatory to enter a valid mandate of the only partner that pays the water costs."
msgstr "Facturació separada de parcel·les: És obligatori indicar un manat validat que pertanyi al soci (únic) que es faci càrrec de les despeses d'aigua."

#. module: base_wua_invoicing_separate_parcel_billing
#: code:addons/base_wua_invoicing_separate_parcel_billing/models/account_banking_mandate.py:35
#, python-format
msgid "Separate parcel billing: The mandate must be a valid mandate, because there are some parcels associated with this mandate (other costs)."
msgstr "Facturació separada de parcel·les: El mandat ha de ser obligatòriament un mandat vàlid, ja que hi ha parcel·les associades a aquest mandat (facturació separada per altres despeses)."

#. module: base_wua_invoicing_separate_parcel_billing
#: code:addons/base_wua_invoicing_separate_parcel_billing/models/account_banking_mandate.py:25
#, python-format
msgid "Separate parcel billing: The mandate must be a valid mandate, because there are some parcels associated with this mandate (water costs)."
msgstr "Facturació separada de parcel·les: El mandat ha de ser obligatòriament un mandat vàlid, ja que hi ha parcel·les associades a aquest mandat (facturació separada per despeses d'aigua)."

#. module: base_wua_invoicing_separate_parcel_billing
#: code:addons/base_wua_invoicing_separate_parcel_billing/models/wua_parcel.py:179
#, python-format
msgid "Separate parcel billing: there can be no more one payer for the other costs."
msgstr "Facturació separada de parcel·les: No es permet que hi hagi més d'un soci a càrrec de despeses diferents de l'aigua."

#. module: base_wua_invoicing_separate_parcel_billing
#: code:addons/base_wua_invoicing_separate_parcel_billing/models/wua_parcel.py:170
#, python-format
msgid "Separate parcel billing: there can be no more one water payer."
msgstr "Facturació separada de parcel·les: No es permet que hi hagi més d'un soci a càrrec de les despeses d'aigua."

