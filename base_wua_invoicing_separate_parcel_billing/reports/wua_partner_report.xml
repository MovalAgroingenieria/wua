<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <template id="wua_partner_report_document" inherit_id="base_wua.wua_partner_report_document">
    <xpath expr="//div[@name='wua_partnerlinks_ids']" position="after">

      <t t-if="o.partnerlink_ids">
        <t t-set="partnerlinks_with_separate_billings"
          t-value="o.partnerlink_ids.filtered(lambda x: x.parcel_id.watercosts_separate_billing or x.parcel_id.othercosts_separate_billing)"/>
        <t t-if="len(partnerlinks_with_separate_billings) > 0">
          <div>
            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                <div class="col-xs-12" style="background: lightgray; padding: 1px 16px;">Parcels with separated billing</div>
            </div>
            <table class="table table-striped" style="margin-top: 2px;">
                <thead>
                    <tr>
                        <th class="text-center">Parcel</th>
                        <th class="text-center">Water costs Separated Billing</th>
                        <th class="text-center">Other costs Separated Billing</th>
                    </tr>
                </thead>
                <tbody>
                    <tr t-foreach="partnerlinks_with_separate_billings" t-as="p">

                        <td class="text-center">
                          <t t-esc="p.parcel_id.name"/>
                        </td>
                        <td class="text-center">
                            <t t-if="p.parcel_id.watercosts_separate_billing"><span>Yes</span></t>
                            <t t-else=""><span>No</span></t>
                        </td>
                        <td class="text-center">
                            <t t-if="p.parcel_id.othercosts_separate_billing"><span>Yes</span></t>
                            <t t-else=""><span>No</span></t>
                        </td>

                    </tr>
                </tbody>
            </table>
          </div>
        </t>
      </t>
    </xpath>
  </template>

</odoo>
