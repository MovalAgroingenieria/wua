<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Avoid reload from attached files -->
    <record id="account.account_invoices" model="ir.actions.report.xml">
        <field name="attachment_use" eval="False"/>
    </record>

    <!-- Inhibit modifications of sale.report_invoice_document_inherit_sale -->
    <template id="wua_report_invoice_document_inherit_sale" inherit_id="sale.report_invoice_document_inherit_sale">
        <xpath expr="//div[@class='col-xs-5 col-xs-offset-7']" position="replace"/>
    </template>


    <!-- Modification report invoice -->
    <template id="wua_report_invoice_document" inherit_id="account.report_invoice_document">

        <!-- Customize address -->
        <xpath expr="//div[@name='invoice_address']" position="replace">
            <div name="invoice_address">
                <div class="row" style="border: 1px solid white; margin: 0px 20px;">
                    <div class="col-xs-12" style="display: table;">
                        <div style="border-right: 1px solid white; width: 60%; display: table-cell;">
                            <p style="margin-bottom: 0px"><i>Invoicing address</i></p>
                            <div>
                                <t t-if="o.partner_id.name"><strong><span t-field="o.partner_id.name"/></strong></t><br/>
                                <t t-if="o.partner_id.vat">
                                    <t t-set="mod_vat" t-value="o.partner_id.vat[2:]"/>
                                    <span>TIN:&amp;nbsp;</span>
                                    <span t-esc="mod_vat"/>
                                </t><br/>
                                <t t-if="o.partner_id.street"><span t-field="o.partner_id.street"/></t>
                                <t t-if="o.partner_id.street2"><span t-field="o.partner_id.street2"/></t>
                                <t t-if="o.partner_id.street_number">
                                    <!-- <span>,&amp;nbsp;</span><span t-field="o.partner_id.street_number"/> -->
                                </t><br/>
                                <t t-if="o.partner_id.city"><span t-field="o.partner_id.city"/></t>
                                <t t-if="o.partner_id.zip"><span>&amp;nbsp;-&amp;nbsp;</span><span t-field="o.partner_id.zip"/></t>
                                <t id="state_invoicing_address" t-if="o.partner_id.state_id">
                                    <span t-tag="span">(</span><span t-field="o.partner_id.state_id"/>
                                    <t t-if="not o.partner_id.country_id"><span>)</span></t>
                                    <t t-else=""><span>-</span></t>
                                </t>
                                <t id="country_invoicing_address" t-if="o.partner_id.country_id">
                                    <t t-if="not o.partner_id.state_id"><span>(</span></t>
                                    <span t-field="o.partner_id.country_id"></span><span>)</span>
                                </t>
                            </div>
                        </div>
                        <div style="width: 40%; display: table-cell; padding: 0px 8px;">
                            <p style="margin-bottom: 0px"><i>Shipping Address</i></p>
                            <div groups="!sale.group_delivery_invoice_address">
                                <div>
                                    <t t-if="o.partner_id.name"><strong><span t-field="o.partner_id.name"/></strong></t><br/>
                                    <t t-if="o.partner_id.vat">
                                        <t t-set="mod_vat" t-value="o.partner_id.vat[2:]"/>
                                        <span>TIN:&amp;nbsp;</span>
                                        <span t-esc="mod_vat"/>
                                    </t><br/>
                                    <t t-if="o.partner_id.street"><span t-field="o.partner_id.street"/></t>
                                    <t t-if="o.partner_id.street2"><span t-field="o.partner_id.street2"/></t>
                                    <t t-if="o.partner_id.street_number">
                                        <!-- <span>,&amp;nbsp;</span><span t-field="o.partner_id.street_number"/> -->
                                    </t><br/>
                                    <t t-if="o.partner_id.city"><span t-field="o.partner_id.city"/></t>
                                    <t t-if="o.partner_id.zip"><span>&amp;nbsp;-&amp;nbsp;</span><span t-field="o.partner_id.zip"/></t>
                                    <t id="state_invoicing_address" t-if="o.partner_id.state_id">
                                        <span t-tag="span">(</span><span t-field="o.partner_id.state_id"/>
                                        <t t-if="not o.partner_id.country_id"><span>)</span></t>
                                        <t t-else=""><span>-</span></t>
                                    </t>
                                    <t id="country_invoicing_address" t-if="o.partner_id.country_id">
                                        <t t-if="not o.partner_id.state_id"><span>(</span></t>
                                        <span t-field="o.partner_id.country_id"></span><span>)</span>
                                    </t>
                                </div>
                            </div>
                            <div groups="sale.group_delivery_invoice_address">
                                <t t-if="o.partner_shipping_id == o.partner_id">
                                    <t t-if="o.partner_id.name"><strong><span t-field="o.partner_id.name"/></strong></t><br/>
                                    <t t-if="o.partner_id.vat">
                                        <t t-set="mod_vat" t-value="o.partner_id.vat[2:]"/>
                                        <span>TIN:&amp;nbsp;</span>
                                        <span t-esc="mod_vat"/>
                                    </t><br/>
                                    <t t-if="o.partner_id.street"><span t-field="o.partner_id.street"/></t>
                                    <t t-if="o.partner_id.street2"><span t-field="o.partner_id.street2"/></t>
                                    <t t-if="o.partner_id.street_number">
                                        <!-- <span>,&amp;nbsp;</span><span t-field="o.partner_id.street_number"/> -->
                                    </t><br/>
                                    <t t-if="o.partner_id.city"><span t-field="o.partner_id.city"/></t>
                                    <t t-if="o.partner_id.zip"><span>&amp;nbsp;-&amp;nbsp;</span><span t-field="o.partner_id.zip"/></t>
                                    <t id="state_invoicing_address" t-if="o.partner_id.state_id">
                                        <span t-tag="span">(</span><span t-field="o.partner_id.state_id"/>
                                        <t t-if="not o.partner_id.country_id"><span>)</span></t>
                                        <t t-else=""><span>-</span></t>
                                    </t>
                                    <t id="country_invoicing_address" t-if="o.partner_id.country_id">
                                        <t t-if="not o.partner_id.state_id"><span>(</span></t>
                                        <span t-field="o.partner_id.country_id"></span><span>)</span>
                                    </t>
                                </t>
                                <t t-if="o.partner_shipping_id != o.partner_id">
                                    <t t-if="o.partner_shipping_id.name"><strong><span t-field="o.partner_shipping_id.name"/></strong></t><br/>
                                    <t t-if="o.partner_shipping_id.vat">
                                        <t t-set="mod_vat_sh" t-value="o.partner_shipping_id.vat[2:]"/>
                                        <span>TIN:&amp;nbsp;</span>
                                        <span t-esc="mod_vat_sh"/>
                                    </t><br/>
                                    <t t-if="o.partner_shipping_id.street"><span t-field="o.partner_shipping_id.street"/></t>
                                    <t t-if="o.partner_shipping_id.street2"><span t-field="o.partner_shipping_id.street2"/></t>
                                    <t t-if="o.partner_shipping_id.street_number">
                                        <!-- <span>,&amp;nbsp;</span><span t-field="o.partner_id.street_number"/> -->
                                    </t><br/>
                                    <t t-if="o.partner_shipping_id.city"><span t-field="o.partner_shipping_id.city"/></t>
                                    <t t-if="o.partner_shipping_id.zip"><span>&amp;nbsp;-&amp;nbsp;</span><span t-field="o.partner_shipping_id.zip"/></t>
                                    <t id="state_invoicing_address" t-if="o.partner_shipping_id.state_id">
                                        <span t-tag="span">(</span><span t-field="o.partner_shipping_id.state_id"/>
                                        <t t-if="not o.partner_id.country_id"><span>)</span></t>
                                        <t t-else=""><span>-</span></t>
                                    </t>
                                    <t id="country_invoicing_address" t-if="o.partner_shipping_id.country_id">
                                        <t t-if="not o.partner_shipping_id.state_id"><span>(</span></t>
                                        <span t-field="o.partner_shipping_id.country_id"></span><span>)</span>
                                    </t>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>

        <!-- Add invoiceset (lot) field to infocells -->
        <xpath expr="//div[@t-if='o.name']" position="before">
            <h3 class="col-xs-12" t-if="o.invoiceset_id" style="margin-bottom: 20px; margin-top: 0px;">
                <strong>Lot:&amp;nbsp;</strong>
                <span t-field="o.invoiceset_id"/>
            </h3>
        </xpath>

        <!-- Overwrite table -->
        <xpath expr="//table[@class='table table-condensed'][1]" position="replace">
            <table class="table">
                <col name="product" width="10%"/>
                <col name="description" width="44%"/>
                <col name="quantity" width="12%"/>
                <col name="price" width="12%"/>
                <col name="taxes" width="12%"/>
                <col name="amount" width="10%"/>
                <thead>
                    <tr>
                        <th name="product">Product</th>
                        <th name="description">Description</th>
                        <th name="src_document" class="hidden">Source Document</th>
                        <th name="quantity" class="text-right">Quantity</th>
                        <th name="price" class="text-right">Price</th>
                        <th t-if="display_discount" name="discount" class="text-right">Disc.(%)</th>
                        <th name="taxes">Taxes</th>
                        <th name="amount" class="text-right">Amount</th>
                    </tr>
                </thead>
                <tbody class="invoice_tbody">
                    <tr t-foreach="o.invoice_line_ids" t-as="l">
                        <td name="product"><span t-field="l.product_id"/></td>
                        <td name="description"><span t-field="l.name"/></td>
                        <td name="src_document" class="hidden"><span t-field="l.origin"/></td>
                        <td name="quantity" class="text-right">
                            <span t-field="l.quantity"/>
                            <span t-field="l.uom_id" groups="product.group_uom"/>
                        </td>
                        <td name="price" class="text-right">
                            <span t-field="l.price_unit" t-options='{"widget": "monetary", "display_currency": l.currency_id}'/>
                            <span>/</span>
                            <span t-field="l.uom_id" groups="product.group_uom"/>
                        </td>
                        <td t-if="display_discount" name="discount" class="text-right">
                            <span t-field="l.discount"/>
                        </td>
                        <td name="taxes">
                            <!-- Change tax column from tax description to tax name (see below) -->
                            <span t-esc="', '.join(map(lambda x: (x.name), l.invoice_line_tax_ids))"/>
                        </td>
                        <td name="amount" class="text-right">
                            <span t-field="l.price_subtotal" 
                                t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                        </td>
                    </tr>
                </tbody>
            </table>
        </xpath>

        <!-- Change tax column from tax description to tax name (in totals table) -->
        <xpath expr="//span[@t-esc=&quot;amount_by_group[0] if len(o.tax_line_ids) &gt; 1 else (o.tax_line_ids.tax_id.description or o.tax_line_ids.tax_id.name)&quot;]" position="replace">
            <span t-esc="amount_by_group[0] if len(o.tax_line_ids) &gt; 1 else (o.tax_line_ids.tax_id.name)"/>
        </xpath>

        <!-- Do not show tax resume table -->
        <xpath expr="//div[@t-if='len(o.tax_line_ids) > 0']" position="attributes">
            <attribute name="t-att-style">"display: none"</attribute>
        </xpath>

        <!-- Add payment mode and bank account (conditional) -->
