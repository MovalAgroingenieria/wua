<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Invoice without details -->
    <report
        id="account_invoice_without_details_report"
        model="account.invoice"
        string="Invoice report (without details)"
        report_type="qweb-pdf"
        name="account_wua.account_invoice_without_details_report_document"
        file="account_wua.account_invoice_without_details_report_document"
        attachment="(object.state in ('open','paid')) and ('INV'+(object.number or '').replace('/','')+'.pdf')"/>


    <record id="account_wua.account_invoice_without_details_report" model="ir.actions.report.xml">
        <field name="attachment_use" eval="False"/>
    </record>

    <template id="account_invoice_report_without_details" inherit_id="account.report_invoice_document" primary="True">
        <xpath expr="//table[@name='details_table']" position="attributes">
            <attribute name="t-att-style">"display: none"</attribute>
        </xpath>
        <xpath expr="//div[@name='subtotal_table']" position="attributes">
            <attribute name="t-att-style">"display: none"</attribute>
        </xpath>
        <xpath expr="//div[@name='product_resume_table']" position="replace">
            <div name="product_resume_table">
                <t t-set="num_of_products" t-value="0"/>
                <table class="table table-condensed">
                    <col name="product" width="57%"/>
                    <col name="total_qty" width="19%"/>
                    <col name="product_price_summary" width="20%"/>
                    <col name="total_amnt_th" width="4%"/>
                    <thead>
                        <tr>
                            <th name="product_th">Product</th>
                            <th name="total_qty_th" class="text-right">Total quantity</th>
                            <th name="product_price_summary_th" class="text-right">Price</th>
                            <th name="total_amnt_th" class="text-right">Total amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="products" t-as="p">
                            <t t-set="num_of_products" t-value="num_of_products + 1"/>
                            <t t-set="product_total_qty" t-value="0.0"/>
                            <t t-set="product_total_amount" t-value="0.0"/>
                            <t t-set="uom_id" t-value="empty"/>
                            <t t-foreach="o.invoice_line_ids" t-as="l">
                                <t t-if="l.product_id.id == p.id">
                                    <t t-set="product_total_qty" t-value="product_total_qty + l.quantity"/>
                                    <t t-set="product_total_amount" t-value="product_total_amount + l.price_subtotal"/>
                                    <t t-set="uom_id" t-value="l.sudo().uom_id.name"/>
                                </t>
                            </t>
                            <td>
                                <span t-field="p.sudo().name"/>
                                <t t-if="p.sudo().attribute_value_ids">
                                    <t t-foreach="p.sudo().attribute_value_ids" t-as="a">
                                        <span t-field="a.name"/>
                                    </t>
                                </t>
                            </td>
                            <td name="total_qty_td" class="text-right">
                                <span name="span_product_total_qty" t-esc="product_total_qty" t-options='{"widget": "float", "precision": 4}'/>
                                <span t-esc="uom_id"/>
                            </td>
                            <td name="product_price_summary_td" class="text-right">
                                <span name="span_product_price_summary" t-field="p.lst_price" t-options='{"widget": "float", "precision": 4}'/>
                                <span>€</span>
                                <span>/</span>
                                <span t-esc="p.uom_id.name"/>
                            </td>
                            <td name="total_amnt_td" class="text-right">
                                <span t-esc="product_total_amount" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                            </td>
                        </tr>
                        <t t-if="num_of_products > 1">
                            <tr name="products_total">
                                <td class="text-right" colspan="3">
                                    <strong>Total:</strong>
                                </td>
                                <td class="text-right">
                                    <strong><span t-field="o.amount_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></strong>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>
        </xpath>
    </template>

    <template id="account_invoice_without_details_report_document">
        <t t-call="report.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="account_wua.account_invoice_report_without_details" t-lang="o.partner_id.lang"/>
            </t>
        </t>
    </template>

</odoo>
