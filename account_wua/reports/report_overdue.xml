<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_overdue_document" inherit_id="account.report_overdue_document">

        <!-- Replace full document -->
        <xpath expr="//div[@class='row']" position="replace">
            <t t-set="report_style" t-value="o.env['ir.values'].get_default('wua.configuration', 'reports_style')"/>

            <!-- Customize address -->
            <div name="overdue_address">
                <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                    <t t-if="report_style == 'light'">
                        <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-user"/></div>
                            <div style="float: left; display: inline;"><strong>Client</strong></div>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-user"/></div>
                            <div style="float: left; display: inline;"><strong>Client</strong></div>
                        </div>
                    </t>
                </div>
                <div class="row" style="border: 1px solid white; margin: 0px 20px; margin-top: 4px;">
                    <div class="col-xs-12" style="display: table;">
                        <div style="border-right: 1px solid white; width: 60%; display: table-cell;">
                            <p style="margin-bottom: 0px"><i>Invoicing address</i></p>
                            <div>
                                <t t-if="o.name"><strong><span t-field="o.name"/></strong></t><br/>
                                <t t-if="o.vat">
                                    <t t-set="mod_vat" t-value="o.vat[2:]"/>
                                    <span>TIN:&amp;nbsp;</span>
                                    <span t-esc="mod_vat"/>
                                </t><br/>
                                <t t-if="o.street_type_show"><span t-field="o.street_type_show"/></t>
                                <t t-if="o.street"><span t-field="o.street"/></t>
                                <t t-if="o.street_num"><span t-field="o.street_num"/></t>
                                <t t-if="o.street2"><span t-field="o.street2"/></t>
                                <br/>
                                <t t-if="o.city"><span t-field="o.city"/></t>
                                <t t-if="o.zip">
                                    <span>&amp;nbsp;-&amp;nbsp;</span>
                                    <span t-field="o.zip"/>
                                </t>
                                <t id="state_address" t-if="o.state_id">
                                    <span t-tag="span">(</span><span t-field="o.state_id"/>
                                    <t t-if="not o.country_id"><span>)</span></t>
                                    <t t-else=""><span>-</span></t>
                                </t>
                                <t id="country_address" t-if="o.country_id">
                                    <t t-if="not o.state_id"><span>(</span></t>
                                    <span t-field="o.country_id"></span><span>)</span>
                                </t>
                            </div>
                        </div>
                        <div style="width: 40%; display: table-cell; padding: 0px 8px;">
                            <p style="margin-bottom: 0px"><i>Shipping Address</i></p>
                            <t name="t_if_child_ids" t-if="o.child_ids">
                                <t t-foreach="o.child_ids" t-as="address">
                                    <t t-if="address.type == 'delivery'">
                                        <t t-set="shipping_address" t-value="address"/>
                                        <div>
                                            <t t-if="shipping_address.name"><strong><span t-field="shipping_address.name"/></strong></t><br/>
                                            <t t-if="shipping_address.street_type_show"><span t-field="shipping_address.street_type_show"/></t>
                                            <t t-if="shipping_address.street"><span t-field="shipping_address.street"/></t>
                                            <t t-if="shipping_address.street_num"><span t-field="shipping_address.street_num"/></t>
                                            <t t-if="shipping_address.street2"><span t-field="shipping_address.street2"/></t>
                                            <br/>
                                            <t t-if="shipping_address.city"><span t-field="shipping_address.city"/></t>
                                            <t t-if="shipping_address.zip">
                                                <span>&amp;nbsp;-&amp;nbsp;</span>
                                                <span t-field="shipping_address.zip"/>
                                            </t>
                                            <t id="state_address" t-if="shipping_address.state_id">
                                                <span t-tag="span">(</span><span t-field="shipping_address.state_id"/>
                                                <t t-if="not shipping_address.country_id"><span>)</span></t>
                                                <t t-else=""><span>-</span></t>
                                            </t>
                                            <t id="country_address" t-if="shipping_address.country_id">
                                                <t t-if="not shipping_address.state_id"><span>(</span></t>
                                                <span t-field="shipping_address.country_id"></span><span>)</span>
                                            </t>
                                        </div>
                                    </t>
                                     <t t-else="">
                                        <div>
                                            <t t-if="o.name"><strong><span t-field="o.name"/></strong></t><br/>
                                            <t t-if="o.street_type_show"><span t-field="o.street_type_show"/></t>
                                            <t t-if="o.street"><span t-field="o.street"/></t>
                                            <t t-if="o.street_num"><span t-field="o.street_num"/></t>
                                            <t t-if="o.street2"><span t-field="o.street2"/></t>
                                            <br/>
                                            <t t-if="o.city"><span t-field="o.city"/></t>
                                            <t t-if="o.zip">
                                                <span>&amp;nbsp;-&amp;nbsp;</span>
                                                <span t-field="o.zip"/>
                                            </t>
                                            <t id="state_address" t-if="o.state_id">
                                                <span t-tag="span">(</span><span t-field="o.state_id"/>
                                                <t t-if="not o.country_id"><span>)</span></t>
                                                <t t-else=""><span>-</span></t>
                                            </t>
                                            <t id="country_address" t-if="o.country_id">
                                                <t t-if="not o.state_id"><span>(</span></t>
                                                <span t-field="o.country_id"></span><span>)</span>
                                            </t>
                                        </div>
                                    </t>
                                </t>
                            </t>
                            <t t-else="">
                                <div>
                                    <t t-if="o.name"><strong><span t-field="o.name"/></strong></t><br/>
                                    <t t-if="o.street_type_show"><span t-field="o.street_type_show"/></t>
                                    <t t-if="o.street"><span t-field="o.street"/></t>
                                    <t t-if="o.street_num"><span t-field="o.street_num"/></t>
                                    <t t-if="o.street2"><span t-field="o.street2"/></t>
                                    <br/>
                                    <t t-if="o.city"><span t-field="o.city"/></t>
                                    <t t-if="o.zip">
                                        <span>&amp;nbsp;-&amp;nbsp;</span>
                                        <span t-field="o.zip"/>
                                    </t>
                                    <t id="state_address" t-if="o.state_id">
                                        <span t-tag="span">(</span><span t-field="o.state_id"/>
                                        <t t-if="not o.country_id"><span>)</span></t>
                                        <t t-else=""><span>-</span></t>
                                    </t>
                                    <t id="country_address" t-if="o.country_id">
                                        <t t-if="not o.state_id"><span>(</span></t>
                                        <span t-field="o.country_id"></span><span>)</span>
                                    </t>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>
            </div>

            <div name="overdue_state" style="margin-top:20px;">
                <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                    <t t-if="report_style == 'light'">
                        <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-file"/></div>
                            <div style="float: left; display: inline;"><strong>Account&amp;nbsp;statement</strong></div>
                            <div style="float: right;">
                                <strong><span t-esc="Date.strftime('%d-%m-%Y')"/></strong>
                            </div>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-file"/></div>
                            <div style="float: left; display: inline;"><strong>Account&amp;nbsp;statement</strong></div>
                            <div style="float: right;">
                                <strong><span t-esc="Date.strftime('%d-%m-%Y')"/></strong>
                            </div>
                        </div>
                    </t>
                </div>

                <!-- Change dates format and do not show litigation column -->
                <t t-if="Lines[o.id]">
                    <span t-field="res_company.with_context(lang=o.lang).overdue_msg"/>
                    <div name="overdue_details" style="margin-top:20px;">
                        <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                            <t t-if="report_style == 'light'">
                                <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                    <div style="float: left; width: 32px;"><span class="fa fa-th-list"/></div>
                                    <div style="float: left; display: inline;"><strong>Details</strong></div>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                    <div style="float: left; width: 32px;"><span class="fa fa-th-list"/></div>
                                    <div style="float: left; display: inline;"><strong>Details</strong></div>
                                </div>
                            </t>
                        </div>
                        <table class="table table-condensed" t-foreach="Lines[o.id]" t-as="currency">
                            <thead>
                                <tr>
                                    <th name="th_move_id">Reference</th>
                                    <th class="text-center" style="width:11%;">Date</th>
                                    <th class="text-center">Due Date</th>
                                    <th>Communication</th>
                                    <th class="text-right">Due</th>
                                    <th class="text-right">Paid</th>
                                </tr>
                            </thead>
                            <tr t-foreach="Lines[o.id][currency]" t-as="line">
                                <td name="td_move_id">
                                    <span t-esc="line['move_id']"/>
                                </td>
                                <td class="text-center">
                                    <span t-esc="datetime.datetime.strptime(line['date'], '%Y-%m-%d').strftime('%d-%m-%Y')"/>
                                </td>
                                <td class="text-center">
                                    <span t-esc="datetime.datetime.strptime(line['date_maturity'], '%Y-%m-%d').strftime('%d-%m-%Y')"/>
                                </td>
                                <td>
                                    <t t-if="line['name'] != '/'"><span t-esc="line['name']"/></t>
                                    <span t-esc="line['ref']"/>
                                </td>
                                <td class="text-right">
                                    <span t-esc="line['debit']" t-options="{'widget': 'monetary', 'display_currency': currency}"/>
                                </td>
                                <td class="text-right">
                                    <span t-esc="line['credit']" t-options="{'widget': 'monetary', 'display_currency': currency}"/>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="3"></td>
                                <td><strong>Subtotal:</strong></td>
                                <td class="text-right"><span t-esc="Totals[o.id][currency]['due']" t-options="{'widget': 'monetary', 'display_currency': currency}"/></td>
                                <td class="text-right"><span t-esc="Totals[o.id][currency]['paid']" t-options="{'widget': 'monetary', 'display_currency': currency}"/></td>
                                <td></td>
                            </tr>
                            <tr>
                                <td colspan="3"></td>
                                <td><strong>Balance:</strong></td>
                                <td class="text-right">
                                    <span t-esc="Totals[o.id][currency]['due'] - Totals[o.id][currency]['paid']" t-options="{'widget': 'monetary', 'display_currency': currency}"/>
                                </td>
                                <td></td>
                            </tr>
                        </table>
                    </div>
                </t>
                <p t-if="not Lines[o.id]">
                    <strong>There is nothing due with this customer.</strong>
                </p>
            </div>
        </xpath>

    </template>

</odoo>
