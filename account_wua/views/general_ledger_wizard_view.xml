<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="general_ledger_wizard" model="ir.ui.view">
        <field name="name">General Ledger</field>
        <field name="model">general.ledger.report.wizard</field>
        <field name="inherit_id" ref="account_financial_report_qweb.general_ledger_wizard"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='show_analytic_tags']" position="after">
                <field name="hide_account_summary"/>
            </xpath>
        </field>
    </record>

</odoo>
