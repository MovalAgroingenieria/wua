<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Assign paper format -->
    <record id="account_credit_control.credit_control_summary" model="ir.actions.report.xml">
        <field name="paperformat_id" ref="base_wua_report.paperformat_wua_reports"/>
    </record>

    <!-- Modification of report -->
    <template id="report_credit_control_summary_document" inherit_id="account_credit_control.report_credit_control_summary_document">

        <!-- Change associated external layout -->
        <xpath expr="//t[@t-call='report.external_layout']" position="attributes">
            <attribute name="t-call">base_wua_report.wua_external_layout</attribute>
        </xpath>

        <!-- Do no show h2 and h3 titles -->
        <xpath expr="//h2[@id='policy_level']" position="attributes">
            <attribute name="t-att-style">"display: none"</attribute>
        </xpath>
        <xpath expr="//h3" position="attributes">
            <attribute name="t-att-style">"display: none"</attribute>
        </xpath>

        <!-- Address and report format -->
        <xpath expr="//div[@id='address']" position="replace">
            <t t-set="report_style" t-value="doc.env['ir.values'].get_default('wua.configuration', 'reports_style')"/>

            <!-- Get first delivery child contact if exists for credit control line (only for shipping address) -->
            <t t-set="shipping_contact_partner" t-value="doc.partner_id"/>
            <t t-foreach="doc.credit_control_line_ids" t-as="line">
                <t t-if="line.partner_id and line.partner_id.child_ids">
                    <t t-set="delivery_children" t-value="line.partner_id.child_ids.filtered(lambda c: c.type == 'delivery')"/>
                    <t t-if="delivery_children">
                        <t t-set="shipping_contact_partner" t-value="delivery_children[0]"/>
                        <t t-break=""/>
                    </t>
                </t>
            </t>

            <div name="partner_data">
                <div class="row h4 mt28 mb4" style="padding-bottom: 4px;" name="partner_title">
                    <t t-if="report_style == 'light'">
                        <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-user"/></div>
                            <div style="float: left; display: inline;"><strong>Partner</strong></div>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-user"/></div>
                            <div style="float: left; display: inline;"><strong>Partner</strong></div>
                        </div>
                    </t>
                </div>
                <div class="row" style="margin-top: 4px;" id='address'>
                    <div name="invoice_address">
                        <div class="row" style="border: 1px solid white; margin: 4px 10px;">
                            <div class="col-xs-12" style="display: table;">
                                <div name="div_invoicing_address" style="border-right: 1px solid white; width: 50%; display: table-cell;">
                                    <p name="p_invoicing_address_title" style="margin-bottom: 0px"><i>Invoicing address</i></p>
                                    <div>
                                        <t t-if="doc.partner_id.name">
                                            <strong><span name="invoicing_address_partner_name" t-field="doc.partner_id.name"/></strong>
                                            <t t-set="partner_code" t-value="str(doc.partner_id.partner_code)"/>
                                            <span>[<span t-esc="partner_code"/>]</span>
                                        </t><br/>
                                        <t t-if="doc.partner_id.vat" name="t_invoicing_address_vat">
                                            <t t-set="mod_vat" t-value="doc.partner_id.vat[2:]"/>
                                            <span>TIN:&amp;nbsp;</span>
                                            <span t-esc="mod_vat"/>
                                        </t><br name="br_invoicing_address_after_vat"/>
                                        <t t-if="doc.partner_id.street_type_show"><span t-field="doc.partner_id.street_type_show"/></t>
                                        <t t-if="doc.partner_id.street"><span t-field="doc.partner_id.street"/></t>
                                        <t t-if="doc.partner_id.street_num"><span t-field="doc.partner_id.street_num"/></t>
                                        <t t-if="doc.partner_id.street2"><span t-field="doc.partner_id.street2"/></t>
                                        <br/>
                                        <t t-if="doc.partner_id.city"><span t-field="doc.partner_id.city"/></t>
                                        <t t-if="doc.partner_id.zip">
                                            <span>&amp;nbsp;-&amp;nbsp;</span>
                                            <span t-field="doc.partner_id.zip"/>
                                        </t>
                                        <t id="state_invoicing_address_1" t-if="doc.partner_id.state_id">
                                            <span t-tag="span">(</span><span t-field="doc.partner_id.state_id"/>
                                            <t t-if="not doc.partner_id.country_id"><span>)</span></t>
                                            <t t-else=""><span>-</span></t>
                                        </t>
                                        <t id="country_invoicing_address_1" t-if="doc.partner_id.country_id">
                                            <t t-if="not doc.partner_id.state_id"><span>(</span></t>
                                            <span t-field="doc.partner_id.country_id"></span><span>)</span>
                                        </t>
                                    </div>
                                </div>
                                <div name="div_shipping_address" style="width: 40%; display: table-cell; padding: 0px 4px;">
                                    <p name="p_shipping_address_title" style="margin-bottom: 0px"><i>Shipping Address</i></p>
                                    <t t-set="latest_sale_config" t-value="doc.env['sale.config.settings'].sudo().search([], limit=1, order='id desc')"/>
                                    <t t-set="delivery_address_config" t-value="latest_sale_config.group_sale_delivery_address if latest_sale_config else 0"/>
                                    <t t-set="delivery_address_enabled" t-value="delivery_address_config == 1"/>
                                    <t t-if="not delivery_address_enabled">
                                        <div>
                                            <t t-if="doc.partner_id.name"><strong><span t-field="doc.partner_id.name"/></strong></t><br/>
                                            <t t-if="doc.partner_id.street_type_show"><span t-field="doc.partner_id.street_type_show"/></t>
                                            <t t-if="doc.partner_id.street"><span t-field="doc.partner_id.street"/></t>
                                            <t t-if="doc.partner_id.street_num"><span t-field="doc.partner_id.street_num"/></t>
                                            <t t-if="doc.partner_id.street2"><span t-field="doc.partner_id.street2"/></t>
                                            <br/>
                                            <t t-if="doc.partner_id.city"><span t-field="doc.partner_id.city"/></t>
                                            <t t-if="doc.partner_id.zip">
                                                <span>&amp;nbsp;-&amp;nbsp;</span>
                                                <span t-field="doc.partner_id.zip"/>
                                            </t>
                                            <t id="state_shipping_address_2" t-if="doc.partner_id.state_id">
                                                <span t-tag="span">(</span><span t-field="doc.partner_id.state_id"/>
                                                <t t-if="not doc.partner_id.country_id"><span>)</span></t>
                                                <t t-else=""><span>-</span></t>
                                            </t>
                                            <t id="country_shipping_address_2" t-if="doc.partner_id.country_id">
                                                <t t-if="not doc.partner_id.state_id"><span>(</span></t>
                                                <span t-field="doc.partner_id.country_id"></span><span>)</span>
                                            </t>
                                        </div>
                                    </t>
                                    <t t-if="delivery_address_enabled">
                                        <div>
                                            <t t-if="shipping_contact_partner.name"><strong><span t-field="shipping_contact_partner.name"/></strong></t><br/>
                                            <t t-if="shipping_contact_partner.street_type_show"><span t-field="shipping_contact_partner.street_type_show"/></t>
                                            <t t-if="shipping_contact_partner.street"><span t-field="shipping_contact_partner.street"/></t>
                                            <t t-if="shipping_contact_partner.street_num"><span t-field="shipping_contact_partner.street_num"/></t>
                                            <t t-if="shipping_contact_partner.street2"><span t-field="shipping_contact_partner.street2"/></t>
                                            <br/>
                                            <t t-if="shipping_contact_partner.city"><span t-field="shipping_contact_partner.city"/></t>
                                            <t t-if="shipping_contact_partner.zip">
                                                <span>&amp;nbsp;-&amp;nbsp;</span>
                                                <span t-field="shipping_contact_partner.zip"/>
                                            </t>
                                            <t id="state_shipping_address_3" t-if="shipping_contact_partner.state_id">
                                                <span t-tag="span">(</span><span t-field="shipping_contact_partner.state_id"/>
                                                <t t-if="not shipping_contact_partner.country_id"><span>)</span></t>
                                                <t t-else=""><span>-</span></t>
                                            </t>
                                            <t id="country_shipping_address_3" t-if="shipping_contact_partner.country_id">
                                                <t t-if="not shipping_contact_partner.state_id"><span>(</span></t>
                                                <span t-field="shipping_contact_partner.country_id"></span><span>)</span>
                                            </t>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>

        <xpath expr="//div[@class='row mt32 mb32'][1]" position="attributes">
            <attribute name="t-att-style">"display: none"</attribute>
        </xpath>

        <xpath expr="//h2[@id='policy_level']" position="after">
            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;" name="communication_title">
                 <t t-if="report_style == 'light'">
                     <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                         <div style="float: left; width: 32px;"><span class="fa fa-money"/></div>
                         <div style="float: left; display: inline;"><strong>Communication&amp;nbsp;debt</strong></div>
                         <div style="float: right;">
                             <strong><span t-field="doc.report_date"/></strong>
                         </div>
                     </div>
                 </t>
                 <t t-else="">
                     <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                         <div style="float: left; width: 32px;"><span class="fa fa-money"/></div>
                         <div style="float: left; display: inline;"><strong>Communication&amp;nbsp;debt</strong></div>
                         <div style="float: right;">
                             <strong><span t-field="doc.report_date"/></strong>
                         </div>
                     </div>
                 </t>
             </div>
             <div>
                <span t-field="doc.current_policy_level.custom_text"/>
             </div>
        </xpath>

        <xpath expr="//table[@id='summary_table']/thead/tr/th" position="after">
            <th width="32%" name="invoiceset_id">Invoiceset</th>
        </xpath>
        <xpath expr="//t[@t-if='not l.invoice_id']" position="after">
            <td name="td_invoiceset_id">
                <t t-if="l.invoiceset_id">
                    <span t-field="l.invoiceset_id.description"/>
                </t>
            </td>
        </xpath>

        <xpath expr="//t[@t-if='doc.current_policy_level.custom_text_after_details']" position="replace">
            <t t-if="doc.current_policy_level.custom_text_after_details">
                <div style="margin-bottom:20px;page-break-inside: avoid;">
                    <p t-field="doc.current_policy_level.custom_text_after_details"/>
                </div>
            </t>
        </xpath>

        <!-- Order lines -->
        <xpath expr="//tr[@t-foreach='doc.credit_control_line_ids']" position="before">
            <t t-set="lines" t-value="doc._get_ordered_lines(doc.credit_control_line_ids.ids)"/>
        </xpath>
        <xpath expr="//tr[@t-foreach='doc.credit_control_line_ids']" position="attributes">
            <attribute name="t-foreach">lines</attribute>
        </xpath>

    </template>

    <!-- Add currency to dunning fees -->
    <template id="report_credit_control_summary_document_dunning_fees"
        inherit_id="account_credit_control_dunning_fees.report_credit_control_summary_document_fees">
        <xpath expr="//span[@t-field='l.dunning_fees_amount']" position="attributes">
            <attribute name="t-field-options">
                {"widget": "monetary", "display_currency": "l.currency_id or l.company_id.currency_id"}
            </attribute>
        </xpath>
    </template>

</odoo>