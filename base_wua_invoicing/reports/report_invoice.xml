<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Modification report invoice -->
    <template id="wua_report_invoice_document" inherit_id="account.report_invoice_document">
        <xpath expr="//span[@t-esc='amount_by_group[0] if len(o.tax_line_ids) > 1 else (o.tax_line_ids.tax_id.name)']" position="after">
            <t t-if="o.env['ir.values'].get_default('wua.invoicing.configuration', 'show_tax_base')">
                <span> in </span>
                <span t-esc="amount_by_group[4]"/>
            </t>
                <t t-else="">
            </t>
        </xpath>
    </template>

</odoo>
