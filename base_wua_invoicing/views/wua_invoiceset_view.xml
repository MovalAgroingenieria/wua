<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_invoiceset_view_form" model="ir.ui.view" >
        <field name="name">Invoice Sets (form view)</field>
        <field name="model">wua.invoiceset</field>
        <field name="priority" eval="1"/>
        <field name="arch" type="xml">
            <form string="Invoce Sets" duplicate="false">
                <field name="configured_invoiceset" invisible="1"/>
                <header>
                    <button name="configure_invoiceset"
                            type="object" string="Configure"
                            states="draft"
                            groups="base_wua.group_wua_manager"/>
                    <button name="calculate_invoiceset"
                            type="object" string="Calculate"
                            attrs="{'invisible':
                                    ['|',
                                     ('configured_invoiceset','=',False),
                                     ('state','=','generated')]}"                            
                            groups="base_wua.group_wua_manager"
                            confirm="Are you sure you want to do this operation?"/>
                    <button name="cancel_invoiceset"
                            type="object" string="Cancel"
                            states="generated"
                            groups="base_wua.group_wua_manager"
                            confirm="Are you sure you want to do this operation?"/>
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,generated"/>                
                </header>
                <sheet>
                    <div name="buttons" class="oe_button_box">
                        <button name="toggle_active"
                                type="object"
                                class="oe_stat_button" 
                                icon="fa-archive"
                                groups="base_wua.group_wua_manager">
                                <field name="active"
                                 widget="boolean_button"
                                 options='{"terminology": "archive"}'/>
                        </button>
                        <button name="action_see_invoices"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-dollar"
                                attrs="{'invisible':
                                        [('state','=','draft')]}">
                                <div class="o_form_field o_stat_info">
                                    <span class="o_stat_value">
                                        <field name="number_of_invoices"/>
                                    </span>
                                    <span class="o_stat_text">
                                        Invoices
                                    </span>
                                </div>                                
                        </button>
                    </div>
                    <group name="master_data" col="10">
                        <group name="master_data_id01" colspan="4">
                            <field name="id" invisible="1"/>
                            <field name="name"
                                   attrs="{'readonly': [('id', '>', 0)]}"/>
                            <field name="date_invoiceset"
                                   attrs="{'readonly':
                                           [('state','=','generated')]}"/>
                            <field name="date_due_invoiceset"
                                   attrs="{'readonly':
                                           [('state','=','generated')]}"/>
                        </group>
                        <group name="master_data_id02" colspan="4">
                            <field name="description"
                                   attrs="{'readonly':
                                           [('state','=','generated')]}"/>                            
                            <field name="journal_id"
                                   domain="[('type','=','sale')]"
                                   attrs="{'readonly':
                                           [('state','=','generated')]}"/>
                            <field name="user_id"/>
                        </group>
                        <group name="master_data_sum" colspan="2"
                               class="oe_subtotal_footer oe_right"
                               attrs="{'invisible': [('state','=','draft')]}">
                            <field name="company_id" invisible="1"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="amount_untaxed"/>
                            <field name="amount_tax"/>
                            <field name="amount_total"/>
                        </group>
                    </group>
                    <group name="slave_data">
                        <notebook name="slave_data_notebook">
                            <page name="lines_page" string="Lines">
                                <field name="line_ids"
                                       context="{'tree_view_ref':
                                                 'base_wua_invoicing.wua_edit_invoiceset_line_view_tree'}"/>                            
                            </page>
                            <page name="notes_page" string="Notes">
                                <field name="notes"/>
                            </page>
                        </notebook>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"
                           widget="mail_followers" groups="base.group_user"/>
                    <field name="message_ids"
                           widget="mail_thread"/>
                </div>                
            </form>
        </field>
    </record>

    <record id="wua_invoiceset_view_tree" model="ir.ui.view">
        <field name="name">Invoice Sets (tree view)</field>
        <field name="model">wua.invoiceset</field>
        <field name="arch" type="xml">
            <tree class="o_base_wua_invoicing_invoiceset_view_tree">
                <field name="name"/>
                <field name="description"/>
                <field name="journal_id"/>
                <field name="date_invoiceset"/>
                <field name="date_due_invoiceset"/>
                <field name="user_id"/>
                <field name="number_of_invoices"/>
                <field name="amount_untaxed"/>
                <field name="amount_tax"/>
                <field name="amount_total"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="wua_invoiceset_view_search" model="ir.ui.view">
        <field name="name">Invoice Sets (search view)</field>
        <field name="model">wua.invoiceset</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="description"/>
                <field name="user_id"/>
                <field name="year_invoiceset"/>
                <filter string="Draft" name="draft"
                 domain="[('state','=','draft')]"/>
                <filter string="Generated" name="generated"
                 domain="[('state','=','generated')]"/>                 
                <separator/>
                <filter string="Archived" name="inactive"
                 domain="[('active','=',False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Journal" name="journal"
                     context="{'group_by':'journal_id'}"/>
                    <filter string="Salesperson" name="user"
                     context="{'group_by':'user_id'}"/>
                    <filter string="Year" name="year"
                     context="{'group_by':'year_invoiceset'}"/>                     
                    <filter string="Totals" name="totals"
                     context="{'group_by':'active'}"/>                     
                </group>
            </search>
        </field>
    </record>

    <record id="wua_edit_invoiceset_line_view_tree" model="ir.ui.view">
        <field name="name">Invoice-Set Lines</field>
        <field name="model">wua.invoiceset.line</field>
        <field name="arch" type="xml">
            <tree class="o_base_wua_invoicing_invoiceset_line_view_tree_notebook"
                  editable="bottom">
                <field name="company_id" invisible="1"/>
                <field name="currency_id" invisible="1"/>
                <field name="configured_line" invisible="1"/>
                <field name="pos_str"/>
                <field name="product_id" widget="many2one_unclickable"
                       attrs="{'readonly':[('configured_line','=',True)]}"
                       domain="[('is_wua_product','=',True)]"/>
                <field name="linkable_unit_type"/>
                <button type="object" class="oe_read_only"
                        icon="fa-check-circle"
                        attrs="{'invisible':
                                [('configured_line','=',False)],
                                'readonly':
                                [('configured_line','=',True)]}"/>                
                <field name="quantity"/>
                <field name="price_unit"/>
                <field name="amount_untaxed"/>
                <field name="taxes_id" widget="many2many_tags"/>
                <field name="amount_tax"/>
                <field name="amount_total"/>
            </tree>        
        </field>
    </record>

