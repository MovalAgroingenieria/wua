                 domain="[('selected','=',True)]"/>
                <filter string="Not Selected" name="notselected"
                 domain="[('selected','!=',True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Is selected (marked)"
                     name="isselected"
                     context="{'group_by':'selected'}"/>
                    <filter string="Irrigation Ditch"
                     name="irrigation_ditch"
                     context="{'group_by':'irrigationditch_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="wua_add_irrigationgate_to_invoiceset" model="ir.actions.server">
        <field name="name">Add to invoice set</field>
        <field name="model_id" ref="model_wua_invoiceset_line_irrigationgate"/>
        <field name="state">code</field>
        <field name="code">
            if context.get('active_ids'):
                action = env['wua.invoiceset.line.irrigationgate'].browse(context['active_ids']).add_to_invoiceset()
        </field>
    </record>
    
    <record id="wua_action_add_irrigationgate_to_invoiceset" model="ir.values">
        <field name="name">Add irrigationgate to invoice set</field>
        <field name="model">wua.invoiceset.line.irrigationgate</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('wua_add_irrigationgate_to_invoiceset'))"/>
    </record>

    <record id="wua_remove_irrigationgate_to_invoiceset" model="ir.actions.server">
        <field name="name">Remove from invoice set</field>
        <field name="model_id" ref="model_wua_invoiceset_line_irrigationgate"/>
        <field name="state">code</field>
        <field name="code">
            if context.get('active_ids'):
                action = env['wua.invoiceset.line.irrigationgate'].browse(context['active_ids']).remove_from_invoiceset()
        </field>
    </record>
    
    <record id="wua_action_remove_irrigationgate_to_invoiceset" model="ir.values">
        <field name="name">Remove irrigationgate from invoice set</field>
        <field name="model">wua.invoiceset.line.irrigationgate</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('wua_remove_irrigationgate_to_invoiceset'))"/>
    </record>

    <record id="wua_invoiceset_action" model="ir.actions.act_window">
        <field name="name">Invoice Sets</field>
        <field name="res_model">wua.invoiceset</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="wua_invoiceset_view_tree"/>
        <field name="search_view_id" ref="wua_invoiceset_view_search"/>
    </record>

    <menuitem id="wua_invoiceset_menu"
              name="Invoice Sets"
              parent="account.menu_finance_receivables"
              action="wua_invoiceset_action"
              sequence="2"
              groups="base_wua.group_wua_user"/>

</odoo>