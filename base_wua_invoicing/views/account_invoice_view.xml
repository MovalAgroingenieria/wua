                <field name="invoiceset_id"/>
                <field name="invoice_id"/>
                <field name="date_invoice"/>
                <field name="product_id"/>
                <field name="name"/>
                <field name="quantity"/>
                <field name="price_unit"/>
                <field name="price_subtotal" sum="Total"/>
            </tree>
        </field>
    </record>

    <record id="wua_invoice_line_partner_view_search" model="ir.ui.view">
        <field name="name">Invoice Lines of Partner (search view)</field>
        <field name="model">account.invoice.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="invoiceset_id"/>
                <field name="invoice_id"/>
                <field name="date_invoice"/>
                <field name="product_id"/>
