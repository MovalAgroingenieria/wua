<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_parcel_view_form" model="ir.ui.view">
        <field name="name">Parcels (form view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id"
               ref="base_wua_infrastructure.wua_parcel_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_see_gis_viewer']"
                   position="after">
                <button name="action_see_invoice_lines"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-dollar"
                        groups="base_wua.group_wua_user">
                        <div class="o_form_field o_stat_info">
                            <span class="o_stat_text">
                                Detail lines
                            </span>
                            <span class="o_stat_text">
                                (invoice-sets)
                            </span>
                        </div>
                </button>
            </xpath>
        </field>
    </record>

    <record id="wua_parcel_view_form_inherit" model="ir.ui.view">
        <field name="name">Parcels (form view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id"
               ref="base_wua.wua_parcel_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='is_billable_expenses']"
                   position="after">
                <field name="use_ownership_percentage_on_invoicing"
                                 colspan="4"/>
            </xpath>
        </field>
    </record>

    <record id="wua_parcel_view_tree" model="ir.ui.view">
        <field name="name">Parcels (tree view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id"
               ref="base_wua_infrastructure.wua_parcel_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="colors">saddlebrown:supply_suspended==True;red:overdue==True</attribute>
            </xpath>
            <xpath expr="//field[@name='number_of_subparcels']" position="after">
                <field name="overdue" invisible="1"/>
            </xpath>
        </field>
    </record>

    <record id="wua_parcel_view_form_overdue_notice" model="ir.ui.view">
        <field name="name">Parcels (form view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id" ref="base_wua.wua_parcel_view_form"/>
        <field name="arch" type="xml">
        <xpath expr="//header/button[@groups='base_wua.group_wua_manager']" position="after">
            <field name="overdue" invisible="1"/>
            <div name="hasoverdue" style="display: inline-block;" attrs="{'invisible':[('overdue','&lt;=',0.0)]}">
                <span class="blink_text">( CREDIT OVERDUE )</span>
            </div>
            </xpath>
        </field>
    </record>

    <record id="wua_parcel_partnerlink_view_tree" model="ir.ui.view" >
        <field name="name">Partner Links (tree view)</field>
        <field name="model">wua.parcel.partnerlink</field>
        <field name="inherit_id" ref="base_wua.wua_parcel_partnerlink_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="colors">red:overdue==True</attribute>
            </xpath>
            <xpath expr="//field[@name='parcel_id']" position="after">
                <field name="overdue" invisible="1"/>
            </xpath>
        </field>
    </record>

</odoo>
