<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_invoicelines_view_tree" model="ir.ui.view">
        <field name="name">Invoice Lines (tree view)</field>
        <field name="model">account.invoice.line</field>
        <field name="arch" type="xml">
            <tree class="o_base_wua_invoicing_invoicelines_view_tree">
                <field name="invoiceset_id"/>
                <field name="invoice_id"/>
                <field name="date_invoice"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="name"/>
                <field name="quantity"/>
                <field name="price_unit"/>
                <field name="price_subtotal" sum="Total"/>
            </tree>
        </field>
    </record>

    <record id="wua_invoicelines_view_search" model="ir.ui.view">
        <field name="name">Invoice Lines (search view)</field>
        <field name="model">account.invoice.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="invoiceset_id"/>
                <field name="invoice_id"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="categ_id"/>
                <field name="parcel_id"/>
                <field name="waterconnection_id"/>
                <field name="irrigationshed_id"/>
                <field name="hydraulicsector_id"/>
                <field name="irrigationgate_id"/>
                <field name="irrigationditch_id"/>
                <filter string="Draft Invoice" name="draft"
                 domain="[('invoice_id.state','=','draft')]"/>
                <filter string="Open Invoice" name="open"
                 domain="[('invoice_id.state','=','open')]"/>
                <filter string="Paid Invoice" name="paid"
                 domain="[('invoice_id.state','=','paid')]"/>
                <filter string="Cancelled Invoice" name="cancel"
                 domain="[('invoice_id.state','=','cancel')]"/>
                <filter string="Proforma Invoice" name="proforma"
                 domain="['|', ('invoice_id.state','=','proforma'),
                               ('invoice_id.state','=','proforma2')]"/>
                <group expand="0" string="Group By">
                    <filter string="Invoice Set" name="invoiceset"
                     context="{'group_by':'invoiceset_id'}"/>
                    <filter string="Invoice" name="invoice"
                     context="{'group_by':'invoice_id'}"/>
                    <filter string="Partner" name="partner"
                     context="{'group_by':'partner_id'}"/>
                    <filter string="Product" name="product"
                     context="{'group_by':'product_id'}"/>
                    <filter string="Product Category" name="categ"
                     context="{'group_by':'categ_id'}"/>
                    <filter string="Parcel" name="parcel"
                     context="{'group_by':'parcel_id'}"/>
                    <filter string="Waterconnection" name="waterconnection"
                     context="{'group_by':'waterconnection_id'}"/>
                    <filter string="Irrigationshed" name="irrshed"
                     context="{'group_by':'irrigationshed_id'}"/>
                    <filter string="Hydraulic Sector" name="hydraulicsector"
                     context="{'group_by':'hydraulicsector_id'}"/>
                    <filter string="Irrigationgate" name="irrigationgate"
                     context="{'group_by':'irrigationgate_id'}"/>
                    <filter string="Irrigationditch" name="irrigationditch"
                     context="{'group_by':'irrigationditch_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="wua_invoicelines_action" model="ir.actions.act_window">
        <field name="name">Invoice Lines</field>
        <field name="res_model">account.invoice.line</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="wua_invoicelines_view_tree"/>
        <field name="search_view_id" ref="wua_invoicelines_view_search"/>
        <field name="context">{'search_default_partner': 1}</field>
    </record>

    <menuitem id="wua_invoicelines_menu"
              name="Invoice Lines"
              parent="account.menu_finance_receivables"
              action="wua_invoicelines_action"
              sequence="3"
              groups="base_wua.group_wua_user"/>

</odoo>
