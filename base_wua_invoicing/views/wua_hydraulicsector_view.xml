<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_hydraulicsector_view_form" model="ir.ui.view">
        <field name="name">Hydraulic Sectors (form view)</field>
        <field name="model">wua.hydraulicsector</field>
        <field name="inherit_id"
               ref="base_wua_infrastructure.wua_hydraulicsector_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button"
                   position="after">
                <button name="action_see_invoice_lines"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-dollar"
                        groups="base_wua.group_wua_user">
                        <div class="o_form_field o_stat_info">
                            <span class="o_stat_text">
                                Detail lines
                            </span>
                            <span class="o_stat_text">
                                (invoice-sets)
                            </span>
                        </div>
                </button>
            </xpath>
        </field>
    </record>

</odoo>