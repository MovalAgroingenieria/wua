<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_move_line_form" model="ir.ui.view">
        <field name="name">Journal Items (form view)</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id"
               ref="account.view_move_line_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='statement_id']" position="after">
                <field name="invoiceset_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_move_line_tree" model="ir.ui.view">
        <field name="name">Journal Items (tree view)</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id"
               ref="account.view_move_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date']" position="after">
                <field name="invoiceset_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_account_move_line_filter" model="ir.ui.view">
        <field name="name">Journal Items (search view)</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id"
               ref="account.view_account_move_line_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="before">
                <field name="invoiceset_id"/>
            </xpath>
            <xpath expr="//filter[@domain='[]']" position="before">
                <filter string="Invoice Set" name="invoiceset"
                        context="{'group_by':'invoiceset_id'}"/>
            </xpath>
        </field>
    </record>

    <record id="view_account_move_filter" model="ir.ui.view">
        <field name="name">account.move.select</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_move_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="before">
                <filter string="With attachments" name="withattachments"
                        domain="[('has_attachments','=',True)]"/>
                <filter string="Without attachments" name="withoutattachments"
                        domain="[('has_attachments','=',False)]"/>
                <separator/>
            </xpath>
        </field>
    </record>

    <record id="view_account_payment_order_form_inherit_confirm" model="ir.ui.view">
    <field name="name">account.payment.order.form.inherit.confirm</field>
    <field name="model">account.payment.order</field>
    <field name="inherit_id" ref="account_payment_order.account_payment_order_form"/>
    <field name="arch" type="xml">
      <xpath expr="//button[@name='action_done_cancel']" position="attributes">
        <attribute name="confirm">IMPORTANT NOTICE. You are about to cancel a charge/payment order from a file uploaded to the bank.
        This may have information loss effects and produce errors in the reconciliation if there are accounting movements subsequent to this charge/payment order
        (returns, bank reconciliation, mandate changes). Consider whether it is really necessary to do so.</attribute>
      </xpath>
        <xpath expr="//button[@name='action_done_cancel']" position="after">
            <button name="action_process_missing_functions" string="Process Pending" type="object" class="btn-primary" invisible="1"/>
        </xpath>
        <xpath expr="//div[@class='oe_title']/h1" position="after">
            <div attrs="{'invisible': [('has_multiple_schemes', '=', False)]}" style="color: red; font-weight: bold; margin-top: 10px;">
                ⚠ ATTENTION: This account payment order contains lines with more than one mandate scheme.
            </div>
        </xpath>
        <xpath expr="//field[@name='name']" position="after">
            <field name="has_multiple_schemes" invisible="1"/>
        </xpath>
    </field>
  </record>

    <record id="action_invoice_cancel_draft" model="ir.actions.server">
        <field name="name">Open Invoices To Draft</field>
        <field name="model_id" ref="account.model_account_invoice"/>
        <field name="binding_model_id" ref="account.model_account_invoice"/>
        <field name="state">code</field>
            <field name="code">
            if context.get('active_ids'):
            invoices = env['account.invoice'].browse(context['active_ids'])
            invoices.action_cancel_and_draft_custom()
            </field>
    </record>

    <record id="action_invoice_cancel_draft_menu" model="ir.values">
        <field name="name">Open Invoices To Draft</field>
        <field name="model">account.invoice</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('action_invoice_cancel_draft'))"/>
    </record>

    <record id="action_set_as_refunded" model="ir.actions.server">
        <field name="name">Set As Refunded</field>
        <field name="model_id" ref="account.model_account_invoice"/>
        <field name="binding_model_id" ref="account.model_account_invoice"/>
        <field name="state">code</field>
            <field name="code">
            if context.get('active_ids'):
            invoices = env['account.invoice'].browse(context['active_ids'])
            invoices.action_set_as_refunded()
            </field>
    </record>

    <record id="action_set_as_refunded_menu" model="ir.values">
        <field name="name">Set As Refunded</field>
        <field name="model">account.invoice</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('action_set_as_refunded'))"/>
    </record>

</odoo>