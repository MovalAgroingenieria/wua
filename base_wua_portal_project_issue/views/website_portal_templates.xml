
<odoo>
    <data>
        <template id="portal_layout" name="Portal layout: Issues menu entry" inherit_id="website_project_issue.portal_layout" priority="30">
            <xpath expr="//li[a[@href='/my/issues']]" position="attributes">
                <attribute name="style">display: none;</attribute>
            </xpath>
        </template>

        <template id="portal_my_home" name="Portal My Home: Issue entries" inherit_id="website_project_issue.portal_my_home" priority="30">
                <xpath expr="//h3[a[@href='/my/issues']]" position="attributes">
                    <attribute name="style">display: none;</attribute>
                </xpath>
        </template>
    </data>
</odoo>