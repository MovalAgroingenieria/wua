<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_invoicing_config_settings_view_form" model="ir.ui.view">
        <field name="name">Parameters</field>
        <field name="model">wua.invoicing.configuration</field>
        <field name="inherit_id"
               ref="base_wua_invoicing.wua_invoicing_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='default_invoiceset_code_type']/ancestor::group"
                   position="after">
                <group name="params_categ_07"
                       string="Invoicing of Pressurized Irrigation">
                    <field name="invoicing_based_on_wc"
                           string="Based on Water Con."/>
                    <field name ="print_consumption_section"/>
                    <field name="group_wc_lines_on_report"
                           attrs="{'invisible': [('invoicing_based_on_wc', '=', True)]}"/>
                    <field name="apply_min_consumption_threshold_per_wc"/>
                    <field name="min_consumption_threshold_per_wc"
                           attrs="{'invisible': [('apply_min_consumption_threshold_per_wc', '=', False)]}"/>

                </group>
            </xpath>
            <xpath expr="//field[@name='group_detail_lines_of_wc_if_same_payer']"
                   position="after">
                    <field name="separate_wc_invoices"/>
            </xpath>
        </field>
    </record>

</odoo>