<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_presconsumption_view_form" model="ir.ui.view">
        <field name="name">Consumptions (form view)</field>
        <field name="model">wua.presconsumption</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation.wua_presconsumption_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='adjustement_volume']"
                   position="attributes">
                <attribute name="attrs">
                    {'readonly':[('invoiced_consumption','=',True)]}
                </attribute>
            </xpath>
            <xpath expr="//field[@name='reading_id']"
             position="after">
                <field name="product_id" readonly="1"/>
                <field name="invoiceset_id" readonly="1"/>
                <field name="invoiced_consumption" invisible="1"/>
            </xpath>
        </field>
    </record>

    <record id="wua_presconsumption_view_search" model="ir.ui.view">
        <field name="name">Consumptions (search view)</field>
        <field name="model">wua.presconsumption</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation.wua_presconsumption_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='hydraulicsector_id']" position="after">
                <field name="product_id"/>
                <field name="invoiceset_id"/>
            </xpath>
            <xpath expr="//filter[@name='withadjustement']" position="after">
                <separator/>
                <filter string="Invoiced" name="invoiced"
                 domain="[('invoiced_consumption','=',True)]"/>
                <filter string="Not invoiced" name="notinvoiced"
                 domain="[('invoiced_consumption','!=',True)]"/>
            </xpath>
            <xpath expr="//filter[@name='hydraulicsector']" position="before">
                <filter string="Water Type" name="product"
                 context="{'group_by':'product_id'}"/>
            </xpath>
            <xpath expr="//filter[@name='waterconnection']" position="after">
                <filter string="Invoice Set" name="invoiceset"
                 context="{'group_by':'invoiceset_id'}"/>
            </xpath>
            <xpath expr="//filter[@name='readingendtime']" position="after">
                <filter string="Invoiced (Yes/No)" name="invoicedgroup"
                 context="{'group_by':'invoiced_consumption'}"/>
            </xpath>
        </field>
    </record>

    <record id="wua_set_presconsumption_as_invoiced" model="ir.actions.server">
        <field name="name">Set as invoiced</field>
        <field name="model_id" ref="model_wua_presconsumption"/>
        <field name="state">code</field>
        <field name="code">
            if context.get('active_ids'):
                action = env['wua.presconsumption'].browse(context['active_ids']).set_as_invoiced()
        </field>
    </record>

    <record id="wua_action_set_presconsumption_as_invoiced" model="ir.values">
        <field name="name">Set consumption as invoiced</field>
        <field name="model">wua.presconsumption</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('wua_set_presconsumption_as_invoiced'))"/>
        <field name="groups_id" eval="[(4, ref('base_wua.group_wua_user'))]"/>
    </record>

    <record id="wua_set_presconsumption_as_not_invoiced" model="ir.actions.server">
        <field name="name">Set as not invoiced</field>
        <field name="model_id" ref="model_wua_presconsumption"/>
        <field name="state">code</field>
        <field name="code">
            if context.get('active_ids'):
                action = env['wua.presconsumption'].browse(context['active_ids']).set_as_not_invoiced()
        </field>
    </record>

    <record id="wua_action_set_presconsumption_as_not_invoiced" model="ir.values">
        <field name="name">Set consumption as not invoiced</field>
        <field name="model">wua.presconsumption</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('wua_set_presconsumption_as_not_invoiced'))"/>
        <field name="groups_id" eval="[(4, ref('base_wua.group_wua_user'))]"/>
    </record>

</odoo>