<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_invoice_document" inherit_id="account.report_invoice_document">
        <xpath expr="//div[@name='details_section']" position="after">
            <t t-set="with_presconsumptions" t-value="False"/>
            <t t-set="is_based_on_wc" t-value="o.sudo()._is_invoicing_based_on_wc()"/>
            <t t-foreach="o.invoice_line_ids" t-as="l">
                <t t-if="l.categ_id.productcategory_code == 7">
                    <t t-set="with_presconsumptions" t-value="True"/>
                </t>
            </t>
            <t t-if="with_presconsumptions">
                <t t-set="consumptions"
                   t-value="o.sudo()._get_presconsumptions_from_lines(o.invoice_line_ids)"/>
                <t t-if="consumptions">
                    <t t-if="not is_based_on_wc">
                      <p style="page-break-after:always;"></p>
                    </t>
                    <div name="consumptions">
                        <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                            <t t-if="report_style == 'light'">
                                <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                    <div style="float: left; wc_idth: 32px;"><span class="fa fa-moval-irrigation"/></div>
                                    <div style="float: left; display: inline;"><strong>Consumptions</strong></div>
                               </div>
                            </t>
                            <t t-else="">
                                <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                    <div style="float: left; wc_idth: 32px;"><span class="fa fa-moval-irrigation"/></div>
                                    <div style="float: left; display: inline;"><strong>Consumptions</strong></div>
                                </div>
                            </t>
                        </div>
                        <div class="row" style="margin: 4 8px;">
                            <table class="table table-condensed">
                                <thead>
                                    <tr>
                                      <t t-if="is_based_on_wc">
                                        <th style="wc_idth: 15%;">Water Connection</th>
                                        <th name= "th_watermeter_based_on_wc" style="wc_idth: 16%;">Water Meter</th>
                                        <th id="th-initial-time-date-label">Initial time date</th>
                                        <th id="th-final-time-date-label">Final time date</th>
                                        <th class="text-right">Initial Reading</th>
                                        <th class="text-right">Final Reading</th>
                                        <th class="text-right">Gross Vol. (m3)</th>
                                        <th class="text-right">Adjust. (m3)</th>
                                        <th class="text-right">Real Vol. (m3)</th>
                                      </t>
                                      <t t-else="">
                                        <th id="th-water-connection-label">Water Connection</th>
                                        <th name= "th_watermeter">Water Meter</th>
                                        <th id="th-initial-time-label">Initial time</th>
                                        <th id="th-final-time-label">Final time</th>
                                        <th class="text-right">Initial Reading</th>
                                        <th class="text-right">Final Reading</th>
                                        <th class="text-right">Gross Vol. (m3)</th>
                                        <th class="text-right">Adjust. (m3)</th>
                                        <th class="text-right">Real Vol. (m3)</th>
                                      </t>
                                    </tr>
                                </thead>
                                <tbody class="invoice_tbody">
                                    <t t-if="is_based_on_wc">
                                      <!-- waterconnection group, dont need do much info-->
                                      <tr t-foreach="consumptions" t-as="c">
                                        <t t-set="reading_initial_time"
                                           t-value="context_timestamp(
                                               datetime.datetime.strptime(
                                               c['reading_initial_time'],'%Y-%m-%d %H:%M:%S')).
                                               strftime('%d/%m/%y')"/>
                                          <t t-set="reading_end_time"
                                           t-value="context_timestamp(
                                               datetime.datetime.strptime(
                                               c['reading_end_time'],'%Y-%m-%d %H:%M:%S')).
                                               strftime('%d/%m/%y')"/>
                                          <t t-set="initial_volume_rounded"
                                           t-value="int(round(c['initial_volume']))"/>
                                          <t t-set="end_volume_rounded"
                                           t-value="int(round(c['end_volume']))"/>
                                          <t t-set="adjustement_volume_rounded"
                                           t-value="int(round(c['adjustement_volume']))"/>
                                          <t t-set="total_volume_rounded"
                                             t-value="end_volume_rounded - initial_volume_rounded"/>
                                          <t t-set="real_volume_rounded"
                                           t-value="total_volume_rounded + adjustement_volume_rounded"/>
                                          <td>
                                              <span t-esc="c['waterconnection']"/>
                                          </td>
                                          <td name= "td_watermeter_based_on_wc">
                                              <span t-esc="c['watermeter']"/>
                                          </td>
                                          <td>
                                              <span t-esc="reading_initial_time"/>
                                          </td>
                                          <td>
                                              <span t-esc="reading_end_time"/>
                                          </td>
                                          <td class="text-right">
                                              <span t-esc="initial_volume_rounded"/>
                                          </td>
                                          <td class="text-right">
                                              <span t-esc="end_volume_rounded"/>
                                          </td>
                                          <td class="text-right">
                                              <span t-esc="total_volume_rounded"/>
                                          </td>
                                          <td class="text-right">
                                              <span t-esc="adjustement_volume_rounded"/>
                                          </td>
                                          <td class="text-right">
                                              <span t-esc="real_volume_rounded"/>
                                          </td>
                                      </tr>
                                    </t>
                                    <t t-else="">
                                      <tr t-foreach="consumptions" t-as="c">
                                          <t t-set="reading_initial_time"
                                           t-value="context_timestamp(
                                               datetime.datetime.strptime(
                                               c['reading_initial_time'],'%Y-%m-%d %H:%M:%S')).
                                               strftime('%d/%m/%y, %H:%M')"/>
                                          <t t-set="reading_end_time"
                                           t-value="context_timestamp(
                                               datetime.datetime.strptime(
                                               c['reading_end_time'],'%Y-%m-%d %H:%M:%S')).
                                               strftime('%d/%m/%y, %H:%M')"/>
                                          <td id="td-water-connection-value">
                                              <span t-esc="c['waterconnection']"/>
                                          </td>
                                          <td name= "td_watermeter">
                                              <span t-esc="c['watermeter']"/>
                                          </td>
                                          <td id="td-reading-initial-time-value">
                                              <span t-esc="reading_initial_time"/>
                                          </td>
                                          <td id="td-reading-end-time-value">
                                              <span t-esc="reading_end_time"/>
                                          </td>
                                          <td id="td-initial-volume-value" class="text-right">
                                              <span t-esc="'{:.3f}'.format(c['initial_volume']).replace('.','%').replace(',','.').replace('%',',')"/>
                                          </td>
                                          <td id="td-end-volume-value" class="text-right">
                                              <span t-esc="'{:.3f}'.format(c['end_volume']).replace('.','%').replace(',','.').replace('%',',')"/>
                                          </td>
                                          <td id="td-volume-value" class="text-right">
                                              <span t-esc="'{:.3f}'.format(c['volume']).replace('.','%').replace(',','.').replace('%',',')"/>
                                          </td>
                                          <td id="td-adjustement-volume-value" class="text-right">
                                              <span t-esc="'{:.3f}'.format(c['adjustement_volume']).replace('.','%').replace(',','.').replace('%',',')"/>
                                          </td>
                                          <td id="td-volume-real-value" class="text-right">
                                              <span t-esc="'{:.3f}'.format(c['volume_real']).replace('.','%').replace(',','.').replace('%',',')"/>
                                          </td>
                                      </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </t>
            </t>
        </xpath>

        <!-- Group consumptions by waterconnection whne not invoicing_based_on_wc -->
        <xpath expr="//tbody[@name='invoice_line_body']/t[@name='t-set-invoice-lines']" position="after">
            <t t-if="not o._is_invoicing_based_on_wc() and o._must_group_wc_lines_on_report()">
                <t t-set="group_lines" t-value="[]"/>
                <t t-set="other_lines" t-value="[]"/>
                <t t-foreach="o.invoice_line_ids" t-as="l">
                    <t t-if="l['product_id'].categ_id.productcategory_code == 7">
                        <t t-set="group_lines" t-value="group_lines + [l]"/>
                        </t>
                    <t t-else="">
                        <t t-set="other_lines" t-value="other_lines + [l]"/>
                    </t>
                </t>
                <t t-set="grouped_by_wc" t-value="{}"/>
                <t t-foreach="group_lines" t-as="l">
                    <t t-set="wc_id" t-value="l['waterconnection_id'].id"/>
                    <t t-set="product_id" t-value="l['product_id'].id"/>
                    <t t-set="key_str" t-value="str(wc_id) + '_' + str(product_id)"/>
                    <t t-if="key_str in grouped_by_wc">
                        <t t-set="prev" t-value="grouped_by_wc[key_str]"/>
                        <t t-set="updated_entry" t-value="{
                            key_str: {
                                'quantity': prev['quantity'] + l['quantity'],
                                'amount': prev['amount'] + l['price_subtotal'],
                                'uom': l['uom_id'],
                                'product_id': l['product_id'],
                                'waterconnection_id': l['waterconnection_id'],
                                'price_unit': l['price_unit'],
                                'discount': l['discount'],
                                'invoice_line_tax_ids': l['invoice_line_tax_ids'],
                                'currency_id': l['currency_id'],
                                'origin': l['origin'],
                            }
                        }"/>
                        <t t-set="grouped_by_wc" t-value="dict(list(grouped_by_wc.items()) + list(updated_entry.items()))"/>
                    </t>
                    <t t-else="">
                        <t t-set="new_entry" t-value="{
                            key_str: {
                                'quantity': l['quantity'],
                                'amount': l['price_subtotal'],
                                'uom': l['uom_id'],
                                'product_id': l['product_id'],
                                'waterconnection_id': l['waterconnection_id'],
                                'price_unit': l['price_unit'],
                                'discount': l['discount'],
                                'invoice_line_tax_ids': l['invoice_line_tax_ids'],
                                'currency_id': l['currency_id'],
                                'origin': l['origin'],
                            }
                        }"/>
                        <t t-set="grouped_by_wc" t-value="dict(list(grouped_by_wc.items()) + list(new_entry.items()))"/>
                    </t>
                </t>
                <t t-set="grouped_wc_lines" t-value="[]"/>
                <t t-foreach="grouped_by_wc.values()" t-as="grp">
                    <t t-set="line_name" t-value="o._get_grouped_wc_description_for_report(grp['waterconnection_id'], grp['quantity'])"/>
                    <t t-set="grouped_wc_lines" t-value="grouped_wc_lines + [{
                    'product_id': grp['product_id'],
                    'name': line_name,
                    'origin': grp['origin'],
                    'quantity': grp['quantity'],
                    'price_unit': grp['price_unit'],
                    'uom_id': grp['uom'],
                    'discount': grp['discount'],
                    'invoice_line_tax_ids': grp['invoice_line_tax_ids'],
                    'price_subtotal': grp['amount'],
                    'currency_id': grp['currency_id'],
                    }]"/>
                </t>
                <t t-set="invoice_line_ids" t-value="grouped_wc_lines + other_lines"/>
            </t>
        </xpath>
    </template>

</odoo>
