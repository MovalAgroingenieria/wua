<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wizard_remove_readings_view_form" model="ir.ui.view">
        <field name="name">Wizard to delete meter readings</field>
        <field name="model">wizard.remove.readings</field>
        <field name="arch" type="xml">
            <form string="Delete meter readings">
                <script>
                    $(document).ready(function(){
                        $('.modal-dialog').css({'width': '450px'});
                        $('.modal-dialog').css({'height': '420px'});
                    });
                </script>
                <group name="body">
                    <field name="initial_date"/>
                    <field name="end_date"/>
                    <field name="num_readings_to_delete"/>
                </group>
                <div>
                    NOTE: The date range must include the last reading.
                </div>
                <footer>
                    <button name="get_delete_period"
                            type="object"
                            string="Delete"
                            class="btn-primary"/>
                    <button string="Cancel"
                            class="btn-default"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <act_window id="action_delete_readings"
        name="Delete readings"
        res_model="wizard.remove.readings"
        src_model="wua.reading"
        view_mode="form"
        target="new"
        groups="base_wua.group_wua_manager"/>

</odoo>