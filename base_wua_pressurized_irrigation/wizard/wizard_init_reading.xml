<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="wizard_init_reading_form_view" model="ir.ui.view">
        <field name="name">wizard.init.reading.form</field>
        <field name="model">wizard.init.reading</field>
        <field name="arch" type="xml">
            <form string="Initialize Reading">
                <group>
                    <field name="date_change" required="1"/>
                    <field name="final_reading" required="1"/>
                    <field name="initial_reading" required="1"/>
                    <field name="notes"/>
                </group>
                <footer>
                    <button name="action_generate_init_readings"
                            string="Confirm"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            class="btn-default"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>