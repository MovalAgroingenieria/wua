<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_waterconnection_irrigation_shift_view_form" model="ir.ui.view">
        <field name="name">Irrigation Shift (form view)</field>
        <field name="model">wua.waterconnection.irrigation.shift</field>
        <field name="arch" type="xml">
            <form duplicate="0">
                <header>
                </header>
                <field name="id" invisible="1"/>
                <sheet>
                    <div name="buttons" class="oe_button_box">
                        <button name="action_see_waterconnections"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-moval-water-counter"
                        groups="base_wua.group_wua_user,
                                base_wua.group_wua_portal_user">
                        <div class="o_form_field o_stat_info">
                            <span class="o_stat_text">Waterconnections</span>
                        </div>
                </button>
                    </div>
                    <group name="master_data">
                        <group name="master_data_left">
                            <field name="name"/>
                        </group>
                        <group name="master_data_right">
                            <field name="description"/>
                        </group>
                    </group>
                    <group name="slave_data">
                        <notebook name="slave_data_notebook">
                            <page name="notes_page" string="Notes">
                                <field name="notes"/>
                            </page>
                        </notebook>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="wua_waterconnection_irrigation_shift_view_tree" model="ir.ui.view">
        <field name="name">Irrigation Shift (tree view)</field>
        <field name="model">wua.waterconnection.irrigation.shift</field>
        <field name="arch" type="xml">
            <tree
             class="o_base_wua_pressurized_irrigation_irrigation_shifts_view_tree">
                <field name="name"/>
                <field name="description"/>
                <field name="notes" invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="wua_waterconnection_irrigation_shift_view_search" model="ir.ui.view">
        <field name="name">Irrigation Shift (search view)</field>
        <field name="model">wua.waterconnection.irrigation.shift</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="description"/>
            </search>
        </field>
    </record>

    <record id="wua_waterconnection_irrigation_shift_action" model="ir.actions.act_window">
        <field name="name">Irrigation Shift</field>
        <field name="res_model">wua.waterconnection.irrigation.shift</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="wua_waterconnection_irrigation_shift_view_tree"/>
        <field name="search_view_id" ref="wua_waterconnection_irrigation_shift_view_search"/>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to add a new Irrigation Shift.
            </p>
        </field>
    </record>

    <menuitem id="wua_waterconnection_irrigation_shift_menu"
              name="Irrigation Shifts"
              parent="wua_structure_irrigation.base_wua_irrigation_configuration_menu"
              action="wua_waterconnection_irrigation_shift_action"
              sequence="2"/>

</odoo>
