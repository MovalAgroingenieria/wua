<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_partner_waterconnection_view_tree" model="ir.ui.view">
        <field name="name">Partner Waterconnections (tree view)</field>
        <field name="model">res.partner.waterconnection</field>
        <field name="inherit_id" ref="base_wua_infrastructure.res_partner_waterconnection_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="class">o_base_wua_pressurized_irrigation_res_partner_waterconnection_view_tree</attribute>
            </xpath>
            <xpath expr="//field[@name='waterconnection_id']" position="after">
                <field name="watermeter_id"/>
                <field name="last_reading_time"/>
                <field name="last_reading_value"/>
                <field name="volume_real"/>
            </xpath>
        </field>
    </record>

    <record id="res_partner_waterconnection_view_kanban" model="ir.ui.view">
        <field name="name">Partner Waterconnections (kanban view)</field>
        <field name="model">res.partner.waterconnection</field>
        <field name="inherit_id" ref="base_wua_infrastructure.res_partner_waterconnection_view_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='partner_div']" position="after">
                <div name="watermeter_div" t-if="record.watermeter_id" style="white-space:nowrap; max-width: 94%;">
                    <a name="action_show_watermeter_id" type="object">
                        <span class="fa fa-moval-flowmeter" title="Watermeter"/>
                        <field name="watermeter_id"/>
                    </a>
                </div>
                <div name="last_reading_time_div" t-if="record.last_reading_time" style="white-space:nowrap; max-width: 94%;">
                    <span class="fa fa-calendar-check-o" title="Last Reading Time"/>
                    <field name="last_reading_time"/>
                </div>
                <div name="last_reading_value_div" t-if="record.last_reading_value" style="white-space:nowrap; max-width: 94%;">
                    <span class="fa fa-list" title="Last Reading Value"/>
                    <field name="last_reading_value"/>
                    <span> (m³)</span>
                </div>
                <div name="volume_real_div" t-if="record.volume_real" style="white-space:nowrap; max-width: 94%;">
                    <span class="fa fa-moval-irrigation" title="Consumption"/>
                    <field name="volume_real"/>
                    <span> (m³)</span>
                </div>
            </xpath>
        </field>
    </record>

</odoo>
