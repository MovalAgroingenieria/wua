<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_edit_parcel_irrigationpointwc_view_tree" model="ir.ui.view">
        <field name="name">Irrigation Points (WC)</field>
        <field name="model">wua.parcel.irrigationpointwc</field>
        <field name="inherit_id" ref="base_wua_infrastructure.wua_edit_parcel_irrigationpointwc_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="class">
                    o_base_wua_infrastructure_parcel_irrigationpointwc_pi_view_tree
                </attribute>
            </xpath>
            <xpath expr="//field[@name='waterconnection_id']" position="after">
                <field name="watermeter_id"/>
            </xpath>
        </field>
    </record>
    <record id="wua_parcel_view_tree" model="ir.ui.view">
        <field name="name">Wua Parcel (Tree view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id" ref="base_wua_infrastructure.wua_parcel_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="inside">
                <field name="zone_id" invisible="1"/>
            </xpath>
        </field>
    </record>

    <record id="wua_parcel_view_search" model="ir.ui.view">
        <field name="name">Wua Parcel (Search view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id" ref="base_wua_infrastructure.wua_parcel_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <field name="zone_id" string="Zone" filter_domain="[]"/>
                <group expand="1" string="Group By">
                    <filter string="Zone" name="zone" context="{'group_by':'zone_id'}"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>