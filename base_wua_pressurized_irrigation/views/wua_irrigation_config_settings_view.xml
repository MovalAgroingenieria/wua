<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_irrigation_config_settings_view_form" model="ir.ui.view">
        <field name="name">Parameters</field>
        <field name="model">wua.irrigation.configuration</field>
        <field name="inherit_id"
               ref="wua_structure_irrigation.wua_irrigation_config_settings_view_form"/>
        <field name="arch" type="xml">
          <xpath expr="//field[@name='default_watermeter_type']"
                 position="after">
            <field name="show_volume_perunitareaandday"/>
            <field name="number_of_presconsumptions_for_average"/>
            <field name="threshold_pressure"/>
          </xpath>
          <xpath expr="//group[@name='pres_irrig']"
                 position="after">
              <group name="irrigation_event" string="Irrigation Events">
                  <field name="normal_irrigation_flow_per_surface"/>
                  <field name="excess_irrigation_percentage"/>
                  <field name="lack_irrigation_percentage"/>
              </group>
            </xpath>
        </field>
    </record>

</odoo>
