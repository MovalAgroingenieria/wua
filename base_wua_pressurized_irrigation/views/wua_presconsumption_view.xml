<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_presconsumption_view_form" model="ir.ui.view">
        <field name="name">Consumptions (form view)</field>
        <field name="model">wua.presconsumption</field>
        <field name="arch" type="xml">
            <form create="0" delete="0" duplicate="0">
                <field name="cancelled" invisible="1"/>
                <header>
                    <button name="change_to_active"
                        type="object" string="Set as Active"
                        groups="base_wua.group_wua_manager"
                        attrs="{'invisible': [('cancelled','=',False)]}"/>
                    <button name="change_to_cancelled"
                        type="object" string="Set As Anulled"
                        groups="base_wua.group_wua_manager"
                        attrs="{'invisible': [('cancelled', '=', True)]}"/>
                    <div name="consumption_cancelled"
                         style="display: inline-block;color:red;padding-top: 5px;padding-bottom: 5px;padding-left: 10px;"
                         attrs="{'invisible':[('cancelled','=',False)]}">
                         ( ANULLED )
                    </div>
                </header>
                <sheet>
                    <div name="buttons" class="oe_button_box">
                    </div>
                    <group name="master_data">
                        <group name="master_data_left">
                            <field name="reading_initial_time"/>
                            <field name="initial_volume"/>
                            <field name="reading_end_time"/>
                            <field name="end_volume"/>
                            <field name="volume"/>
                            <field name="adjustement_volume"/>
                            <field name="volume_real"/>
                            <field name="volume_perunitarea"/>
                            <field name="volume_perunitareaandday"/>
                        </group>
                        <group name="master_data_right">
                            <field name="watermeter_id"/>
                            <field name="waterconnection_id"/>
                            <field name="irrigationshed_id"/>
                            <field name="hydraulicsector_id"/>
                            <field name="reading_id"/>
                            <field name="validated"/>
                        </group>
                    </group>
                    <group name="slave_data">
                        <notebook name="slave_data_notebook">
                            <page name="notes_page" string="Notes">
                                <field name="notes"/>
                            </page>
                        </notebook>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="wua_presconsumption_view_tree" model="ir.ui.view">
        <field name="name">Consumptions (tree view)</field>
        <field name="model">wua.presconsumption</field>
        <field name="arch" type="xml">
            <tree create="0" delete="0" duplicate="0"
             class="o_base_wua_pressurized_irrigation_consumptions_view_tree">
                <field name="waterconnection_id"/>
                <field name="watermeter_id"/>
                <field name="reading_initial_time"/>
                <field name="reading_end_time"/>
                <field name="volume"/>
                <field name="adjustement_volume"/>
                <field name="volume_real"/>
                <field name="volume_perunitarea"/>
                <field name="volume_perunitareaandday"/>
                <field name="reading_id"/>
                <field name="validated" string="Valid consumption"/>
            </tree>
        </field>
    </record>

    <record id="wua_technical_presconsumption_view_tree" model="ir.ui.view">
        <field name="name">Consumptions (tree view)</field>
        <field name="model">wua.presconsumption</field>
        <field name="arch" type="xml">
            <tree class="o_base_wua_pressurized_irrigation_consumptions_view_tree">
                <field name="waterconnection_id"/>
                <field name="watermeter_id"/>
                <field name="reading_initial_time"/>
                <field name="reading_end_time"/>
                <field name="volume"/>
                <field name="adjustement_volume"/>
                <field name="volume_real"/>
                <field name="reading_id"/>
                <field name="validated" string="Valid consumption"/>
            </tree>
        </field>
    </record>

    <record id="wua_presconsumption_view_search" model="ir.ui.view">
        <field name="name">Consumptions (search view)</field>
        <field name="model">wua.presconsumption</field>
        <field name="arch" type="xml">
            <search>
                <field name="waterconnection_id"/>
                <field name="watermeter_id"/>
                <field name="irrigationshed_id"/>
                <field name="hydraulicsector_id"/>
                <field name="agriculturalseason_id"/>
                <filter string="With adjustement" name="withadjustement"
                 domain="[('adjustement_volume','!=',0)]"/>
                <separator/>
                <filter string="Validated Consumption: Yes" name="isvalidatedyes"
                 domain="[('validated','=',True)]"/>
                <filter string="Validated Consumption: No" name="isvalidatedno"
                 domain="[('validated','=',False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Agricultural Season"
                     name="agriculturalseason"
                     context="{'group_by':'agriculturalseason_id'}"/>
                    <filter string="Hydraulic Sector"
                     name="hydraulicsector"
                     context="{'group_by':'hydraulicsector_id'}"/>
                    <filter string="Irrigation Shed"
                     name="irrigationshed"
                     context="{'group_by':'irrigationshed_id'}"/>
                    <filter string="Water Connection"
                     name="waterconnection"
                     context="{'group_by':'waterconnection_id'}"/>
                    <filter string="Reading Date"
                     name="readingendtime"
                     context="{'group_by':'reading_end_time:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="wua_presconsumption_one_waterconnection_view_tree" model="ir.ui.view">
        <field name="name">Consumptions (tree view)</field>
        <field name="model">wua.presconsumption</field>
        <field name="arch" type="xml">
            <tree create="0" delete="0" duplicate="0"
             class="o_base_wua_pressurized_irrigation_consumptions_one_waterconnection_view_tree">
                <field name="reading_initial_time"/>
                <field name="reading_end_time"/>
                <field name="volume"/>
                <field name="adjustement_volume"/>
                <field name="volume_real"/>
                <field name="reading_id"/>
                <field name="validated" string="Valid Consumption"/>
            </tree>
        </field>
    </record>

    <record id="wua_presconsumption_one_waterconnection_view_search" model="ir.ui.view">
        <field name="name">Consumptions (search view)</field>
        <field name="model">wua.presconsumption</field>
        <field name="arch" type="xml">
            <search>
                <field name="agriculturalseason_id"/>
                <filter string="With adjustement" name="withadjustement"
                 domain="[('adjustement_volume','!=',0)]"/>
                <separator/>
                <filter string="Validated Consumption: Yes" name="isvalidatedyes"
                 domain="[('validated','=',True)]"/>
                <filter string="Validated Consumption: No" name="isvalidatedno"
                 domain="[('validated','=',False)]"/>
                <group expand="0" string="Group By">
                  <filter string="Agricultural Season"
                    name="agriculturalseason"
                    context="{'group_by':'agriculturalseason_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="wua_presconsumption_view_graphic" model="ir.ui.view">
        <field name="name">Consumptions (graph view)</field>
        <field name="model">wua.presconsumption</field>
        <field name="arch" type="xml">
            <graph string="Pressure Consumptions" type="bar">
                <field name="hydraulicsector_id"/>
                <field name="volume_real" type='measure'/>
            </graph>
        </field>
    </record>

    <record id="wua_presconsumption_view_pivot" model="ir.ui.view">
        <field name="name">Pressurized Consumptions (pivot view)</field>
        <field name="model">wua.presconsumption</field>
        <field name="arch" type="xml">
            <pivot string="Agregated Values" display_quantity="true">
                <field name="volume" type="measure"/>
                <field name="adjustement_volume" type="measure"/>
                <field name="volume_real" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="wua_presconsumption_action" model="ir.actions.act_window">
        <field name="name">Consumptions</field>
        <field name="res_model">wua.presconsumption</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form,graph,pivot</field>
        <field name="view_id" ref="wua_presconsumption_view_tree"/>
        <field name="search_view_id" ref="wua_presconsumption_view_search"/>
        <field name="context">{'search_default_hydraulicsector': 0, 'search_default_readingendtime': 0}</field>
    </record>

    <record id="wua_technical_assign_agriculturalseason_to_consumptions_action"
            model="ir.actions.server">
        <field name="name">Assign agricultural seasons to pressurized consumptions</field>
        <field name="model_id" ref="base_wua_pressurized_irrigation.model_wua_presconsumption"/>
        <field name="code">action = env["wua.presconsumption"].action_assign_agriculturalseason_to_consumptions()</field>
    </record>

    <record id="wua_technical_presconsumptions_action" model="ir.actions.act_window">
        <field name="name">Consumptions (low-level)</field>
        <field name="res_model">wua.presconsumption</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="wua_technical_presconsumption_view_tree"/>
        <field name="search_view_id" ref="wua_presconsumption_view_search"/>
    </record>

    <menuitem id="wua_presconsumption_menu"
              name="Consumptions"
              parent="wua_structure_irrigation.base_wua_pressurized_irrigation_menu"
              action="wua_presconsumption_action"
              sequence="3"
              groups="base_wua.group_wua_user"/>

    <menuitem id="wua_technical_assign_agriculturalseason_to_consumptions_menu"
              name="Calculation: pres. consumptions"
              parent="wua_structure_irrigation.base_wua_irrigation_technical_menu"
              action="wua_technical_assign_agriculturalseason_to_consumptions_action"
              sequence="1"/>

    <menuitem id="wua_technical_presconsumptions_menu"
              name="Pressurized Consumptions"
              parent="wua_structure_irrigation.base_wua_irrigation_technical_menu"
              action="wua_technical_presconsumptions_action"
              sequence="2"/>

</odoo>
