<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_waterconnection_view_form" model="ir.ui.view">
        <field name="name">Water Connections (form view)</field>
        <field name="model">wua.waterconnection</field>
        <field name="inherit_id"
               ref="base_wua_infrastructure.wua_waterconnection_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='toggle_active']"
                   position="after">
                <field name='number_of_irrigation_schedules' invisible="1"/>
                <field name='number_of_irrigation_events' invisible="1"/>
                <field name="tertiarypipe_id" invisible="1"/>
                <button name="action_see_readings"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-list"
                        groups="base_wua.group_wua_user,
                                base_wua.group_wua_portal_user">
                        <div class="o_form_field o_stat_info">
                            <span class="o_stat_text">Readings</span>
                        </div>
                </button>
                <button name="action_see_presconsumptions"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-moval-irrigation"
                        groups="base_wua.group_wua_user">
                        <div class="o_form_field o_stat_info">
                            <span class="o_stat_text">Consumptions</span>
                        </div>
                </button>
                <button name="action_see_irrigation_schedules"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-calendar"
                        groups="base_wua.group_wua_user"
                        attrs="{'invisible':
                                [('number_of_irrigation_schedules','&lt;=',0),]}">
                        <div class="o_form_field o_stat_info">
                            <span class="o_stat_text">Schedules</span>
                        </div>
                </button>
                <button name="action_see_irrigation_events"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-history"
                        groups="base_wua.group_wua_user"
                        attrs="{'invisible':
                                [('number_of_irrigation_events','&lt;=',0),]}">
                        <div class="o_form_field o_stat_info"><span class="o_stat_text">
                            Irrigation
                        </span><span class="o_stat_text">
                            Events
                        </span></div>
                </button>
                <button name="action_see_tertiary_pipe"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-share-alt"
                        attrs="{'invisible': [('tertiarypipe_id', '=', False)]}">
                    <div class="o_form_field o_stat_info">
                        <span class="o_stat_text">Tertiary</span>
                        <span class="o_stat_text">Pipe</span>
                    </div>
                </button>
            </xpath>
            <xpath expr="//field[@name='total_affected_area_official']"
             position="after">
                <field name="watermeter_id"
                 domain="[('waterconnection_id','=',False),
                          ('state','=','active')]"
                 options="{'no_quick_create':True, 'no_create_edit':True}"/>
                <newline/>
                <field name="last_reading_time"/>
                <field name="average_consumption"/>
                <field name="estimated_monthly_consumption"/>
                <field name="last_reading_type"/>
                <newline/>
                <field name="last_reading_value"/>
                <newline/>
                <field name="last_reading_consumption" string="Last Reading (consumption)"/>
                <field name="waterconnection_state_id" string="State"
                 options="{'no_create': True, 'no_create_edit': True}"/>"
                <field name="is_state_close" invisible="1"/>
            </xpath>
            <xpath expr="//page[@name='parcels_page']" position="after">
                <page name="irrigation_shifts" string="Irrigation Shifts">
                <field name="irrigation_shift_ids">
                    <tree editable="bottom"
                        class="o_base_wua_parcel_partnerlink_view_tree_notebook">
                        <field name="irrigation_shift_id"/>
                        <field name="description" readonly="1"/>
                        <field name="notes" readonly="1"/>
                    </tree>
                </field>
                </page>
            </xpath>
            <xpath expr="//page[@name='parcels_page']" position="after">
                <page name="watermeters_page" string="Water Meters">
                    <field name="wcwm_ids">
                        <tree create="false" edit="false" delete="false"
                         class="o_base_wua_pressurized_irrigation_watermeters_view_tree_notebook">
                            <field name="assign_start"/>
                            <field name="assign_end"/>
                            <field name="watermeter_id"/>
                            <field name="type"/>
                            <field name="nominal_diameter"/>
                            <field name="nominal_water_flow"/>
                            <field name="pressure"/>
                            <field name="days" sum="Total"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="wua_waterconnection_view_tree" model="ir.ui.view">
        <field name="name">Water Connections (tree view)</field>
        <field name="model">wua.waterconnection</field>
        <field name="inherit_id"
               ref="base_wua_infrastructure.wua_waterconnection_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="class">o_base_wua_pressurized_irrigation_waterconnection_view_tree</attribute>
                <attribute name="colors">red:is_state_close==True</attribute>
            </xpath>
            <xpath expr="//field[@name='number_of_parcels']" position="after">
                <field name="number_of_irrigation_schedules" invisible="1"/>
                <field name="number_of_irrigation_events" invisible="1"/>
                <field name="watermeter_id"/>
                <button name="action_see_irrigation_schedules"
                        type="object" class="oe_stat_button"
                        string="Irrigation Schedules"
                        icon="fa-calendar"
                        attrs="{'invisible':
                                [('number_of_irrigation_schedules','=',0),]}"/>
                <button name="action_see_irrigation_events"
                        type="object" class="oe_stat_button"
                        string="Irrigation Events"
                        icon="fa-history"
                        attrs="{'invisible':
                                [('number_of_irrigation_events','=',0),]}">
                        <div class="o_form_field o_stat_info">
                            <span class="o_stat_text">
                                Irrigation
                            </span>
                            <span class="o_stat_text">
                                Events
                            </span>
                        </div>
                </button>
                <field name="last_reading_time" string="Last Reading (time)"/>
                <field name="last_reading_value" string="Last Reading (value)"/>
                <field name="last_reading_consumption" string="Last Reading (consumption)"/>
                <field name="average_consumption"/>
                <field name="estimated_monthly_consumption" invisible="1"/>
                <field name="last_reading_type"/>
                <field name="waterconnection_state_id" string="State"/>
                <field name="is_state_close" invisible="1"/>
            </xpath>
        </field>
    </record>

    <record id="wua_waterconnection_view_search" model="ir.ui.view">
        <field name="name">Water Connections (search view)</field>
        <field name="model">wua.waterconnection</field>
        <field name="inherit_id"
               ref="base_wua_infrastructure.wua_waterconnection_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='hydraulicsector_id']" position="after">
                <field name="watermeter_id"/>
                <filter string="With water meter" name="withwatermeter"
                 domain="[('with_watermeter','=',True)]"/>
                <filter string="Without water meter" name="withoutwatermeter"
                 domain="[('with_watermeter','=',False)]"/>
                <separator/>
                <filter string="Closed" name="closed"
                 domain="[('is_state_close','=',True)]"/>
                 <filter string="Is open" name="is_open"
                 domain="[('is_state_close','!=',True)]"/>
                <separator/>
                <filter string="Last Reading (type): Estimated" name="last_reading_type_estimated"
                    domain="[('last_reading_type','=','01_estimated')]"/>
                <filter string="Last Reading (type): Real Worker" name="last_reading_type_real_worker"
                    domain="[('last_reading_type','=','02_real_worker')]"/>
                <filter string="Last Reading (type): Real Partner" name="reading_real_partner"
                    domain="[('last_reading_type','=','03_real_partner')]"/>
            </xpath>
            <xpath expr="//search" position="inside">
                <field name="zone_id" string="Zone"/>
                <filter string="Last Reading (type)"
                    name="last_reading_type"
                    context="{'group_by':'last_reading_type'}"/>
                <group expand="1" string="Group By">
                    <filter string="Zone" name="zone" context="{'group_by':'zone_id'}"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="wua_technical_irrigationshiftlinks_view_tree" model="ir.ui.view">
        <field name="name">Irrigation Shifts Links(tree view)</field>
        <field name="model">wua.waterconnection.irrigation.shiftlink</field>
        <field name="arch" type="xml">
            <tree>
                <field name="waterconnection_id" />
                <field name="irrigation_shift_id" />
                <field name="description"/>
                <field name="notes"/>
            </tree>
        </field>
    </record>
    <record id="wua_technical_irrigationshiftlinks_view_search" model="ir.ui.view">
        <field name="name">Irrigation Shifts Links(tree view)</field>
        <field name="model">wua.waterconnection.irrigation.shiftlink</field>
        <field name="arch" type="xml">
            <search>
            </search>
        </field>
    </record>
    <record id="wua_technical_irrigation_shift_action" model="ir.actions.act_window">
        <field name="name">Water Shifts</field>
        <field name="res_model">wua.waterconnection.irrigation.shiftlink</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="wua_technical_irrigationshiftlinks_view_tree"/>
        <field name="search_view_id" ref="wua_technical_irrigationshiftlinks_view_search"/>
    </record>
    <menuitem id="menu_irrigation_shift"
              name="Irrigation Shifts" sequence="10"
              action="wua_technical_irrigation_shift_action"
              parent="base_wua_infrastructure.base_wua_infrastructure_technical_menu"/>

    <record id="wua_waterconnection_irrigation_shift_rel_view_tree" model="ir.ui.view">
        <field name="name">Irrigation Shifts Links(tree view)</field>
        <field name="model">wua.waterconnection.irrigation.shift.relation</field>
        <field name="arch" type="xml">
            <tree>
                <field name="waterconnection_id" />
                <field name="irrigation_shift_id" />
            </tree>
        </field>
    </record>
    <record id="wua_waterconnection_irrigation_shift_rel_view_search" model="ir.ui.view">
        <field name="name">Irrigation Shifts</field>
        <field name="model">wua.waterconnection.irrigation.shift.relation</field>
        <field name="arch" type="xml">
            <search>
            </search>
        </field>
    </record>
    <record id="wua_waterconnection_irrigation_shift_rel_action" model="ir.actions.act_window">
        <field name="name">Irrigation Shift</field>
        <field name="res_model">wua.waterconnection.irrigation.shift.relation</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="wua_waterconnection_irrigation_shift_rel_view_tree"/>
        <field name="search_view_id" ref="wua_waterconnection_irrigation_shift_rel_view_search"/>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to add a new Irrigation Shift.
            </p>
        </field>
    </record>
    <menuitem id="menu_irrigation_shift_technical"
              name="Irrigation Shifts Technical" sequence="10"
              action="wua_waterconnection_irrigation_shift_rel_action"
              parent="base_wua_infrastructure.base_wua_infrastructure_technical_menu"/>
</odoo>
