<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <report id="irrigation_distribution_report"
        string="Irrigation distribution report"
        model="wizard.irrigation.distribution.report"
        report_type="qweb-pdf"
        file="base_wua_irrigation_report.irrigation_distribution_report_report_document"
        name="base_wua_irrigation_report.irrigation_distribution_report_report_document"
        paperformat="base_wua_report.paperformat_wua_reports"/>

    <template id="irrigation_distribution_report_report_document">
        <t t-call="report.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="base_wua_report.wua_external_layout">
                    <div class="page">

                        <!-- Vars -->
                        <t t-set="report_style" t-value="o.env['ir.values'].get_default('wua.configuration', 'reports_style')"/>

                        <!-- Title -->
                        <div name="title" class="text-center">
                            <h4 style="margin-top:0px; padding-top:0px;">
                                <strong>Irrigation distribution report</strong>
                            </h4>
                        </div>

                        <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                            <t t-if="report_style == 'light'">
                                <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                    <div style="float: left; width: 32px;"><span class="fa fa-moval-file-irrigation"/></div>
                                    <div style="float: left; display: inline;"><strong>Irrigation&amp;nbsp;Reports</strong></div>
                            </div>
                            </t>
                            <t t-else="">
                                <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                    <div style="float: left; width: 32px;"><span class="fa fa-moval-file-irrigation"/></div>
                                    <div style="float: left; display: inline;"><strong>Irrigation&amp;nbsp;Reports</strong></div>
                                </div>
                            </t>
                        </div>
                        <t t-set="data_in_hours" t-value="o.env['ir.values'].get_default('wua.irrigation.configuration', 'data_in_hours')"/>
                        <t t-set="hours_sexagesimal" t-value="o.env['ir.values'].get_default('wua.irrigation.configuration', 'hours_sexagesimal')"/>
                        <div class="row" style="margin: 4 8px;">
                            <table class="table table-condensed">
                                <thead>
                                    <tr>
                                        <th name="th_report_number" class="text-center">Num.</th>
                                        <th name="th_wua_partner">Partner</th>
                                        <th name="th_parcel" class="text-center">Parcel</th>
                                        <th name="th_report_start_time" class="text-center">Start time</th>
                                        <th name="th_report_end_time" class="text-center">End time</th>
                                        <t t-if="data_in_hours">
                                            <t t-if="hours_sexagesimal">
                                                <th name="th_hours_sexagesimal" class="text-center">Hours</th>
                                            </t>
                                            <t t-else="">
                                                <th name="th_hours" class="text-right">Hours</th>
                                            </t>
                                        </t>
                                        <t t-else="">
                                            <th name="th_initial_volume" class="text-right">Initial Value (m³)</th>
                                            <th name="th_final_volume" class="text-right">Final Value (m³)</th>
                                        </t>
                                        <th name="th_volume_real" class="text-right">
                                            <span>Volume (m³)</span>
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="o.irrigationreport_ids" t-as="ir">
                                        <td name="td_report_number" class="text-center">
                                            <span t-field="ir.irrigationreport_number"/>
                                        </td>
                                        <td name="td_wua_partner">
                                            <span t-field="ir.partner_id.name"/>
                                        </td>
                                        <td name="td_parcel" class="text-center">
                                            <span t-field="ir.parcel_id"/>
                                        </td>
                                        <td name="td_report_start_time" class="text-center">
                                            <span t-field="ir.report_initial_time" t-options="{'format': 'dd/MM/YYYY'}"/>
                                            <b><span t-field="ir.report_initial_time" t-options="{'format': 'hh:mm'}"/></b>
                                        </td>
                                        <td name="td_report_end_time" class="text-center">
                                            <span t-field="ir.report_end_time" t-options="{'format': 'dd/MM/YYYY'}"/>
                                            <b><span t-field="ir.report_end_time" t-options="{'format': 'hh:mm'}"/></b>
                                        </td>
                                        <t t-if="data_in_hours">
                                            <t t-if="ir.hours">
                                                <t t-if="hours_sexagesimal">
                                                    <td name="td_hours_sexagesinal" class="text-center">
                                                        <span t-esc="'%02d:%02d' % (int(ir.hours), round(ir.hours % 1 * 60))"/>
                                                    </td>
                                                </t>
                                                <t t-else="">
                                                    <td name="td_hours" class="text-right">
                                                        <span t-field="ir.hours" t-options='{"widget": "float", "precision": 2}'/>
                                                    </td>
                                                </t>
                                             </t>
                                        </t>
                                        <t t-else="">
                                            <td name="td_initial_volume" class="text-right">
                                                <span t-field="ir.initial_volume"/>
                                            </td>
                                            <td name="td_final_volume" class="text-right">
                                                <span t-field="ir.end_volume"/>
                                            </td>
                                        </t>
                                        <td name="td_volume_real" class="text-right">
                                            <span t-field="ir.volume_real"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                    </div><!--end page -->
                </t>
            </t>
        </t>
    </template>

</odoo>
