<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="0">
        
        <record id="group_wua_irrigationreport_writer" model="res.groups">
            <field name="name">Manage irrigation reports</field>
            <field name="category_id"
                ref="base.module_category_hidden"/>
            <field name="implied_ids"
                eval="[(4, ref('base_wua.group_wua_user'))]"/>
        </record>

        <record id="base_wua_irrigation_report.base_wua_irrigation_report_menu" model="ir.ui.menu">
            <field name="groups_id"
                eval="[(4, ref('base_wua.group_wua_portal_user'))]"/>
        </record>

    </data>

    <data noupdate="0">
        
        <record id="rule_wua_irrigationreport_group_wua_portal_user" model="ir.rule">
            <field name="name">Rule for Wua Portal User on irrigation reports</field>
            <field name="model_id" ref="model_wua_irrigationreport"/>
            <field name="domain_force">
                ['|', ('partner_id','=',user.partner_id.id),
                      ('partner_id.child_ids','=',user.partner_id.id)]
            </field>
            <field name="groups" eval="[(4, ref('base_wua.group_wua_portal_user'))]"/>
        </record>

    </data>

</odoo>