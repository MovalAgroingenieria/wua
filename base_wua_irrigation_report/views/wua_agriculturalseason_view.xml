<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_agriculturalseason_view_form" model="ir.ui.view">
        <field name="name">Agricultural Seasons (form view)</field>
        <field name="model">wua.agriculturalseason</field>
        <field name="arch" type="xml">
            <form duplicate="0">
                <sheet>
                    <div name="buttons" class="oe_button_box">
                        <button name="action_see_irrigationreports"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-file"
                                groups="base_wua.group_wua_user"
                                attrs="{'invisible':[('num_irrigationreports_stat','=', 0)]}">
                                <div class="o_form_field o_stat_info">
                                    <span class="o_stat_value">
                                        <field name="num_irrigationreports_stat"/>
                                    </span>
                                    <span class="o_stat_text">
                                        reports
                                    </span>
                                </div>
                        </button>
                    </div>
                    <group name="master_data">
                        <group name="master_data_left">
                            <field name="initial_date"
                                   attrs="{'readonly':[('number_of_irrigationreports','>', 0)]}"/>
                            <field name="end_date"
                                   attrs="{'readonly':[('number_of_irrigationreports','>', 0)]}"/>
                            <field name="description"/>
                        </group>
                        <group name="master_data_right">
                            <field name="active_agriculturalseason"/>
                            <field name="number_of_irrigationreports"/>
                            <field name="total_volume"/>
                        </group>
                    </group>
                    <group name="slave_data">
                        <notebook name="slave_data_notebook">
                            <page name="notes_page" string="Notes">
                                <field name="notes"/>
                            </page>
                        </notebook>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="wua_agriculturalseason_view_tree" model="ir.ui.view">
        <field name="name">Agricultural Seasons (tree view)</field>
        <field name="model">wua.agriculturalseason</field>
        <field name="arch" type="xml">
            <tree class="o_base_wua_irrigationreport_agriculturalseason_view_tree">
                <field name="initial_date" string="Initial Date"/>
                <field name="end_date" string="End Date"/>
                <field name="description" string="Description"/>
                <field name="number_of_irrigationreports"/>
                <field name="total_volume"/>
                <field name="active_agriculturalseason"/>
            </tree>
        </field>
    </record>

    <record id="wua_agriculturalseason_view_search" model="ir.ui.view">
        <field name="name">Agricultural Seasons (search view)</field>
        <field name="model">wua.agriculturalseason</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Agricultural Season"/>
                <field name="description" string="Description"/>
                <filter name="active_agriculturalseason" string="Active Agricultural Season"
                    domain="[('active_agriculturalseason','=',True)]"/>
            </search>
        </field>
    </record>

    <!-- Window action -->
    <record id="base_wua_irrigationreport_agriculturalseason_action" model="ir.actions.act_window">
        <field name="name">Agricultural Seasons</field>
        <field name="res_model">wua.agriculturalseason</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids"
         eval="[(5, 0),
                (0, 0, {'view_mode': 'tree', 'view_id': ref('wua_agriculturalseason_view_tree')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('wua_agriculturalseason_view_form')})]"/>
        <field name="search_view_id" ref="wua_agriculturalseason_view_search"/>
    </record>

    <!-- Menu entry -->
    <menuitem name="Agricultural Seasons" id="wua_agriculturalseason_menu"
        parent="base_wua_irrigation_report_menu" sequence="1"
        action="base_wua_irrigationreport_agriculturalseason_action"/>

</odoo>