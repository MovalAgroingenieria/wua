<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_irrigation_config_settings_view_form" model="ir.ui.view">
        <field name="name">Parameters</field>
        <field name="model">wua.irrigation.configuration</field>
        <field name="inherit_id"
               ref="wua_structure_irrigation.wua_irrigation_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='watering_req']" position="after">
                <group name="irrig_reports" string="Irrigation Reports">
                    <field name="data_in_hours"/>
                    <field name="hours_sexagesimal"
                     attrs="{'invisible': [('data_in_hours','=',False)]}"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>