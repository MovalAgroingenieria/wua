<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_irrigationreport_view_form" model="ir.ui.view">
        <field name="name">Irrigation Reports (form view)</field>
        <field name="model">wua.irrigationreport</field>
        <field name="inherit_id" ref="base_wua_irrigation_report.wua_irrigationreport_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="is_field_irrigationreport" invisible="1"/>
                <field name="with_end_time" invisible="1"/>
                <field name="is_field_irrigationreport"
                    attrs="{'invisible':[('is_field_irrigationreport','=', False)]}"/>
                <field name="irrigationreport_writer_id"
                    attrs="{'invisible':[('is_field_irrigationreport','=', False)]}"/>
                <field name="irrigationshed_id"
                    attrs="{'invisible':[('irrigationshed_id', '=', False)]}"/>
                <field name="flowdivider_id"
                    attrs="{'invisible':['|', ('flowdivider_id', '=', False), ('is_field_irrigationreport','=', False)]}"/>
                <field name="irrigationgate_id"
                    attrs="{'invisible':['|', ('irrigationgate_id', '=', False), ('is_field_irrigationreport','=', False)]}"/>
            </xpath>
            <xpath expr="//page[@name='signature_page']" position="after">
                <page name="irrigationreport_img" string="Irrigationreport Image">
                    <group name="irrigationreport_img_group">
                        <field name="irrigationreport_img" widget="image" class="oe_img_259_160"/>
                    </group>
                </page>
            </xpath>
            <xpath expr="//field[@name='report_initial_time']" position="after">
                <div style="color: red;" attrs="{'invisible': [('with_end_time','=',True)]}" colspan="2">
                    <span>REPORT END DATE NOT SETTED</span>
                </div>
            </xpath>
            <xpath expr="//field[@name='intake_id']" position="attributes">
                <attribute name="attrs">{'readonly': ['|', ('state', '=', 'validated'), '&amp;', ('id', '>', 0), ('is_field_irrigationreport', '=', False)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='report_end_time']" position="attributes">
                <attribute name="attrs">{'invisible': [('with_end_time', '=', False)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='hours']" position="attributes">
                <attribute name="attrs">{'invisible': [('with_end_time', '=', False)],
                                         'readonly':[('invoiced','=', True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='volume']" position="attributes">
                <attribute name="attrs">{'invisible': [('with_end_time', '=', False)],
                                         'readonly': 1}</attribute>
            </xpath>
            <xpath expr="//field[@name='conversion_factor']" position="attributes">
                <attribute name="attrs">{'invisible': [('with_end_time', '=', False)],
                                         'readonly':[('invoiced','=', True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='adjustement_volume']" position="attributes">
                <attribute name="attrs">{'invisible': [('with_end_time', '=', False)],
                                         'readonly':[('invoiced','=', True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='volume_real']" position="attributes">
                <attribute name="attrs">{'invisible': [('with_end_time', '=', False)],
                                         'readonly': 1}</attribute>
            </xpath>
        </field>
    </record>

    <record id="wua_irrigationreport_view_search" model="ir.ui.view">
        <field name="name">Irrigation Reports (search view)</field>
        <field name="model">wua.irrigationreport</field>
        <field name="inherit_id" ref="base_wua_irrigation_report.wua_irrigationreport_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='parcel_id']" position="after">
                <field name="irrigationshed_id"/>
                <field name="flowdivider_id"/>
                <field name="irrigationgate_id"/>
            </xpath>
            <xpath expr="//filter[@name='state']" position="before">
                <filter name="is_field_irrigationreport_true" string="Is field irrigationreport: Yes"
                        domain="[('is_field_irrigationreport','=',True)]"/>
                <filter name="is_field_irrigationreport_false" string="Is field irrigationreport: No"
                        domain="[('is_field_irrigationreport','=',False)]"/>
                <separator/>
                <filter name="with_end_time_false" string="In progress"
                        domain="[('with_end_time','=',False)]"/>
                <separator/>
            </xpath>
            <xpath expr="//filter[@name='employee_id']" position="after">
                <filter name="irrigationshed_id"
                        string="Irrigationshed"
                        context="{'group_by':'irrigationshed_id'}"/>
                <filter name="flowdivider_id"
                        string="Flowdivider"
                        context="{'group_by':'flowdivider_id'}"/>
                <filter name="irrigationgate_id"
                        string="Irrigationgate"
                        context="{'group_by':'irrigationgate_id'}"/>
                <filter name="irrigationreport_writer_id"
                        string="Irrigationreport Writer"
                        context="{'group_by':'irrigationreport_writer_id'}"/>
            </xpath>
        </field>
    </record>

</odoo>
