<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_flowdivider_view_form" model="ir.ui.view">
        <field name="name">Flow Dividers (form view)</field>
        <field name="model">wua.flowdivider</field>
        <field name="inherit_id"
               ref="base_wua_infrastructure.wua_flowdivider_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='gis_viewer_y']" position="after">
                <field name="can_register_irrigationreport"/>
            </xpath>
        </field>
    </record>

     <record id="wua_flowdivider_view_search" model="ir.ui.view">
        <field name="name">Flow Dividers (search view)</field>
        <field name="model">wua.flowdivider</field>
        <field name="inherit_id" ref="base_wua_infrastructure.wua_flowdivider_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='irrigationditch_id']" position="after">
                <filter string="Register irrigationreport: Yes" name="register_irrigationreport_yes" domain="[('can_register_irrigationreport','=',True)]"/>
                <filter string="Register irrigationreport: No" name="register_irrigationreport_no" domain="[('can_register_irrigationreport','=',False)]"/>
            </xpath>
        </field>
    </record>

</odoo>
