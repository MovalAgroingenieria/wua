<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_irrigation_config_settings_view_form" model="ir.ui.view">
        <field name="name">Parameters</field>
        <field name="model">wua.irrigation.configuration</field>
        <field name="inherit_id"
               ref="base_wua_irrigation_report.wua_irrigation_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='hours_sexagesimal']" position="after">
                <field name="default_field_irrigationreport_intake_id" style="width:200px"/>
            </xpath>
        </field>
    </record>

</odoo>