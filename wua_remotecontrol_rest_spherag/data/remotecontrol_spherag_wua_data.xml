<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">

        <record id="remotecontrol_spherag_wua_action_import_infrastructure"
                model="remotecontrol.action">
            <field name="name">Spherag WUA: Import infrastructure</field>
            <field name="remote_id" ref="remotecontrol_spherag.remotecontrol_spherag"/>
            <field name="active">True</field>
            <field name="readonly">True</field>
            <field name="rate_limit_seconds">0.0</field>
            <field name="max_retries">1</field>
            <field name="backoff">1.0</field>
            <field name="code"><![CDATA[
attachment_id = bag.get('attachment_id')
if not attachment_id:
    raise Exception('Missing discovery attachment generated by previous step.')

attachment = env['ir.attachment'].browse(attachment_id)
if not attachment.exists():
    raise Exception('Discovery attachment not found.')

try:
    raw_json = base64.b64decode(attachment.datas or '')
    discovery_data = json.loads(raw_json)
except Exception as e:
    raise Exception('Error decoding Spherag discovery attachment: %s' % e)

result = env['wua.waterconnection'].import_from_spherag_discovery_json(
    discovery_data)

self.remote_id.message_post(
    body=u'[Spherag/WUA] sheds=%s waterconnections=%s watermeters=%s updates=%s skipped=%s' % (
        result.get('created_irrigationsheds', 0),
        result.get('created_waterconnections', 0),
        result.get('created_watermeters', 0),
        result.get('updated_waterconnections', 0),
        result.get('skipped_elements', 0)
    ),
    attachment_ids=[attachment.id]
)

bag['wua_import_result'] = result
bag['attachment_name'] = attachment.datas_fname or attachment.name or ''
            ]]></field>
        </record>

        <record id="remotecontrol_spherag_wua_procedure_import_infrastructure"
                model="remotecontrol.procedure">
            <field name="name">Spherag WUA: Import infrastructure</field>
            <field name="remote_id" ref="remotecontrol_spherag.remotecontrol_spherag"/>
            <field name="active">True</field>
            <field name="schedule_cron">False</field>
            <field name="readonly">True</field>
        </record>

        <record id="remotecontrol_spherag_wua_step_10_token"
                model="remotecontrol.step">
            <field name="name">Get Token</field>
            <field name="procedure_id"
                   ref="remotecontrol_spherag_wua_procedure_import_infrastructure"/>
            <field name="action_id"
                   ref="remotecontrol_spherag.remotecontrol_spherag_action_get_token"/>
            <field name="sequence">10</field>
        </record>

        <record id="remotecontrol_spherag_wua_step_20_discovery"
                model="remotecontrol.step">
            <field name="name">Fetch discovery catalog</field>
            <field name="procedure_id"
                   ref="remotecontrol_spherag_wua_procedure_import_infrastructure"/>
            <field name="action_id"
                   ref="remotecontrol_spherag.remotecontrol_spherag_action_import_devices"/>
            <field name="sequence">20</field>
        </record>

        <record id="remotecontrol_spherag_wua_step_30_import"
                model="remotecontrol.step">
            <field name="name">Create sheds, waterconnections and meters</field>
            <field name="procedure_id"
                   ref="remotecontrol_spherag_wua_procedure_import_infrastructure"/>
            <field name="action_id"
                   ref="remotecontrol_spherag_wua_action_import_infrastructure"/>
            <field name="sequence">30</field>
        </record>

    </data>

</odoo>