<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_remotecontrol_view_form_spherag" model="ir.ui.view">
        <field name="name">wua.remotecontrol.form.spherag</field>
        <field name="model">wua.remotecontrol</field>
        <field name="inherit_id"
               ref="base_wua_remotecontrol_rest.wua_remotecontrol_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_import_spherag_infrastructure"
                        string="Import Spherag Infrastructure"
                        type="object"
                        class="btn-primary"/>
            </xpath>
        </field>
    </record>

</odoo>