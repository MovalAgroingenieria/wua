<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_waterconnection_view_form" model="ir.ui.view">
        <field name="name">wua.waterconnection.form.spherag</field>
        <field name="model">wua.waterconnection</field>
        <field name="inherit_id" ref="base_wua_remotecontrol_rest.wua_waterconnection_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='telecontrol_associated']" position="after">
                <field name="spherag_flow_accumulated_element_id"
                       attrs="{'invisible': [('telecontrol_associated', '!=', 'spherag')],
                               'required': [('telecontrol_associated', '=', 'spherag')]}"/>
                  <field name="spherag_system_id"
                      attrs="{'invisible': [('telecontrol_associated', '!=', 'spherag')],
                           'required': [('telecontrol_associated', '=', 'spherag')]}"/>
                  <field name="spherag_imei"
                      attrs="{'invisible': [('telecontrol_associated', '!=', 'spherag')],
                           'required': [('telecontrol_associated', '=', 'spherag')]}"/>
                  <field name="spherag_flow_accumulated_chart_type_id"
                      attrs="{'invisible': [('telecontrol_associated', '!=', 'spherag')],
                           'required': [('telecontrol_associated', '=', 'spherag')]}"/>
                <field name="spherag_data"
                       attrs="{'invisible': [('telecontrol_associated', '!=', 'spherag')]}"/>
            </xpath>
        </field>
    </record>

</odoo>
