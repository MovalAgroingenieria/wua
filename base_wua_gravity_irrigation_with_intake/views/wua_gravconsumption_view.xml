<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="wua_gravconsumption_view_form" model="ir.ui.view">
      <field name="name">Gravity Consumptions (form view)</field>
      <field name="model">wua.gravconsumption</field>
      <field name="inherit_id" ref="base_wua_gravity_irrigation.wua_gravconsumption_view_form"/>
      <field name="arch" type="xml">
        <xpath expr="//field[@name='irrigationditch_id']" position="after">
          <field name="intake_id"/>
        </xpath>
      </field>
  </record>

  <record id="wua_gravconsumption_view_tree" model="ir.ui.view">
      <field name="name">Gravity Consumptions (tree view)</field>
      <field name="model">wua.gravconsumption</field>
      <field name="inherit_id" ref="base_wua_gravity_irrigation.wua_gravconsumption_view_tree"/>
      <field name="arch" type="xml">
        <xpath expr="//field[@name='watering_id']" position="before">
          <field name="intake_id"/>
        </xpath>
      </field>
  </record>

  <record id="wua_gravconsumption_view_search" model="ir.ui.view">
      <field name="name">Gravity Consumptions (search view)</field>
      <field name="model">wua.gravconsumption</field>
      <field name="inherit_id" ref="base_wua_gravity_irrigation.wua_gravconsumption_view_search"/>
      <field name="arch" type="xml">
            <xpath expr="//field[@name='subparcel_id']" position="after">
              <field name="intake_id"/>
            </xpath>
            <xpath expr="//filter[@name='agriculturalseason']" position="after">
              <filter string="Intake"
               name="intake"
               context="{'group_by':'intake_id'}"/>
            </xpath>
      </field>
  </record>


</odoo>
