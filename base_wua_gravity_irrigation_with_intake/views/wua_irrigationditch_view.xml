<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_irrigationditch_view_form" model="ir.ui.view">
        <field name="name">Irrigation Ditches (form view)</field>
        <field name="model">wua.irrigationditch</field>
        <field name="inherit_id"
               ref="base_wua_gravity_irrigation.wua_irrigationditch_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='number_of_parcels']"
                   position="before">
                <field name="intake_id"/>
            </xpath>
        </field>
    </record>

</odoo>
