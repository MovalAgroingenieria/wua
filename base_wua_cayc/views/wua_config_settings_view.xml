<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_config_settings_view_form" model="ir.ui.view">
        <field name="name">Parameters</field>
        <field name="model">wua.configuration</field>
        <field name="inherit_id"
               ref="base_wua.wua_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='url_gis_viewer_parcel_param']"
                   position="after">
                <field name="url_gis_viewer_parcel_class_param"/>
            </xpath>
            <xpath expr="//group[@name='group_gis_settings']"
                   position="before">
                <group string="CAYC Parameters">
                    <field name="cayc_remote_ip"/>
                    <field name="cayc_remote_port"/>
                    <field name="cayc_remote_database"/>
                    <field name="cayc_remote_database_user"/>
                    <field name="cayc_remote_database_password"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
