<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_parcel_view_form" model="ir.ui.view">
        <field name="name">Parcels (form view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id" ref="base_wua.wua_parcel_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='concession_ids']" position="attributes">
                <attribute name="attrs">{'readonly': [('with_gis_parcel', '=', True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='area_official']" position="attributes">
                <attribute name="attrs">{'readonly': [('with_gis_parcel', '=', True)]}</attribute>
            </xpath>
            <xpath expr="//button[@id='change_parcel_name']" position="attributes">
                <attribute name="attrs">{'invisible': [('with_gis_parcel', '=', True)]}</attribute>
            </xpath>
        </field>
    </record>

</odoo>
