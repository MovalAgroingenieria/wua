<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_parcel_view_form" model="ir.ui.view" >
        <field name="name">Parcels (form view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id" ref="base_wua.wua_parcel_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='subparcels']"
                   position="before">
                <page name="parcel_classes" string="Classes">
                    <field name="parcel_class_ids"
                            context="{'tree_view_ref':
                                        'base_wua_cayc.wua_edit_parcel_class_view_tree'}"/>
                </page>
            </xpath>
            <xpath expr="//field[@name='cadastral_sector']"
                   position="before">
                <field name="class_sharer" colspan="8"/>
            </xpath>
        </field>
    </record>

    <record id="wua_parcel_view_tree" model="ir.ui.view" >
        <field name="name">Parcels (tree view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id" ref="base_wua.wua_parcel_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='cadastral_polygon']"
                   position="before">
                <field name="intake_cayc" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='intake_id']"
                   position="attributes">
                <attribute name="invisible">0</attribute>
            </xpath>
            <xpath expr="//field[@name='area_official']"
                   position="after">
                <field name="area_official_cayc" invisible="1"/>
            </xpath>
        </field>
    </record>

    <record id="wua_parcel_view_search" model="ir.ui.view" >
        <field name="name">Parcels (search view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id" ref="base_wua.wua_parcel_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='inactive']"
                   position="before">
                <separator/>
                <filter string="Parcel Mapped: Yes" name="parcelmappedyes"
                 domain="[('mapped_parcel','=', True)]"/>
                <filter string="Parcel Mapped: No" name="parcelmappedno"
                 domain="[('mapped_parcel','=', False)]"/>
                <separator/>
            </xpath>
        </field>
    </record>

    <record id="wua_parcel_partnerlink_view_tree" model="ir.ui.view" >
        <field name="name">Partner Links (tree view)</field>
        <field name="model">wua.parcel.partnerlink</field>
        <field name="inherit_id" ref="base_wua.wua_parcel_partnerlink_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='area_official']" position="after">
                <field name="area_official_cayc" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='cadastral_reference']" position="before">
                <field name="intake_id"/>
                <field name="intake_cayc"  invisible="1"/>
            </xpath>
        </field>
    </record>

    <record id="wua_parcel_partnerlink_view_search" model="ir.ui.view" >
        <field name="name">Partner Links (search view)</field>
        <field name="model">wua.parcel.partnerlink</field>
        <field name="inherit_id" ref="base_wua.wua_parcel_partnerlink_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='propietary']" position="after">
                <filter string="Intake" name="intake"
                        context="{'group_by':'intake_id'}"/>
            </xpath>
        </field>
    </record>

    <record id="wua_edit_parcel_class_view_tree" model="ir.ui.view">
        <field name="name">Parcel Classes</field>
        <field name="model">wua.parcel.class</field>
        <field name="arch" type="xml">
            <tree class="o_base_wua_cayc_parcel_class_view_tree_notebook"
                  editable="bottom">
                <field name="name" invisible="1"/>
                <field name="gis_viewer_link" invisible="1"/>
                <field name="with_gis_parcel_class" invisible="1"/>
                <field name="parcel_class"/>
                <field name="resolution_year" invisible="1"/>
                <field name="area_official"/>
                <field name="area_gis" invisible="1"/>
                <button name="action_see_gis_viewer"
                    type="object" class="oe_stat_button"
                    string="GIS Viewer (zoom to parcel)"
                    icon="fa-map-marker"
                    attrs="{'invisible':
                            ['|',('gis_viewer_link','=',False),
                                    ('with_gis_parcel_class','=',False)]}"/>
            </tree>
        </field>
    </record>

    <record id="wua_parcel_class_view_form" model="ir.ui.view" >
        <field name="name">Parcel Classes (form view)</field>
        <field name="model">wua.parcel.class</field>
        <field name="arch" type="xml">
            <form duplicate="0" create="false" delete="false">
                <sheet>
                    <div name="buttons" class="oe_button_box">
                        <field name="gis_viewer_link" invisible="1"/>
                        <field name="with_gis_parcel_class" invisible="1"/>
                        <button name="toggle_active"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-archive"
                                confirm="Are you sure you want to toggle visibility?"
                                groups="base_wua.group_wua_user">
                                <field name="active"
                                 widget="boolean_button"
                                 options='{"terminology": "archive"}'/>
                        </button>
                        <button name="action_see_gis_viewer"
                                type="object"
                                class="oe_stat_button"
                                string="GIS Viewer"
                                icon="fa-map-marker"
                                attrs="{'invisible':
                                        ['|',('gis_viewer_link','=',False),
                                             ('with_gis_parcel_class','=',False)]}"
                                groups="base_wua.group_wua_user,
                                        base_wua.group_wua_portal_user"/>
                    </div>
                    <group name="master_data" col="9">
                        <group name="master_data_fields" colspan="6" col="4">
                            <group name="master_data_fields_left" colspan="2">
                                <field name="parcel_id" readonly="1"/>
                                <field name="parcel_class" readonly="1"/>
                                <field name="resolution_year" readonly="1"/>
                                <field name="class_sharer" readonly="1"/>
                            </group>
                            <group name="master_data_fields_right" colspan="2">
                                <field name="area_official" readonly="1"/>
                                <field name="area_gis"/>
                            </group>
                        </group>
                    </group>
                    <group name="slave_data">
                        <notebook name="slave_data_notebook">
                            <page name="notes_page" string="Notes">
                                <field name="notes"/>
                            </page>
                        </notebook>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <record id="wua_parcel_class_view_tree" model="ir.ui.view" >
        <field name="name">Parcel Classes (tree view)</field>
        <field name="model">wua.parcel.class</field>
        <field name="arch" type="xml">
            <tree create="false" edit="false" delete="false"
                class="o_base_wua_cayc_parcel_class_view_tree"
                order="parcel_id asc">
                <field name="parcel_id"/>
                <field name="name"/>
                <field name="gis_viewer_link" invisible="1"/>
                <field name="with_gis_parcel_class" invisible="1"/>
                <field name="parcel_class"/>
                <field name="class_sharer"/>
                <field name="resolution_year" invisible="1"/>
                <field name="area_official"/>
                <field name="area_gis" invisible="1"/>
                <button name="action_see_gis_viewer"
                    type="object" class="oe_stat_button"
                    string="GIS Viewer (zoom to parcel)"
                    icon="fa-map-marker"
                    attrs="{'invisible':
                            ['|',('gis_viewer_link','=',False),
                                    ('with_gis_parcel_class','=',False)]}"/>
                <field name="notes" invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="wua_parcel_class_view_search" model="ir.ui.view">
        <field name="name">Parcel Classes (search view)</field>
        <field name="model">wua.parcel.class</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="parcel_id"/>
                <filter string="GIS Parcel Class: Yes" name="gisparcelclassyes"
                 domain="[('with_gis_parcel_class','=',True)]"/>
                <filter string="GIS Parcel Class: No" name="gisparcelclassno"
                 domain="[('with_gis_parcel_class','=',False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Parcel" name="parcel_id"
                     context="{'group_by':'parcel_id'}"/>
                    <filter string="Parcel Class" name="parcel_class"
                     context="{'group_by':'parcel_class'}"/>
                    <filter string="Class Sharer" name="class_sharer"
                     context="{'group_by':'class_sharer'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="wua_parcel_class_view_pivot" model="ir.ui.view" >
        <field name="name">Parcel Classes (pivot view)</field>
        <field name="model">wua.parcel.class</field>
        <field name="arch" type="xml">
            <pivot string="Parcel Classes" display_quantity="true">
                <field name="parcel_class"/>
                <field name="area_official" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="wua_technical_parcel_class_view_tree" model="ir.ui.view" >
        <field name="name">Parcel Classes (tree view)</field>
        <field name="model">wua.parcel.class</field>
        <field name="arch" type="xml">
            <tree class="o_base_wua_cayc_parcel_class_view_tree" order="parcel_id asc">
                <field name="parcel_id"/>
                <field name="name"/>
                <field name="gis_viewer_link" invisible="1"/>
                <field name="with_gis_parcel_class" invisible="1"/>
                <field name="parcel_class"/>
                <field name="class_sharer"/>
                <field name="resolution_year" invisible="1"/>
                <field name="area_official"/>
                <field name="area_gis" invisible="1"/>
                <button name="action_see_gis_viewer"
                    type="object" class="oe_stat_button"
                    string="GIS Viewer (zoom to parcel)"
                    icon="fa-map-marker"
                    attrs="{'invisible':
                            ['|',('gis_viewer_link','=',False),
                                    ('with_gis_parcel_class','=',False)]}"/>
                <field name="notes" invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="wua_parcel_class_action" model="ir.actions.act_window">
        <field name="name">Parcel Classes</field>
        <field name="res_model">wua.parcel.class</field>
        <field name="view_mode">tree,form,pivot</field>
        <field name="view_id" ref="wua_parcel_class_view_tree"/>
        <field name="search_view_id" ref="wua_parcel_class_view_search"/>
    </record>

    <menuitem id="wua_parcel_class_menu"
              name="Parcel Classes"
              parent="base_wua.base_wua_census_landparcels_menu"
              action="wua_parcel_class_action"
              sequence="12"/>

    <record id="wua_technical_parcel_classes_action" model="ir.actions.act_window">
        <field name="name">Parcel Classes (low-level)</field>
        <field name="res_model">wua.parcel.class</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form,pivot</field>
        <field name="view_id" ref="wua_technical_parcel_class_view_tree"/>
        <field name="search_view_id" ref="wua_parcel_class_view_search"/>
    </record>

    <menuitem id="wua_technical_parcel_classes_menu"
              name="Parcel Classes"
              parent="base_wua.base_wua_technical_menu"
              action="wua_technical_parcel_classes_action"
              sequence="1"
              groups="base.group_system"/>

</odoo>
