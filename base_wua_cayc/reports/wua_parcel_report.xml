<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="wua_parcel_report_document" inherit_id="base_wua.wua_parcel_report_document">
        <xpath expr="//div[@name='subparcels_data']" position="before">
            <div name="classes_data" style="margin-top:20px;">
                <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                    <t t-if="report_style == 'light'">
                        <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-moval-subparcel"/></div>
                            <div style="float: left; display: inline;"><strong>Classes</strong></div>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-moval-subparcel"/></div>
                            <div style="float: left; display: inline;"><strong>Classes</strong></div>
                        </div>
                    </t>
                </div>
                <div style="margin-top: 4px;">
                    <t t-if="len(o.parcel_class_ids) > 0">
                        <table name="parcel_class_data" class="table table-striped" style="width:100%;">
                            <thead>
                                <t t-set="measurement_unit" t-value="o._compute_area_measurement_name()"/>
                                <th name="th_parcel_class">Parcel Class</th>
                                <th class="text-right" name="th_area_official">Class Official Area (<span t-esc="measurement_unit"/>)</th>
                                <th class="text-right" name="th_area_gis">GIS Area (<span t-esc="measurement_unit"/>)</th>
                            </thead>
                            <tbody>
                                <t t-foreach="o.parcel_class_ids" t-as="i" style="page-break-inside: avoid;">
                                    <tr>
                                        <td name="td_parcel_class">
                                            <span t-field="i.parcel_class"/>
                                        </td>
                                        <td class="text-right" name="td_area_official">
                                            <span t-field="i.area_official"/>
                                        </td>
                                        <td class="text-right" name="td_area_gis">
                                            <span t-field="i.area_gis"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>
                    <t t-else="">
                        <div class="text-center">
                            (There is no classes associated with this parcel)
                        </div>
                    </t>
                </div>

            </div>
        </xpath>

    </template>

</odoo>
