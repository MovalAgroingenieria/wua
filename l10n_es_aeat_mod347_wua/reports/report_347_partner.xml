<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_347_partner_document" inherit_id="l10n_es_aeat_mod347.report_347_partner_document">
        <xpath expr="//t[@t-call='report.external_layout']" position="attributes">
            <attribute name="t-call">base_wua_report.wua_external_layout</attribute>
        </xpath>
        <xpath expr="//div[@name='invoice_address']" position="replace">
            <div name="invoice_address" class="row" style="border: 1px solid white; margin: 0px 20px;">
                <div class="col-xs-12" style="display: table;">
                    <div style="border-right: 1px solid white; width: 60%; display: table-cell;">
                        <p style="margin-bottom: 0px"><i>Invoicing address</i></p>
                        <div>
                            <t t-if="o.partner_id.name"><strong><span t-field="o.partner_id.name"/></strong></t><br/>
                            <t t-if="o.partner_id.vat">
                                <t t-set="mod_vat" t-value="o.partner_id.vat[2:]"/>
                                <span>TIN:&amp;nbsp;</span>
                                <span t-esc="mod_vat"/>
                            </t><br/>
                            <t t-if="o.partner_id.street_type_show"><span t-field="o.partner_id.street_type_show"/></t>
                            <t t-if="o.partner_id.street"><span t-field="o.partner_id.street"/></t>
                            <t t-if="o.partner_id.street_num"><span t-field="o.partner_id.street_num"/></t>
                            <t t-if="o.partner_id.street2"><span t-field="o.partner_id.street2"/></t>
                            <br/>
                            <t t-if="o.partner_id.city"><span t-field="o.partner_id.city"/></t>
                            <t t-if="o.partner_id.zip">
                                <span>&amp;nbsp;-&amp;nbsp;</span>
                                <span t-field="o.partner_id.zip"/>
                            </t>
                            <t id="state_address" t-if="o.partner_id.state_id">
                                <span t-tag="span">(</span><span t-field="o.partner_id.state_id"/>
                                <t t-if="not o.partner_id.country_id"><span>)</span></t>
                                <t t-else=""><span>-</span></t>
                            </t>
                            <t id="country_address" t-if="o.partner_id.country_id">
                                <t t-if="not o.partner_id.state_id"><span>(</span></t>
                                <span t-field="o.partner_id.country_id"></span><span>)</span>
                            </t>
                        </div>
                    </div>
                    <div style="width: 40%; display: table-cell; padding: 0px 8px;">
                        <p style="margin-bottom: 0px"><i>Shipping Address</i></p>
                        <t t-set="shipping_address" t-value="False"/>
                        <t t-if="o.partner_id.child_ids">
                            <t t-foreach="o.partner_id.child_ids" t-as="address">
                                <t t-if="address.type == 'delivery'">
                                    <t t-set="shipping_address" t-value="address"/>
                                </t>
                            </t>
                        </t>
                        <t t-if="shipping_address">
                            <div>
                                <t t-if="shipping_address.name"><strong><span t-field="shipping_address.name"/></strong></t><br/>
                                <t t-if="shipping_address.street_type_show"><span t-field="shipping_address.street_type_show"/></t>
                                <t t-if="shipping_address.street"><span t-field="shipping_address.street"/></t>
                                <t t-if="shipping_address.street_num"><span t-field="shipping_address.street_num"/></t>
                                <t t-if="shipping_address.street2"><span t-field="shipping_address.street2"/></t>
                                <br/>
                                <t t-if="shipping_address.city"><span t-field="shipping_address.city"/></t>
                                <t t-if="shipping_address.zip">
                                    <span>&amp;nbsp;-&amp;nbsp;</span>
                                    <span t-field="shipping_address.zip"/>
                                </t>
                                <t id="state_address" t-if="shipping_address.state_id">
                                    <span t-tag="span">(</span><span t-field="shipping_address.state_id"/>
                                    <t t-if="not shipping_address.country_id"><span>)</span></t>
                                    <t t-else=""><span>-</span></t>
                                </t>
                                <t id="country_address" t-if="shipping_address.country_id">
                                    <t t-if="not shipping_address.state_id"><span>(</span></t>
                                    <span t-field="shipping_address.country_id"></span><span>)</span>
                                </t>
                            </div>
                        </t>
                        <t t-else="">
                            <div>
                                <t t-if="o.partner_id.name"><strong><span t-field="o.partner_id.name"/></strong></t><br/>
                                <t t-if="o.partner_id.street_type_show"><span t-field="o.partner_id.street_type_show"/></t>
                                <t t-if="o.partner_id.street"><span t-field="o.partner_id.street"/></t>
                                <t t-if="o.partner_id.street_num"><span t-field="o.partner_id.street_num"/></t>
                                <t t-if="o.partner_id.street2"><span t-field="o.partner_id.street2"/></t>
                                <br/>
                                <t t-if="o.partner_id.city"><span t-field="o.partner_id.city"/></t>
                                <t t-if="o.partner_id.zip">
                                    <span>&amp;nbsp;-&amp;nbsp;</span>
                                    <span t-field="o.partner_id.zip"/>
                                </t>
                                <t id="state_address" t-if="o.partner_id.state_id">
                                    <span t-tag="span">(</span><span t-field="o.partner_id.state_id"/>
                                    <t t-if="not o.partner_id.country_id"><span>)</span></t>
                                    <t t-else=""><span>-</span></t>
                                </t>
                                <t id="country_address" t-if="o.partner_id.country_id">
                                    <t t-if="not o.partner_id.state_id"><span>(</span></t>
                                    <span t-field="o.partner_id.country_id"></span><span>)</span>
                                </t>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

</odoo>
