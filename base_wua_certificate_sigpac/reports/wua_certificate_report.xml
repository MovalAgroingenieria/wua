<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_wua_certificate_document" inherit_id="base_wua_certificate.report_wua_certificate_document">
        <xpath expr="//t[@name='parcels_table']/table" position="after">
            <t t-set="certificatesigpac_ids" t-value="o.certificatesigpac_ids.filtered(lambda x: x.included_in_certificate)"/>
            <t t-if="certificatesigpac_ids" name="sigpacenclosures_table">
                <div class="row h4 mt28 mb4" name="section_sigpac_detail" style="padding-bottom: 4px;">
                    <t t-if="report_style == 'light'">
                        <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-moval-sigpac"/></div>
                            <div style="float: left; display: inline;"><strong>Enclosures</strong></div>
                       </div>
                    </t>
                    <t t-else="">
                        <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-moval-sigpac"/></div>
                            <div style="float: left; display: inline;"><strong>Enclosures</strong></div>
                        </div>
                    </t>
                </div>
                <table class="table table-condensed table-striped">
                    <thead>
                        <tr>
                            <th class="text-left">Land Parcel</th>
                            <th class="text-right">Number</th>
                            <th class="text-left">Land Use</th>
                            <th class="text-right">Irrig. Coef. (0-100)</th>
                            <th class="text-right">Area (GIS, <span><t t-esc="measurement_unit"/></span>)</th>
                            <th class="text-right">% of parcel</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="certificatesigpac_ids" t-as="s">
                            <td align="left"><span t-field="s.parcel_id"/></td>
                            <td align="right"><span t-field="s.enclosure_number"/></td>
                            <td name="td_uso_sigpac" align="left"><span t-field="s.uso_sigpac"/></td>
                            <td name="td_coef_rega" align="right"><span t-field="s.coef_rega"/></td>
                            <td name="td_area_ha" align="right"><span t-field="s.area_ha"/></td>
                            <td name="td_intersection_percentage" align="right"><span t-field="s.intersection_percentage"/></td>
                        </tr>
                    </tbody>
                </table>
            </t>
        </xpath>
    </template>

</odoo>