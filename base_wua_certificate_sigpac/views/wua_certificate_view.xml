<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_certificate_display_view_form" model="ir.ui.view">
        <field name="name">Certificates (form view to display)</field>
        <field name="model">wua.certificate</field>
        <field name="inherit_id" ref="base_wua_certificate.wua_certificate_display_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='parcels_page']"
                   position="after">
                <page name="sigpac_page" string="SIGPAC">
                    <field name="certificatesigpac_ids"
                           readonly="1"
                           context="{'tree_view_ref':
                           'base_wua_certificate_sigpac.wua_certificate_sigpac_view_tree'}"/>
                </page>
            </xpath>
        </field>
    </record>

    <record id="wua_certificate_sigpac_view_tree" model="ir.ui.view">
        <field name="name">SIGPAC enclosures of certificate (tree view)</field>
        <field name="model">wua.certificate.sigpac</field>
        <field name="arch" type="xml">
            <tree class=
                  "o_base_wua_certificate_sigpac_certificate_sigpac_view_tree">
                <field name="parcel_id" string="Parcel"/>
                <field name="enclosure_number" string=""/>
                <field name="sigpac_code" string="SIGPAC Enclosure"/>
                <field name="uso_sigpac" string="Land Use"/>
                <field name="coef_rega" string="Irrig. Coef. (0-100)"/>
                <field name="parcel_area_ha" string="Parcel Area (GIS, ha)"/>
                <field name="area_ha" string="Intersection (GIS, ha)"/>
                <field name="intersection_percentage" string="% of parcel"/>
                <field name="included_in_certificate" string="Included"/>
            </tree>
        </field>
    </record>

</odoo>