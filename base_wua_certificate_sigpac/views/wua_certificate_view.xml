<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_certificate_display_view_form" model="ir.ui.view">
        <field name="name">Certificates (form view to display)</field>
        <field name="model">wua.certificate</field>
        <field name="inherit_id" ref="base_wua_certificate.wua_certificate_display_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='parcels_page']"
                   position="after">
                <page name="sigpac_page" string="SIGPAC">
                    <field name="certificatesigpac_ids"
                        context="{'tree_view_ref': 'base_wua_certificate_sigpac.wua_certificate_sigpac_view_tree'}"
                        attrs="{'readonly': [('state','!=','01_draft')]}"/>
                </page>
            </xpath>
        </field>
    </record>

    <record id="wua_certificate_sigpac_view_tree" model="ir.ui.view">
        <field name="name">SIGPAC enclosures of certificate (tree view)</field>
        <field name="model">wua.certificate.sigpac</field>
        <field name="arch" type="xml">
            <tree class="o_base_wua_certificate_sigpac_certificate_sigpac_view_tree"
                editable="bottom" create="false" delete="false">
                <field name="parcel_id" string="Parcel"/>
                <field name="enclosure_number" string=""/>
                <field name="sigpac_code" string="SIGPAC Enclosure" readonly="1"/>
                <field name="uso_sigpac" string="Land Use" readonly="1"/>
                <field name="coef_rega" string="Irrig. Coef. (0-100)" readonly="1"/>
                <field name="parcel_area_ha" string="Parcel Area (GIS, ha)" readonly="1"/>
                <field name="area_ha" string="Intersection (GIS, ha)" readonly="1"/>
                <field name="intersection_percentage" string="% of parcel" readonly="1"/>
                <field name="included_in_certificate" string="Parcel included"/>
                <field name="enclosure_included_in_certificate"/>
            </tree>
        </field>
    </record>

</odoo>