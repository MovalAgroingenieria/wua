<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_fertconsumption_view_form" model="ir.ui.view">
        <field name="name">Consumptions (form view)</field>
        <field name="model">wua.fertconsumption</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation_with_fertilizer.wua_fertconsumption_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='presconsumption_id']"
             position="after">
                <field name="invoiced_consumption" invisible="1"/>
                <field name="invoiceset_id" readonly="1"  attrs="{'invisible': [('invoiced_consumption', '=', False)]}"/>
            </xpath>
            <xpath expr="//field[@name='amount']"
             position="after">
              <field name="uom_id"/>
            </xpath>
            <xpath expr="//field[@name='reading_end_time']"
             position="after">
                <field name="product_id"/>
            </xpath>
        </field>
    </record>

    <record id="wua_fertconsumption_view_tree" model="ir.ui.view">
        <field name="name">Consumptions (tree view)</field>
        <field name="model">wua.fertconsumption</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation_with_fertilizer.wua_fertconsumption_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='presconsumption_id']" position="after">
              <field name='product_id'/>
              <field name='uom_id'/>
              <field name='invoiceset_id'/>
            </xpath>
        </field>
    </record>

    <record id="wua_fertconsumption_view_search" model="ir.ui.view">
        <field name="name">Consumptions (search view)</field>
        <field name="model">wua.fertconsumption</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation_with_fertilizer.wua_fertconsumption_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='waterconnection_id']" position="before">
                <field name="product_id"/>
            </xpath>
            <xpath expr="//filter[@name='isvalidatedno']" position="after">
                <separator/>
                <filter string="Invoiced" name="invoiced"
                 domain="[('invoiced_consumption','=',True)]"/>
                <filter string="Not invoiced" name="notinvoiced"
                 domain="[('invoiced_consumption','!=',True)]"/>
            </xpath>
            <xpath expr="//filter[@name='agriculturalseason']" position="after">
              <filter string="Product"
               name="product"
               context="{'group_by':'product_id'}"/>
              <filter string="Invoice Set"
               name="invoiceset"
               context="{'group_by':'invoiceset_id'}"/>
              <filter string="Invoiced (Yes/No)"
               name="invoicedgroup"
               context="{'group_by':'invoiced_consumption'}"/>
            </xpath>
        </field>
    </record>

</odoo>
