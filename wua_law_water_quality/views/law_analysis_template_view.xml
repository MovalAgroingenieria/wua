<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="law_analysis_template_view_form" model="ir.ui.view">
        <field name="name">WUA Laboratory Template Analysis for Waters (form view)</field>
        <field name="model">law.analysis.template</field>
        <field name="inherit_id" ref="law_water_quality.law_analysis_template_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='watertype_id']" position="before">
                <field name="intake_id"/>
            </xpath>
        </field>
    </record>

</odoo>