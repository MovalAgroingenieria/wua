<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_server_export_images_zip"
            model="ir.actions.server">
        <field name="name">Export Images (ZIP)</field>
        <field name="model_id"
               ref="maintenance.model_maintenance_request"/>
        <field name="state">code</field>
        <field name="code">
wizard = env['wizard.export.images.zip'].create({})
action = wizard.with_context(active_ids=context.get('active_ids', [])).action_export_images_zip()
        </field>
    </record>

    <record id="ir_values_export_images_zip" model="ir.values">
        <field name="name">Export Images (ZIP)</field>
        <field name="model">maintenance.request</field>
        <field name="key2">client_action_multi</field>
        <field name="value"
               eval="'ir.actions.server,' + str(ref('action_server_export_images_zip'))"/>
    </record>

</odoo>
