<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_image_preview_wizard_form" model="ir.ui.view">
        <field name="name">Image Preview</field>
        <field name="model">wizard.image.preview</field>
        <field name="arch" type="xml">
            <form string="Image Preview" create="0" edit="0" readonly="1">
                <sheet>
                    <field name="image" widget="image" nolabel="1"/>
                    <field name="show_prev" invisible="1"/>
                    <field name="show_next" invisible="1"/>
                </sheet>
                <footer>
                    <button string="Previous" type="object" name="action_prev_image"
                            attrs="{'invisible': [('show_prev', '=', False)]}" class="btn-secondary"/>
                    <button string="Next" type="object" name="action_next_image"
                            attrs="{'invisible': [('show_next', '=', False)]}" class="btn-secondary"/>
                </footer>
            </form>

        </field>
    </record>

</odoo>

