<?xml version="1.0" encoding="utf-8"?>
<odoo>



    <!-- Maintenance request report (droplist menu) -->
    <report
        id="maintenance_request_report"
        string="Maintenance Request Report"
        model="maintenance.request"
        report_type="qweb-pdf"
        file="wua_maintenance.maintenance_request_report_document"
        name="wua_maintenance.maintenance_request_report_document"
    />

    <!-- Maintenance Request report -->
    <template id="maintenance_request_report_document">
        <t t-call="report.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="base_wua_report.wua_external_layout">
                    <div class="page">

                        <!-- Vars -->
                        <t t-set="report_style" t-value="o.env['ir.values'].get_default('wua.configuration', 'reports_style')"/>

                        <!-- Request data -->
                        <div name="maintenance_request_data">
                            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                <t t-if="report_style == 'light'">
                                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;"><span class="fa fa-file-text"/></div>
                                        <div style="float: left; display: inline;">
                                            <strong>
                                                <span t-field="o.name"/>
                                            </strong>
                                            <br/>
                                            <span t-field="o.sequence" style="font-size: 12px;"/>
                                        </div>
                                   </div>
                                </t>
                                <t t-else="">
                                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;"><span class="fa fa-file-text"/></div>
                                        <div style="float: left; display: inline;">
                                            <strong>
                                                <span t-field="o.name"/>
                                            </strong>
                                            <br/>
                                            <span t-field="o.sequence" style="font-size: 12px;"/>
                                        </div>
                                    </div>
                                </t>
                            </div>
                            <div class="row" style="margin-top: 4px;">
                                <div class="col-xs-12" style="display: table;">
                                    <div style="width: 50%; display: table-cell;">
                                        <t t-if="o.equipment_id or o.category_id or o.maintenance_kind_id">
                                            <t t-if="o.equipment_id"><b>Equipment:</b>&amp;nbsp;<span t-field="o.equipment_id"/><br/></t>
                                            <t t-if="o.category_id"><b>Category:</b>&amp;nbsp;<span t-field="o.category_id"/><br/></t>
                                            <t t-if="o.maintenance_kind_id"><b>Maintenance Kind:</b>&amp;nbsp;<span t-field="o.maintenance_kind_id"/><br/></t>
                                            <t t-if="o.maintenance_type"><b>Maintenance Type:</b>&amp;nbsp;<span t-field="o.maintenance_type"/><br/></t>
                                        </t>
                                    </div>
                                </div>
                            </div>
                            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                <t t-if="report_style == 'light'">
                                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;"><span class="fa fa-user"/></div>
                                        <div style="float: left; display: inline;">
                                            <strong>
                                                Personnel
                                            </strong>
                                        </div>
                                   </div>
                                </t>
                                <t t-else="">
                                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;"><span class="fa fa-user"/></div>
                                        <div style="float: left; display: inline;">
                                            <strong>
                                                Personnel
                                            </strong>
                                        </div>
                                    </div>
                                </t>
                            </div>
                             <div class="row" style="margin-top: 4px;">
                                <div class="col-xs-12" style="display: table;">
                                    <div style="width: 50%; display: table-cell;">
                                        <t t-if="o.technician_user_id or o.maintenance_team_id">
                                            <b>Created by:</b>&amp;nbsp;<span t-field="o.employee_id"/>
                                            <br/>
                                            <t t-if="o.technician_user_id"><b>Maintenance Responsible:</b>&amp;nbsp;<span t-field="o.technician_user_id"/><br/></t>
                                            <t t-if="o.maintenance_team_id"><b>Maintenance Team:</b>&amp;nbsp;<span t-field="o.maintenance_team_id"/><br/></t>
                                        </t>
                                    </div>
                                </div>
                            </div>
                            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                <t t-if="report_style == 'light'">
                                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;"><span class="fa fa-calendar"/></div>
                                        <div style="float: left; display: inline;">
                                            <strong>
                                                Dates
                                            </strong>
                                        </div>
                                   </div>
                                </t>
                                <t t-else="">
                                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;"><span class="fa fa-calendar"/></div>
                                        <div style="float: left; display: inline;">
                                            <strong>
                                                Dates
                                            </strong>
                                        </div>
                                    </div>
                                </t>
                            </div>
                             <div class="row" style="margin-top: 4px;">
                                <div class="col-xs-12" style="display: table;">
                                    <div style="width: 50%; display: table-cell;">
                                        <t t-if="o.request_date or o.schedule_date or o.priority">
                                            <t t-if="o.request_date"><b>Request Date:</b>&amp;nbsp;<span t-field="o.request_date"/><br/></t>
                                            <t t-if="o.request_date"><b>Close Date:</b>&amp;nbsp;<span t-field="o.close_date"/><br/></t>
                                            <t t-if="o.schedule_date"><b>Scheduled Date:</b>&amp;nbsp;<span t-field="o.schedule_date"/><br/></t>
                                            <t t-if="o.schedule_date"><b>Priority:</b>&amp;nbsp;<span t-if="o.priority == '0'">Very Low<br/></span>
                                                                                                  <span t-if="o.priority == '1'">Low<br/></span>
                                                                                                  <span t-if="o.priority == '2'">Normal<br/></span>
                                                                                                  <span t-if="o.priority == '3'">High<br/></span>
                                                                                                  <span t-if="o.priority == '4'">Very High<br/></span>
                                            </t>
                                        </t>
                                    </div>
                                </div>
                            </div>
                            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                <t t-if="o.description">
                                    <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                        <t t-if="report_style == 'light'">
                                            <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                                <div style="float: left; width: 32px;"><span class="fa fa-pencil"/></div>
                                                <div style="float: left; display: inline;">
                                                    <strong>
                                                        Notes
                                                    </strong>
                                                </div>
                                            </div>
                                        </t>
                                        <t t-else="">
                                            <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                                <div style="float: left; width: 32px;"><span class="fa fa-pencil"/></div>
                                                <div style="float: left; display: inline;">
                                                    <strong>
                                                        Notes
                                                    </strong>
                                                </div>
                                            </div>
                                        </t>
                                    </div>
                                </t>
                            </div>
                            <div class="row" style="margin-top: 4px;">
                                <div class="col-xs-12" style="display: table;">
                                    <div style="width: 50%; display: table-cell;">
                                        <t t-if="o.description">
                                            <span t-field="o.description"/><br/>
                                        </t>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
