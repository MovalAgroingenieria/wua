<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Maintenance request report PERTE (droplist menu) -->
    <report id="maintenance_request_report_perte"
        string="Maintenance Request Report PERTE"
        model="maintenance.request"
        report_type="qweb-pdf"
        file="wua_maintenance.maintenance_request_report_perte_document"
        name="wua_maintenance.maintenance_request_report_perte_document"/>

    <!-- Maintenance Request report PERTE (without request_date and close_date) -->
    <template id="maintenance_request_report_perte_document">
        <t t-call="report.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="base_wua_report.wua_external_layout">
                    <div class="page">
                        <!-- Vars -->
                        <t t-set="report_style" t-value="o.env['ir.values'].get_default('wua.configuration', 'reports_style')"/>
                        <!-- Title -->
                        <div name="title" class="text-center">
                            <h4><b>Maintenance request report PERTE</b></h4>
                            <span>[<span t-field="o.name"></span>]</span>
                        </div>
                        <!-- Maintenance request data -->
                        <div name="maintenance_request_data">
                            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                <t t-if="report_style == 'light'">
                                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;"><span class="fa fa-moval-hammer"/></div>
                                        <div style="float: left; display: inline;"><b>Request</b></div>
                                        <div style="float: right;"><span t-field="o.sequence"/></div>
                                   </div>
                                </t>
                                <t t-else="">
                                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;"><span class="fa fa-moval-hammer"/></div>
                                        <div style="float: left; display: inline;"><b>Request</b></div>
                                        <div style="float: right;"><span t-field="o.sequence"/></div>
                                    </div>
                                </t>
                            </div>
                            <div class="row" style="margin-top: 4px;">
                                <div class="col-xs-12" style="display: table;">
                                    <div style="width: 50%; display: table-cell;">
                                        <table style="width: 100%;">
                                            <tbody>
                                                <t t-if="o.equipment_id">
                                                    <tr name="tr_equipment">
                                                        <td><span><b>Equipment</b></span></td>
                                                        <td class="text-right">
                                                            <span t-field="o.equipment_id"/>
                                                        </td>
                                                    </tr>
                                                </t>
                                                <t t-if="o.category_id">
                                                    <tr name="tr_category">
                                                        <td><span><b>Category</b></span></td>
                                                        <td class="text-right">
                                                            <span t-field="o.category_id"/>
                                                        </td>
                                                    </tr>
                                                </t>
                                                <t t-if="o.employee_id">
                                                    <tr name="tr_employee">
                                                        <td><span><b>Created by</b></span></td>
                                                        <td class="text-right">
                                                            <span t-field="o.employee_id"/>
                                                        </td>
                                                    </tr>
                                                </t>
                                                <t t-if="o.schedule_date">
                                                    <tr name="tr_schedule_date">
                                                        <td><span><b>Scheduled Date</b></span></td>
                                                        <td class="text-right">
                                                            <span t-field="o.schedule_date"/>
                                                        </td>
                                                    </tr>
                                                </t>
                                                <t t-if="o.equipment_id and o.equipment_id.geojson_geom">
                                                    <tr name="tr_coordinates">
                                                        <td><span><b>Coordinates</b></span></td>
                                                        <td class="text-right">
                                                            <span t-esc="o.get_equipment_coordinates()"/>
                                                        </td>
                                                    </tr>
                                                </t>
                                            </tbody>
                                        </table>
                                    </div>
                                    <div style="display: table-cell; padding-left: 32px;">
                                        <table style="width: 100%;">
                                            <tbody>
                                                <t t-if="o.maintenance_type">
                                                    <tr name="tr_maintenance_type">
                                                        <td><span><b>Type</b></span></td>
                                                        <td class="text-right">
                                                            <span t-field="o.maintenance_type"/>
                                                        </td>
                                                    </tr>
                                                </t>
                                                <t t-if="o.maintenance_kind_id">
                                                    <tr name="tr_maintenance_kind">
                                                        <td><span><b>Kind</b></span></td>
                                                        <td class="text-right">
                                                            <span t-field="o.maintenance_kind_id"/>
                                                        </td>
                                                    </tr>
                                                </t>
                                                <t t-if="o.stage_id">
                                                    <tr name="tr_stage">
                                                        <td><span><b>Stage</b></span></td>
                                                        <td class="text-right">
                                                            <span t-field="o.stage_id"/>
                                                        </td>
                                                    </tr>
                                                </t>
                                                <t t-if="o.maintenance_team_id">
                                                    <tr name="tr_maintenance_team">
                                                        <td><span><b>Team</b></span></td>
                                                        <td class="text-right">
                                                            <span t-field="o.maintenance_team_id"/>
                                                        </td>
                                                    </tr>
                                                </t>
                                                <t t-if="o.technician_user_id">
                                                    <tr name="tr_technician_user">
                                                        <td><span><b>Manager</b></span></td>
                                                        <td class="text-right">
                                                            <span t-field="o.technician_user_id"/>
                                                        </td>
                                                    </tr>
                                                </t>
                                                <tr name="tr_priority">
                                                    <td><span><b>Priority</b></span></td>
                                                    <td class="text-right">
                                                        <t t-if="o.priority == '0'">
                                                            <span class="fa fa-star-o"/>
                                                            <span class="fa fa-star-o"/>
                                                            <span class="fa fa-star-o"/>
                                                        </t>
                                                        <t t-if="o.priority == '1'">
                                                            <span class="fa fa-star"/>
                                                            <span class="fa fa-star-o"/>
                                                            <span class="fa fa-star-o"/>
                                                        </t>
                                                        <t t-if="o.priority == '2'">
                                                            <span class="fa fa-star"/>
                                                            <span class="fa fa-star"/>
                                                            <span class="fa fa-star-o"/>
                                                        </t>
                                                        <t t-if="o.priority == '3'">
                                                            <span class="fa fa-star"/>
                                                            <span class="fa fa-star"/>
                                                            <span class="fa fa-star"/>
                                                        </t>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <t t-set="extra_data" t-value="o.get_served_parcels_and_payer()"/>
                            <t t-if="extra_data['parcels']">
                                <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;"><span class="fa fa-map"/></div>
                                        <div style="float: left; display: inline;">
                                            <strong>Parcels Served</strong>
                                        </div>
                                    </div>
                                </div>
                                <table class="table table-condensed" style="margin-top: 4px; width: 100%; table-layout: fixed;">
                                    <thead>
                                        <tr>
                                            <th style="width:20%; text-align:center;">Code</th>
                                            <th style="width:20%; text-align:center;">Hydraulic Sector</th>
                                            <th style="width:20%; text-align:center;">Polygon</th>
                                            <th style="width:20%; text-align:center;">Parcel</th>
                                            <th style="width:20%; text-align:center;">Declared Area</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="extra_data['parcels']" t-as="p">
                                            <tr>
                                                <td style="text-align:center;"><span t-esc="p['code']"/></td>
                                                <td style="text-align:center;"><span t-esc="p['hydraulic_sector']"/></td>
                                                <td style="text-align:center;"><span t-esc="p['polygon']"/></td>
                                                <td style="text-align:center;"><span t-esc="p['parcel']"/></td>
                                                <td style="text-align:center;">
                                                    <span t-esc="p['area']"/> ha
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                                <t t-if="extra_data['extra_info']">
                                    <div class="row h4 mt16 mb4">
                                        <t t-if="report_style == 'light'">
                                            <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                                <div style="float: left; width: 32px;"><span class="fa fa-info-circle"/></div>
                                                <div style="float: left; display: inline;">
                                                    <strong>Extra Information</strong>
                                                </div>
                                            </div>
                                        </t>
                                        <t t-else="">
                                            <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                                <div style="float: left; width: 32px;"><span class="fa fa-info-circle"/></div>
                                                <div style="float: left; display: inline;">
                                                    <strong>Extra Information</strong>
                                                </div>
                                            </div>
                                        </t>
                                    </div>
                                    <div style="white-space: pre-line;">
                                        <span t-raw="extra_data['extra_info']"/>
                                    </div>
                                </t>
                            </t>
                        <!-- Notes / Description -->
                        <t t-if="o.description">
                            <div name="notes_data">
                                <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                    <t t-if="report_style == 'light'">
                                        <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                            <div style="float: left; width: 32px;"><span class="fa fa-pencil"/></div>
                                            <div style="float: left; display: inline;"><strong>Notes</strong></div>
                                        </div>
                                    </t>
                                    <t t-else="">
                                        <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                            <div style="float: left; width: 32px;"><span class="fa fa-pencil"/></div>
                                            <div style="float: left; display: inline;"><strong>Notes</strong></div>
                                        </div>
                                    </t>
                                </div>
                                <div style="margin-top: 4px;">
                                    <span t-field="o.description"/>
                                </div>
                            </div>
                        </t>
                        <!-- Resolution Description -->
                        <t t-if="o.resolution_description">
                            <div name="resolution_description_data">
                                <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                    <t t-if="report_style == 'light'">
                                        <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                            <div style="float: left; width: 32px;"><span class="fa fa-check-circle"/></div>
                                            <div style="float: left; display: inline;"><strong>Resolution Description</strong></div>
                                        </div>
                                    </t>
                                    <t t-else="">
                                        <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                            <div style="float: left; width: 32px;"><span class="fa fa-check-circle"/></div>
                                            <div style="float: left; display: inline;"><strong>Resolution Description</strong></div>
                                        </div>
                                    </t>
                                </div>
                                <div style="margin-top: 4px;">
                                    <span t-field="o.resolution_description"/>
                                </div>
                            </div>
                        </t>
                        <!-- Additional Information (Resolution Dynamic Fields) -->
                        <t t-if="o.resolution_dynamic_fields">
                            <div name="resolution_dynamic_fields_data">
                                <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                    <t t-if="report_style == 'light'">
                                        <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                            <div style="float: left; width: 32px;"><span class="fa fa-info-circle"/></div>
                                            <div style="float: left; display: inline;"><strong>Additional Information</strong></div>
                                        </div>
                                    </t>
                                    <t t-else="">
                                        <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                            <div style="float: left; width: 32px;"><span class="fa fa-info-circle"/></div>
                                            <div style="float: left; display: inline;"><strong>Additional Information</strong></div>
                                        </div>
                                    </t>
                                </div>
                                <div style="margin-top: 4px; white-space: pre-line;">
                                    <span t-esc="o.resolution_dynamic_fields"/>
                                </div>
                            </div>
                        </t>
                        <!-- Images Before Resolution -->
                        <t t-if="o.resolution_images_before">
                            <div name="resolution_images_before_data">
                                <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                    <t t-if="report_style == 'light'">
                                        <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                            <div style="float: left; width: 32px;"><span class="fa fa-image"/></div>
                                            <div style="float: left; display: inline;"><strong>Images Before</strong></div>
                                        </div>
                                    </t>
                                    <t t-else="">
                                        <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                            <div style="float: left; width: 32px;"><span class="fa fa-image"/></div>
                                            <div style="float: left; display: inline;"><strong>Images Before</strong></div>
                                        </div>
                                    </t>
                                </div>
                                <div style="margin-top: 4px; text-align: center;">
                                    <t t-foreach="o.resolution_images_before[:3]" t-as="img">
                                        <img t-att-src="'data:image/png;base64,%s' % img.image" style="max-width: 30%; max-height: 300px; margin: 5px; display: inline-block;"/>
                                    </t>
                                </div>
                            </div>
                        </t>
                        <!-- Images After Resolution -->
                        <t t-if="o.resolution_images_after">
                            <div name="resolution_images_after_data">
                                <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                    <t t-if="report_style == 'light'">
                                        <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                            <div style="float: left; width: 32px;"><span class="fa fa-image"/></div>
                                            <div style="float: left; display: inline;"><strong>Images After</strong></div>
                                        </div>
                                    </t>
                                    <t t-else="">
                                        <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                            <div style="float: left; width: 32px;"><span class="fa fa-image"/></div>
                                            <div style="float: left; display: inline;"><strong>Images After</strong></div>
                                        </div>
                                    </t>
                                </div>
                                <div style="margin-top: 4px; text-align: center;">
                                    <t t-foreach="o.resolution_images_after[:3]" t-as="img">
                                        <img t-att-src="'data:image/png;base64,%s' % img.image" style="max-width: 30%; max-height: 300px; margin: 5px; display: inline-block;"/>
                                    </t>
                                </div>
                            </div>
                        </t>

                    </div> <!-- end page -->
                </t>
            </t>
        </t>
    </template>

</odoo>
