<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_maintenance_kind_form" model="ir.ui.view">
        <field name="name">maintenance.kind.form</field>
        <field name="model">maintenance.kind</field>
        <field name="arch" type="xml">
            <form string="Maintenance Kind">
                <sheet>
                    <div name="buttons" class="oe_button_box">
                        <button name="toggle_active"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-archive"
                                confirm="Are you sure you want to toggle visibility?"
                                groups="base_maintenance_config.group_maintenance_manager">
                                <field name="active"
                                 widget="boolean_button"
                                 options='{"terminology": "archive"}'/>
                        </button>
                    </div>
                    <group name="master_data">
                        <group>
                            <field name="name"/>
                            <field name="category_id"/>
                            <field name="images_required"/>
                            <field name="procedure_description"/>
                        </group>
                    </group>
                    <group name="slave_data">
                        <notebook>
                            <page string="Dynamic Fields">
                                <field name="dynamic_field_ids">
                                    <tree editable="bottom">
                                        <field name="name"/>
                                        <field name="field_type"/>
                                        <field name="fixed_option_ids" widget="many2many_tags"/>
                                        <field name="required"/>
                                        <field name="field_path"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="maintenance_kind_view_tree" model="ir.ui.view">
        <field name="name">maintenance.kind.tree</field>
        <field name="model">maintenance.kind</field>
        <field name="inherit_id" ref="maintenance_plan.maintenance_kind_view_tree" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='active']" position="after">
                <field name="category_id"/>
            </xpath>
            <xpath expr="//tree" position="attributes">
                <attribute name="editable" delete="1"/>
            </xpath>
        </field>
    </record>

    <record id="maintenance_kind_view_search" model="ir.ui.view">
        <field name="name">maintenance.kind.search</field>
        <field name="model">maintenance.kind</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter string="Active" name="filter_active" domain="[('active','=',True)]"/>
                <filter string="Archived" name="filter_archived" domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

    <record id="maintenance_plan.maintenance_kind_action" model="ir.actions.act_window">
        <field name="name">Maintenance Kinds</field>
        <field name="res_model">maintenance.kind</field>
        <field name="view_mode">tree,form</field>
        <field name="view_type">form</field>
    </record>

</odoo>