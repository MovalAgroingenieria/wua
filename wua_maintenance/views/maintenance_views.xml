    <record id="hr_equipment_category_view_search" model="ir.ui.view">
        <field name="name">equipment.category.search.inherit</field>
        <field name="model">maintenance.equipment.category</field>
        <field name="inherit_id" ref="maintenance.hr_equipment_category_view_search" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <filter string='Is WUA: Yes' name="filter_is_wua_true" domain="[('is_wua', '!=', False)]" />
                <filter string='Is WUA: No' name="filter_is_wua_false" domain="[('is_wua', '!=', True)]" />
                <filter string='Primary' name="filter_is_primary" domain="[('is_primary', '!=', False)]" />
            </xpath>
            <xpath expr="(//group[1]/filter)[last()]" position="after">
                <filter string='Infrastructure Type' domain="[]" context="{'group_by' : 'infrastructure_type'}" />
            </xpath>
        </field>
    </record>

    <record id="maintenance_equipment_view_search_inherit_hr" model="ir.ui.view">
        <field name="name">equipment.search.inherit</field>
        <field name="model">maintenance.equipment</field>
        <field name="inherit_id" ref="hr_maintenance.maintenance_equipment_view_search_inherit_hr" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='owner_user_id']" position="after">
                <filter string='Is WUA: Yes' name="filter_is_wua_true" domain="[('is_wua', '!=', False)]" />
                <filter string='Is WUA: No' name="filter_is_wua_false" domain="[('is_wua', '!=', True)]" />
                <filter string='Primary' name="filter_is_primary" domain="[('is_primary', '!=', False)]" />
            </xpath>
            <xpath expr="//group[1]" position="replace">
                <filter string="Technicians" domain="[]" context="{'group_by': 'technician_user_id'}" />
                <filter string="Category" domain="[]" context="{'group_by': 'category_id'}" />
                <filter string="Owner" domain="[]" context="{'group_by': 'owner_user_id'}" />
                <filter string="Vendor" domain="[]" context="{'group_by': 'partner_id'}" />
                <filter string="Employee" domain="[]" context="{'group_by': 'employee_id'}" />
                <filter string="Department" domain="[]" context="{'group_by': 'department_id'}" />
                <filter string='Infrastructure Type' domain="[]" context="{'group_by' : 'infrastructure_type'}" />
            </xpath>
            <xpath expr="//search" position="inside">
                <field name="tag_ids" placeholder="Equipment Tag" />
            </xpath>
        </field>
    </record>

    <record id="maintenance.menu_maintenance_configuration" model="ir.ui.menu">
