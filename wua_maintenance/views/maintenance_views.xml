        <field name="model">wua.drainageditch</field>
        <field name="inherit_id" ref="base_wua_infrastructure_gravity_hierarchy.wua_drainageditch_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_see_gis_viewer']" position="after">
                <field name="equipment_id" invisible="1" />
                <button name="action_get_equipment" type="object" class="oe_stat_button" icon="fa-gear" groups="base_wua.group_wua_user" attrs="{'invisible': [('equipment_id','=',None)]}">
                    <div class="o_form_field o_stat_info">
                        <span class="o_stat_text">Associated</span>
                        <span class="o_stat_text">Equipment</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

