                        groups="base_wua.group_wua_user" attrs="{'invisible': [('equipment_id', '=', None)]}">
                    <div class="o_form_field o_stat_info">
                        <span class="o_stat_text">Associated</span>
                        <span class="o_stat_text">Equipment</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

    <record id="maintenance_equipmenttag_view_tree" model="ir.ui.view">
        <field name="name">Equipment Tags (tree view)</field>
        <field name="model">maintenance.equipmenttag</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="color" />
            </tree>
        </field>
    </record>

    <record id="maintenance_equipmenttag_view_search" model="ir.ui.view">
        <field name="name">Equipment Tags (search view)</field>
        <field name="model">maintenance.equipmenttag</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
            </search>
        </field>
    </record>

    <record id="maintenance.menu_maintenance_configuration" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('base_maintenance_config.group_maintenance_user'))]" />
    </record>

    <record id="maintenance_equipmenttag_action" model="ir.actions.act_window">
        <field name="name">Equipment Tags</field>
        <field name="res_model">maintenance.equipmenttag</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="maintenance_equipmenttag_view_tree" />
        <field name="search_view_id" ref="maintenance_equipmenttag_view_search" />
    </record>

    <record id="maintenance_plan.menu_maintenance_kind_configuration" model="ir.ui.menu">
        <field name="name">Maintenance kinds</field>
    </record>

    <menuitem id="maintenance_equipmenttag_menu" name="Equipment Tags" parent="maintenance.menu_maintenance_configuration" action="maintenance_equipmenttag_action" sequence="4" />

        <record id="maintenance_equipment_view_pivot" model="ir.ui.view">
        <field name="name">maintenance.equipment.pivot</field>
        <field name="model">maintenance.equipment</field>
        <field name="arch" type="xml">
            <pivot string="Equipments">
                <field name="category_id" type="row"/>
            </pivot>
        </field>
    </record>


    <record id="maintenance.hr_equipment_action" model="ir.actions.act_window">
        <field name="view_mode">tree,kanban,form,pivot</field>
        <field name="view_id" ref="wua_maintenance.hr_equipment_view_tree" />
        <field name="search_view_id" ref="wua_maintenance.maintenance_equipment_view_search_inherit_hr" />
        <field name="context">{}</field>
    </record>

    <record id="maintenance_team_view_search" model="ir.ui.view">
        <field name="name">maintenance.team.search</field>
        <field name="model">maintenance.team</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>

                <separator/>
                <filter string="Active" name="filter_active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="filter_archived" domain="[('active', '=', False)]"/>

                <group expand="0" string="Group By">
                    <filter string="Category" name="group_by_category" context="{'group_by': 'category_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="maintenance_team_view_form" model="ir.ui.view">
        <field name="name">Maintenance Teams Form</field>
        <field name="model">maintenance.team</field>
        <field name="inherit_id" ref="maintenance.maintenance_team_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//sheet/div[@class='oe_title']" position="before">
                <div name="button_box" class="oe_button_box">
                    <button name="toggle_active"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-archive"
                            confirm="Are you sure you want to toggle visibility?"
                            groups="base.group_erp_manager">
                        <field name="active"
                               widget="boolean_button"
                               options='{"terminology": "archive"}'/>
                    </button>
                </div>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="replace">
                <group>
                    <group>
                        <field name="default_team_for_viewer_creation"/>
                        <field name="partner_id" placeholder="Responsible" />
                        <field name="category_id" placeholder="Category" />
                        <field name="partner_ids" widget="many2many_tags" options="{'no_create': True}" domain="[]"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

    <record id="maintenance_team_view_tree" model="ir.ui.view">
        <field name="name">maintenance.team.tree</field>
        <field name="model">maintenance.team</field>
        <field name="inherit_id" ref="maintenance.maintenance_team_view_tree" />
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="editable"></attribute>
            </xpath>
            <xpath expr="//field[@name='name']" position="after">
                <field name="partner_id" placeholder="Responsible" />
                <field name="category_id" placeholder="Category" />
            </xpath>
        </field>
    </record>

    <record id="maintenance_team_kanban" model="ir.ui.view">
        <field name="name">maintenance.team.kanban</field>
        <field name="model">maintenance.team</field>
        <field name="inherit_id" ref="maintenance.maintenance_team_kanban" />
        <field name="arch" type="xml">
            <xpath expr="//t[@t-name='kanban-box']/div[position()=1]" position="attributes">
                <attribute name="class">oe_kanban_global_click</attribute>
            </xpath>
            <xpath expr="//div[@class='o_primary']" position="inside">
                <br />
                <br />
                <field name="partner_id" placeholder="Responsible" />
                <br />
                <field name="category_id" placeholder="Category" />
            </xpath>
        </field>
    </record>

    <record id="maintenance.maintenance_team_action_settings" model="ir.actions.act_window">
        <field name="name">Teams</field>
        <field name="res_model">maintenance.team</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="maintenance_team_view_tree" />
        <field name="view_type">form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
            Click to add a team in the maintenance request.
            </p>
        </field>
    </record>

    <record id="maintenance_dashboard_action" model="ir.actions.act_window">
        <field name="name">Maintenance Team</field>
        <field name="res_model">maintenance.team</field>
        <field name="view_type">form</field>
        <field name="view_mode">kanban,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
            Click to add a stage in the maintenance request.
            </p>
        </field>
        <field name="inherit_id" ref="maintenance.maintenance_dashboard_action" />
    </record>

</odoo>