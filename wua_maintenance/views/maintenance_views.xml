<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="maintenance_equipmenttag_view_form" model="ir.ui.view">
        <field name="name">Equipment Tags (form view)</field>
        <field name="model">maintenance.equipmenttag</field>
        <field name="arch" type="xml">
            <form duplicate="0">
                <group name="master_data">
                    <field name="name" style="width:200px" />
                    <field name="color" />
                    <field name="description" invisible="1" />
                </group>
                <group name="slave_data">
                    <notebook name="slave_data_notebook">
                        <page name="notes_page" string="Notes">
                            <field name="notes" />
                        </page>
                    </notebook>
                </group>
            </form>
        </field>
    </record>

    <record id="wua_drainageditch_view_form" model="ir.ui.view">
        <field name="name">Drainage Ditchs (form view)</field>
        <field name="model">wua.drainageditch</field>
        <field name="inherit_id" ref="base_wua_infrastructure_gravity_hierarchy.wua_drainageditch_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_see_gis_viewer']" position="after">
                <field name="equipment_id" invisible="1" />
                <button name="action_get_equipment" type="object" class="oe_stat_button" icon="fa-gear" groups="base_wua.group_wua_user" attrs="{'invisible': [('equipment_id','=',None)]}">
                    <div class="o_form_field o_stat_info">
                        <span class="o_stat_text">Associated</span>
                        <span class="o_stat_text">Equipment</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

