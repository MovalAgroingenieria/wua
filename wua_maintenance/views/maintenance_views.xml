<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_equipment_view_form" model="ir.ui.view">
        <field name="name">hr.equipment.view.form.inherit</field>
        <field name="model">maintenance.equipment</field>
        <field name="inherit_id" ref="maintenance.hr_equipment_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//form" position="attributes">
                <attribute name="duplicate">0</attribute>
            </xpath>
            <xpath expr="//div[@name='button_box']/button[1]" position="before">
                <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive" confirm="Are you sure you want to toggle visibility?" groups="base_wua.group_wua_user">
                    <field name="active" widget="boolean_button" options='{"terminology": "archive"}' />
                </button>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <field name="is_wua" invisible="1" />
                <button name="action_get_wua_infrastructure_item" type="object" class="oe_stat_button" icon="fa-cogs" attrs="{'invisible': [('is_wua','=',False)]}" groups="base_wua.group_wua_user">
                    <div class="o_form_field o_stat_info">
                        <span class="o_stat_text">Infrastructure</span>
                        <span class="o_stat_text">Item</span>
                    </div>
                </button>
            </xpath>
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="attrs">{'readonly': [('is_wua', '=', True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='category_id']" position="attributes">
                <attribute name="attrs">{'readonly': [('is_wua', '=', True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="hydraulicsector_id" placeholder="Hydraulic Sector" />
            </xpath>
            <xpath expr="//field[@name='owner_user_id']" position="after">
                <field name="tag_ids" widget="many2many_tags" />
            </xpath>
        </field>
    </record>

    <record id="hr_equipment_request_view_form" model="ir.ui.view">
        <field name="name">hr.equipment.request.view.form.inherit</field>
        <field name="model">maintenance.request</field>
        <field name="inherit_id" ref="maintenance.hr_equipment_request_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="hydraulicsector_id" placeholder="Hydraulic Sector" />
            </xpath>
        </field>
    </record>

    <record id="maintenance_equipmenttag_view_form" model="ir.ui.view">
        <field name="name">Equipment Tags (form view)</field>
        <field name="model">maintenance.equipmenttag</field>
        <field name="arch" type="xml">
            <form duplicate="0">
                <group name="master_data">
                    <field name="name" style="width:200px" />
                    <field name="color" />
                    <field name="description" invisible="1" />
                </group>
                <group name="slave_data">
                    <notebook name="slave_data_notebook">
                        <page name="notes_page" string="Notes">
                            <field name="notes" />
                        </page>
                    </notebook>
                </group>
            </form>
        </field>
    </record>

