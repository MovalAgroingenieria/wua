<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="maintenance_plan_view_tree" model="ir.ui.view">
        <field name="name">maintenance.plan.tree</field>
        <field name="model">maintenance.plan</field>
        <field name="inherit_id" ref="maintenance_plan.maintenance_plan_view_tree" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='duration']" position="after">
                <field name="days_to_create_new_maintenance"/>
            </xpath>
        </field>
    </record>

    <record id="maintenance_plan_view_form" model="ir.ui.view">
        <field name="name">maintenance.plan.form</field>
        <field name="model">maintenance.plan</field>
        <field name="inherit_id" ref="maintenance_plan.maintenance_plan_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='duration']" position="after">
                <field name="days_to_create_new_maintenance"/>
                <field name="first_execution_date"/>
            </xpath>
            <xpath expr="//field[@name='duration']" position="after">
                <field name="first_execution_date"/>
            </xpath>
        </field>
    </record>

    <record id="maintenance_plan_view_search" model="ir.ui.view">
        <field name="name">Maintenance plans (search view)</field>
        <field name="model">maintenance.plan</field>
        <field name="arch" type="xml">
            <search>
                <field name="equipment_id"/>
                <group expand="0" string="Group By">
                    <filter string="Archived" name="filter_archived" domain="[('active', '=', False)]"/>
                    <filter string="Equipment" name="equipment_id"
                     context="{'group_by':'equipment_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="maintenance_plan_configuration_view_form" model="ir.ui.view">
        <field name="name">maintenance.plan.configuration.form</field>
        <field name="model">maintenance.plan</field>
        <field name="arch" type="xml">
            <form string="Maintenance Plan">
                <div name="buttons" class="oe_button_box">
                    <button name="toggle_active"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-archive"
                            confirm="Are you sure you want to toggle visibility?"
                            groups="base.group_erp_manager">
                        <field name="active"
                                widget="boolean_button"
                                options='{"terminology": "archive"}'/>
                    </button>
                </div>
                <group>
                    <field name="equipment_id"/>
                    <field name="maintenance_kind_id"/>
                    <field name="period"/>
                    <field name="duration"/>
                    <field name="next_maintenance_date"/>
                    <field name="first_execution_date"/>
                    <field name="days_to_create_new_maintenance"/>
                    <field name="next_creation_date"/>
                </group>
            </form>
        </field>
    </record>

    <record id="maintenance_plan_configuration_view_tree" model="ir.ui.view">
        <field name="name">maintenance.plan.configuration.tree</field>
        <field name="model">maintenance.plan</field>
        <field name="arch" type="xml">
            <tree>
                <field name="equipment_id"/>
                <field name="maintenance_kind_id"/>
                <field name="period"/>
                <field name="duration"/>
                <field name="next_maintenance_date"/>
                <field name="days_to_create_new_maintenance"/>
                <field name="next_creation_date"/>
            </tree>
        </field>
    </record>

    <record id="maintenance_plan_view_pivot" model="ir.ui.view">
        <field name="name">Maintenance plans (pivot view)</field>
        <field name="model">maintenance.plan</field>
        <field name="arch" type="xml">
            <pivot string="Maintenance Plan Pivot">
                <field name="equipment_id" type="row"/>
            </pivot>
        </field>
    </record>

    <record id="maintenance_plan_view_calendar" model="ir.ui.view">
        <field name="name">Maintenance plans (calendar view)</field>
        <field name="model">maintenance.plan</field>
        <field name="arch" type="xml">
            <calendar string="Maintenance Plan Calendar" date_start="next_maintenance_date">
                <field name="equipment_id"/>
            </calendar>
        </field>
    </record>

    <record id="maintenance_plan_action" model="ir.actions.act_window">
        <field name="name">Maintenance plans</field>
        <field name="res_model">maintenance.plan</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form,pivot,calendar</field>
        <field name="view_ids"
         eval="[(5, 0),
                (0, 0, {'view_mode': 'tree',
                        'view_id': ref('maintenance_plan_configuration_view_tree')}),
                (0, 0, {'view_mode': 'form',
                        'view_id': ref('maintenance_plan_configuration_view_form')}),
                (0, 0, {'view_mode': 'pivot', 'view_id': ref('maintenance_plan_view_pivot')}),
                (0, 0, {'view_mode': 'calendar', 'view_id': ref('maintenance_plan_view_calendar')})]"/>
        <field name="search_view_id" ref="maintenance_plan_view_search"/>
    </record>

    <menuitem
        id="menu_maintenance_plan_configuration"
        name="Maintenance plans"
        parent="maintenance.menu_maintenance_configuration"
        action="maintenance_plan_action"
        sequence="5" />

</odoo>