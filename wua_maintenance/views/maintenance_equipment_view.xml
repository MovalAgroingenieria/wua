<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_equipment_request_all_action_from_equipment" model="ir.actions.act_window">
        <field name="name">Maintenance Requests</field>
        <field name="res_model">maintenance.request</field>
        <field name="src_model">maintenance.equipment</field>
        <field name="view_mode">tree,form,kanban,pivot,graph,calendar</field>
        <field name="context">{
            'default_equipment_id': active_id,
            'active_test': False,
        }</field>
        <field name="domain">[('equipment_id', '=', active_id)]</field>
    </record>

    <record id="hr_equipment_view_form" model="ir.ui.view">
        <field name="name">hr.equipment.view.form.inherit</field>
        <field name="model">maintenance.equipment</field>
        <field name="inherit_id" ref="maintenance.hr_equipment_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//form" position="attributes">
                <attribute name="duplicate">0</attribute>
            </xpath>
            <xpath expr="//div[@name='button_box']/button[1]" position="replace">
                <button name="%(hr_equipment_request_all_action_from_equipment)d"
                    type="action"
                    class="oe_stat_button"
                    icon="fa-ticket">
                    <field string="Requests" name="request_count" widget="statinfo"/>
                </button>
            </xpath>
            <xpath expr="//div[@name='button_box']/button[1]" position="before">
                <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive" confirm="Are you sure you want to toggle visibility?" groups="base_maintenance_config.group_maintenance_manager">
                    <field name="active" widget="boolean_button" options='{"terminology": "archive"}' />
                </button>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <field name="is_wua" invisible="1" />
                <button name="action_get_wua_infrastructure_item" type="object" class="oe_stat_button" icon="fa-cogs" attrs="{'invisible': [('is_wua','=',False)]}" groups="base_wua.group_wua_user">
                    <div class="o_form_field o_stat_info">
                        <span class="o_stat_text">Infrastructure</span>
                        <span class="o_stat_text">Item</span>
                    </div>
                </button>
                <button name="action_get_equipment_childs" type="object" class="oe_stat_button" icon="fa-object-group" attrs="{'invisible': [('is_wua','=',False)]}">
                    <div class="o_form_field o_stat_info">
                        <span class="o_stat_text">Equipment</span>
                        <span class="o_stat_text">Childs</span>
                    </div>
                </button>
                <button name="action_see_gis_viewer"
                                type="object"
                                class="oe_stat_button"
                                string="GIS Viewer"
                                icon="fa-map-marker"
                                attrs="{'invisible':
                                        [('geojson_geom','=',False)]}"/>
            </xpath>
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="attrs">{'readonly': [('is_wua', '=', True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='category_id']" position="attributes">
                <attribute name="attrs">{'readonly': [('is_wua', '=', True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='category_id']" position="before">
                <field name="parent_id" attrs="{'readonly': [('is_wua', '=', True)]}"/>
            </xpath>
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="hydraulicsector_id" placeholder="Hydraulic Sector" />
            </xpath>
            <xpath expr="//field[@name='owner_user_id']" position="after">
                <field name="tag_ids" widget="many2many_tags" />
            </xpath>
            <xpath expr="//field[@name='maintenance_team_id']" position="before">
                <field name="image" widget="image" class="oe_img_259_160"/>
            </xpath>
            <xpath expr="//notebook/page[last()]" position="after">
                <page string="Geometry">
                    <group>
                        <field name="geojson_geom"
                               attrs="{'readonly': [('is_wua', '=', True)]}"/>
                    </group>
                </page>
            </xpath>
            <xpath expr="//field[@name='serial_no']" position="after">
                <field name="dynamic_fields_data"/>
            </xpath>
            <xpath expr="//notebook/page[last()]" position="after">
                <page string="Requests">
                    <field name="request_ids" context="{'active_test': False}">
                        <tree>
                            <field name="sequence"/>
                            <field name="name"/>
                            <field name="request_date"/>
                            <field name="maintenance_type"/>
                            <field name="stage_id"/>
                            <field name="close_date"/>
                            <field name="active"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="hr_equipment_maintenance_plan_view_form" model="ir.ui.view">
        <field name="name">hr.equipment.view.form.inherit</field>
        <field name="model">maintenance.equipment</field>
        <field name="inherit_id" ref="maintenance_plan.hr_equipment_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='maintenance_plan_ids']" position="inside">
                <tree>
                    <field name="maintenance_kind_id"/>
                    <field name="period"/>
                    <field name="duration"/>
                    <field name="next_maintenance_date"/>
                    <field name="days_to_create_new_maintenance"/>
                    <field name="next_creation_date"/>
                </tree>
            </xpath>
        </field>
    </record>

    <record id="hr_equipment_view_tree" model="ir.ui.view">
        <field name="name">equipment.tree</field>
        <field name="model">maintenance.equipment</field>
        <field name="inherit_id" ref="maintenance.hr_equipment_view_tree" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='category_id']" position="attributes">
                <attribute name="string">Equipment Category</attribute>
            </xpath>
            <xpath expr="//field[@name='name']" position="after">
                <field name="with_infrastructure_gis" invisible="1"/>
                <button name="action_see_gis_viewer"
                        type="object" class="oe_stat_button"
                        string="GIS Viewer"
                        icon="fa-map-marker"
                        attrs="{'invisible':
                                [('with_infrastructure_gis','=',False)]}"/>
            </xpath>
        </field>
    </record>

    <record id="maintenance_equipment_view_search_inherit_hr" model="ir.ui.view">
        <field name="name">equipment.search.inherit</field>
        <field name="model">maintenance.equipment</field>
        <field name="inherit_id" ref="hr_maintenance.maintenance_equipment_view_search_inherit_hr" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='owner_user_id']" position="after">
                <filter string='Is WUA: Yes' name="filter_is_wua_true" domain="[('is_wua', '!=', False)]" />
                <filter string='Is WUA: No' name="filter_is_wua_false" domain="[('is_wua', '!=', True)]" />
                <separator/>
                <filter string='Primary' name="filter_is_primary" domain="[('is_primary', '!=', False)]"/>
                <separator/>
                <filter string='With Infrastructure GIS ' name="filter_with_infrastructure_gis" domain="[('with_infrastructure_gis', '=', True)]"/>
                <filter string='Without Infrastructure GIS ' name="filter_without_infrastructure_gis" domain="[('with_infrastructure_gis', '!=', True)]"/>
                <separator/>
                <filter string='With Requests' name="filter_with_requests" domain="[('request_count', '&gt;', 0)]"/>
                <filter string='With Open Requests' name="filter_with_open_requests" domain="[('request_open_count', '&gt;', 0)]"/>
            </xpath>
            <xpath expr="//group[1]" position="replace">
                <filter string="Technicians" domain="[]" context="{'group_by': 'technician_user_id'}" />
                <filter string="Category" domain="[]" name="group_by_category_id" context="{'group_by': 'category_id'}" />
                <filter string="Owner" domain="[]" context="{'group_by': 'owner_user_id'}" />
                <filter string="Vendor" domain="[]" context="{'group_by': 'partner_id'}" />
                <filter string="Employee" domain="[]" context="{'group_by': 'employee_id'}" />
                <filter string="Department" domain="[]" context="{'group_by': 'department_id'}" />
                <filter string='Infrastructure Type' domain="[]" context="{'group_by' : 'infrastructure_type'}" />
            </xpath>
            <xpath expr="//search" position="inside">
                <field name="tag_ids" placeholder="Equipment Tag"/>
                <field name="category_id"/>
            </xpath>
        </field>
    </record>

    <record id="hr_equipment_view_kanban" model="ir.ui.view">
        <field name="name">equipment.kanban.inherit</field>
        <field name="model">maintenance.equipment</field>
        <field name="inherit_id" ref="maintenance.hr_equipment_view_kanban" />
        <field name="arch" type="xml">
            <xpath expr="//div[@class='mt4']" position="before">
                <field name="tag_html" invisible="1" />
                <div class="o_kanban_tags" t-raw="record.tag_html.value" />
            </xpath>
        </field>
    </record>

</odoo>