<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_waterconnection_view_form_scada_mula" model="ir.ui.view">
        <field name="name">wua.waterconnection form (wua_remotecontrol_scada_mula)</field>
        <field name="model">wua.waterconnection</field>
        <field name="inherit_id"
               ref="base_wua_remotecontrol_rest.wua_waterconnection_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='telecontrol_associated']"
                   position="after">
                <field name="scada_mula_sector"
                       attrs="{'invisible': [('telecontrol_associated', '!=', 'scada_mula')]}"/>
                <field name="scada_mula_arqueta"
                       attrs="{'invisible': [('telecontrol_associated', '!=', 'scada_mula')]}"/>
                <field name="scada_mula_parcela"
                       attrs="{'invisible': [('telecontrol_associated', '!=', 'scada_mula')]}"/>
            </xpath>
        </field>
    </record>

</odoo>
