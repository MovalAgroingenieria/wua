<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_wua_wateringrequest_document" inherit_id="base_wua_gravity_irrigation.report_wua_wateringrequest_document">
        <xpath expr="//div[@name='wua_irrigator_data']" position="after">
            <!-- Quota balances -->
            <div name="quota_balances_data" style="margin-top:20px;">
                <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                        <div style="float: left; width: 32px;"><span class="fa fa-moval-quotas"/></div>
                        <div style="float: left; display: inline;"><strong>Quota balances</strong></div>
                    </div>
                </div>
                <div class="text-center" style="margin-top: 4px;">
                    <span t-field="o.html_quota_balance"/>
                </div>
            </div>
        </xpath>
    </template>

</odoo>
