<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_filteringstation_view_form" model="ir.ui.view">
        <field name="name">Filteringstations (form view)</field>
        <field name="model">wua.filteringstation</field>
        <field name="inherit_id" ref="base_wua_infrastructure_primary.wua_filteringstation_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='slave_data']" position="after">
                <templates>
                    <t t-name="gisviewer">
                         <field name="with_gis_filteringstation" invisible="1"/>
                         <div id="gisviewer_filteringstation" attrs="{'invisible': [('with_gis_filteringstation','=',False)]}">
                             <field name="html_gisviewer_frame" widget="html"/>
                         </div>
                    </t>
                </templates>
            </xpath>
        </field>
    </record>

</odoo>
