<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_reservoirreading_view_tree" model="ir.ui.view">
        <field name="name">Reservoirreading (tree view)</field>
        <field name="model">wua.reservoirreading</field>
        <field name="inherit_id" ref="base_wua_reservoir.wua_reservoirreading_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='is_last_reading']" position="after">
                <field name="from_import" string="Man."/>
            </xpath>
        </field>
    </record>

    <record id="wua_reservoirreading_view_search" model="ir.ui.view">
        <field name="name">Reservoirreadings (search view)</field>
        <field name="model">wua.reservoirreading</field>
        <field name="inherit_id" ref="base_wua_reservoir.wua_reservoirreading_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='reservoir_id']" position="after">
                <separator/>
                <filter string="Manual Introduction: Yes"
                 name="fromimportyes"
                 domain="[('from_import','=',True)]"/>
                <filter string="Manual Introduction: No (from remote control)"
                 name="fromimportno"
                 domain="[('from_import','=',False)]"/>
            </xpath>
        </field>
    </record>

</odoo>