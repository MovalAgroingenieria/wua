<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_reservoir_view_form" model="ir.ui.view">
        <field name="name">Reservoir (form view)</field>
        <field name="model">wua.reservoir</field>
        <field name="inherit_id"
               ref="base_wua_reservoir.wua_reservoir_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <field name="remotecontrol_enabled" invisible="1"/>
                <field name="id" invisible="1"/>
                <header>
                    <button name="do_import_reservoirreadings_from_reservoir"
                            type="object" string="Get readings"
                            icon="fa-rss"
                            attrs="{'invisible':
                                    ['|', ('remotecontrol_enabled','=',False),
                                          ('id', '=', 0)]}"
                            groups="base_wua.group_wua_manager"
                            confirm="Import reservoir readings?"/>
                </header>
            </xpath>
            <xpath expr="//field[@name='to_vol_coef_c']" position="after">
              <field name="telecontrol_associated"/>
            </xpath>
        </field>
    </record>

    <record id="wua_reservoir_view_tree" model="ir.ui.view">
        <field name="name">Reservoir (tree view)</field>
        <field name="model">wua.reservoir</field>
        <field name="inherit_id" ref="base_wua_reservoir.wua_reservoir_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='volume_nmn']" position="after">
                <field name="telecontrol_associated"/>
            </xpath>
        </field>
    </record>

    <record id="wua_import_reservoirreadings_from_reservoirs" model="ir.actions.server">
        <field name="name">Get readings</field>
        <field name="model_id" ref="model_wua_reservoir"/>
        <field name="state">code</field>
        <field name="code">
            if context.get('active_ids'):
                action = env['wua.reservoir'].do_import_reservoirreadings_from_reservoirs(context['active_ids'])
        </field>
    </record>

    <record id="wua_action_import_reservoirreadings_from_reservoirs" model="ir.values">
        <field name="name">Get readings</field>
        <field name="model">wua.reservoir</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('wua_import_reservoirreadings_from_reservoirs'))"/>
    </record>

</odoo>