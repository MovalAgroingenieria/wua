<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_quota_view_form" model="ir.ui.view">
        <field name="name">Quotas (form view)</field>
        <field name="model">wua.quota</field>
        <field name="inherit_id"
               ref="base_wua_quota_management.wua_quota_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='master_data']"
                   position="before">
                <div class="oe_button_box" name="button_box">
                    <button name="action_get_particularpresconsumptions"
                            type="object" class="oe_stat_button"
                            icon="fa-monitoring-control"
                            attrs="{'invisible':[('provisional_extra_consumption','=',0)]}">
                        <div class="o_form_field o_stat_info">
                            <span class="o_stat_text">Extra</span>
                            <span class="o_stat_text">Consumptions</span>
                        </div>
                    </button>
                </div>
            </xpath>
            <xpath expr="//field[@name='negative_balance']"
                   position="after">
                <field name="provisional_extra_consumption"
                       string="Extra C. (provisional)"/>
                <field name="provisional_balance"/>
            </xpath>
        </field>
    </record>

    <record id="wua_quota_view_tree" model="ir.ui.view">
        <field name="name">Quotas (tree view)</field>
        <field name="model">wua.quota</field>
        <field name="inherit_id"
               ref="base_wua_quota_management.wua_quota_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='balance']"
                   position="after">
                <field name="provisional_extra_consumption"
                       string="Extra Cons. (provisional)"/>
                <field name="provisional_balance"/>
            </xpath>
        </field>
    </record>

    <record id="wua_quota_aggregatevalue_view_tree" model="ir.ui.view">
        <field name="name">Quotas Aggregate (tree view)</field>
        <field name="model">wua.quota.aggregatevalue</field>
        <field name="inherit_id"
               ref="base_wua_quota_management.wua_quota_aggregatevalue_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='balance']"
                   position="after">
                <field name="provisional_extra_consumption"
                       string="Extra Cons. (provisional)"/>
                <field name="provisional_balance"/>
            </xpath>
        </field>
    </record>

</odoo>