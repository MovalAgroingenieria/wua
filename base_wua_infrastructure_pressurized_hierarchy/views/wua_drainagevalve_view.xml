<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_airvalve_view_form" model="ir.ui.view">
        <field name="name">Airvalves (form view)</field>
        <field name="model">wua.airvalve</field>
        <field name="inherit_id" ref="base_wua_infrastructure.wua_airvalve_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='hydraulicsector_id']" position="before">
                <field name="waterpipe_id"/>
            </xpath>
            <xpath expr="//field[@name='hydraulicsector_id']" position="attributes">
                <attribute name="attrs">{'readonly': [('waterpipe_id', '!=', False)]}</attribute>
            </xpath>
        </field>
    </record>

    <record id="wua_airvalve_view_tree" model="ir.ui.view">
        <field name="name">Airvalves (tree view)</field>
        <field name="model">wua.airvalve</field>
        <field name="inherit_id" ref="base_wua_infrastructure.wua_airvalve_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='hydraulicsector_id']" position="after">
                <field name="waterpipe_id" invisible="1"/>
            </xpath>
        </field>
    </record>

    <record id="wua_airvalve_view_search" model="ir.ui.view">
        <field name="name">Airvalves (search view)</field>
        <field name="model">wua.airvalve</field>
        <field name="inherit_id" ref="base_wua_infrastructure.wua_airvalve_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='hydraulic_sector']" position="after">
                <filter string="Waterpipe"
                        name="waterpipe"
                        context="{'group_by':'waterpipe_id'}"/>
            </xpath>
        </field>
    </record>

</odoo>