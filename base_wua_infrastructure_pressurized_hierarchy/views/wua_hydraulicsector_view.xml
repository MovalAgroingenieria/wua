<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_hydraulicsector_view_form" model="ir.ui.view">
        <field name="name">Hydraulic Sectors (form view)</field>
        <field name="model">wua.hydraulicsector</field>
        <field name="inherit_id" ref="base_wua_infrastructure.wua_hydraulicsector_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='total_affected_area_official']" position="after">
                <field name="main_waterpipe_id"/>
            </xpath>
        </field>
    </record>

    <record id="wua_hydraulicsector_view_tree" model="ir.ui.view">
        <field name="name">Hydraulic Sectors (tree view)</field>
        <field name="model">wua.hydraulicsector</field>
        <field name="inherit_id" ref="base_wua_infrastructure.wua_hydraulicsector_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='number_of_parcels']" position="after">
                <field name="main_waterpipe_id"/>
            </xpath>
        </field>
    </record>

</odoo>
