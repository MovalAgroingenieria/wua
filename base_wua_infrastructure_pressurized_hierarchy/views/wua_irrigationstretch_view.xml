<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_irrigationstretch_view_form" model="ir.ui.view">
        <field name="name">Irrigation Stretches (form view)</field>
        <field name="model">wua.irrigationstretch</field>
        <field name="inherit_id" ref="base_wua_infrastructure.wua_irrigationstretch_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='channel_section_width']" position="after">
                <field name="waterpipe_id"
                       attrs="{'invisible': [('type','!=','pressure')]}"/>
            </xpath>
        </field>
    </record>


</odoo>
