<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_presconsumption_view_form" model="ir.ui.view">
        <field name="name">Consumptions (form view)</field>
        <field name="model">wua.presconsumption</field>
        <field name="inherit_id" ref="base_wua_pressurized_irrigation.wua_presconsumption_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='hydraulicsector_id']" position="after">
                <field name="waterpipe_id"/>
            </xpath>
        </field>
    </record>

    <record id="wua_presconsumption_view_search" model="ir.ui.view">
        <field name="name">Consumptions (search view)</field>
        <field name="model">wua.presconsumption</field>
        <field name="inherit_id" ref="base_wua_pressurized_irrigation.wua_presconsumption_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='hydraulicsector_id']" position="after">
                <field name="waterpipe_id"/>
            </xpath>
            <xpath expr="//filter[@name='waterconnection']" position="after">
                <filter string="Water Pipe" name="waterpipe"
                     context="{'group_by':'waterpipe_id'}"/>
            </xpath>
        </field>
    </record>

   <record id="wua_technical_update_waterpipe_id_in_presconsumptions_action" model="ir.actions.server">
        <field name="name">Update Waterpipe in Presconsumptions</field>
        <field name="model_id" ref="base_wua_infrastructure_pressurized_hierarchy.model_wua_presconsumption"/>
        <field name="code">
            action = env["wua.presconsumption"].update_waterpipe_id()
        </field>
    </record>

    <menuitem id="wua_technical_update_waterpipe_id_in_presconsumptions_menu"
              name="Calculation: Watepipe in pres. consumptions"
              parent="wua_structure_irrigation.base_wua_irrigation_technical_menu"
              action="wua_technical_update_waterpipe_id_in_presconsumptions_action"
              sequence="8"/>

</odoo>
