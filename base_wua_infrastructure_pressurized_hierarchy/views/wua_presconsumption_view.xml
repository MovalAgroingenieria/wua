<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_presconsumption_view_form" model="ir.ui.view">
        <field name="name">Consumptions (form view)</field>
        <field name="model">wua.presconsumption</field>
        <field name="inherit_id" ref="base_wua_pressurized_irrigation.wua_presconsumption_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='hydraulicsector_id']" position="after">
                <field name="waterpipe_id"/>
            </xpath>
        </field>
    </record>

    <record id="wua_presconsumption_view_search" model="ir.ui.view">
        <field name="name">Consumptions (search view)</field>
        <field name="model">wua.presconsumption</field>
        <field name="inherit_id" ref="base_wua_pressurized_irrigation.wua_presconsumption_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='hydraulicsector_id']" position="after">
                <field name="waterpipe_id"/>
            </xpath>
            <xpath expr="//filter[@name='waterconnection']" position="after">
                <filter string="Water Pipe" name="waterpipe"
                     context="{'group_by':'waterpipe_id'}"/>
            </xpath>
        </field>
    </record>

</odoo>
