<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_invoice_document" inherit_id="account.report_invoice_document">
        <xpath expr="//div[@name='details_section']" position="after">
            <t t-set="with_hydricmov_presconsumptions" t-value="False"/>
            <t t-foreach="o.invoice_line_ids" t-as="l">
                <t t-if="l.categ_id.productcategory_code == 14">
                    <t t-set="with_hydricmov_presconsumptions" t-value="True"/>
                </t>
            </t>
            <t t-if="with_hydricmov_presconsumptions">
                <t t-set="consumptions_hydricmov" t-value="o.get_hydricmov_presconsumptions_from_lines(o.invoice_line_ids)"/>
                <t t-if="consumptions_hydricmov">
                    <div name="consumptions_hydricmov">
                        <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                            <t t-if="report_style == 'light'">
                                <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                    <div style="float: left; width: 32px;"><span class="fa fa-moval-irrigation"/></div>
                                    <div style="float: left; display: inline;"><strong>Consumptions</strong></div>
                               </div>
                            </t>
                            <t t-else="">
                                <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                    <div style="float: left; width: 32px;"><span class="fa fa-moval-irrigation"/></div>
                                    <div style="float: left; display: inline;"><strong>Consumptions</strong></div>
                                </div>
                            </t>
                        </div>
                        <div class="row" style="margin: 4 8px;">
                            <table class="table table-condensed">
                                <thead>
                                    <tr>
                                        <th name="th_waterconnection">Water Connection</th>
                                        <th class="text-center">Date initial time</th>
                                        <th class="text-center">Date final time</th>
                                        <th class="text-center">Initial Reading</th>
                                        <th class="text-right">Final Reading</th>
                                        <th class="text-right">Gross Vol. (m³)</th>
                                        <th class="text-right">Adjust. (m³)</th>
                                        <th class="text-right">Real Vol. (m³)</th>
                                    </tr>
                                </thead>
                                <tbody class="invoice_tbody">
                                      <tr t-foreach="consumptions_hydricmov" t-as="c">
                                          <t t-set="reading_initial_time" t-value="context_timestamp(datetime.datetime.strptime(c['reading_initial_time'],'%Y-%m-%d %H:%M:%S')).strftime('%d/%m/%y')"/>
                                          <t t-set="reading_end_time" t-value="context_timestamp(datetime.datetime.strptime(c['reading_end_time'],'%Y-%m-%d %H:%M:%S')).strftime('%d/%m/%y')"/>
                                          <td name="td_waterconnection"><span t-esc="c['waterconnection']"/></td>
                                          <td class="text-center"><span t-esc="reading_initial_time"/></td>
                                          <td class="text-center"><span t-esc="reading_end_time"/></td>
                                          <td class="text-right">
                                              <t t-set="initial_volume"
                                                 t-value="o.env['wua.parcel'].transform_float_to_locale(c['initial_volume'], 0)"/>
                                              <span t-esc="initial_volume"/>
                                          </td>
                                          <td class="text-right">
                                              <t t-set="end_volume"
                                                 t-value="o.env['wua.parcel'].transform_float_to_locale(c['end_volume'], 0)"/>
                                              <span t-esc="end_volume"/>
                                          </td>
                                          <td class="text-right">
                                              <t t-set="volume"
                                                 t-value="o.env['wua.parcel'].transform_float_to_locale(c['volume'], 0)"/>
                                              <span t-esc="volume"/>
                                          </td>
                                          <td class="text-right">
                                              <t t-set="adjustement_volume"
                                                 t-value="o.env['wua.parcel'].transform_float_to_locale(c['adjustement_volume'], 0)"/>
                                              <span t-esc="adjustement_volume"/>
                                          </td>
                                          <td class="text-right">
                                              <t t-set="volume_real"
                                                 t-value="o.env['wua.parcel'].transform_float_to_locale(c['volume_real'], 0)"/>
                                              <span t-esc="volume_real"/>
                                          </td>
                                      </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </t>
            </t>
        </xpath>
    </template>

</odoo>
