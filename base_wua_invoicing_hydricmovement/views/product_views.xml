<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_template_form_view" model="ir.ui.view">
        <field name="name">Products (form view)</field>
        <field name="model">product.template</field>
        <field name="inherit_id"
               ref="base_wua_quota_management.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='reduction_factor']" position="after">
              <field name="possible_related_product" invisible="1"/>
              <field name="related_product"
                     attrs="{'invisible': [('possible_related_product','=',False)],
                             'required':[('possible_related_product','=', True)]}"/>
            </xpath>
        </field>
    </record>

</odoo>
