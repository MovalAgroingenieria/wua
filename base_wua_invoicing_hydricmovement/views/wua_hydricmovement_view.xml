<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="wua_hydricmovement_view_tree" model="ir.ui.view">
      <field name="name">Hydricmovement (tree view)</field>
      <field name="model">wua.hydricmovement</field>
      <field name="inherit_id" ref="base_wua_quota_management.wua_hydricmovement_view_tree"/>
      <field name="arch" type="xml">
          <xpath expr="//field[@name='description']" position="after">
              <field name="invoiced_hydricmovement"/>
              <field name="number_of_invoices"/>
          </xpath>
      </field>
  </record>

  <record id="wua_hydricmovement_view_search" model="ir.ui.view">
      <field name="name">Hydricmovements (search view)</field>
      <field name="model">wua.hydricmovement</field>
      <field name="inherit_id" ref="base_wua_quota_management.wua_hydricmovement_view_search"/>
      <field name="arch" type="xml">
          <xpath expr="//group[@expand='0']" position="before">
              <filter string="Invoiced: Yes" name="invoicedyes"
               domain="[('invoiced_hydricmovement','=',True)]"/>
              <filter string="Invoiced: No" name="invoicedno"
               domain="[('invoiced_hydricmovement','=',False)]"/>
               <separator/>
          </xpath>
          <xpath expr="//filter[@name='grouped_partner']" position="after">
            <filter string="Invoiceset"
                    name="grouped_invoiceset"
             context="{'group_by':'invoiceset_id'}"/>
          </xpath>
      </field>
  </record>

</odoo>
