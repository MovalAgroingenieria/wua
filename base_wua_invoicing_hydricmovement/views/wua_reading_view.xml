<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_reading_view_form" model="ir.ui.view">
        <field name="name">Readings (form view)</field>
        <field name="model">wua.reading</field>
        <field name="inherit_id" ref="base_wua_pressurized_irrigation.wua_reading_view_form"/>
        <field name="arch" type="xml">
          <xpath expr="//field[@name='volume']" position="attributes">
              <attribute name="attrs">
                  {'readonly':['|', '|', '&amp;', ('id', '>', 0),
                   ('is_last_reading', '!=', True),
                   ('invoiced_reading_quota','=',True),
                   ('invoiced_reading','=',True)]}
              </attribute>
          </xpath>
          <xpath expr="//field[@name='validated']"
                 position="attributes">
              <attribute name="attrs">
                  {'readonly':['|', ('invoiced_reading','=',True),
                    ('invoiced_reading_quota','=',True)]}
              </attribute>
          </xpath>
          <xpath expr="//field[@name='volume']" position="before">
              <field name="invoiced_reading_quota" invisible="1"/>
          </xpath>
        </field>
    </record>

</odoo>
