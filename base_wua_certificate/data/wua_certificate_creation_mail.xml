<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Certificate creation mail template-->
        <record model="mail.template" id="email_template_certificate_creation">
            <field name="name">Certificate creation notification</field>
            <field name="model_id" ref="model_wua_certificate"/>
            <field name="subject">Certificate creation - ${object.name}</field>
            <field name="email_from"></field>
            <field name="email_to"></field>
            <field name="lang"></field>
            <field name="auto_delete">True</field>
            <field name="body_html">
                <![CDATA[
                <p>Created new certificate with the following details:</p>
                <ul>
                    <li>Element identifier: ${object.name}</li>
                    <li>Date of issue: ${object.date_of_issue}</li>
                    <li>Type of certificate: ${object.certificatetype_id.name}</li>
                    <li>Issuer: ${object.partner_id.name}</li>
                </ul>
                ]]>
            </field>
        </record>
    </data>
</odoo>