<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">
    
        <record id="certificatetype_no_variation_email_template"
                model="mail.template">
            <field name="name">Standard Certificate</field>
            <field name="model_id" ref="base_wua_certificate.model_wua_certificate"/>
            <field name="partner_to">${object.partner_id.id}</field>
            <field name="subject">Certificate: ${object.reference_number}, from ${object.partner_id.company_id.name}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        Dear Sir/Madam,
                        <br/><br/>
                        Attached to this letter, you will find the requested certificate.
                        <br/><br/>
                        Best regards.
                    </p>
                </div>
            </field>
            <field name="lang">${object.partner_id.lang}</field>
            <field name="report_template" ref="action_wua_certificate_report"/>
            <field name="report_name">${object.name}</field>
            <field name="comp_cons">True</field>
        </record>

    </data>

</odoo>