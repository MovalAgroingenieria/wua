<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="0">

        <record id="rule_wua_certificate_group_wua_portal_user" model="ir.rule">
            <field name="name">Rule for Wua Portal User on certificates</field>
            <field name="model_id" ref="model_wua_certificate"/>
            <field name="domain_force">
                ['|', ('partner_id','=',user.partner_id.id),
                      ('partner_id.child_ids','=',user.partner_id.id)]
            </field>
            <field name="groups" eval="[(4, ref('base_wua.group_wua_portal_user'))]"/>
        </record>

        <record id="rule_wua_certificate_parcel_group_wua_portal_user" model="ir.rule">
            <field name="name">Rule for Wua Portal User on parcels of certificate</field>
            <field name="model_id" ref="model_wua_certificate_parcel"/>
            <field name="domain_force">
                ['|', ('certificate_id.partner_id','=',user.partner_id.id),
                      ('certificate_id.partner_id.child_ids','=',user.partner_id.id)]
            </field>
            <field name="groups" eval="[(4, ref('base_wua.group_wua_portal_user'))]"/>
        </record>

    </data>

</odoo>