<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="assets_backend"
              name="static_resources_base_wua_certificate"
              inherit_id="web.assets_backend">
        <xpath expr="." position="inside">
            <link rel="stylesheet"
             href="/base_wua_certificate/static/src/css/base_wua_certificate.css"/>
        </xpath>
    </template>

    <template id="minimal_layout_certificate_mod" name="certificate report modifications" inherit_id="report.minimal_layout">
        <xpath expr="//head" position="inside">
            <link rel="stylesheet" type="text/css" href="/base_wua_certificate/static/src/css/certificate_report.css"/>
        </xpath>
    </template>

</odoo>