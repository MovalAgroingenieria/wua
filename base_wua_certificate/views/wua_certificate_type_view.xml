<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_certificate_type_view_form" model="ir.ui.view">
        <field name="name">Types of certificate (form view)</field>
        <field name="model">wua.certificate.type</field>
        <field name="arch" type="xml">
            <form duplicate="0">
                <field name="id" invisible="1"/>
                <field name='number_of_certificates' invisible="1"/>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_get_certificates"
                                type="object" class="oe_stat_button"
                                icon="fa-certificate"
                                attrs="{'invisible': [('number_of_certificates','=',0)]}"
                                groups="base_wua.group_wua_user">
                            <div class="o_form_field o_stat_info">
                                <span class="o_stat_value">
                                    <field name="number_of_certificates"/>
                                </span>
                                <span class="o_stat_text">Certificates</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name" string="Certificate Type:"/>
                        <h1>
                             <field name="name"
                                    style="margin-top:5px"
                                    attrs="{'readonly': [('certificatetype_code','=',1)]}"/>
                        </h1>
                        <div>
                            <label for="certificatetype_code"/>
                            <field name="certificatetype_code"
                                   style="width:100px"
                                   attrs="{'readonly': [('id','>',0)]}"/>
                        </div>
                    </div>
                    <group name="master_data"
                           groups="base_wua.group_wua_user">
                        <group name="master_data_left">
                            <field name="mailtemplate_id"/>
                            <div name="include_parcel"
                                 style="margin-top:16px" colspan="2">
                                <span style="font-weight:bold;">
                                When creating the certificate, include a parcel if...
                                </span><br/>
                                <field name="include_parcel_if_owner"
                                       nolabel="1" style="margin-top:10px"/>
                                <span>The partner is owner</span><br/>
                                <field name="include_parcel_if_lessee"
                                       nolabel="1"/>
                                <span>The partner is lessee</span><br/>
                                <field name="include_parcel_if_payer"
                                       nolabel="1"/>
                                <span>The partner is payer</span>
                            </div>
                        </group>
                        <group name="master_data_right">
                            <div name="section_notes" colspan="2"
                                style="text-align:center;">
                                <span style="font-weight:bold;">
                                N O T E S
                                </span>
                            </div>
                            <hr colspan="2"/>
                            <field name="notes"
                                   nolabel="1" colspan="2"/>
                        </group>
                    </group>
                    <div name="template_data"
                         groups="base_wua.group_wua_user">
                        <hr/>
                        <div name="section_main_page"
                            style="text-align:center;">
                            <span style="font-weight:bold;">
                            T E M P L A T E
                            </span>
                        </div>
                        <hr/>
                        <field name="main_page" nolabel="1"/>
                        <hr/>
                        <div name="section_final_paragraph"
                            style="text-align:center;">
                            <span style="font-weight:bold;margin-right:16px">
                            F I N A L
                            </span>
                            <span style="font-weight:bold;">
                            P A R A G R A P H
                            </span>
                        </div>
                        <hr/>
                        <field name="final_paragraph" nolabel="1"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="wua_certificate_type_view_tree" model="ir.ui.view">
        <field name="name">Types of certificate (tree view)</field>
        <field name="model">wua.certificate.type</field>
        <field name="arch" type="xml">
            <tree class=
                  "o_base_wua_certificate_certificate_type_view_tree">
                <field name="certificatetype_code"/>
                <field name="name"/>
                <field name="notes_text"
                       string="Notes of interest"/>
                <field name="number_of_certificates"
                       string="N. of certificates"/>
            </tree>
        </field>
    </record>

    <record id="wua_certificate_type_view_search" model="ir.ui.view">
        <field name="name">Types of certificate (search view)</field>
        <field name="model">wua.certificate.type</field>
        <field name="arch" type="xml">
            <search>
                <field name="certificatetype_code"/>
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="wua_certificate_type_action"
            model="ir.actions.act_window">
        <field name="name">Types of certificate</field>
        <field name="res_model">wua.certificate.type</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids"
         eval="[(5, 0),
                (0, 0, {'view_mode': 'tree',
                        'view_id': ref('wua_certificate_type_view_tree')}),
                (0, 0, {'view_mode': 'form',
                        'view_id': ref('wua_certificate_type_view_form')})]"/>
        <field name="search_view_id" ref="wua_certificate_type_view_search"/>
    </record>

    <menuitem id="certificate_type_menu"
              name="Certificate Types"
              parent="base_wua.base_wua_census_configuration_menu"
              sequence="30"
              action="wua_certificate_type_action"/>

</odoo>