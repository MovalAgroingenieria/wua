<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <report id="action_wua_certificate_report"
            string="Certificate"
            model="wua.certificate"
            report_type="qweb-pdf"
            name="base_wua_certificate.report_wua_certificate"
            paperformat="base_wua_report.paperformat_wua_reports"
            menu="False"
            groups="base_wua.group_wua_user"/>

    <template id="report_wua_certificate">
        <t t-call="report.html_container">
            <t t-call="base_wua_report.wua_external_layout">
                <div class="page">
                    <t t-foreach="docs" t-as="o">
                        <t t-call="base_wua_certificate.report_wua_certificate_document"/>
                        <p style="page-break-after:always;"></p>
                    </t>
                </div>
            </t>
        </t>
    </template>

    <template id="report_wua_certificate_document">
        <t t-set="report_style" t-value="o.env['ir.values'].get_default('wua.configuration', 'reports_style')"/>
        <t t-set="use_intersected_area" t-value="o.env['ir.values'].get_default('wua.configuration', 'use_intersected_area') and o.env['ir.values'].get_default('wua.configuration', 'intersection_management')"/>
        <div name="full_report">
            <div class="row" name="section_master">
                <!-- Title -->
                <div class="col-xs-12 text-justify" style="margin-top: 10px;margin-bottom: 40px;">
                    <span t-field="o.html_certificate_title"/>
                </div>
                <t t-if="o.state == '01_draft'">
                    <div class="col-xs-12 text-center theme-report-color" style="margin-bottom: 20px;">
                        <span>( D R A F T )</span>
                    </div>
                </t>
            </div>
            <!-- Text -->
            <div class="row h4 mt28 mb4" name="section_parcel" style="padding-bottom: 4px;">
                <t t-if="report_style == 'light'">
                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                        <div style="float: left; width: 32px;"><span class="fa fa-certificate"/></div>
                        <div style="float: left; display: inline;"><strong>Certificate</strong></div>
                        <div style="float: right;">
                            <strong><span t-field="o.reference_number"/></strong>
                        </div>
                   </div>
                </t>
                <t t-else="">
                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                        <div style="float: left; width: 32px;"><span class="fa fa-certificate"/></div>
                        <div style="float: left; display: inline;"><strong>Certificate</strong></div>
                        <div style="float: right;">
                            <strong><span t-field="o.reference_number"/></strong>
                        </div>
                    </div>
                </t>
            </div>
            <div name="main_page_div" class="col-xs-12 text-justify" style="margin-top: 4px;">
                <span t-field="o.sudo().rendered_main_page"/>
            </div>

            <p style="page-break-after:always;"></p>

            <!-- Parcels -->
            <div class="row h4 mt28 mb4" name="section_detail" style="padding-bottom: 4px;">
                <t t-if="report_style == 'light'">
                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                        <div style="float: left; width: 32px;"><span class="fa fa-moval-parcel"/></div>
                        <div style="float: left; display: inline;"><strong>Parcels</strong></div>
                   </div>
                </t>
                <t t-else="">
                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                        <div style="float: left; width: 32px;"><span class="fa fa-moval-parcel"/></div>
                        <div style="float: left; display: inline;"><strong>Parcels</strong></div>
                    </div>
                </t>
            </div>
            <t t-set="certificateparcel_ids" t-value="o.certificateparcel_ids.filtered(lambda x: x.included_in_certificate)"/>
            <t t-if="certificateparcel_ids">
                <t t-set="measurement_unit" t-value="certificateparcel_ids[0].parcel_id._compute_area_measurement_name()"/>
            </t>
            <t t-else="">
                <t t-set="measurement_unit" t-value="str('N/A')"/>
            </t>
            <t t-if="certificateparcel_ids" name="parcels_table">
                <table class="table table-condensed table-striped">
                    <thead>
                        <tr>
                            <th name="th_parcel_id" class="text-left">Land Parcel</th>
                            <th name="th_cadastral_reference" class="text-center">Cadastral Reference</th>
                            <th name="th_area_official" class="text-right">Area (<span><t t-esc="measurement_unit"/></span>)</th>
                            <th name="th_ownership_percentage" class="text-right">Ownership %</th>
                            <th name="th_water_costs_percentage" class="text-right">Water Costs %</th>
                            <th name="th_other_costs_percentage" class="text-right">Other Costs %</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-set="total_area_official" t-value="0.0"/>
                        <tr t-foreach="certificateparcel_ids" t-as="l">
                            <td name="td_parcel_id" align="left"><span t-field="l.parcel_id"/></td>
                            <td name="td_cadastral_reference" align="center"><span t-field="l.cadastral_reference"/></td>
                            <td name="td_area_official"align="right">
                                <t t-if="use_intersected_area">
                                    <span t-field="l.area_intersected_perimeter"/>
                                    <t t-set="total_area_official" t-value="total_area_official + l.area_intersected_perimeter"/>
                                </t>
                                <t t-else="">
                                    <span t-field="l.area_official"/>
                                    <t t-set="total_area_official" t-value="total_area_official + l.area_official"/>
                                </t>
                             </td>
                            <td name="td_ownership_percentage" align="right"><span t-field="l.ownership_percentage"/></td>
                            <td name="td_water_costs_percentage" align="right"><span t-field="l.water_costs_percentage"/></td>
                            <td name="td_other_costs_percentage" align="right"><span t-field="l.other_costs_percentage"/></td>
                        </tr>
                        <tr name="total_area">
                            <td></td>
                            <td><b>Total area:</b></td>
                            <td class="text-right"><span t-esc="o.env['wua.parcel'].transform_float_to_locale(total_area_official, 4)"/></td>
                            <td></td><td></td><td></td>
                        </tr>
                    </tbody>
                </table>
            </t>
            <t t-else="">
                <span>No parcel found for this partner.</span>
            </t>
            <t t-if="o.rendered_final_paragraph">
                <div name="final_paragraph_div" class="col-xs-12 text-justify" style="padding-left: 40px;padding-right: 40px;padding-top: 40px">
                    <span t-field="o.sudo().rendered_final_paragraph"/>
                </div>
            </t>

            <!-- Force new page -->
            <div style="
                page-break-after: always;
                height: 0;
                display: block;
                clear: both;">&amp;nbsp;</div>

            <!-- Aerial images -->
            <t t-if="o.map_type_in_report == '01_one'">
                <div name="wua_parcel_aerial_images_01">
                    <t t-set="parcels_show" t-value="o.certificateparcel_ids.filtered(lambda x: x.included_in_certificate)"/>
                    <t t-if="parcels_show">
                        <t t-foreach="parcels_show" t-as="p">
                            <t t-set="parcel_img_to_use" t-value="p.parcel_id.aerial_img_current"/>
                            <t t-if="o.parcel_img_coordinate_grid">
                                <t t-set="parcel_img_to_use" t-value="p.parcel_id.aerial_img_with_grid_current"/>
                            </t>
                            <span name="span_hook_before_fist_parcel_check" style="display: none;"/>
                            <t t-if="parcel_img_to_use">
                                <div name="aerial_image" class="text-center" style="border: 1px solid black; padding: 1% 0%;">
                                    <img t-attf-src="data:image/png;base64, #{parcel_img_to_use}" style="max-width: 824px; max-height: 824px;"/>
                                </div>
                            </t>
                            <t t-else="">
                                <div name="aerial_image" class="text-center text-muted"
                                    style="border: 1px solid black; padding: 1% 0%; width: 100%; height: 824px; padding-top: 40%;">
                                    Aerial image not found
                                </div>
                            </t>
                            <div style="display: table; border: 1px solid black; border-top:0px; width:100%;">
                                <div class="text-center" style="padding: 1%; border-right: 1px solid black; width: 20%; display: table-cell;">
                                    <img src="/web/binary/company_logo" style="max-height: 100px; max-width: 100px;"/>
                                </div>
                                <div style="border-right: 1px solid black; width: 40%; display: table-cell; vertical-align: top; padding: 1%;">
                                    <table style="width: 100%;">
                                        <tbody>
                                            <tr>
                                                <td><strong>Parcel</strong></td>
                                                <td class="text-right"><span t-field="p.parcel_id.name"/></td>
                                            </tr>
                                            <tr style="border-top: 1pt solid lightgrey;margin-top: 2%;"><td>&amp;nbsp;</td><td>&amp;nbsp;</td></tr>
                                            <tr>
                                                <td><strong>Cadastral reference</strong></td>
                                                <td class="text-right"><span t-field="p.parcel_id.cadastral_reference"/></td>
                                            </tr>
                                            <tr>
                                                <td><strong>County</strong></td>
                                                <td class="text-right"><span t-field="p.parcel_id.county_id"/></td>
                                            </tr>
                                            <tr>
                                                <td><strong>Area</strong></td>
                                                <td class="text-right">
                                                    <t t-if="use_intersected_area">
                                                        <span t-field="p.area_intersected_perimeter"/>
                                                    </t>
                                                    <t t-else="">
                                                        <span t-field="p.area_official"/>
                                                    </t>
                                                    <span><t t-esc="measurement_unit"/></span>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                                <div style="width: 40%; display: table-cell; vertical-align: top; padding: 1%;">
                                    <t t-set="scale_aprox" t-value="int(round(p.parcel_id.aerial_img_scale_current / 0.801, 0))"/>
                                    <table style="width: 100%; padding:1%;">
                                        <tbody>
                                            <tr>
                                                <td><strong>Printed</strong></td>
                                                <td class="text-right"><span t-field="p.parcel_id.date_now" t-options="{'format': 'dd MMMM YYYY'}"/></td>
                                            </tr>
                                            <tr style="border-top: 1pt solid lightgrey;margin-top: 2%;"><td>&amp;nbsp;</td><td>&amp;nbsp;</td></tr>
                                            <tr>
                                                <td>
                                                    <strong>Scale</strong>
                                                </td>
                                                <td class="text-right"><span>~ 1:<span t-esc="scale_aprox"/></span></td>
                                            </tr>
                                            <tr>
                                                <td><strong>Image date</strong></td>
                                                <td class="text-right"><span t-field="p.parcel_id.aerial_img_date_current"/></td>
                                            </tr>
                                            <tr>
                                                <td><strong>Accuracy (m/px)</strong></td>
                                                <td class="text-right"><span t-field="p.parcel_id.aerial_img_accuracy_current"/></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            <p style="page-break-after:always;"></p>
                        </t>
                    </t>
                </div>
            </t>

            <t t-if="o.map_type_in_report == '02_four'">
                <div name="wua_parcel_aerial_images_02">
                    <t t-set="parcels_show" t-value="o.certificateparcel_ids.filtered(lambda x: x.included_in_certificate)"/>
                    <t t-if="parcels_show">
                        <t t-foreach="parcels_show" t-as="p">
                        <t t-set="parcel_img_to_use" t-value="p.parcel_id.aerial_img_current"/>
                        <t t-if="o.parcel_img_coordinate_grid">
                            <t t-set="parcel_img_to_use" t-value="p.parcel_id.aerial_img_with_grid_current"/>
                        </t>
                            <div style="width: 48%; float: left; display: table; border: 1px solid black; margin: 1.5% 0.5%; page-break-inside: avoid;">
                                <div name="parcel_data" style="border-bottom: 1px solid black; padding: 2%;">
                                    <table style="width: 100%;">
                                        <tbody>
                                            <tr>
                                                <td>
                                                    <strong>Parcel</strong>
                                                    <t t-if="p.parcel_id.aerial_img_date_current">
                                                        <span>(image of <span t-field="p.parcel_id.aerial_img_date_current" t-options="{'format': 'MMMM YYYY'}"></span>)</span>
                                                    </t>
                                                </td>
                                                <td class="text-right"><span t-field="p.parcel_id"/></td>
                                            </tr>
                                            <tr>
                                                <td><strong>Cadastral reference</strong></td>
                                                <td class="text-right"><span t-field="p.cadastral_reference"/></td>
                                            </tr>
                                            <tr>
                                                <td><strong>Area</strong></td>
                                                <td class="text-right">
                                                    <t t-if="use_intersected_area">
                                                        <span t-field="p.area_intersected_perimeter"/>
                                                    </t>
                                                    <t t-else="">
                                                        <span t-field="p.area_official"/>
                                                    </t>
                                                    <span><t t-esc="measurement_unit"/></span>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                                <div name="parcel_aerial_image" class="text-center">
                                    <span name="span_hook_before_second_parcel_check" style="display: none;"/>
                                    <t t-if="parcel_img_to_use">
                                        <img t-attf-src="data:image/png;base64, #{parcel_img_to_use}" style="max-width: 408px; max-height: 408px;"/>
                                    </t>
                                    <t t-else="">
                                        <div class="text-center text-muted" style="width: 408px; height: 408px; padding-top: 40%;">
                                            Aerial image not found
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </t>
                    </t>
                </div>
            </t>

            <t t-else=""></t>

        </div>
    </template>

</odoo>