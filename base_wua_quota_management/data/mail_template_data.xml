<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">

        <!-- Mail for owner which lease is about to end -->
        <record id="quota_notice_partner_report_email_template"
                model="mail.template">
            <field name="name">Aviso Saldo de Cupo disponible</field>
            <field name="model_id" ref="base_wua_quota_management.model_wua_quota"/>
            <field name="email_from">"${object.partner_id.company_id.name|safe}" &lt;${(object.partner_id.company_id.email or user.email)|safe}&gt;</field>
            <field name="partner_to">${object.partner_id.id}</field>
            <field name="subject">Balance of ${object.superproduct_id.name|safe}</field>
            <field name="body_html" type="html">
                <p style="margin: 0px; padding: 0px; font-size: 13px;">
                    Dear Mr/Ms ${object.partner_id.name}.

                    According to the information available. The quota balance of the ${object.superproduct_id.name} is ${object.balance|safe} m³.
                </p>
                <br/>
                <p style="margin: 0px; padding: 0px;">
                   If you have any doubts or think it may be an error, contact with us via mail ${(object.partner_id.company_id.email or user.email)|safe} or phone ${(object.partner_id.company_id.phone)|safe}.
                </p>
                <br/>
                <p>
                    Receive a cordial greeting.
                </p>
            </field>
            <field name="lang">${object.partner_id.lang}</field>
        </record>

    </data>

</odoo>