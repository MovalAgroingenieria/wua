<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="0">

        <record id="group_wua_quota_manager" model="res.groups">
            <field name="name">Quota Manager</field>
            <field name="category_id"
                ref="base.module_category_water_users_associations"/>
            <field name="implied_ids"
                eval="[(4, ref('base_wua.group_wua_manager'))]"/>
            <field name="users"
                eval="[(4, ref('base.user_root'))]"/>
        </record>

    </data>

    <data noupdate="1">

        <record id="rule_wua_quota_group_wua_portal_user" model="ir.rule">
            <field name="name">Rule for Wua Portal User on quotas</field>
            <field name="model_id" ref="model_wua_quota"/>
            <field name="domain_force">
                ['|', ('partner_id','=',user.partner_id.id),
                      ('partner_id.child_ids','=',user.partner_id.id)]
            </field>
            <field name="groups" eval="[(4, ref('base_wua.group_wua_portal_user'))]"/>
        </record>

        <record id="rule_wua_hydricmovement_group_wua_portal_user" model="ir.rule">
            <field name="name">Rule for Wua Portal User on hydric movements</field>
            <field name="model_id" ref="model_wua_hydricmovement"/>
            <field name="domain_force">
                ['|', ('partner_id','=',user.partner_id.id),
                      ('partner_id.child_ids','=',user.partner_id.id)]
            </field>
            <field name="groups" eval="[(4, ref('base_wua.group_wua_portal_user'))]"/>
        </record>

        <record id="rule_wua_quotaperiodlineparcel_wua_portal_user" model="ir.rule">
            <field name="name">Rule for Wua Portal User on quota period lines parcel</field>
            <field name="model_id" ref="model_wua_quotaperiod_line_parcel"/>
            <field name="domain_force">
                ['|', ('partner_id','=',user.partner_id.id),
                      ('partner_id.child_ids','=',user.partner_id.id)]
            </field>
            <field name="groups" eval="[(4, ref('base_wua.group_wua_portal_user'))]"/>
        </record>

    </data>

</odoo>