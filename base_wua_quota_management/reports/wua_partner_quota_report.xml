<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Wua partner quotas report (droplist menu) -->
    <report id="wua_partner_quota_report" string="Quotas report" model="res.partner" report_type="qweb-pdf" file="base_wua_quota_management.wua_partner_quota_report_document" name="base_wua_quota_management.wua_partner_quota_report_document" paperformat="base_wua_report.paperformat_wua_reports" />

    <!-- Wua partner quota report -->
    <template id="wua_partner_quota_report_document">
        <t t-call="report.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="base_wua_report.wua_external_layout">

                    <!-- Set global variables -->
                    <t t-set="agriculturalseason" t-value="o.get_agriculturalseason_id()" />
                    <t t-set="hydricmovements" t-value="o.get_partner_active_agriculturalseason_hydricmovements()" />
                    <t t-set="report_style" t-value="o.env['ir.values'].get_default('wua.configuration', 'reports_style')" />

                    <div class="page">

                        <!-- Report title -->
                        <div name="title" class="text-center" style="font-size: 16px;">
                            <strong>Quotas report</strong>
                            <t t-if="agriculturalseason">
                                <span>&amp;nbsp; [</span>
                                <t t-esc="agriculturalseason.description" />
                                <span>]</span>
                            </t>
                        </div>

                        <!-- Partner data -->
                        <div name="wua_partner_data">
                            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                <t t-if="report_style == 'light'">
                                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;">
                                            <span class="fa fa-user" />
                                        </div>
                                        <div style="float: left; display: inline;">
                                            <strong>Partner</strong>
                                        </div>
                                    </div>
                                </t>
                                <t t-else="">
                                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;">
                                            <span class="fa fa-user" />
                                        </div>
                                        <div style="float: left; display: inline;">
                                            <strong>Partner</strong>
                                        </div>
                                    </div>
                                </t>
                            </div>
                            <div class="row" style="margin-top: 4px;">
                                <div class="col-xs-12" style="display: table;">
                                    <div style="width: 50%; display: table-cell;">
                                        <t t-if="o.name">
                                            <strong>
                                                <span t-field="o.name" />
                                            </strong>
                                            <t t-if="o.vat">
                                                <span>(NIF:&amp;nbsp;<span t-field="o.vat" />
)</span>
                                            </t>
                                            <br />
                                        </t>
                                        <t t-if="o.street_type_show or o.street or o.street_num or o.street2">
                                            <t t-if="o.street_type_show">
                                                <span t-field="o.street_type_show" />
                                            </t>
                                            <t t-if="o.street">
                                                <span t-field="o.street" />
                                            </t>
                                            <t t-if="o.street_num">
                                                <span t-field="o.street_num" />
                                            </t>
                                            <t t-if="o.street2">
                                                <span t-field="o.street2" />
                                            </t>
                                            <br />
                                        </t>
                                        <t t-if="o.city or o.zip">
                                            <t t-if="o.city">
                                                <span t-field="o.city" />
                                            </t>
                                            <t t-if="o.zip">
                                                <span>-&amp;nbsp;</span>
                                                <span t-field="o.zip" />
                                            </t>
                                            <br />
                                        </t>
                                        <t t-if="o.state_id or o.country_id">
                                            <t t-if="o.state_id">
                                                <span t-field="o.state_id" />
                                            </t>
                                            <t t-if="o.country_id">
                                                <span>-&amp;nbsp;</span>
                                                <span t-field="o.country_id"></span>
                                            </t>
                                            <br />
                                        </t>
                                        <t t-if="o.phones or o.phone or o.mobile">
                                            <t t-if="o.phones">
                                                <span t-field="o.phones" />
                                            </t>
                                            <t t-else="">
                                                <t t-if="o.phone">
                                                    <span t-field="o.phone" />
                                                </t>
                                                <t t-if="o.mobile">
                                                    <span t-field="o.mobile" />
                                                </t>
                                            </t>
                                            <br />
                                        </t>
                                        <t t-if="o.email">
                                            <span t-field="o.email" />
                                            <br />
                                        </t>
                                    </div>
                                    <div style="display: table-cell; padding-left: 32px;">
                                        <div>&amp;nbsp;</div>
                                        <table style="width: 100%;">
                                            <tbody>
                                                <tr>
                                                    <td>
                                                        <span>Wua partner code:</span>
                                                    </td>
                                                    <td class="text-right">
                                                        <span t-field="o.partner_code" />
                                                    </td>
                                                </tr>
                                                <tr name="tr_number_of_votes">
                                                    <td>
                                                        <span>Number of votes:</span>
                                                    </td>
                                                    <td class="text-right">
                                                        <span t-field="o.number_of_votes" />
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td>
                                                        <span>Number of parcels:</span>
                                                    </td>
                                                    <td class="text-right">
                                                        <span t-field="o.parcel_number" />
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td>
                                                        <span>Total area:</span>
                                                    </td>
                                                    <td class="text-right" style="padding: 0 0 0 28px;">
                                                        <span t-field="o.parcel_total_area" />
                                                        <t t-if="o.partnerlink_ids">
                                                            <t t-set="measurement_unit" t-value="o.partnerlink_ids[0].parcel_id._compute_area_measurement_name()" />
                                                            <span>
                                                                <t t-esc="measurement_unit" />
                                                            </span>
                                                        </t>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Waterconnection data -->
                        <t t-if="o.env['ir.values'].get_default('wua.quotas.configuration', 'show_wc_on_partner_quota_report')">
                            <div name="wua_waterconnection_data" style="margin-top: 20px;">
                                <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                    <t t-if="report_style == 'light'">
                                        <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                            <div style="float: left; width: 32px;">
                                                <span class="fa fa-moval-infra" />
                                            </div>
                                            <div style="float: left; display: inline;">
                                                <strong>Waterconnections</strong>
                                            </div>
                                        </div>
                                    </t>
                                    <t t-else="">
                                        <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                            <div style="float: left; width: 32px;">
                                                <span class="fa fa-moval-infra" />
                                            </div>
                                            <div style="float: left; display: inline;">
                                                <strong>Waterconnections</strong>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                                <!-- Get waterconnections -->
                                <t t-if="o.waterconnectionlink_ids and len(o.waterconnectionlink_ids) > 0">
                                    <table class="table table-striped" style="width:100%;">
                                        <thead>
                                            <th name="th_waterconnection">
                                                <span>Waterconnection</span>
                                            </th>
                                            <th name="th_last_reading_time" class="text-center">Last Reading Time
                                            </th>
                                            <th name="th_last_reading_volume" class="text-right">Last Reading Volume (m<sup>3</sup>)
                                            </th>
                                            <th name="th_volume_real" class="text-right">Consumption (m³)
                                            </th>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="o.waterconnectionlink_ids" t-as="wc">
                                                <tr style="page-break-before: always; page-break-after: auto; page-break-inside: avoid;">
                                                    <td name="td_waterconnection">
                                                        <span t-field="wc.waterconnection_id.name" />
                                                        <span>(</span>
                                                        <span t-field="wc.waterconnection_id.total_affected_area_official" />
                                                        <span t-esc="measurement_unit"/>
                                                        <span>)</span>
                                                    </td>
                                                    <td name="td_last_reading_time" class="text-center">
                                                        <span t-field="wc.last_reading_time"/>
                                                    </td>
                                                    <td name="td_last_reading_volume" class="text-right">
                                                        <span t-field="wc.last_reading_value"/>
                                                    </td>
                                                    <td name="td_last_reading_volume" class="text-right">
                                                        <span t-field="wc.volume_real"/>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </t>
                                <t t-else="">
                                    <div class="text-center">(There are no waterconnections for this partner)</div>
                                </t>
                            </div>
                        </t>

                        <!-- Quota data -->
                        <div name="wua_quota_data" style="margin-top: 20px;">
                            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                <t t-if="report_style == 'light'">
                                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;">
                                            <span class="fa fa-moval-quotas" />
                                        </div>
                                        <div style="float: left; display: inline;">
                                            <strong>Quotas</strong>
                                        </div>
                                    </div>
                                </t>
                                <t t-else="">
                                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;">
                                            <span class="fa fa-moval-quotas" />
                                        </div>
                                        <div style="float: left; display: inline;">
                                            <strong>Quotas</strong>
                                        </div>
                                    </div>
                                </t>
                            </div>
                            <!-- Get quota periods -->
                            <t t-if="agriculturalseason">
                                <t t-set="quota_periodes" t-value="o.get_quotaperiod_of_agriculturalseason(agriculturalseason.id)" />
                                <t t-foreach="quota_periodes" t-as="p">
                                    <div name="period_title" class="text-center" style="margin-top:10px;">
                                        <strong>Period </strong>
                                        <strong t-field="p.display_name" />
                                        <hr style="margin: 0px 0px;" />
                                    </div>
                                    <t t-set="quotas" t-value="o.get_partner_active_agriculturalseason_quotas(p.id)" />
                                    <t t-if="not len(quotas) > 0">
                                        <div class="text-center">(There are no quotas in this period)</div>
                                    </t>
                                    <t t-else="">
                                        <table class="table table-striped" style="width:100%;">
                                            <thead>
                                                <th name="th_superproduct">Water type</th>
                                                <th name="th_input" class="text-right">Input (m<sup>3</sup>)
                                                </th>
                                                <th name="th_consumption" class="text-right">Consumption (m<sup>3</sup>)
                                                </th>
                                                <th name="th_balance" class="text-right">Balance (m<sup>3</sup>)
                                                </th>
                                            </thead>
                                            <tbody>
                                                <t t-set="total_input" t-value="0.0" />
                                                <t t-set="total_consumption" t-value="0.0" />
                                                <t t-set="total_balance" t-value="0.0" />
                                                <!-- Total sum -->
                                                <t t-set="quotas_totalized" t-value="quotas.filtered(lambda x: not x.superproduct_id.is_debt_supraproduct)"/>
                                                <t t-set="quotas_not_totalized" t-value="quotas.filtered(lambda x: x.superproduct_id.is_debt_supraproduct)"/>
                                                <t t-foreach="quotas_totalized" t-as="q">
                                                    <tr style="page-break-before: always; page-break-after: auto; page-break-inside: avoid;">
                                                        <td name="td_superproduct">
                                                            <span t-field="q.superproduct_id" />
                                                        </td>
                                                        <td name="td_input" class="text-right">
                                                            <t t-set="total_input" t-value="total_input + q.accumulated_input"/>
                                                            <span t-esc="q.accumulated_input" t-options='{"widget": "float", "precision": 2}'/>
                                                        </td>
                                                        <td name="td_consumption" class="text-right">
                                                            <t t-set="total_consumption" t-value="total_consumption + q.accumulated_consumption"/>
                                                            <span t-esc="q.accumulated_consumption" t-options='{"widget": "float", "precision": 2}'/>
                                                        </td>
                                                        <td name="td_balance" class="text-right">
                                                            <t t-set="total_balance" t-value="total_balance + q.balance"/>
                                                            <span t-esc="q.balance" t-options='{"widget": "float", "precision": 2}'/>
                                                        </td>
                                                    </tr>
                                                </t>
                                                <tr style="page-break-before: always; page-break-after: auto; page-break-inside: avoid;">
                                                    <td></td>
                                                    <td name="td_total_input" class="text-right">
                                                        <strong>
                                                            <t t-esc="total_input" t-options='{"widget": "float", "precision": 2}'/>
                                                        </strong>
                                                    </td>
                                                    <td name="td_total_consumption" class="text-right">
                                                        <strong>
                                                            <t t-esc="total_consumption" t-options='{"widget": "float", "precision": 2}'/>
                                                        </strong>
                                                    </td>
                                                    <td name="td_total_balance" class="text-right">
                                                        <strong>
                                                            <t t-esc="total_balance" t-options='{"widget": "float", "precision": 2}'/>
                                                        </strong>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                        <t t-if="len(quotas_not_totalized) > 0">
                                            <table class="table table-striped" style="width:100%;">
                                                <thead>
                                                    <th name="th_superproduct_not_totalized">Debt type</th>
                                                    <th name="th_consumption_not_totalized" class="text-right">Debt (m<sup>3</sup>)
                                                    </th>
                                                    <th name="th_input_not_totalized" class="text-right">Compensated (m<sup>3</sup>)
                                                    </th>
                                                    <th name="th_balance_not_totalized" class="text-right">Balance (m<sup>3</sup>)
                                                    </th>
                                                </thead>
                                                <tbody>
                                                    <t t-foreach="quotas_not_totalized" t-as="q">
                                                        <tr style="page-break-before: always; page-break-after: auto; page-break-inside: avoid;">
                                                            <td name="td_superproduct_not_totalized">
                                                                <span t-field="q.superproduct_id" />
                                                            </td>
                                                            <td name="td_consumption_not_totalized" class="text-right">
                                                                <t t-set="total_consumption" t-value="total_consumption + q.accumulated_consumption"/>
                                                                <span t-esc="q.accumulated_consumption" t-options='{"widget": "float", "precision": 2}'/>
                                                            </td>
                                                            <td name="td_input_not_totalized" class="text-right">
                                                                <t t-set="total_input" t-value="total_input + q.accumulated_input"/>
                                                                <span t-esc="q.accumulated_input" t-options='{"widget": "float", "precision": 2}'/>
                                                            </td>
                                                            <td name="td_balance_not_totalized" class="text-right">
                                                                <t t-set="total_balance" t-value="total_balance + q.balance"/>
                                                                <span t-esc="q.balance" t-options='{"widget": "float", "precision": 2}'/>
                                                            </td>
                                                        </tr>
                                                    </t>
                                                    <tr style="page-break-before: always; page-break-after: auto; page-break-inside: avoid;">
                                                        <td></td>
                                                        <td name="td_total_input_not_totalized" class="text-right">
                                                        </td>
                                                        <td name="td_total_consumption_not_totalized" class="text-right">
                                                            <strong>
                                                                Total Available:
                                                            </strong>
                                                        </td>
                                                        <td name="td_total_balance_not_totalized" class="text-right">
                                                            <strong>
                                                                <t t-esc="total_balance" t-options='{"widget": "float", "precision": 2}'/>
                                                            </strong>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </t>
                                    </t>
                                </t>
                            </t>
                        </div>

                        <!-- Hydric movements data -->
                        <div name="wua_hydricmovements_data">
                            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                <t t-if="report_style == 'light'">
                                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;">
                                            <span class="fa fa-list-ol" />
                                        </div>
                                        <div style="float: left; display: inline;">
                                            <strong>Hydric&amp;nbsp;movements</strong>
                                        </div>
                                    </div>
                                </t>
                                <t t-else="">
                                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;">
                                            <span class="fa fa-list-ol" />
                                        </div>
                                        <div style="float: left; display: inline;">
                                            <strong>Hydric&amp;nbsp;movements</strong>
                                        </div>
                                    </div>
                                </t>
                            </div>
                            <table class="table table-striped" style="width:100%;">
                                <thead>
                                    <th name="th_superproduct">Water type</th>
                                    <th name="th_date" class="text-center">Date</th>
                                    <th name="th_description">Description</th>
                                    <th name="th_volume" class="text-right">Volume (m<sup>3</sup>)
                                    </th>
                                </thead>
                                <tbody>
                                    <t t-foreach="hydricmovements" t-as="h">
                                        <tr style="page-break-before: always; page-break-after: auto; page-break-inside: avoid;">
                                            <td name="td_superproduct">
                                                <span t-field="h.superproduct_id" />
                                            </td>
                                            <td name="td_date" class="text-center">
                                                <span t-field="h.event_time" t-field-options="{'format': 'dd/MM/yyyy'}" />
                                            </td>
                                            <td name="td_description">
                                                <span t-field="h.description" />
                                            </td>
                                            <td name="td_volume" class="text-right">
                                                <span t-field="h.accounting_volume" />
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>

                        <!-- Info -->
                        <t t-set="informative_clauses" t-value="o.env['ir.values'].get_default('wua.configuration', 'reports_informative_clauses')" />

                        <t t-if="informative_clauses">
                            <div name="info_div" style="margin-top: 20px;">
                                <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                    <t t-if="report_style == 'light'">
                                        <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                            <div style="float: left; width: 32px;">
                                                <span class="fa fa-info-circle" />
                                            </div>
                                            <div style="float: left; display: inline;">
                                                <strong>Information</strong>
                                            </div>
                                        </div>
                                    </t>
                                    <t t-else="">
                                        <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                            <div style="float: left; width: 32px;">
                                                <span class="fa fa-info-circle" />
                                            </div>
                                            <div style="float: left; display: inline;">
                                                <strong>Information</strong>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                            </div>
                            <t t-if="informative_clauses">
                                <div name="informative_clause_div">
                                    <span t-raw="informative_clauses" />
                                </div>
                            </t>
                        </t>

                    </div>                    <!-- end page -->
                </t>
            </t>
        </t>
    </template>

</odoo>
