<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wizard_massive_cancelnegativebalances_view_form" model="ir.ui.view">
        <field name="name">Wizard to compensate balances</field>
        <field name="model">wizard.massive.cancelnegativebalances</field>
        <field name="arch" type="xml">
            <form string="Massive transfers of balance (to compensate)">
                <script>
                    $(document).ready(function(){
                        $('.modal-dialog').css({'width': '500px'});
                    });
                </script>
                <div style="text-align:center">
                    <h4><field name="quotaperiod_name"
                         readonly="1"/></h4>
                </div>
                <div>Enter the following data to cancel the negative balances of this quota period. The operation will apply to all partners.
                </div>
                <br/>
                <group name="body">
                    <field name="superproduct_id"
                           options="{'no_quick_create': True,
                                     'no_create_edit': True}"/>
                    <field name="category_id"
                           options="{'no_quick_create': True,
                                     'no_create_edit': True}"/>
                    <field name="event_time"/>
                    <field name="reason"/>
                </group>
                <footer>
                    <button name="execute_cancelnegativebalances"
                            type="object"
                            string="Apply"
                            class="btn-primary"/>
                    <button string="Cancel"
                            class="btn-default"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>