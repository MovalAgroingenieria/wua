<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_quotaperiod_view_form" model="ir.ui.view">
        <field name="name">Quota Periods (form view)</field>
        <field name="model">wua.quotaperiod</field>
        <field name="arch" type="xml">
            <form duplicate="0">
                <sheet>
                    <group name="master_data">
                        <group name="master_data_left">
                            <field name="agriculturalseason_id"/>
                            <field name="initial_date"/>
                            <field name="end_date"/>
                        </group>
                        <group name="master_data_left">
                            <field name="description"/>
                        </group>
                    </group>
                    <group name="slave_data">
                        <notebook name="slave_data_notebook">
                            <page name="notes_page" string="Notes">
                                <field name="notes"/>
                            </page>
                        </notebook>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="wua_quotaperiod_view_tree" model="ir.ui.view">
        <field name="name">Quota Periods (tree view)</field>
        <field name="model">wua.quotaperiod</field>
        <field name="arch" type="xml">
            <tree class=
                  "o_base_wua_quota_management_quotaperiod_view_tree">
                <field name="agriculturalseason_id"/>
                <field name="initial_date"/>
                <field name="initial_date"/>
                <field name="end_date"/>
                <field name="description"/>
            </tree>
        </field>
    </record>

    <record id="wua_quotaperiod_view_search" model="ir.ui.view">
        <field name="name">Quota Periods (search view)</field>
        <field name="model">wua.quotaperiod</field>
        <field name="arch" type="xml">
            <search>
                <field name="description"/>
            </search>
        </field>
    </record>

    <record id="wua_quotaperiod_action"
            model="ir.actions.act_window">
        <field name="name">Quota Periods</field>
        <field name="res_model">wua.quotaperiod</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids"
         eval="[(5, 0),
                (0, 0, {'view_mode': 'tree',
                        'view_id': ref('wua_quotaperiod_view_tree')}),
                (0, 0, {'view_mode': 'form',
                        'view_id': ref('wua_quotaperiod_view_form')})]"/>
        <field name="search_view_id" ref="wua_quotaperiod_view_search"/>
    </record>

    <menuitem id="quotaperiod_menu"
              name="Quota Periods"
              parent="management_menu"
              sequence="2"
              action="wua_quotaperiod_action"/>

</odoo>