<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_gravconsumption_view_form" model="ir.ui.view">
        <field name="name">Consumptions (form view)</field>
        <field name="model">wua.gravconsumption</field>
        <field name="inherit_id"
               ref="base_wua_gravity_irrigation.wua_gravconsumption_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='master_data']" position="before">
                <header>
                    <field name="number_of_hydricmovements" invisible="1"/>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_get_hydric_movements"
                                type="object" class="oe_stat_button"
                                icon="fa-list-ol"
                                attrs="{'invisible':
                                        [('number_of_hydricmovements', '=', 0)]}">
                            <div class="o_form_field o_stat_info">
                                <span class="o_stat_text">Hydric</span>
                                <span class="o_stat_text">Movements</span>
                            </div>
                        </button>
                    </div>
                </header>
            </xpath>
        </field>
    </record>

</odoo>