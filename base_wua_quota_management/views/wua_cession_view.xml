<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_cession_view_form" model="ir.ui.view">
        <field name="name">Cessions (form view)</field>
        <field name="model">wua.cession</field>
        <field name="arch" type="xml">
            <form duplicate="0">
                <field name="id" invisible="1"/>
                <field name="state_change_available" invisible="1"/>
                <header>
                     <button name="cancel_cession"
                            type="object" string="Cession Cancel"
                            class="oe_read_only"
                            style="width: 105px;"
                            groups="base_wua_quota_management.group_wua_quota_manager"
                            attrs="{'invisible':['|', '|', ('id','=',False), ('state_change_available', '=', False), ('cession_state', '=', '00_draft')]}"/>
                     <button name="validate_cession"
                            type="object" string="Cession Validate"
                            class="oe_read_only"
                            style="width: 105px;"
                            groups="base_wua_quota_management.group_wua_quota_manager"
                            attrs="{'invisible':['|', '|', ('id','=',False), ('state_change_available', '=', False), ('cession_state', '=', '01_validated')]}"/>
                     <field name="cession_state"
                            widget="statusbar"
                            attrs="{'invisible':['|', ('id','=',False), ('state_change_available', '=', False)]}"
                            statusbar_visible="00_draft,01_validated"/>
                </header>
                <sheet>
                    <div class="panel-body text-center" style="background:#ededed;border-radius:4px;border-color:#696969;border-width:1px;border-style:solid;padding-top:1px;padding-bottom:8px;margin-bottom:5px"><h2>CESSION</h2></div>
                    <group name="master_data" col="5">
                        <group name="master_data_left"
                               colspan="3" col="4">
                            <field name="agriculturalseason_id" colspan="4"
                                   options="{'no_quick_create':True,
                                             'no_create_edit':True}"
                                   attrs="{'readonly':[('id','>',0)]}"/>
                            <field name="quotaperiod_id" colspan="4"
                                   options="{'no_quick_create':True,
                                             'no_create_edit':True}"
                                   attrs="{'readonly':[('id','>',0)]}"/>
                            <field name="superproduct_id" colspan="4"
                                   options="{'no_quick_create':True,
                                             'no_create_edit':True}"
                                   attrs="{'readonly':[('id','>',0)]}"/>
                            <field name="quota_id" colspan="4"
                                   options="{'no_quick_create':True,
                                             'no_create_edit':True}"
                                   string="Transferor Partner"
                                   attrs="{'invisible':[('id','>',0)]}"
                                   context="{'show_only_partner_data': True}"/>
                            <field name="partner_id" colspan="4"
                                   attrs="{'invisible':[('id','=',False)]}"/>
                            <field name="quota_readonly_id" colspan="4"
                                   attrs="{'invisible':[('id','=',False)]}"/>
                            <field name="receiver_partner_id" colspan="4"
                                   options="{'no_quick_create':True,
                                             'no_create_edit':True}"
                                   domain="[('is_wua_partner', '=', True)]"
                                   attrs="{'readonly':[('id','>',0)]}"/>
                            <field name="receiver_quota_id" colspan="4"
                                   attrs="{'invisible':[('id','=',False)]}"/>
                            <field name="event_time" colspan="3"
                                   attrs="{'readonly':[('id','>',0), ('cession_state', '=', '01_validated')]}"/>
                            <div colspan="1"></div>
                            <field name="volume" colspan="3"
                                   attrs="{'readonly':[('id','>',0), ('cession_state', '=', '01_validated')]}"/>
                            <div colspan="1"></div>
                            <field name="finish_date" colspan="3"
                                   attrs="{'readonly':[('id','>',0), ('cession_state', '=', '01_validated')]}"/>
                            <div colspan="1"></div>
                            <field name="reason" colspan="4"/>
                        </group>
                        <group name="master_data_right"
                               colspan="2"
                               style="text-align:right;">
                            <field name="quota_accumulated_input"/>
                            <field name="quota_accumulated_consumption"/>
                            <field name="quota_balance"
                             attrs="{'invisible':[('quota_balance','&lt;',0)]}"/>
                            <field name="quota_negative_balance" style="color:red"
                             attrs="{'invisible':[('quota_balance','>=',0)]}"/>
                        </group>
                    </group>
                    <group name="slave_data">
                        <notebook name="slave_data_notebook">
                            <page name="notes_page" string="Notes">
                                <field name="notes"/>
                            </page>
                        </notebook>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"
                           widget="mail_followers" groups="base_wua.group_wua_manager"/>
                    <field name="message_ids"
                           widget="mail_thread" groups="base_wua.group_wua_manager"/>
                </div>
            </form>
        </field>
    </record>

    <record id="wua_cession_view_tree" model="ir.ui.view">
        <field name="name">Cessions (tree view)</field>
        <field name="model">wua.cession</field>
        <field name="arch" type="xml">
            <tree class="o_base_wua_quota_management_cession_view_tree"
                  default_order="event_time desc, name">
                <field name="superproduct_id"/>
                <field name="partner_id"/>
                <field name="quotaperiod_id"
                       widget="many2one_unclickable"/>
                <button name="action_open_quota_form"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-external-link"/>
                <field name="event_time"
                       string="Date" widget="date"/>
                <field name="receiver_partner_id"/>
                <field name="reason"/>
                <field name="volume"/>
                <field name="cession_state" invisible="1"/>
                <field name="cession_ended" invisible="1"/>
                <field name="close_to_end_cession" invisible="1"/>
                <field name="finish_date" invisible="1"
                    bg_color="red:cession_ended == True; orange:close_to_end_cession == True;"/>
            </tree>
        </field>
    </record>

    <record id="wua_cession_view_search" model="ir.ui.view">
        <field name="name">Cessions (search view)</field>
        <field name="model">wua.cession</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <field name="receiver_partner_id"/>
                <field name="reason"/>
                <filter string="Active Agricultural Season"
                        name="active_agriculturalseason"
                        domain="[('of_active_agriculturalseason','=',True)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Agricultural Season"
                            name="grouped_agriculturalseason"
                     context="{'group_by':'agriculturalseason_id'}"/>
                    <filter string="Quota Period"
                            name="grouped_quotaperiod"
                     context="{'group_by':'quotaperiod_id'}"/>
                    <filter string="Date"
                            name="grouped_event_time"
                     context="{'group_by':'event_time'}"/>
                    <filter string="Superproduct"
                            name="grouped_superproduct"
                     context="{'group_by':'superproduct_id'}"/>
                    <filter string="Transferor Partner"
                            name="grouped_partner"
                     context="{'group_by':'partner_id'}"/>
                    <filter string="Receiver Partner"
                            name="grouped_receiver_partner"
                     context="{'group_by':'receiver_partner_id'}"/>
                    <filter string="Cession State"
                            name="grouped_cession_state"
                     context="{'group_by':'cession_state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="wua_validate_cessions" model="ir.actions.server">
      <field name="name">Validate Cession</field>
      <field name="model_id" ref="model_wua_cession"/>
      <field name="state">code</field>
      <field name="code">
          if context.get('active_ids'):
              action = env['wua.cession'].validate_cessions(context['active_ids'])
      </field>
  </record>

  <record id="wua_action_validate_cessions" model="ir.values">
      <field name="name">Validate</field>
      <field name="model">wua.cession</field>
      <field name="key">action</field>
      <field name="key2">client_action_multi</field>
      <field name="value" eval="'ir.actions.server,' + str(ref('wua_validate_cessions'))"/>
  </record>

  <record id="wua_cancel_cessions" model="ir.actions.server">
      <field name="name">Cancel Cession</field>
      <field name="model_id" ref="model_wua_cession"/>
      <field name="state">code</field>
      <field name="code">
          if context.get('active_ids'):
              action = env['wua.cession'].cancel_cessions(context['active_ids'])
      </field>
  </record>

  <record id="wua_action_cancel_cessions" model="ir.values">
      <field name="name">Cancel Cession</field>
      <field name="model">wua.cession</field>
      <field name="key">action</field>
      <field name="key2">client_action_multi</field>
      <field name="value" eval="'ir.actions.server,' + str(ref('wua_cancel_cessions'))"/>
  </record>

    <record id="wua_cession_action"
            model="ir.actions.act_window">
        <field name="name">Cessions</field>
        <field name="res_model">wua.cession</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids"
         eval="[(5, 0),
                (0, 0, {'view_mode': 'tree',
                        'view_id': ref('wua_cession_view_tree')}),
                (0, 0, {'view_mode': 'form',
                        'view_id': ref('wua_cession_view_form')})]"/>
        <field name="search_view_id" ref="wua_cession_view_search"/>
        <field name="context">
          {'compressed_agriculturalseason': True,
           'compressed_quotaperiod': True,
           'search_default_active_agriculturalseason': True}
        </field>
    </record>

    <menuitem id="cession_menu"
              name="Cessions"
              parent="management_menu"
              sequence="10"
              action="wua_cession_action"/>

</odoo>