<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_quotas_config_settings_view_form" model="ir.ui.view">
        <field name="name">Parameters</field>
        <field name="model">wua.quotas.configuration</field>
        <field name="arch" type="xml">
            <form string="Quotas Settings" class="oe_form_configuration">
                <header>
                    <button string="Apply" type="object" name="execute"
                            class="oe_highlight"/>
                    <button string="Cancel" type="object" name="cancel"
                            class="oe_link"/>
                </header>
                <group string="Quota Periods">
                    <field name="sorted_quotas"/>
                </group>
            </form>
        </field>
    </record>

    <record id="wua_quotas_configuration_action" model="ir.actions.act_window">
        <field name="name">Configure Quotas</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">wua.quotas.configuration</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
    </record>

    <menuitem id="parameters_menu"
              name="Parameters"
              parent="configuration_menu"
              sequence="1"
              action="wua_quotas_configuration_action"
              groups="base.group_system"/>

</odoo>