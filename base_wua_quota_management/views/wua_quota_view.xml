<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_quota_view_form" model="ir.ui.view">
        <field name="name">Quotas (form view)</field>
        <field name="model">wua.quota</field>
        <field name="arch" type="xml">
            <form create="false" duplicate="0">
                <field name="is_current_quotaperiod" invisible="1"/>
                <header>
                    <button name="action_open_individualinput_form"
                            type="object" string="Assign"
                            icon="fa-plus"
                            class="oe_read_only"
                            style="width: 105px;"
                            groups="base_wua_quota_management.group_wua_quota_manager"/>
                    <button name="action_open_cession_form"
                            type="object" string="Give"
                            icon="fa-minus"
                            class="oe_read_only"
                            style="width: 105px;"
                            attrs="{'invisible': [('balance', '&lt;=', 0)]}"
                            groups="base_wua_quota_management.group_wua_quota_manager"/>
                </header>
                <sheet>
                    <group name="master_data" col="6">
                        <group name="master_data_left"
                               colspan="4">
                            <field name="agriculturalseason_id"/>
                            <field name="quotaperiod_id"/>
                            <field name="superproduct_id"/>
                            <field name="partner_id"/>
                        </group>
                        <group name="master_data_right"
                               colspan="2"
                               style="text-align:right;">
                            <field name="accumulated_input"/>
                            <field name="accumulated_consumption"/>
                            <field name="balance"
                             attrs="{'invisible':[('balance','&lt;',0)]}"/>
                            <field name="negative_balance" style="color:red"
                             attrs="{'invisible':[('balance','>=',0)]}"/>
                            <field name="available_quota_percentage_with_suffix"
                                   string="Available Quota"/>
                            <field name="average_daily_consumption"
                                   string="Cons./Day"/>
                            <field name="number_of_days_elapsed_and_pending"
                                   string="Elapsed-Pending"
                                   attrs="{'invisible':[('is_current_quotaperiod','=',False)]}"/>
                            <field name="estimated_consumption"
                                   string="Estim. Cons."
                                   attrs="{'invisible':[('is_current_quotaperiod','=',False)]}"/>
                            <field name="estimated_balance"
                                   string="Estim. Ending Bal."
                                   attrs="{'invisible':[('is_current_quotaperiod','=',False)]}"/>
                            <field name="expected_date_for_zero_balance"
                                   string="Exp. 0 balance date"
                                   attrs="{'invisible':[('is_current_quotaperiod','=',False)]}"/>
                        </group>
                    </group>
                    <group name="slave_data">
                        <notebook name="slave_data_notebook">
                            <page name="hydricmovements_page" string="Movements">
                                <field name="hydricmovement_ids"
                                       context="{'tree_view_ref':
                                                 'base_wua_quota_management.wua_hydricmovement_of_quota_view_tree'}"/>
                            </page>
                            <page name="notes_page" string="Notes">
                                <field name="notes"/>
                            </page>
                        </notebook>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"
                           widget="mail_followers" groups="base_wua.group_wua_manager"/>
                    <field name="message_ids"
                           widget="mail_thread" groups="base_wua.group_wua_manager"/>
                </div>
            </form>
        </field>
    </record>

    <record id="wua_quota_view_tree" model="ir.ui.view">
        <field name="name">Quotas (tree view)</field>
        <field name="model">wua.quota</field>
        <field name="arch" type="xml">
            <tree class="o_base_wua_quota_management_quota_view_tree"
                  colors="red:balance&lt;0;orange:estimated_balance&lt;0;"
                  create="false">
                <field name="partner_id"/>
                <field name="quotaperiod_id"
                       widget="many2one_unclickable"/>
                <field name="superproduct_id"/>
                <field name="accumulated_input"/>
                <field name="accumulated_consumption"/>
                <field name="balance"/>
                <field name="available_quota_percentage"/>
                <field name="estimated_balance"
                       string="Estim. Ending Balance"/>
                <field name="expected_date_for_zero_balance"
                       string="Exp. ending date"/>
            </tree>
        </field>
    </record>

    <record id="wua_quota_view_search" model="ir.ui.view">
        <field name="name">Quotas (search view)</field>
        <field name="model">wua.quota</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <filter string="Active Agricultural Season"
                        name="active_agriculturalseason"
                        domain="[('of_active_agriculturalseason','=',True)]"/>
                <separator/>
                <filter string="Positive Quotas"
                        name="positive_quotas"
                        domain="[('balance','&gt;=',0)]"/>
                <filter string="Negative Quotas"
                        name="negative_quotas"
                        domain="[('balance','&lt;',0)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Agricultural Season"
                            name="grouped_agriculturalseason"
                     context="{'group_by':'agriculturalseason_id'}"/>
                    <filter string="Quota Period"
                            name="grouped_quotaperiod"
                     context="{'group_by':'quotaperiod_id'}"/>
                    <filter string="Superproduct"
                            name="grouped_superproduct"
                     context="{'group_by':'superproduct_id'}"/>
                    <filter string="Partner"
                            name="grouped_partner"
                     context="{'group_by':'partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="wua_quota_view_graph" model="ir.ui.view">
        <field name="name">Quotas (graph view)</field>
        <field name="model">wua.quota</field>
        <field name="arch" type="xml">
            <graph string="Quotas" stacked="False">
                <field name="quotaperiod_id"/>
                <field name="accumulated_consumption" type='measure'/>
            </graph>
        </field>
    </record>

    <record id="wua_quota_view_pivot" model="ir.ui.view" >
        <field name="name">Quotas (pivot view)</field>
        <field name="model">wua.quota</field>
        <field name="arch" type="xml">
            <pivot string="Quotas" display_quantity="true">
                <field name="quotaperiod_id"/>
                <field name="accumulated_consumption" type='measure'/>
            </pivot>
        </field>
    </record>

    <record id="wua_quota_aggregatevalue_view_tree" model="ir.ui.view">
        <field name="name">Quotas Aggregate (tree view)</field>
        <field name="model">wua.quota.aggregatevalue</field>
        <field name="arch" type="xml">
            <tree class="o_base_wua_quota_management_quota_aggregatevalue_view_tree"
                  colors="red:balance&lt;0" create="false" order="partner_id">
                <field name="partner_id"/>
                <field name="quotaperiod_id" widget="many2one_unclickable"/>
                <field name="accumulated_input"/>
                <field name="accumulated_consumption"/>
                <field name="balance"/>
                <field name="available_quota_percentage"/>
                <field name="estimated_balance"
                       string="Estim. Ending Balance"/>
                <field name="expected_date_for_zero_balance"
                       string="Exp. ending date"/>
            </tree>
        </field>
    </record>

    <record id="wua_quota_aggregatevalue_view_search" model="ir.ui.view">
        <field name="name">Quotas Aggregate (search view)</field>
        <field name="model">wua.quota.aggregatevalue</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <separator/>
                <filter string="Positive Quotas"
                        name="positive_quotas"
                        domain="[('balance','&gt;=',0)]"/>
                <filter string="Negative Quotas"
                        name="negative_quotas"
                        domain="[('balance','&lt;',0)]"/>
            </search>
        </field>
    </record>

    <record id="wua_quota_action"
            model="ir.actions.act_window">
        <field name="name">Quotas</field>
        <field name="res_model">wua.quota</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form,graph,pivot</field>
        <field name="view_ids"
         eval="[(5, 0),
                (0, 0, {'view_mode': 'tree',
                        'view_id': ref('wua_quota_view_tree')}),
                (0, 0, {'view_mode': 'form',
                        'view_id': ref('wua_quota_view_form')})]"/>
        <field name="search_view_id" ref="wua_quota_view_search"/>
        <field name="context">
          {'compressed_agriculturalseason': True,
           'compressed_quotaperiod': True,
           'search_default_active_agriculturalseason': True}
        </field>
    </record>

    <record id="technical_calculation_quotas_action"
            model="ir.actions.server">
        <field name="name">Global recalculation of quotas</field>
        <field name="model_id"
               ref="base_wua_quota_management.model_wua_quota"/>
        <field name="code">
          action = env["wua.quota"].action_recalculate_quotas()
        </field>
    </record>

    <record id="technical_refresh_parcels_action"
            model="ir.actions.server">
        <field name="name">Refresh of parcels (quota flag)</field>
        <field name="model_id"
               ref="base_wua_quota_management.model_wua_quota"/>
        <field name="code">
          action = env["wua.quota"].action_refresh_parcels()
        </field>
    </record>

    <record id="wua_quota_ggregatevalue_action" model="ir.actions.act_window">
        <field name="name">Aggregated Quotas</field>
        <field name="res_model">wua.quota.aggregatevalue</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids"
         eval="[(5, 0),
                (0, 0, {'view_mode': 'tree',
                        'view_id': ref('wua_quota_aggregatevalue_view_tree')})]"/>
        <field name="search_view_id" ref="wua_quota_aggregatevalue_view_search"/>
    </record>

    <menuitem id="quota_menu"
              name="Partner Quotas"
              parent="management_menu"
              sequence="3"
              action="wua_quota_action"/>

    <menuitem id="quota_aggregatevalue_menu"
              name="Partner aggregated quotas"
              parent="management_menu"
              sequence="4"
              action="wua_quota_ggregatevalue_action"/>

    <menuitem id="technical_calculation_quotas_menu"
              name="Calculation: quotas"
              parent="technical_menu"
              sequence="1"
              action="technical_calculation_quotas_action"/>

    <menuitem id="technical_refresh_parcels_menu"
              name="Calculation: parcels (refresh quota flag)"
              parent="technical_menu"
              sequence="2"
              action="technical_refresh_parcels_action"/>

</odoo>