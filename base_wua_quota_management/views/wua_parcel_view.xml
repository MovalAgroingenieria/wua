<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_parcel_view_form" model="ir.ui.view">
        <field name="name">Parcels (form view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id"
               ref="base_wua.wua_parcel_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button" position="after">
                <field name="mapped_to_current_quotaperiod" invisible="1"/>
                <button name="action_assign_provision_not_confirm"
                        type="object" string="Provision"
                        icon="fa-moval-quotas"
                        attrs="{'invisible':
                                [('mapped_to_current_quotaperiod','=',True)]}"
                        groups="base_wua.group_wua_manager"/>
                <button name="action_assign_provision_confirm"
                        type="object" string="Provision"
                        icon="fa-moval-quotas"
                        attrs="{'invisible':
                                [('mapped_to_current_quotaperiod','=',False)]}"
                        groups="base_wua.group_wua_manager"
                        confirm="This parcel already has quotas. Are you sure you want to continue?"/>
            </xpath>
            <xpath expr="//field[@name='county_id']"
                   position="after">
                <div name="not_mapped_to_current_quotaperiod"
                     colspan="2"
                     style="display: inline-block;color:red;padding-top:10px;"
                     attrs="{'invisible':
                             [('mapped_to_current_quotaperiod', '=', True)]}"
                     class="oe_read_only">
                     WARNING: Parcel not included in quotas
                </div>
            </xpath>
            <xpath expr="//button[@name='toggle_active']" position="after">
                <button name="action_get_quota_data"
                        type="object" class="oe_stat_button"
                        icon="fa-moval-quotas">
                    <div class="o_form_field o_stat_info">
                        <span class="o_stat_text">Quota</span>
                        <span class="o_stat_text">Data</span>
                    </div>
                </button>
            </xpath>
            <xpath expr="//field[@name='tag_ids']" position="after">
                <field name="selected_for_current_quotaperiod"
                       string="In current quota" invisible="1"/>
            </xpath>
        </field>
    </record>

    <record id="wua_parcel_view_tree" model="ir.ui.view">
        <field name="name">Parcels (tree view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id"
               ref="base_wua.wua_parcel_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']"
                   position="after">
                <field name="mapped_to_current_quotaperiod"/>
            </xpath>
        </field>
    </record>

    <record id="wua_parcel_view_search" model="ir.ui.view">
        <field name="name">Parcels (search view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id"
               ref="base_wua_infrastructure.wua_parcel_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='hydraulic_infrastructure_type_0']"
                   position="before">
                <filter string="In quotas: Yes" name="inquotasyes"
                 domain="[('mapped_to_current_quotaperiod','=',True)]"/>
                <filter string="In quotas: No" name="inquotasno"
                 domain="[('mapped_to_current_quotaperiod','=',False)]"/>
                <separator/>
            </xpath>
        </field>
    </record>

</odoo>