<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_quota_general_view_form" model="ir.ui.view">
        <field name="name">Quotas General (form view)</field>
        <field name="model">wua.quota.general</field>
        <field name="arch" type="xml">
            <form create="false" unlink="false" duplicate="0">
                <field name="is_current_quotaperiod" invisible="1"/>
                <header>
                </header>
                <sheet>
                    <group name="master_data" col="6">
                        <group name="master_data_left"
                               colspan="4">
                            <field name="agriculturalseason_id"/>
                            <field name="quotaperiod_id"/>
                            <field name="superproduct_id"/>
                        </group>
                        <group name="master_data_right"
                               colspan="2"
                               style="text-align:right;">
                            <field name="water_contributed"/>
                            <field name="water_distributed"/>
                            <field name="water_consumed"/>
                            <field name="distributed_balance"/>
                            <field name="consumed_balance"/>
                        </group>
                    </group>
                    <group name="slave_data">
                        <notebook name="slave_data_notebook">
                            <page name="notes_page" string="Notes">
                                <field name="notes"/>
                            </page>
                        </notebook>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"
                           widget="mail_followers" groups="base_wua.group_wua_manager"/>
                    <field name="message_ids"
                           widget="mail_thread" groups="base_wua.group_wua_manager"/>
                </div>
            </form>
        </field>
    </record>

    <record id="wua_quota_general_view_tree" model="ir.ui.view">
        <field name="name">Quotas General (tree view)</field>
        <field name="model">wua.quota.general</field>
        <field name="arch" type="xml">
            <tree class="o_base_wua_quota_management_quota_general_view_tree"
                  create="false">
                <field name="quotaperiod_id"
                       widget="many2one_unclickable"/>
                <field name="superproduct_id"/>
                <field name="water_contributed"/>
                <field name="water_distributed"/>
                <field name="water_consumed"/>
                <field name="distributed_balance"/>
                <field name="consumed_balance"/>
            </tree>
        </field>
    </record>

    <record id="wua_quota_general_view_search" model="ir.ui.view">
        <field name="name">Quotas General (search view)</field>
        <field name="model">wua.quota.general</field>
        <field name="arch" type="xml">
            <search>
                <filter string="Active Agricultural Season"
                        name="active_agriculturalseason"
                        domain="[('of_active_agriculturalseason','=',True)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Agricultural Season"
                            name="grouped_agriculturalseason"
                     context="{'group_by':'agriculturalseason_id'}"/>
                    <filter string="Quota Period"
                            name="grouped_quotaperiod"
                     context="{'group_by':'quotaperiod_id'}"/>
                    <filter string="Superproduct"
                            name="grouped_superproduct"
                     context="{'group_by':'superproduct_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="wua_quota_general_action"
            model="ir.actions.act_window">
        <field name="name">Quotas General</field>
        <field name="res_model">wua.quota.general</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids"
         eval="[(5, 0),
                (0, 0, {'view_mode': 'tree',
                        'view_id': ref('wua_quota_general_view_tree')}),
                (0, 0, {'view_mode': 'form',
                        'view_id': ref('wua_quota_general_view_form')})]"/>
        <field name="search_view_id" ref="wua_quota_general_view_search"/>
        <field name="context">
          {'compressed_agriculturalseason': True,
           'compressed_quotaperiod': True,
           'search_default_active_agriculturalseason': True}
        </field>
    </record>

    <menuitem id="quota_general_menu"
              name="General Quotas"
              parent="management_menu"
              sequence="3"
              action="wua_quota_general_action"/>

</odoo>