<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_waterconnection_view_form" model="ir.ui.view">
        <field name="name">Water Connections (form view)</field>
        <field name="model">wua.waterconnection</field>
        <field name="inherit_id"
               ref="base_wua_invoicing_pressurized_irrigation.wua_waterconnection_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="fixed_water"/>
                <field name="water_product_order"
                       attrs="{'invisible':[('fixed_water','=',True)]}"/>
            </xpath>
            <xpath expr="//page[@name='watermeters_page']" position="after">

                <page name="consumptions_graph_page" string="Graph"
                    attrs="{'invisible':[('consumptions_graph_invisible','=',True)]}">
                        <field name="consumptions_graph_invisible"
                            invisible="1"/>
                        <field name="consumptions_graph"
                            widget="bokeh_chart" nolabel="1"/>
                </page>
            </xpath>
        </field>
    </record>

    <record id="wua_waterconnection_view_tree" model="ir.ui.view">
        <field name="name">Water Connections (tree view)</field>
        <field name="model">wua.waterconnection</field>
        <field name="inherit_id"
               ref="base_wua_invoicing_pressurized_irrigation.wua_waterconnection_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="fixed_water"/>
            </xpath>
        </field>
    </record>

    <record id="wua_waterconnection_view_search" model="ir.ui.view">
        <field name="name">Water Connections (search view)</field>
        <field name="model">wua.waterconnection</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation.wua_waterconnection_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='withoutwatermeter']" position="after">
                <separator/>
                <filter string="Fixed Water: Yes" name="fixed_water_yes"
                 domain="[('fixed_water','=',True)]"/>
                <filter string="Fixed Water: No" name="fixed_water_no"
                 domain="[('fixed_water','=',False)]"/>
            </xpath>
        </field>
    </record>

    <record id="wua_with_fixed_water" model="ir.actions.server">
        <field name="name">Put with fixed water</field>
        <field name="model_id" ref="model_wua_waterconnection"/>
        <field name="state">code</field>
        <field name="code">
            if context.get('active_ids'):
                action = env['wua.waterconnection'].with_fixed_water(context['active_ids'])
        </field>
    </record>

    <record id="wua_action_with_fixed_water" model="ir.values">
        <field name="name">Put with fixed water</field>
        <field name="model">wua.waterconnection</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('wua_with_fixed_water'))"/>
    </record>

    <record id="wua_without_fixed_water" model="ir.actions.server">
        <field name="name">Put without fixed water</field>
        <field name="model_id" ref="model_wua_waterconnection"/>
        <field name="state">code</field>
        <field name="code">
            if context.get('active_ids'):
                action = env['wua.waterconnection'].without_fixed_water(context['active_ids'])
        </field>
    </record>

    <record id="wua_action_without_fixed_water" model="ir.values">
        <field name="name">Put without fixed water</field>
        <field name="model">wua.waterconnection</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('wua_without_fixed_water'))"/>
    </record>

</odoo>