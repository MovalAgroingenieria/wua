<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_wateringrequest_view_form" model="ir.ui.view">
        <field name="name">Watering Requests (form view)</field>
        <field name="model">wua.wateringrequest</field>
        <field name="inherit_id"
               ref="base_wua_gravity_irrigation.wua_wateringrequest_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='buttons']" position="inside">
                <field name="number_of_hydricmovements" invisible="1"/>
                <button name="action_get_hydric_movements"
                        type="object" class="oe_stat_button"
                        icon="fa-list-ol"
                        attrs="{'invisible':
                                [('number_of_hydricmovements', '=', 0)]}">
                    <div class="o_form_field o_stat_info">
                        <span class="o_stat_text">Hydric</span>
                        <span class="o_stat_text">Movements</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

</odoo>