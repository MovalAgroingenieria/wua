<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_template_form_view" model="ir.ui.view">
        <field name="name">Products (form view)</field>
        <field name="model">product.template</field>
        <field name="inherit_id"
               ref="base_wua_invoicing.product_template_form_view"/>        
        <field name="arch" type="xml">
            <xpath expr="//field[@name='is_wua_product']" position="before">
                <field name="is_superproduct" invisible="1"/>
                <field name="possible_superproduct" invisible="1"/>
                <field name="superproduct_id"
                       attrs="{'invisible':
                               ['|',('is_superproduct','=',True),
                                    ('possible_superproduct','=',False)]}"/>
            </xpath>
        </field>
    </record>

    <record id="product.product_template_action"
            model="ir.actions.act_window">
        <field name="domain">[('is_superproduct','=',False)]</field>
    </record>

    <record id="purchase.product_normal_action_puchased"
            model="ir.actions.act_window">
        <field name="domain">[('is_superproduct','=',False)]</field>
    </record>

</odoo>