<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_individualinput_massive_assignment_view_form" model="ir.ui.view">
        <field name="name">Individual Input Massive Assignments (form view)</field>
        <field name="model">wua.individualinput.massive.assignment</field>
        <field name="arch" type="xml">
            <form duplicate="0">
                <field name="id" invisible="1"/>
                <field name="state" invisible="1"/>
                <header>
                    <button name="execute_massive_assignment"
                            type="object" string="Execute"
                            attrs="{'invisible':['|', ('id','=',False), ('state', '=', '01_executed')]}"
                            groups="base_wua.group_wua_manager"
                            confirm="Are you sure you want to do this operation?"/>
                    <button name="cancel_massive_assignment"
                            type="object" string="Cancel"
                            attrs="{'invisible':['|', ('id','=',False), ('state', '=', '00_draft')]}"
                            groups="base_wua.group_wua_manager"
                            confirm="Are you sure you want to do this operation?"/>
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="00_draft,01_executed"/>
                </header>
                <sheet>
                    <div class="panel-body text-center" style="background:#ededed;border-radius:4px;border-color:#696969;border-width:1px;border-style:solid;padding-top:1px;padding-bottom:8px;margin-bottom:5px"><h2>INDIVIDUAL INPUT MASSIVE ASSIGNMENT</h2></div>
                    <div style="text-align:right;margin-right: 40px;margin-top: 15px;" attrs="{'invisible':[('state','!=','01_executed')]}" class="oe_button_box" name="button_box">
                        <button name="action_show_individualinputs"
                                type="object" class="oe_stat_button"
                                icon="fa-list-ol">

                            <div class="o_form_field o_stat_info">
                                <span class="o_stat_text">Individual</span>
                                <span class="o_stat_text">Inputs</span>
                            </div>
                        </button>
                    </div>
                    <group name="master_data" col="5">
                        <group name="master_data_left"
                               colspan="3" col="4">
                            <field name="agriculturalseason_id" colspan="4"
                                   options="{'no_quick_create':True,
                                             'no_create_edit':True}"
                                   attrs="{'readonly':[('state','=','01_executed')]}"/>
                            <field name="quotaperiod_id" colspan="4"
                                   options="{'no_quick_create':True,
                                             'no_create_edit':True}"
                                   attrs="{'readonly':[('state','=','01_executed')]}"/>
                            <field name="superproduct_id" colspan="4"
                                   options="{'no_quick_create':True,
                                             'no_create_edit':True}"
                                   attrs="{'readonly':[('state','=','01_executed')]}"/>
                            <field name="category_id" colspan="4"
                                   options="{'no_quick_create':True,
                                             'no_create_edit':True}"
                                   attrs="{'readonly':[('state','=','01_executed')]}"/>
                            <field name="event_time" colspan="3"
                                   attrs="{'readonly':[('state','=','01_executed')]}"/>
                            <div colspan="1"></div>
                            <field name="reason" colspan="4"/>
                        </group>
                        <group name="master_data_right"
                               colspan="2"
                               col="4">
                            <field name='total_volume' colspan="4"/>
                            <field name='total_effective_volume' colspan="4"/>
                        </group>
                    </group>
                    <group name="slave_data">
                        <notebook name="slave_data_notebook">
                            <page name="assignment_lines_page" string="Assignment Lines">
                                <field name="assignment_line_ids" context="{'default_reason' : reason}" attrs="{'readonly':[('state','=','01_executed')]}">
                                    <tree editable="bottom" class="o_base_wua_quota_management_individualinput_massive_assignment_line_view_tree">
                                        <field name="name"
                                         invisible="1"/>
                                        <field name="partner_id"
                                            options="{'no_quick_create':True,
                                             'no_create_edit':True}"
                                            domain="[('is_wua_partner', '=', True)]"/>
                                        <field name="volume"/>
                                        <field name="effective_volume"/>
                                        <field name="reason"/>
                                    </tree>
                                </field>
                            </page>
                            <page name="notes_page" string="Notes">
                                <field name="notes"/>
                            </page>
                        </notebook>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"
                           widget="mail_followers" groups="base_wua.group_wua_manager"/>
                    <field name="message_ids"
                           widget="mail_thread" groups="base_wua.group_wua_manager"/>
                </div>
            </form>
        </field>
    </record>

    <record id="wua_individualinput_massive_assignment_view_tree" model="ir.ui.view">
        <field name="name">Individual Inputs (tree view)</field>
        <field name="model">wua.individualinput.massive.assignment</field>
        <field name="arch" type="xml">
            <tree class="o_base_wua_quota_management_individualinput_massive_assignment_view_tree"
                  default_order="event_time desc, name">
                <field name="superproduct_id"/>
                <field name="quotaperiod_id"
                       widget="many2one_unclickable"/>
                <field name="event_time"
                       string="Date" widget="date"/>
                <field name="category_id"/>
                <field name="reason"/>
                <field name='total_effective_volume'/>
                <field name='state'/>
            </tree>
        </field>
    </record>

    <record id="wua_individualinput_massive_assignment_view_search" model="ir.ui.view">
        <field name="name">Individual Inputs Massive Assignment (search view)</field>
        <field name="model">wua.individualinput.massive.assignment</field>
        <field name="arch" type="xml">
            <search>
                <field name="reason"/>
                <filter string="Active Agricultural Season"
                        name="active_agriculturalseason"
                        domain="[('of_active_agriculturalseason','=',True)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Agricultural Season"
                            name="grouped_agriculturalseason"
                     context="{'group_by':'agriculturalseason_id'}"/>
                    <filter string="Quota Period"
                            name="grouped_quotaperiod"
                     context="{'group_by':'quotaperiod_id'}"/>
                    <filter string="Date"
                            name="grouped_event_time"
                     context="{'group_by':'event_time'}"/>
                    <filter string="Superproduct"
                            name="grouped_superproduct"
                     context="{'group_by':'superproduct_id'}"/>
                    <filter string="Category"
                            name="grouped_category"
                     context="{'group_by':'category_id'}"/>
                </group>
            </search>
        </field>
    </record>


    <record id="wua_individualinput_massive_assignment_action"
            model="ir.actions.act_window">
        <field name="name">Individual Inputs Massive Assignments</field>
        <field name="res_model">wua.individualinput.massive.assignment</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids"
         eval="[(5, 0),
                (0, 0, {'view_mode': 'tree',
                        'view_id': ref('wua_individualinput_massive_assignment_view_tree')}),
                (0, 0, {'view_mode': 'form',
                        'view_id': ref('wua_individualinput_massive_assignment_view_form')})]"/>
        <field name="search_view_id" ref="wua_individualinput_massive_assignment_view_search"/>
        <field name="context">
          {'compressed_agriculturalseason': True,
           'compressed_quotaperiod': True,
           'search_default_active_agriculturalseason': True,}
        </field>
    </record>

    <menuitem id="individualinput_massive_assignment_menu"
              name="Individual Inputs Massive Assignments"
              parent="management_menu"
              sequence="7"
              action="wua_individualinput_massive_assignment_action"/>

</odoo>