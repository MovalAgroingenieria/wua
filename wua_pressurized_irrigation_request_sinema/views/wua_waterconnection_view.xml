<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_waterconnection_view_form" model="ir.ui.view">
        <field name="name">Water Connections (form view)</field>
        <field name="model">wua.waterconnection</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation_request.wua_waterconnection_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='default_request_initial_hour']" position="after">
                <field name="siemens_id"/>
            </xpath>
        </field>
    </record>


</odoo>
