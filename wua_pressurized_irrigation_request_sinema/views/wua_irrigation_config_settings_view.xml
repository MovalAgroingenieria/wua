<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_irrigation_config_settings_view_form" model="ir.ui.view">
        <field name="name">Parameters</field>
        <field name="model">wua.irrigation.configuration</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation.wua_irrigation_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='irrigation_event']"
                   position="after">
                <group name="siemens_data_info" string="SINEMA Endpoint">
                    <field name="sinema_endpoint"/>
                    <field name="sinema_username"/>
                    <field name="sinema_password"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
