<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record model="ir.actions.server" id="action_send_email_on_negative_flowreading">
            <field name="name">Enviar correo electrónico en lectura de caudalímetro negativa</field>
            <field name="model_id" ref="model_wua_negative_flowreading"/>
            <field name="state">code</field>
            <field name="code">
            <![CDATA[
if record:
    template = env.ref('base_wua_irrigation_measurement.email_template_negative_flowreading')
    template.sudo().send_mail(record.id, force_send=True)
True]]>
            </field>
        </record>

        <record model="base.action.rule" id="action_rule_send_email_on_negative_flowreading">
            <field name="name">Regla de acción para enviar correo electrónico en lectura de caudalímetro negativa</field>
            <field name="sequence">10</field>
            <field name="model_id" ref="model_wua_negative_flowreading"/>
            <field name="server_action_ids" eval="[(6, 0, [ref('action_send_email_on_negative_flowreading')])]"/>
            <field name="kind">on_create</field>
            <field name="domain_force">[]</field>
            <field name="active">False</field>
        </record>

    </data>

</odoo>