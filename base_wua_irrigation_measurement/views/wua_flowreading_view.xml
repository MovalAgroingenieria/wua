<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="wua_flowreading_view_tree" model="ir.ui.view">
      <field name="name">Flowreading (tree view)</field>
      <field name="model">wua.flowreading</field>
      <field name="arch" type="xml">
          <tree class="o_base_wua_irrigation_measurement_flowreading_view_tree">
            <field name="flowmeter_id"/>
            <field name="reading_time"/>
            <field name="volume"/>
            <field name="initialization_reading"/>
            <field name="instant_flow"/>
            <field name="is_last_reading"/>
            <field name="intakeconsumption_id"/>
            <field name="validated" string="Validated Flow R."/>
          </tree>
      </field>
  </record>

  <record id="wua_flowreading_view_form" model="ir.ui.view">
      <field name="name">Flowreading (form view)</field>
      <field name="model">wua.flowreading</field>
      <field name="arch" type="xml">
        <form duplicate="0">
            <header>
                <button name="%(action_delete_flowmeter_readings)d"
                        type="action" string="Delete readings"
                        groups="base_wua.group_wua_manager"/>
            </header>
            <field name="id" invisible="1"/>
            <field name="reading_of_intake" invisible="1"/>
            <field name="is_last_reading" invisible="1"/>
            <sheet>
                <div name="buttons" class="oe_button_box">
                    <img src="/base_wua_irrigation_measurement/static/image/img_last.png"
                         hspace="2"
                         attrs="{'invisible':[('is_last_reading', '=', False)]}"/>
                </div>
                <group name="master_data">
                    <group name="master_data_left">
                      <field name="flowmeter_id"
                             attrs="{'readonly': [('id', '>', 0)]}"/>
                        <field name="volume"
                               attrs="{'readonly':
                                       [('id', '>', 0),
                                        ('is_last_reading', '!=', True)]}"/>
                        <field name="reading_time"
                               attrs="{'readonly': [('id', '>', 0)]}"/>
                        <field name="instant_flow"
                               attrs="{'readonly': [('id', '>', 0)]}"/>
                        <field name="initialization_reading"
                               attrs="{'readonly': [('id', '>', 0)]}"/>
                    </group>
                    <group name="master_data_right">
                        <field name="intake_id" attrs="{'invisible': [('reading_of_intake', '=', False)]}"/>
                        <field name="intakeconsumption_id" attrs="{'invisible': [('reading_of_intake', '=', False)]}"/>
                        <field name="validated" readonly="1"/>
                    </group>
                </group>
                <group name="slave_data">
                    <notebook name="slave_data_notebook">
                        <page name="notes_page" string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </group>
            </sheet>
        </form>
      </field>
  </record>

  <record id="wua_flowreading_view_search" model="ir.ui.view">
      <field name="name">Flowreading (search view)</field>
      <field name="model">wua.flowreading</field>
      <field name="arch" type="xml">
          <search>
            <field string="Flowmeter" name="flowmeter_id"/>
            <field string="Intake" name="intake_id"/>
            <filter string="Initialization Reading" name="initreadingyes"
             domain="[('initialization_reading','=',True)]"/>
            <filter string="Normal Reading" name="initreadingno"
             domain="[('initialization_reading','=',False)]"/>
            <separator/>
            <filter string="Reading of intake: Yes" name="readingintakeyes"
              domain="[('reading_of_intake','=',True)]"/>
            <filter string="Reading of intake: No" name="readingintakeno"
              domain="[('reading_of_intake','=',False)]"/>
            <separator/>
            <filter string="Validated Reading: Yes" name="isvalidatedyes"
             domain="[('validated','=',True)]"/>
            <filter string="Validated Reading: No" name="isvalidatedno"
             domain="[('validated','=',False)]"/>
            <group expand="0" string="Group By">
                <filter string="Flowmeter"
                  name="flowmeter"
                  context="{'group_by':'flowmeter_id'}"/>
                <filter string="Intake"
                  name="intake"
                  context="{'group_by':'intake_id'}"/>
              </group>
          </search>
      </field>
  </record>

  <record id="wua_flowreading_view_pivot" model="ir.ui.view">
    <field name="name">Flowreading (pivot view)</field>
    <field name="model">wua.flowreading</field>
    <field name="arch" type="xml">
        <pivot string="Agregated Values" display_quantity="false">
            <field name="volume" type="measure"/>
        </pivot>
    </field>
  </record>

  <record id="wua_validate_flowreadings" model="ir.actions.server">
      <field name="name">Validate</field>
      <field name="model_id" ref="model_wua_flowreading"/>
      <field name="state">code</field>
      <field name="code">
          if context.get('active_ids'):
              action = env['wua.flowreading'].validate_flowreadings(context['active_ids'])
      </field>
  </record>

  <record id="wua_action_validate_flowreadings" model="ir.values">
      <field name="name">Validate</field>
      <field name="model">wua.flowreading</field>
      <field name="key">action</field>
      <field name="key2">client_action_multi</field>
      <field name="value" eval="'ir.actions.server,' + str(ref('wua_validate_flowreadings'))"/>
  </record>

  <record id="wua_cancel_flowreadings" model="ir.actions.server">
      <field name="name">Cancel</field>
      <field name="model_id" ref="model_wua_flowreading"/>
      <field name="state">code</field>
      <field name="code">
          if context.get('active_ids'):
              action = env['wua.flowreading'].cancel_flowreadings(context['active_ids'])
      </field>
  </record>

  <record id="wua_action_cancel_flowreadings" model="ir.values">
      <field name="name">Cancel</field>
      <field name="model">wua.flowreading</field>
      <field name="key">action</field>
      <field name="key2">client_action_multi</field>
      <field name="value" eval="'ir.actions.server,' + str(ref('wua_cancel_flowreadings'))"/>
  </record>

  <record id="wua_flowreading_action" model="ir.actions.act_window">
      <field name="name">Flowmeter Readings</field>
      <field name="res_model">wua.flowreading</field>
      <field name="view_type">form</field>
      <field name="view_mode">tree,form,pivot</field>
      <field name="view_id" ref="wua_flowreading_view_tree"/>
      <field name="search_view_id" ref="wua_flowreading_view_search"/>
  </record>

  <menuitem
      name="Flow Meter Readings"
      id="wua_flowreading_menu"
      parent="base_wua_irrigation_measurement_menu"
      sequence="2"
      action="wua_flowreading_action"/>

</odoo>