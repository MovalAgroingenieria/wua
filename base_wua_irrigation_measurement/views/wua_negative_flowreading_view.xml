<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_negative_flowreading_view_form" model="ir.ui.view">
        <field name="name">Negative Flowreadings (form view)</field>
        <field name="model">wua.negative.flowreading</field>
        <field name="arch" type="xml">
            <form create="false" edit="false" delete="false" duplicate="0">
                <field name="id" invisible="1"/>
                <sheet>
                    <group name="master_data">
                        <group name="master_data_left">
                            <field name="volume"/>
                            <field name="consumption_volume" string="Cons. Value (m³)"/>
                            <field name="instant_flow"/>
                            <field name="reading_time"/>
                            <field name="flowmeter_id"/>
                        </group>
                        <group name="master_data_right">
                            <field name="intake_id"/>
                        </group>
                    </group>
                    <group name="slave_data">
                        <notebook name="slave_data_notebook">
                            <page name="notes_page" string="Notes">
                                <field name="notes"/>
                            </page>
                        </notebook>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="wua_negative_flowreading_view_tree" model="ir.ui.view">
        <field name="name">Negative Flow-Readings (tree view)</field>
        <field name="model">wua.negative.flowreading</field>
        <field name="arch" type="xml">
            <tree
             class="base_wua_irrigation_measurement_infrastructure_negative_flowreadings_view_tree"
             create="false">
                <field name="flowmeter_id"/>
                <field name="intake_id"/>
                <field name="reading_time"/>
                <field name="volume"/>
                <field name="instant_flow"/>
                <field name="consumption_volume" string="Cons. Value (m³)"/>
            </tree>
        </field>
    </record>

    <record id="wua_negative_flowreading_view_search" model="ir.ui.view">
        <field name="name">Negative Flow-Readings (search view)</field>
        <field name="model">wua.negative.flowreading</field>
        <field name="arch" type="xml">
            <search>
                <field name="flowmeter_id"/>
                <field name="intake_id"/>
                <group expand="0" string="Group By">
                    <filter string="Intake"
                     name="intake"
                     context="{'group_by':'intake_id'}"/>
                    <filter string="Flow Meter"
                     name="flowmeter"
                     context="{'group_by':'flowmeter_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="wua_negative_intake_reading_action" model="ir.actions.act_window">
        <field name="name">Negative Intake Readings</field>
        <field name="res_model">wua.negative.flowreading</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="wua_negative_flowreading_view_tree"/>
        <field name="search_view_id" ref="wua_negative_flowreading_view_search"/>
        <field name="domain">[("intake_id", "!=", False)]</field>
    </record>

    <menuitem id="wua_negative_intake_reading_menu"
              name="Negative Intake Readings"
              parent="base_wua_irrigation_measurement_menu"
              action="wua_negative_intake_reading_action"
              sequence="98"
              groups="base_wua.group_wua_user"/>

</odoo>
