<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <report id="action_wua_wateringrequest_report"
            string="Watering Request"
            model="wua.wateringrequest"
            report_type="qweb-pdf"
            name="base_wua_gravity_irrigation.report_wua_wateringrequest"
            file="base_wua_gravity_irrigation.report_wua_wateringrequest"
            paperformat="base_wua_report.paperformat_wua_reports"/>

    <template id="report_wua_wateringrequest">
        <t t-call="report.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="base_wua_report.wua_external_layout">
                    <t t-call="base_wua_gravity_irrigation.report_wua_wateringrequest_document"/>
                </t>
            </t>
        </t>
    </template>

    <template id="report_wua_wateringrequest_document">
        <div class="page">

            <!-- Vars -->
            <t t-set="report_style" t-value="request.env['ir.values'].get_default('wua.configuration', 'reports_style')"/>

            <!-- Title -->
            <div name="title" class="text-center">
                <h4><strong>Watering request</strong></h4>
            </div>

            <!-- Partner (irrigator) data -->
            <div name="wua_irrigator_data">
                <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                    <t t-if="report_style == 'light'">
                        <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-user"/></div>
                            <div style="float: left; display: inline;"><strong>Irrigator</strong></div>
                       </div>
                    </t>
                    <t t-else="">
                        <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-user"/></div>
                            <div style="float: left; display: inline;"><strong>Irrigator</strong></div>
                        </div>
                    </t>
                </div>
                <div class="row" style="margin-top: 4px;">
                    <div class="col-xs-12" style="display: table;">
                        <div style="width: 50%; display: table-cell;">
                            <t t-if="o.partner_id.name">
                                <strong><span t-field="o.partner_id.name"/></strong>
                                <t t-if="o.partner_id.vat"><span>(NIF:&amp;nbsp;<span t-field="o.partner_id.vat"/>)</span></t>
                                <br/>
                            </t>
                            <t t-if="o.partner_id.street_type_show or o.partner_id.street or o.street_num or o.partner_id.street2">
                                <t t-if="o.partner_id.street_type_show"><span t-field="o.partner_id.street_type_show"/></t>
                                <t t-if="o.partner_id.street"><span t-field="o.partner_id.street"/></t>
                                <t t-if="o.partner_id.street_num"><span t-field="o.partner_id.street_num"/></t>
                                <t t-if="o.partner_id.street2"><span t-field="o.partner_id.street2"/></t>
                                <br/>
                            </t>
                            <t t-if="o.partner_id.city or o.partner_id.zip">
                                <t t-if="o.partner_id.city"><span t-field="o.partner_id.city"/></t>
                                <t t-if="o.partner_id.zip"><span>-&amp;nbsp;</span><span t-field="o.partner_id.zip"/></t>
                                <br/>
                            </t>
                            <t t-if="o.partner_id.state_id or o.partner_id.country_id">
                                <t t-if="o.partner_id.state_id"><span t-field="o.partner_id.state_id"/></t>
                                <t t-if="o.partner_id.country_id"><span>-&amp;nbsp;</span><span t-field="o.partner_id.country_id"></span></t>
                                <br/>
                            </t>
                            <t t-if="o.partner_id.phones or o.partner_id.phone or o.partner_id.mobile">
                                <t t-if="o.partner_id.phones"><span t-field="o.partner_id.phones"/></t>
                                <t t-else="">
                                    <t t-if="o.partner_id.phone"><span t-field="o.partner_id.phone"/></t>
                                    <t t-if="o.partner_id.mobile"><span t-field="o.partner_id.mobile"/></t>
                                </t>
                                <br/>
                            </t>
                            <t t-if="o.partner_id.email"><span t-field="o.partner_id.email"/><br/></t>
                        </div>
                        <div style="display: table-cell; padding-left: 32px;">
                            <div>&amp;nbsp;</div>
                            <t t-if="o.partner_id.partnerlink_ids">
                                <t t-set="measurement_unit" t-value="o.partner_id.partnerlink_ids[0].parcel_id._compute_area_measurement_name()"/>
                            </t>
                            <table style="width:100%;">
                                <tbody>
                                    <tr>
                                        <td><span>Wua partner code:</span></td>
                                        <td class="text-right" style="padding: 0 0 0 90px;">
                                           <t t-if="o.partner_id.partner_code">
                                               <t t-set="partner_code" t-value="str(o.partner_id.partner_code)"/>
                                           </t>
                                           <span t-esc="partner_code"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><span>Number of requests:</span></td>
                                        <td class="text-right">
                                           <t t-if="o.partner_id.number_of_requests">
                                               <t t-set="number_of_requests" t-value="str(o.partner_id.number_of_requests)"/>
                                           </t>
                                           <span t-esc="number_of_requests"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><span>Number of gravity consumptions:</span></td>
                                        <td class="text-right">
                                           <t t-if="o.partner_id.number_of_gravconsumptions">
                                               <t t-set="number_of_gravconsumptions" t-value="str(o.partner_id.number_of_gravconsumptions)"/>
                                           </t>
                                           <span t-esc="number_of_gravconsumptions"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Insert from base_wua_gravity_irrigation_with_quota -->

            <!-- Watering request -->
            <div name="watering_request_data" style="margin-top:20px;">
                <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                    <t t-if="report_style == 'light'">
                        <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-moval-watering-request"/></div>
                            <div style="float: left; display: inline;"><strong>Watering&amp;nbsp;request</strong></div>
                            <div style="float: right; width: 32px;">
                                <t t-if="o.state == 'pending'"><span class="fa fa-moval-lock-open"/></t>
                                <t t-else=""><span class="fa fa-lock"/></t>
                            </div>
                       </div>
                    </t>
                    <t t-else="">
                        <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-moval-watering-request"/></div>
                            <div style="float: left; display: inline;"><strong>Watering&amp;nbsp;request</strong></div>
                            <div style="float: right; width: 32px;">
                                <t t-if="o.state == 'pending'"><span class="fa fa-moval-lock-open"/></t>
                                <t t-else=""><span class="fa fa-lock"/></t>
                            </div>
                        </div>
                    </t>
                </div>
                <div class="row" style="margin-top: 4px;">
                    <div class="col-xs-12" style="display: table;">
                        <div style="display: table-cell;">
                            <table name="request_data_left" class="table-condensed" style="width:90%;">
                                <tbody>
                                    <tr name="tr_name">
                                        <td><span>Watering Request:</span></td>
                                        <td class="text-right"><span t-field="o.name"/></td>
                                    </tr>
                                    <tr name="tr_wateringperiod_id">
                                        <td>
                                            <span>Watering Period:</span>
                                        </td>
                                        <td class="text-right">
                                            <span t-field="o.wateringperiod_id"/>
                                            <t t-if="o.is_open"><span class="fa fa-moval-lock-open"/></t>
                                            <t t-if="not o.is_open"><span class="fa fa-lock"/></t>
                                        </td>
                                    </tr>
                                    <tr name="tr_agriculturalseason_id">
                                        <td><span>Agricultural season:</span></td>
                                        <td class="text-right"><span t-field="o.agriculturalseason_id"/></td>
                                    </tr>
                                    <tr name="tr_state">
                                        <td><span>Request state:</span></td>
                                        <td class="text-right">
                                            <b><span t-field="o.state"/></b>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <div style="display: table-cell; padding-left: 10px;">
                            <table name="request_data_right" class="table-condensed" style="width:90%;">
                                <tbody>
                                    <tr name="tr_request_date">
                                        <td><span>Request Date:</span></td>
                                        <td class="text-right"><b><span t-field="o.request_date"/></b></td>
                                    </tr>
                                     <tr name="tr_product_id">
                                        <td><span>Water type:</span></td>
                                        <td class="text-right"><span t-field="o.product_id"/></td>
                                    </tr>
                                    <tr name="tr_pnumber_of_subparcels">
                                        <td><span>Number of subparcels:</span></td>
                                        <td class="text-right"><span t-field="o.number_of_subparcels"/></td>
                                    </tr>
                                    <tr name="tr_is_portal_user">
                                        <td><span>Created by the partner:</span></td>
                                        <td class="text-right">
                                            <t t-if="o.is_portal_user"><span class="fa fa-check"/></t>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <t t-if="o.notes">
                    <div name="notes" style="margin-top: 12px;">
                        <span>Notes:</span><br/>
                        <div style="margin-left: 4px; margin-right: 38px;">
                            <span t-field="o.notes"/>
                        </div>
                    </div>
                </t>
            </div>

            <!-- Requested Subparcels -->
            <div name="requested_subparcels_data" style="margin-top:20px;">
                <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                    <t t-if="report_style == 'light'">
                        <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-moval-drop-water"/></div>
                            <div style="float: left; display: inline;"><strong>Requested&amp;nbsp;Subparcels</strong></div>
                       </div>
                    </t>
                    <t t-else="">
                        <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-moval-drop-water"/></div>
                            <div style="float: left; display: inline;"><strong>Requested&amp;nbsp;Subparcels</strong></div>
                        </div>
                    </t>
                </div>
                <div style="margin-top: 4px;">
                    <t t-if="o.gravconsumption_ids and len(o.gravconsumption_ids) > 0">
                        <table class="table table-striped" style="width:100%;">
                            <thead>
                                <th name="th_subparcel" class="text-center">Subparcel</th>
                                <th name="th_parcel" class="text-center">Parcel</th>
                                <th name="th_irrigationditch" class="text-left">Irrigationditch</th>
                                <th name="th_surface" class="text-right">
                                    <span>Surface</span>
                                    <t t-if="measurement_unit">
                                        <span>(<t t-esc="measurement_unit"/>)</span>
                                    </t>
                                </th>
                                <th name="th_cadastral_ref" class="text-center">Cadastral reference</th>
                                <th name="th_duration" class="text-right">Duration (min)</th>
                            </thead>
                            <tbody>
                                <t t-foreach="o.gravconsumption_ids" t-as="l" style="page-break-inside: avoid;">
                                    <tr>
                                        <td name="td_subparcel" align="center">
                                            <span t-field="l.subparcel_id"/>
                                        </td>
                                        <td name="td_parcel" align="center">
                                            <span t-field="l.parcel_id"/>
                                        </td>
                                        <td name="td_irrigationditch" align="left">
                                            <span t-field="l.irrigationditch_id"/>
                                        </td>
                                        <td name="td_surface" align="right">
                                            <span t-field="l.subparcel_id.area_official"/>
                                        </td>
                                        <td name="td_cadastral_ref" align="center">
                                            <span t-field="l.parcel_id.cadastral_reference"/>
                                        </td>
                                        <td name="td_duration" align="right">
                                            <t t-if="l.watering_duration">
                                                <t t-set="watering_duration" t-value="str(l.watering_duration)"/>
                                                <span t-esc="l.watering_duration"/>
                                            </t>
                                            
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>
                </div>
            </div>

            <!-- Conformity -->
            <div name="conformity" style="margin-top: 32px;">
                <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                    <t t-if="report_style == 'light'">
                        <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-check-square-o"/></div>
                            <div style="float: left; display: inline;"><strong>Conformity</strong></div>
                       </div>
                    </t>
                    <t t-else="">
                        <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                            <div style="float: left; width: 32px;"><span class="fa fa-check-square-o"/></div>
                            <div style="float: left; display: inline;"><strong>Conformity</strong></div>
                        </div>
                    </t>
                </div>
                <div name="signature" class="row" style="border: 1px solid lightgrey; margin: 2px 1px; page-break-inside: avoid;">
                    <div class="col-xs-12" style="display: table;">
                        <div style="border-right: 1px solid lightgrey; width: 50%; display: table-cell;">
                            <p style="margin-left: -8px; margin-top: 2px; margin-bottom: 0px;">
                                <span>Place and date</span>
                            </p>
                            <t t-if="request.env.user.company_id.city and request.env.user.company_id.state_id.name">
                                <p class="text-center" style="margin-top: 4px;">
                                    <span t-esc="request.env.user.company_id.city"/>
                                    (<span t-esc="request.env.user.company_id.state_id.name"/>),
                                    <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y')"/><br/>
                                    <span style="font-size: 10px;" t-esc="context_timestamp(datetime.datetime.now()).strftime('%H:%M:%S')"/>
                                </p>
                            </t>
                            <t t-else="">
                                <p>&amp;nbsp;</p>
                                <p>&amp;nbsp;</p>
                            </t>
                        </div>
                        <div style="width: 50%; display: table-cell; padding: 0px 8px;">
                            <p style="margin-top: 2px; margin-bottom: 0px">
                                <span>Signature</span>
                            </p>
                             <t t-if="o.signature_image">
                                <div class="text-center">
                                    <img style="max-width: 380px;" t-attf-src="data:image/*;base64,{{o.signature_image}}"/>
                                </div>
                            </t>
                            <t t-else="">
                                <p>&amp;nbsp;</p>
                                <p>&amp;nbsp;</p>
                                <p>&amp;nbsp;</p>
                            </t>
                        </div>
                    </div>
                </div>
            </div>

        </div><!-- end page -->
    </template>

</odoo>
