<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        
        <record id="rule_wua_wateringrequest_group_wua_portal_user" model="ir.rule">
            <field name="name">Rule for Wua Portal User on watering requests</field>
            <field name="model_id" ref="model_wua_wateringrequest"/>
            <field name="domain_force">[('partner_id','=',user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base_wua.group_wua_portal_user'))]"/>
        </record>

        <record id="rule_wua_gravconsumption_group_wua_portal_user" model="ir.rule">
            <field name="name">Rule for Wua Portal User on gravity consumptions</field>
            <field name="model_id" ref="model_wua_gravconsumption"/>
            <field name="domain_force">['|',('partner_id','=',user.partner_id.id),('partner_id','=',False)]</field>
            <field name="groups" eval="[(4, ref('base_wua.group_wua_portal_user'))]"/>
        </record>

    </data>
</odoo>