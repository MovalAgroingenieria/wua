    <record id="wua_set_consumption_as_selected" model="ir.actions.server">
        <field name="name">Select for calculation</field>
        <field name="model_id" ref="model_wua_gravconsumption"/>
        <field name="state">code</field>
        <field name="code">
            if context.get('active_ids'):
                action = env['wua.gravconsumption'].set_as_selected(context['active_ids'])
        </field>
    </record>
    
    <record id="wua_action_set_consumption_as_selected" model="ir.values">
        <field name="name">Set consumption as selected</field>
        <field name="model">wua.gravconsumption</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('wua_set_consumption_as_selected'))"/>
    </record>

