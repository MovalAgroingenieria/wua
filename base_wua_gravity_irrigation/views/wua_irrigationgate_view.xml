<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_irrigationgate_view_form" model="ir.ui.view">
        <field name="name">Irrigation Gates (form view)</field>
        <field name="model">wua.irrigationgate</field>
        <field name="inherit_id" ref="base_wua_infrastructure.wua_irrigationgate_view_form"/>        
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_see_gis_googlemaps']"
                   position="after">
                <button name="action_see_gravconsumptions"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-moval-irrigation"
                        groups="base_wua.group_wua_user">
                        <div class="o_form_field o_stat_info">
                            <span class="o_stat_text">Consumptions</span>
                        </div>
                </button>
            </xpath>
        </field>
    </record>

</odoo>