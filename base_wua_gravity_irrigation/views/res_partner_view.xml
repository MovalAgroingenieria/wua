<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form" model="ir.ui.view">
        <field name="name">Partners (form view)</field>
        <field name="model">res.partner</field>
        <field name="inherit_id"
               ref="base_wua_infrastructure.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_see_gis_viewer']"
                   position="after">
                <button name="action_see_watering_requests"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-file"
                        groups="base_wua.group_wua_user,
                                base_wua.group_wua_portal_user">
                        <div class="o_form_field o_stat_info">
                            <span class="o_stat_value">
                                <field name="number_of_requests"/>
                            </span>
                            <span class="o_stat_text">
                                water requests
                            </span>
                        </div>
                </button>
            </xpath>
        </field>
    </record>

</odoo>