<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_irrigation_config_settings_view_form" model="ir.ui.view">
        <field name="name">Parameters</field>
        <field name="model">wua.irrigation.configuration</field>
        <field name="inherit_id" ref="wua_structure_irrigation.wua_irrigation_config_settings_view_form"/>
        <field name="arch" type="xml">
          <xpath expr="//field[@name='default_distribute_extra_volume']"
                 position="after">
              <field name="watering_allow_open_period"/>
              <field name="watering_allow_early_start" style="width:100px"/>
              <field name="notice_prior_irrigation_days"/>
          </xpath>
        </field>
    </record>

</odoo>
