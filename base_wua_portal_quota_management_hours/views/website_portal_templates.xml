<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="portal_my_quotas_hours"
                  inherit_id="base_wua_portal_quota_management.portal_my_quotas"
                  name="Portal My Quotas - Conditional Hours Table">

            <xpath expr="//th[@id='water_type_th']" position="after">
                <t t-set="show_hours_portal"
                   t-value="request.env['ir.values'].sudo().get_default('wua.quotas.configuration', 'show_hours_portal')"/>

                <th t-if="show_hours_portal">Assignation (h)</th>
                <th t-if="show_hours_portal">Consumption (h)</th>
                <th t-if="show_hours_portal">Available (h)</th>
                <th t-if="show_hours_portal">Available %</th>
            </xpath>

            <xpath expr="//th[@id='assignation_th']" position="attributes">
                <attribute name="t-if">not show_hours_portal</attribute>
            </xpath>
            <xpath expr="//th[@id='consumptions_th']" position="attributes">
                <attribute name="t-if">not show_hours_portal</attribute>
            </xpath>
            <xpath expr="//th[@id='available_th']" position="attributes">
                <attribute name="t-if">not show_hours_portal</attribute>
            </xpath>
            <xpath expr="//th[@id='available_percentage_th']" position="attributes">
                <attribute name="t-if">not show_hours_portal</attribute>
            </xpath>

            <xpath expr="//td[@id='assignation_td']" position="after">
                <td t-if="show_hours_portal"><t t-esc="quota.accumulated_input_hours"/></td>
                <td t-if="show_hours_portal"><t t-esc="quota.accumulated_consumption_hours"/></td>
                <td t-if="show_hours_portal"><t t-esc="quota.balance_hours"/></td>
                <td t-if="show_hours_portal"><t t-esc="quota.available_quota_percentage"/></td>
            </xpath>

            <xpath expr="//td[@id='assignation_td']" position="attributes">
                <attribute name="t-if">not show_hours_portal</attribute>
            </xpath>
            <xpath expr="//td[@id='consumptions_td']" position="attributes">
                <attribute name="t-if">not show_hours_portal</attribute>
            </xpath>
            <xpath expr="//td[@id='available_td']" position="attributes">
                <attribute name="t-if">not show_hours_portal</attribute>
            </xpath>
            <xpath expr="//td[@id='available_percentage_td']" position="attributes">
                <attribute name="t-if">not show_hours_portal</attribute>
            </xpath>
        </template>
    </data>
</odoo>
