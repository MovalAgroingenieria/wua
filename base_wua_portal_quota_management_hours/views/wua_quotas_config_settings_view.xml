<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_quotas_config_settings_view_form" model="ir.ui.view">
        <field name="name">Parameters</field>
        <field name="model">wua.quotas.configuration</field>
        <field name="inherit_id" ref="base_wua_quota_management_hours.wua_quotas_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group" position="after">
                <group string="Portal Quota Display Options">
                    <field name="show_hours_portal"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>