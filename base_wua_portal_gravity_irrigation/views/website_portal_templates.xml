<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Portal view for gravity irrigation consumptions -->
        <template id="portal_my_gravconsumptions" name="My Gravity Consumptions">
            <t t-call="website.layout">
                <t t-call="base_wua_portal.portal_wua_navbar"/>
                <t t-if="not gravconsumptions">
                    <div class="alert alert-info" role="alert">
                        There are currently no gravity irrigation consumptions for your account.
                    </div>
                </t>
                <t t-if="gravconsumptions">
                    <div id="wrap">
                        <div class="container-fluid mb64" style="max-width: 98%; margin: 0 auto;">
                            <div class="col-md-12">
                                <h3 class="page-header">Gravity Irrigation Consumptions</h3>
                                <div class="row" style="margin-bottom:6px;">
                                    <div class="col-md-3">
                                        <form method="GET" class="form-inline" style="margin:0;">
                                            <input type="hidden" name="filter_state" t-att-value="filter_state or ''"/>
                                            <div class="form-group">
                                                <label for="wateringperiod_filter" class="mr8">Period:</label>
                                                <select name="wateringperiod_id" id="wateringperiod_filter" class="form-control" onchange="this.form.submit()">
                                                    <option value="">All Periods</option>
                                                    <t t-foreach="wateringperiods" t-as="period">
                                                        <option t-att-value="period.id" t-att-selected="'selected' if selected_wateringperiod_id == period.id else None">
                                                            <t t-esc="period.display_name"/>
                                                        </option>
                                                    </t>
                                                </select>
                                            </div>
                                        </form>
                                    </div>
                                    <div class="col-md-2">
                                        <form method="GET" class="form-inline" style="margin:0;">
                                            <input type="hidden" name="wateringperiod_id" t-att-value="selected_wateringperiod_id or ''"/>
                                            <div class="form-group">
                                                <label for="state_filter" class="mr8">Status:</label>
                                                <select name="filter_state" id="state_filter" class="form-control" onchange="this.form.submit()">
                                                    <option value="">All</option>
                                                    <option value="proposed" t-att-selected="'selected' if filter_state == 'proposed' else None">Proposed</option>
                                                    <option value="planned" t-att-selected="'selected' if filter_state == 'planned' else None">Planned</option>
                                                    <option value="executed" t-att-selected="'selected' if filter_state == 'executed' else None">Executed</option>
                                                </select>
                                            </div>
                                        </form>
                                    </div>
                                    <div class="col-md-7">
                                        <form method="GET" style="width:100%;">
                                            <input type="hidden" name="wateringperiod_id" t-att-value="selected_wateringperiod_id or ''"/>
                                            <input type="hidden" name="filter_state" t-att-value="filter_state or ''"/>
                                            <div style="display:flex; align-items:center;">
                                                <div class="form-group mr8">
                                                    <select name="search_field" class="form-control">
                                                        <option value="">Search by...</option>
                                                        <option value="watering" t-att-selected="'selected' if search_field == 'watering' else None">Watering</option>
                                                        <option value="parcel" t-att-selected="'selected' if search_field == 'parcel' else None">Parcel</option>
                                                        <option value="irrigationditch" t-att-selected="'selected' if search_field == 'irrigationditch' else None">Irrigation Ditch</option>
                                                        <option value="state" t-att-selected="'selected' if search_field == 'state' else None">Status</option>
                                                    </select>
                                                </div>
                                                <div class="form-group mr8" style="flex:1;">
                                                    <input type="text" name="search" class="form-control" placeholder="Search..." t-att-value="search_query or ''" style="width:100%; box-sizing:border-box;"/>
                                                </div>
                                                <div class="form-group">
                                                    <button type="submit" class="btn btn-primary">Search</button>
                                                    <a href="/my/gravconsumptions" class="btn btn-default ml8">Clear</a>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>

                                <div class="table-responsive">
                                    <t t-if="not grouped_consumptions">
                                        <p class="text-muted">There are no gravity irrigation consumptions.</p>
                                    </t>
                                    <t t-else="">
                                        <t t-foreach="grouped_consumptions.items()" t-as="period_group">
                                            <t t-set="period_name" t-value="period_group[0]"/>
                                            <t t-set="state_groups" t-value="period_group[1]"/>

                                            <div class="panel panel-default" style="margin-top: 15px;">
                                                <div class="panel-heading" style="background-color: #f5f5f5;">
                                                    <h4 class="panel-title" style="margin: 0; font-weight: bold;">
                                                        <i class="fa fa-calendar"></i>
                                                        <t t-esc="period_name"/>
                                                    </h4>
                                                </div>
                                                <div class="panel-body" style="padding: 0;">
                                                    <t t-foreach="['Proposed', 'Planned', 'Executed']" t-as="status">
                                                        <t t-if="state_groups.get(status)">
                                                            <div style="margin: 10px;">
                                                                <table class="table table-hover o_my_status_table" style="margin-bottom: 0;">
                                                                    <thead>
                                                                        <tr class="active">
                                                                            <th style="width:14%;">Irrigation Ditch</th>
                                                                            <th style="width:12%;">Parcel</th>
                                                                            <th class="text-center" style="width:5%;">Day</th>
                                                                            <th class="text-center" style="width:11%;">Start Time</th>
                                                                            <th class="text-center" style="width:5%;">Day</th>
                                                                            <th class="text-center" style="width:11%;">End Time</th>
                                                                            <th class="text-right" style="width:7%;">Duration (min)</th>
                                                                            <th class="text-right" style="width:7%;">Watering Vol. (m³)</th>
                                                                            <th class="text-right" style="width:7%;">Extra Vol. (m³)</th>
                                                                            <th class="text-right" style="width:7%;">Total Vol. (m³)</th>
                                                                            <th class="text-right" style="width:7%;">Area (m²)</th>
                                                                            <th class="text-center" style="width:7%;">State</th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody>
                                                                        <t t-foreach="state_groups[status]" t-as="consumption">
                                                                            <tr>
                                                                                <td style="overflow:hidden; text-overflow:ellipsis;" t-att-title="consumption.irrigationditch_id.name or ''">
                                                                                    <t t-esc="consumption.irrigationditch_id.name or '-'"/>
                                                                                </td>
                                                                                <td style="overflow:hidden; text-overflow:ellipsis;" t-att-title="consumption.parcel_id.name or ''">
                                                                                    <t t-esc="consumption.parcel_id.name or '-'"/>
                                                                                </td>
                                                                                <td class="text-center">
                                                                                    <t t-esc="consumption.day_of_watering_initial_time or '-'"/>
                                                                                </td>
                                                                                <td class="text-center">
                                                                                    <t t-if="consumption.watering_initial_time">
                                                                                        <t t-esc="consumption.watering_initial_time[8:10] + '/' + consumption.watering_initial_time[5:7] + '/' + consumption.watering_initial_time[0:4] + ' ' + consumption.watering_initial_time[11:]"/>
                                                                                    </t>
                                                                                    <t t-else="">-</t>
                                                                                </td>
                                                                                <td class="text-center">
                                                                                    <t t-esc="consumption.day_of_watering_end_time or '-'"/>
                                                                                </td>
                                                                                <td class="text-center">
                                                                                    <t t-if="consumption.watering_end_time">
                                                                                        <t t-esc="consumption.watering_end_time[8:10] + '/' + consumption.watering_end_time[5:7] + '/' + consumption.watering_end_time[0:4] + ' ' + consumption.watering_end_time[11:]"/>
                                                                                    </t>
                                                                                    <t t-else="">-</t>
                                                                                </td>
                                                                                <td class="text-right">
                                                                                    <t t-esc="consumption.watering_duration or 0"/>
                                                                                </td>
                                                                                <td class="text-right">
                                                                                    <t t-esc="'%.2f' % (consumption.watering_volume or 0)"/>
                                                                                </td>
                                                                                <td class="text-right">
                                                                                    <t t-esc="'%.2f' % (consumption.extra_volume or 0)"/>
                                                                                </td>
                                                                                <td class="text-right">
                                                                                    <t t-esc="'%.2f' % (consumption.watering_volume_real or 0)"/>
                                                                                </td>
                                                                                <td class="text-right">
                                                                                    <t t-esc="'%.4f' % (consumption.area_official or 0)"/>
                                                                                </td>
                                                                                <td class="text-center">
                                                                                    <t t-esc="status"/>
                                                                                </td>
                                                                            </tr>
                                                                        </t>
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        </t>
                                                    </t>
                                                </div>
                                            </div>
                                        </t>
                                    </t>
                                </div>

                                <t t-if="pager">
                                    <div class="o_portal_pager text-center">
                                        <t t-call="website.pager">
                                            <t t-set="classname">pagination</t>
                                        </t>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </template>

    </data>
</odoo>
