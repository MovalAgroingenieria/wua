<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_reservoir_view_form" model="ir.ui.view">
        <field name="name">Reservoir (form view)</field>
        <field name="model">wua.reservoir</field>
        <field name="inherit_id" ref="base_wua_reservoir.wua_reservoir_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='slave_data']" position="after">
                <templates>
                    <t t-name="gisviewer">
                         <field name="with_gis_reservoir" invisible="1"/>
                         <div id="gisviewer_reservoir" attrs="{'invisible': [('with_gis_reservoir','=',False)]}">
                             <field name="html_gisviewer_frame" widget="html"/>
                         </div>
                    </t>
                </templates>
            </xpath>
        </field>
    </record>

</odoo>
