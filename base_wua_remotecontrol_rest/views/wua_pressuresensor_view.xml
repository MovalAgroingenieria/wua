<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_pressuresensor_view_form" model="ir.ui.view">
        <field name="name">Pressure Sensor (form view)</field>
        <field name="model">wua.pressuresensor</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation.wua_pressuresensor_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <field name="remotecontrol_enabled" invisible="1"/>
                <field name="id" invisible="1"/>
                <header>
                    <button name="do_import_pressuresensormeasurements_from_pressuresensor"
                            type="object" string="Get pressure measurements"
                            icon="fa-rss"
                            attrs="{'invisible':
                                    ['|', ('remotecontrol_enabled','=',False),
                                          ('id', '=', 0)]}"
                            groups="base_wua.group_wua_manager"
                            confirm="Import pressure measurements?"/>
                </header>
            </xpath>
            <xpath expr="//field[@name='irrigationshed_id']" position="after">
              <field name="telecontrol_associated"/>
            </xpath>
        </field>
    </record>

    <record id="wua_pressuresensor_view_tree" model="ir.ui.view">
        <field name="name">Pressure Sensor (tree view)</field>
        <field name="model">wua.pressuresensor</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation.wua_pressuresensor_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='irrigationshed_id']" position="after">
              <field name="telecontrol_associated"/>
            </xpath>
        </field>
    </record>

    <record id="wua_pressuresensor_view_search" model="ir.ui.view">
        <field name="name">Pressure Sensor (tree view)</field>
        <field name="model">wua.pressuresensor</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation.wua_pressuresensor_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='irrigationshed']" position="after">
              <field name=""/>
              <filter string="Type of telecontrol associated"
                     name="telecontrolassociated"
                     context="{'group_by':'telecontrol_associated'}"/>
            </xpath>
        </field>
    </record>

    <record id="wua_import_pressuresensormeasurements_from_pressuresensors" model="ir.actions.server">
        <field name="name">Get pressuresensormeasurements</field>
        <field name="model_id" ref="model_wua_pressuresensor"/>
        <field name="state">code</field>
        <field name="code">
            if context.get('active_ids'):
                action = env['wua.pressuresensor'].do_import_pressuresensormeasurements_from_pressuresensors(context['active_ids'])
        </field>
    </record>

    <record id="wua_action_import_pressuresensormeasurements_from_pressuresensors" model="ir.values">
        <field name="name">Get pressuresensormeasurements</field>
        <field name="model">wua.pressuresensor</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('wua_import_pressuresensormeasurements_from_pressuresensors'))"/>
    </record>

</odoo>
