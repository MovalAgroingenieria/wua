<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_waterconnection_irrigation_schedule_view_form" model="ir.ui.view">
        <field name="name">Irrigation Schedule (form view)</field>
        <field name="model">wua.waterconnection.irrigation.schedule</field>
        <field name="inherit_id" ref="base_wua_pressurized_irrigation.wua_waterconnection_irrigation_schedule_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='id']" position="after">
                <field name="from_remotecontrol" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='waterconnection_id']" position="attributes">
                <attribute name="attrs">{'readonly': [('from_remotecontrol','=',True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='irrigation_start_day']" position="attributes">
                <attribute name="attrs">{'readonly': [('from_remotecontrol','=',True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='shift_number']" position="attributes">
                <attribute name="attrs">{'readonly': [('from_remotecontrol','=',True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='irrigation_start_hour']" position="attributes">
                <attribute name="attrs">{'readonly': [('from_remotecontrol','=',True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='irrigation_end_hour']" position="attributes">
                <attribute name="attrs">{'readonly': [('from_remotecontrol','=',True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='irrigation_duration']" position="attributes">
                <attribute name="attrs">{'readonly': [('from_remotecontrol','=',True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='max_irrigation_volume']" position="attributes">
                <attribute name="attrs">{'readonly': [('from_remotecontrol','=',True)]}</attribute>
            </xpath>
        </field>
    </record>

    <record id="wua_waterconnection_irrigation_schedule_view_search" model="ir.ui.view">
        <field name="name">Irrigation Schedule (search view)</field>
        <field name="model">wua.waterconnection.irrigation.schedule</field>
        <field name="inherit_id" ref="base_wua_pressurized_irrigation.wua_waterconnection_irrigation_schedule_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='stateactive']" position="after">
                <separator/>
                <filter string="From Remotecontrol: Yes" name="fromremotecontrolyes"
                 domain="[('from_remotecontrol','=',True)]"/>
                <filter string="From Remotecontrol: No" name="fromremoteconrtolno"
                 domain="[('from_remotecontrol','=',False)]"/>
            </xpath>
        </field>
    </record>

</odoo>
