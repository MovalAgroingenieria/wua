<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_negative_reading_view_search" model="ir.ui.view">
        <field name="name">Negative Readings (search view)</field>
        <field name="model">wua.negative.reading</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation.wua_negative_reading_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='hydraulicsector_id']" position="after">
                <separator/>
                <filter string="From remotecontrol: Yes" name="fromremotecontrolyes"
                 domain="[('from_remotecontrol','=',True)]"/>
                <separator/>
            </xpath>
        </field>
    </record>


</odoo>