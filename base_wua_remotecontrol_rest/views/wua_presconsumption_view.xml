<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_presconsumption_view_tree" model="ir.ui.view">
        <field name="name">Consumptions (tree view)</field>
        <field name="model">wua.presconsumption</field>
        <field name="inherit_id"
         ref="base_wua_pressurized_irrigation.wua_presconsumption_view_tree"/>        
        <field name="arch" type="xml">
            <xpath expr="//field[@name='reading_id']" position="after">
                <field name="validated" string="Valid"/>
            </xpath>        
        </field>
    </record>

    <record id="wua_presconsumption_view_search" model="ir.ui.view">
        <field name="name">Consumptions (search view)</field>
        <field name="model">wua.presconsumption</field>
        <field name="inherit_id"
         ref="base_wua_pressurized_irrigation.wua_presconsumption_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='withadjustement']" position="after">
                <separator/>
                <filter string="Validated: Yes" name="isvalidatedyes"
                 domain="[('validated','=',True)]"/>
                <filter string="Validated: No" name="isvalidatedno"
                 domain="[('validated','=',False)]"/>
            </xpath>        
        </field>
    </record>

    <record id="wua_presconsumption_one_waterconnection_view_tree" model="ir.ui.view">
        <field name="name">Consumptions (tree view)</field>
        <field name="model">wua.presconsumption</field>
        <field name="inherit_id"
         ref="base_wua_pressurized_irrigation.wua_presconsumption_one_waterconnection_view_tree"/>        
        <field name="arch" type="xml">
            <xpath expr="//field[@name='reading_id']" position="after">
                <field name="validated" string="Valid"/>
            </xpath>        
        </field>
    </record>

    <record id="wua_presconsumption_one_waterconnection_view_search" model="ir.ui.view">
        <field name="name">Consumptions (search view)</field>
        <field name="model">wua.presconsumption</field>
        <field name="inherit_id"
         ref="base_wua_pressurized_irrigation.wua_presconsumption_one_waterconnection_view_search"/>        
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='withadjustement']" position="after">
                <separator/>
                <filter string="Validated: Yes" name="isvalidatedyes"
                 domain="[('validated','=',True)]"/>
                <filter string="Validated: No" name="isvalidatedno"
                 domain="[('validated','=',False)]"/>
            </xpath>        
        </field>
    </record>

</odoo>