<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form" model="ir.ui.view">
        <field name="name">Partners (form view)</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base_wua_infrastructure.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="before">
                <field name="remotecontrol_enabled" invisible="1"/>
            </xpath>
            <xpath expr="//header" position="inside">
                <button name="do_synchronization_partner"
                            type="object" string="Synchronize"
                            icon="fa-rss"
                            attrs="{'invisible':
                                    ['|', ('remotecontrol_enabled','=',False),
                                          ('is_wua_partner','=',False)]}"
                            groups="base_wua.group_wua_manager"/>
                <button name="do_unsynchronization_partner"
                        type="object" string="Unsynchronize"
                        icon="fa-chain-broken"
                        attrs="{'invisible':
                                ['|', ('updated_in_remotecontrol','=',False),
                                    '|', ('remotecontrol_enabled','=',False),
                                        ('is_wua_partner','=',False)]}"
                        groups="base_wua.group_wua_manager"/>
            </xpath>
            <xpath expr="//field[@name='category_id']" position="before">
                <field name="updated_in_remotecontrol"
                       string="In Remote Control" readonly="1"
                       attrs="{'invisible': ['|', ('remotecontrol_enabled',
                                                   '=', False),
                                                  ('is_wua_partner',
                                                   '=', False)]}"/>
            </xpath>
        </field>
    </record>

    <record id="view_partner_search" model="ir.ui.view">
        <field name="name">Partners (search view)</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base_wua.view_partner_search"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='inactive']" position="before">
                <filter string="In Remote control: Yes" name="updated_rc_yes"
                 domain="[('updated_in_remotecontrol','=',True)]"/>
                <filter string="In Remote control: No" name="updated_rc_no"
                 domain="[('updated_in_remotecontrol','=',False)]"/>
                <separator/>
            </xpath>
        </field>
    </record>

    <record id="res_partner_waterconnection_view_tree" model="ir.ui.view">
        <field name="name">Partner Waterconnections (tree view)</field>
        <field name="model">res.partner.waterconnection</field>
        <field name="inherit_id" ref="base_wua_pressurized_irrigation.res_partner_waterconnection_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="class">o_base_wua_remotecontrol_rest_partner_waterconnection_view_tree</attribute>
            </xpath>
            <xpath expr="//field[@name='volume_real']" position="after">
                <field name="last_data_time"/>
                <field name="last_total_volume"/>
                <field name="last_waterflow"/>
                <field name="last_valve_open"/>
                <field name="last_valve_scheduled"/>
            </xpath>
        </field>
    </record>

    <record id="wua_synchronize_partners" model="ir.actions.server">
        <field name="name">Synchronize partner with remote control</field>
        <field name="model_id" ref="model_res_partner"/>
        <field name="state">code</field>
        <field name="code">
            if context.get('active_ids'):
                action = env['res.partner'].do_synchronization_partners(context['active_ids'], True)
        </field>
    </record>

    <record id="wua_action_synchronize_partners" model="ir.values">
        <field name="name">Synchronize partner with remote control</field>
        <field name="model">res.partner</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('wua_synchronize_partners'))"/>
    </record>

    <record id="wua_technical_synchronize_partners_action" model="ir.actions.server">
        <field name="name">Partners Synchronization (remote control)</field>
        <field name="model_id" ref="base_wua.model_res_partner"/>
        <field name="code">action = env["res.partner"].do_synchronization_all_partners(True)</field>
    </record>

    <menuitem id="wua_technical_synchronize_partners_menu"
              name="Remote C.: Synch. Partners"
              parent="base_wua.base_wua_technical_menu"
              action="wua_technical_synchronize_partners_action"
              sequence="1001"
              groups="base.group_system"/>

</odoo>
