<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_irrigation_config_settings_view_form" model="ir.ui.view">
        <field name="name">Parameters</field>
        <field name="model">wua.irrigation.configuration</field>
        <field name="inherit_id"
               ref="wua_structure_irrigation.wua_irrigation_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='pres_irrig']"
                   position="after">
                <group name="remote_control" string="Remote Control">
                    <field name="enable_remotecontrol"/>
                    <field name="url_remotecontrol_rest"
                     attrs="{'invisible':[('enable_remotecontrol','=',False)],
                             'required': [('enable_remotecontrol', '=', True)]}"/>
                    <field name="url_remotecontrol_application"
                     attrs="{'invisible':[('enable_remotecontrol','=',False)]}"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="wua_remotecontrol_application_action" model="ir.actions.server">
        <field name="name">Native Remote Control Application</field>
        <field name="model_id" ref="model_wua_reading"/>
        <field name="state">code</field>
        <field name="code">
            action = env['wua.reading'].run_remotecontrol_application_url()
        </field>
    </record>

    <menuitem id="wua_remotecontrol_application_menu"
              name="Native Remote Control"
              parent="wua_structure_irrigation.base_wua_irrigation_configuration_menu"
              action="wua_remotecontrol_application_action"
              sequence="2"/>

</odoo>