<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_waterconnection_view_form" model="ir.ui.view">
        <field name="name">Water Connections (form view)</field>
        <field name="model">wua.waterconnection</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation.wua_waterconnection_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <field name="remotecontrol_enabled" invisible="1"/>
                <field name="id" invisible="1"/>
                <header>
                    <button name="do_import_readings_from_waterconnection"
                            type="object" string="Get readings"
                            icon="fa-rss"
                            attrs="{'invisible':
                                    ['|', ('remotecontrol_enabled','=',False),
                                          ('id', '=', 0)]}"
                            groups="base_wua.group_wua_manager"
                            confirm="Import readings?"/>
                </header>
            </xpath>
            <xpath expr="//field[@name='last_reading_value']" position="after">
              <field name="conversion_factor"/>
            </xpath>
            <xpath expr="//group[@name='slave_data']" position="before">
              <field name="html_last_telecontrol_info" nolabel="1"/>
            </xpath>
        </field>
    </record>

    <record id="wua_waterconnection_view_tree" model="ir.ui.view">
        <field name="name">Water Connections (tree view)</field>
        <field name="model">wua.waterconnection</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation.wua_waterconnection_view_tree"/>
        <field name="arch" type="xml">
          <xpath expr="//field[@name='number_of_parcels']" position="after">
            <field name="last_data_time"/>
            <field name="last_waterflow"/>
          </xpath>
        </field>
    </record>

    <record id="wua_waterconnection_view_search" model="ir.ui.view">
        <field name="name">Water Connections (search view)</field>
        <field name="model">wua.waterconnection</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation.wua_waterconnection_view_search"/>
        <field name="arch" type="xml">
          <xpath expr="//filter[@name='withoutwatermeter']" position="after">
            <separator/>
            <filter string="Valve Open: Yes" name="last_valve_open_true"
             domain="[('last_valve_open','=',True)]"/>
            <filter string="Valve Open: No" name="last_valve_open_false"
             domain="[('last_valve_open','=',False)]"/>
            <separator/>
            <filter string="Valve Scheduled: Yes" name="last_valve_scheduled_true"
             domain="[('last_valve_scheduled','=',True)]"/>
            <filter string="Valve Scheduled: No" name="last_valve_scheduled_false"
             domain="[('last_valve_scheduled','=',False)]"/>
          </xpath>
        </field>
    </record>

    <record id="wua_import_readings_from_waterconnections" model="ir.actions.server">
        <field name="name">Get readings</field>
        <field name="model_id" ref="model_res_partner"/>
        <field name="state">code</field>
        <field name="code">
            if context.get('active_ids'):
                action = env['wua.waterconnection'].do_import_readings_from_waterconnections(context['active_ids'])
        </field>
    </record>

    <record id="wua_action_import_readings_from_waterconnections" model="ir.values">
        <field name="name">Get readings</field>
        <field name="model">wua.waterconnection</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('wua_import_readings_from_waterconnections'))"/>
    </record>

</odoo>
