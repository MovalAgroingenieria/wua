<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Cron Job: Transform Reservoir Readings (Inactive by default) -->
        <record id="cron_transform_reservoir_readings" model="ir.cron">
            <field name="name">Transform Reservoir Sensor Readings</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="model">mdm.sensor.reading.transform.template</field>
            <field name="function">cron_transform_reservoir_readings</field>
            <field name="args">()</field>
            <field name="active" eval="False"/>
        </record>

    </data>
</odoo>
