<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_wizard_import_dynamic_fields_form" model="ir.ui.view">
        <field name="name">wizard.maintenance.dynamic.field.import.form</field>
        <field name="model">wizard.maintenance.dynamic.field.import</field>
        <field name="arch" type="xml">
            <form string="Import Dynamic Fields">
                <group>
                    <field name="category_id" readonly="1"/>
                </group>
                <button name="action_fetch_fields" type="object" class="btn btn-link"
                            string="Bring Fields" icon="fa-download" style="margin-top:2px; margin-bottom:2px;"/>
                <field name="field_ids">
                    <tree editable="bottom">
                        <field name="name"/>
                        <field name="field_path"/>
                        <field name="field_type"/>
                        <field name="to_import"/>
                    </tree>
                </field>
                <footer>
                    <button name="action_import_selected" string="Import Selected" type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn-default" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <act_window id="action_import_dynamic_fields"
        name="Import Dynamic Fields"
        res_model="wizard.maintenance.dynamic.field.import"
        src_model="maintenance.equipment.category"
        view_mode="form"
        target="new"
        context="{'default_category_id': active_id}" />

</odoo>
