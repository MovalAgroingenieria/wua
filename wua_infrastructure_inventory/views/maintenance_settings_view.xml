<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <record id="maintenance_config_settings_view_form" model="ir.ui.view">
        <field name="name">Settings</field>
        <field name="model">maintenance.config.settings</field>
        <field name="inherit_id" ref="wua_maintenance.maintenance_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//group[@name='maintenance_request_parameters']" position="after">
                <group name="inventory_parameters" string="Inventory">
                    <field name="default_gis_inventory_refresh_interval"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>