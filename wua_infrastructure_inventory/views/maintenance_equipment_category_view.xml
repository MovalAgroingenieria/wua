<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_equipment_category_view_form" model="ir.ui.view">
        <field name="name">equipment.category.form</field>
        <field name="model">maintenance.equipment.category</field>
        <field name="inherit_id" ref="wua_maintenance.hr_equipment_category_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='model_id']" position="after">
                <field name="available_for_inventory"/>
                <field name="load_geometries_by_default"/>
            </xpath>
            <xpath expr="//page[@name='template_page']" position="after">
                <page string="Dynamic Fields for GIS inventory">
                    <header>
                        <button name="%(action_import_dynamic_fields)d" type="action"
                                class="btn btn-link"
                                string="Import Dynamic Fields" icon="fa-download"
                                style="margin-top:2px; margin-bottom:2px;"/>
                        <button name="action_validate_dynamic_fields" type="object" class="btn btn-link"
                            string="Validate Dynamic Fields" icon="fa-search" style="margin-top:2px; margin-bottom:2px;"
                        />
                    </header>
                    <field name="dynamic_field_ids">
                        <tree colors="green:validation_status=='valid';red:validation_status=='invalid'"
                              editable="bottom">
                            <field name="readonly" invisible="1"/>
                            <field name="name"/>
                            <field name="field_type"
                                   attrs="{'readonly': [('readonly', '=', True)]}"/>
                            <field name="fixed_option_ids" widget="many2many_tags"
                                   attrs="{'readonly': [('readonly', '=', True)]}"/>
                            <field name="required"
                                   attrs="{'readonly': [('readonly', '=', True)]}"/>
                            <field name="field_path"
                                   attrs="{'readonly': [('readonly', '=', True)]}"/>
                            <field name="gis_path"
                                   attrs="{'readonly': [('readonly', '=', True)]}"/>
                            <field name="field_domain"
                                   />
                            <field name="related_category_id"
                                   />
                            <field name="validation_status" readonly="1"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="hr_equipment_category_view_tree" model="ir.ui.view">
        <field name="name">equipment.category.tree</field>
        <field name="model">maintenance.equipment.category</field>
        <field name="inherit_id" ref="wua_maintenance.hr_equipment_category_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='technician_user_id']" position="after">
                <field name="available_for_inventory"/>
            </xpath>
        </field>
    </record>

    <record id="action_import_dynamic_fields" model="ir.actions.act_window">
        <field name="name">Import Dynamic Fields</field>
        <field name="res_model">wizard.maintenance.dynamic.field.import</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_category_id': active_id}</field>
    </record>

</odoo>