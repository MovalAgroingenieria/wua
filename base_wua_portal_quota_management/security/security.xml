<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="rule_wua_hydricmovement_group_portal" model="ir.rule">
            <field name="name">Rule for Portal User on hydricmovements</field>
            <field name="model_id" ref="base_wua_quota_management.model_wua_hydricmovement"/>
            <field name="domain_force">
                ['|',
                 ('partner_id','=',user.partner_id.id),
                 ('partner_id','parent_of',user.partner_id.id)]
            </field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        </record>
        <record id="rule_wua_quota_group_portal" model="ir.rule">
            <field name="name">Rule for Portal User on quotas</field>
            <field name="model_id" ref="base_wua_quota_management.model_wua_quota"/>
            <field name="domain_force">
                ['|',
                 ('partner_id','=',user.partner_id.id),
                 ('partner_id','parent_of',user.partner_id.id)]
            </field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        </record>
    </data>
</odoo>
