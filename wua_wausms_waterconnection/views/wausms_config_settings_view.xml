<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wausms_config_settings_view_form" model="ir.ui.view">
        <field name="name">WauSMS parameters</field>
        <field name="model">wausms.configuration</field>
        <field name="inherit_id" ref="wausms_client_sms.wausms_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='default_invoice_template_id']" position="after">
                <field name="default_waterconnection_template_id" domain="[('type','=','waterconnection')]"/>
            </xpath>
        </field>
    </record>

</odoo>