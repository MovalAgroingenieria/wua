<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="attendance_leaves_report.menu_employee_attendance_print" model="ir.actions.report.xml">
        <field name="paperformat_id" ref="base_wua_report.paperformat_wua_reports"/>
    </record>

    <template id="main_employee_attendance" inherit_id="attendance_leaves_report.main_employee_attendance">

        <xpath expr="//t[@t-call='report.external_layout']" position="attributes">
            <attribute name="t-call">base_wua_report.wua_external_layout</attribute>
        </xpath>

        <xpath expr="//div[@name='report_employee_data']" position="before">
            <t t-set="report_style" t-value="request.env['ir.values'].get_default('wua.configuration', 'reports_style')"/>
            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                <t t-if="report_style == 'light'">
                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                       <div style="float: left; width: 32px;"><span class="fa fa-user"/></div>
                       <div style="float: left; display: inline;"><strong>Employee&amp;nbsp;and&amp;nbsp;date&amp;nbsp;range</strong></div>
                    </div>
                </t>
                <t t-else="">
                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                        <div style="float: left; width: 32px;"><span class="fa fa-user"/></div>
                        <div style="float: left; display: inline;"><strong>Employee&amp;nbsp;and&amp;nbsp;date&amp;nbsp;range</strong></div>
                    </div>
                </t>
            </div>
        </xpath>

        <xpath expr="//div[@name='attendance_title']" position="replace">
            <div name="attendance_title" class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                <t t-if="report_style == 'light'">
                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                       <div style="float: left; width: 32px;"><span class="fa fa-moval-user-check"/></div>
                       <div style="float: left; display: inline;"><strong>Attendances</strong></div>
                    </div>
                </t>
                <t t-else="">
                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                        <div style="float: left; width: 32px;"><span class="fa fa-moval-user-check"/></div>
                        <div style="float: left; display: inline;"><strong>Attendances</strong></div>
                    </div>
                </t>
            </div>
        </xpath>

        <xpath expr="//div[@name='leave_title']" position="replace">
            <div name="leave_title" class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                <t t-if="report_style == 'light'">
                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                       <div style="float: left; width: 32px;"><span class="fa fa-moval-sun"/></div>
                       <div style="float: left; display: inline;"><strong>Leaves</strong></div>
                    </div>
                </t>
                <t t-else="">
                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                        <div style="float: left; width: 32px;"><span class="fa fa-moval-sun"/></div>
                        <div style="float: left; display: inline;"><strong>Leaves</strong></div>
                    </div>
                </t>
            </div>
        </xpath>

        <xpath expr="//div[@name='public_holidays_title']" position="replace">
            <div name="public_holidays_title" class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                <t t-if="report_style == 'light'">
                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                       <div style="float: left; width: 32px;"><span class="fa fa-calendar"/></div>
                       <div style="float: left; display: inline;"><strong>Public&amp;nbsp;holidays</strong></div>
                    </div>
                </t>
                <t t-else="">
                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                        <div style="float: left; width: 32px;"><span class="fa fa-calendar"/></div>
                        <div style="float: left; display: inline;"><strong>Public&amp;nbsp;holidays</strong></div>
                    </div>
                </t>
            </div>
        </xpath>

        <xpath expr="//div[@name='conformity_title']" position="replace">
            <div name="conformity_title" class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                <t t-if="report_style == 'light'">
                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                       <div style="float: left; width: 32px;"><span class="fa fa-check-square-o"/></div>
                       <div style="float: left; display: inline;"><strong>Conformity</strong></div>
                    </div>
                </t>
                <t t-else="">
                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                        <div style="float: left; width: 32px;"><span class="fa fa-check-square-o"/></div>
                        <div style="float: left; display: inline;"><strong>Conformity</strong></div>
                    </div>
                </t>
            </div>
        </xpath>

    </template>

</odoo>