<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wizard_partner_file_view_form" model="ir.ui.view">
        <field name="name">Wizard partner file</field>
        <field name="model">wizard.partner.file</field>
        <field name="arch" type="xml">
            <form>
                <field name="category_id" invisible="1"/>
                <group colspan="6" col="4">
                    <field name="file_code"/>
                    <field name="date_file"/>
                    <field name="subject" colspan="4"/>
                </group>
                <group>
                    <field name="selected_partners"/>
                    <field name="selected_parcels"/>
                </group>
                <div class="text-muted text-right" style="font-size: 0.8em;">
                    <span class="fa fa-lg fa-info-circle"/>
                    <span> All other parameters of the File are edited after its creation.
                           One partner is selected as File's main and repeated items are removed.
                    </span>
                </div>
                <footer>
                    <button name="create_file" type="object" class="oe_highlight">
                        <div class="o_form_field">
                            <span class="fa fa-lg fa-filemgmt-files"/>
                            <span style="margin-left:8px;">Create file</span>
                        </div>
                    </button>
                    <button string="Cancel" class="btn-default" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

   <!-- Droplist action -->
    <act_window id="action_add_partners_to_file"
        name="Create File"
        res_model="wizard.partner.file"
        src_model="res.partner"
        key2="client_action_multi"
        view_mode="form"
        target="new"/>

</odoo>
