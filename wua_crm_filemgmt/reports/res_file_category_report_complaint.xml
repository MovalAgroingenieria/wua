<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <report
        id="res_file_category_report_complaint"
        string="Complaint report"
        model="res.file"
        report_type="qweb-pdf"
        file="wua_crm_filemgmt.category_report_complaint_document"
        name="wua_crm_filemgmt.category_report_complaint_document"
        paperformat="base_wua_report.paperformat_wua_reports"
        menu="False"/>

    <template id="wua_crm_filemgmt.category_report_complaint_document">
        <t t-call="report.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="base_wua_report.wua_external_layout">
                    <div class="page">

                        <!-- Vars -->
                        <t t-set="report_style" t-value="o.env['ir.values'].get_default('wua.configuration', 'reports_style')"/>
                        <t t-set="complainant" t-value="bool('')"/>
                        <t t-set="denounced" t-value="bool('')"/>
                        <t t-if="o.partnerlink_complaint_ids">
                            <t t-foreach="o.partnerlink_complaint_ids" t-as="p">
                                <t t-if="p.is_complainant">
                                    <t t-set="complainant" t-value="p"/>
                                </t>
                                <t t-if="p.is_denounced">
                                    <t t-set="denounced" t-value="p"/>
                                </t>
                            </t>
                        </t>

                        <!-- Title -->
                        <div name="title" class="text-center">
                            <h4>
                                <strong>COMPLIANT REPORT</strong>
                                <strong> - </strong>
                                <strong t-field="o.name"/>
                            </h4>
                            <span class="text-muted">[ <span t-field="o.stage_id"/> ]</span>
                        </div>

                        <!-- Complainant and denounced data -->
                        <div style="display: table; margin-bottom: 10px; width: 100%;" name="lessor_and_tenant">
                            <div style="display: table-cell; width: 48%;">
                                <table name="identity_complainant" class="table-condensed">
                                    <tbody>
                                        <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                            <t t-if="report_style == 'light'">
                                                <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                                    <div style="float: left; width:32px;"><span class="fa fa-user"/></div>
                                                    <div style="float: left; display:inline;"><strong>Complainant</strong></div>
                                                </div>
                                            </t>
                                            <t t-else="">
                                                <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                                    <div style="float: left; width:32px;"><span class="fa fa-user"/></div>
                                                    <div style="float: left; display:inline;"><strong>Complainant</strong></div>
                                                </div>
                                            </t>
                                        </div>
                                        <div name="complainant_data">
                                            <t t-if="complainant.partner_id.name">
                                                <strong><span t-field="complainant.partner_id.name"/></strong>
                                                <t t-if="complainant.partner_id.vat"><span>(NIF:&amp;nbsp;<span t-field="complainant.partner_id.vat"/>)</span></t>
                                                <br/>
                                            </t>
                                            <t t-if="complainant.partner_id.street_type_show or complainant.partner_id.street or complainant.partner_id.street_num or complainant.partner_id.street2">
                                                <t t-if="complainant.partner_id.street_type_show"><span t-field="complainant.partner_id.street_type_show"/></t>
                                                <t t-if="complainant.partner_id.street"><span t-field="complainant.partner_id.street"/></t>
                                                <t t-if="complainant.partner_id.street_num"><span t-field="complainant.partner_id.street_num"/></t>
                                                <t t-if="complainant.partner_id.street2"><span t-field="complainant.partner_id.street2"/></t>
                                                <br/>
                                            </t>
                                            <t t-if="complainant.partner_id.city or complainant.partner_id.zip">
                                                <t t-if="complainant.partner_id.city"><span t-field="complainant.partner_id.city"/></t>
                                                <t t-if="complainant.partner_id.zip"><span>-&amp;nbsp;</span><span t-field="complainant.partner_id.zip"/></t>
                                                <br/>
                                            </t>
                                            <t t-if="complainant.partner_id.state_id or complainant.partner_id.country_id">
                                                <t t-if="complainant.partner_id.state_id"><span t-field="complainant.partner_id.state_id"/></t>
                                                <t t-if="complainant.partner_id.country_id"><span>-&amp;nbsp;</span><span t-field="complainant.partner_id.country_id"></span></t>
                                                <br/>
                                            </t>
                                            <t t-if="complainant.partner_id.phones or complainant.partner_id.phone or complainant.partner_id.mobile">
                                                <t t-if="complainant.partner_id.phones"><span t-field="complainant.partner_id.phones"/></t>
                                                <t t-else="">
                                                    <t t-if="complainant.partner_id.phone"><span t-field="complainant.partner_id.phone"/></t>
                                                    <t t-if="complainant.partner_id.mobile"><span t-field="complainant.partner_id.mobile"/></t>
                                                </t>
                                                <br/>
                                            </t>
                                            <t t-if="complainant.partner_id.email"><span t-field="complainant.partner_id.email"/><br/></t>
                                        </div>
                                    </tbody>
                                </table>
                            </div>
                            <div style="width: 4%;"></div>
                            <div style="display: table-cell; width: 48%;">
                                <table name="identity_denounced" class="table-condensed">
                                    <tbody>
                                        <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                            <t t-if="report_style == 'light'">
                                                <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                                    <div style="float: left; width:32px;"><span class="fa fa-user"/></div>
                                                    <div style="float: left; display:inline;"><strong>Denounced</strong></div>
                                                </div>
                                            </t>
                                            <t t-else="">
                                                <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                                    <div style="float: left; width:32px;"><span class="fa fa-user"/></div>
                                                    <div style="float: left; display:inline;"><strong>Denounced</strong></div>
                                                </div>
                                            </t>
                                        </div>
                                        <div name="denounced_data">
                                            <t t-if="denounced.partner_id.name">
                                                <strong><span t-field="denounced.partner_id.name"/></strong>
                                                <t t-if="denounced.partner_id.vat"><span>(NIF:&amp;nbsp;<span t-field="denounced.partner_id.vat"/>)</span></t>
                                                <br/>
                                            </t>
                                            <t t-if="denounced.partner_id.street_type_show or denounced.partner_id.street or denounced.partner_id.street_num or denounced.partner_id.street2">
                                                <t t-if="denounced.partner_id.street_type_show"><span t-field="denounced.partner_id.street_type_show"/></t>
                                                <t t-if="denounced.partner_id.street"><span t-field="denounced.partner_id.street"/></t>
                                                <t t-if="denounced.partner_id.street_num"><span t-field="denounced.partner_id.street_num"/></t>
                                                <t t-if="denounced.partner_id.street2"><span t-field="denounced.partner_id.street2"/></t>
                                                <br/>
                                            </t>
                                            <t t-if="denounced.partner_id.city or denounced.partner_id.zip">
                                                <t t-if="denounced.partner_id.city"><span t-field="denounced.partner_id.city"/></t>
                                                <t t-if="denounced.partner_id.zip"><span>-&amp;nbsp;</span><span t-field="denounced.partner_id.zip"/></t>
                                                <br/>
                                            </t>
                                            <t t-if="denounced.partner_id.state_id or denounced.partner_id.country_id">
                                                <t t-if="denounced.partner_id.state_id"><span t-field="denounced.partner_id.state_id"/></t>
                                                <t t-if="denounced.partner_id.country_id"><span>-&amp;nbsp;</span><span t-field="denounced.partner_id.country_id"></span></t>
                                                <br/>
                                            </t>
                                            <t t-if="denounced.partner_id.phones or denounced.partner_id.phone or denounced.partner_id.mobile">
                                                <t t-if="denounced.partner_id.phones"><span t-field="denounced.partner_id.phones"/></t>
                                                <t t-else="">
                                                    <t t-if="denounced.partner_id.phone"><span t-field="denounced.partner_id.phone"/></t>
                                                    <t t-if="denounced.partner_id.mobile"><span t-field="denounced.partner_id.mobile"/></t>
                                                </t>
                                                <br/>
                                            </t>
                                            <t t-if="denounced.partner_id.email"><span t-field="denounced.partner_id.email"/><br/></t>
                                        </div>
                                    </tbody>
                                </table>
                            </div>
                        </div>



                        <!-- Template start -->
                        <div name="template_start_rendered">
                            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                <t t-if="report_style == 'light'">
                                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">&amp;nbsp;</div>
                                </t>
                                <t t-else="">
                                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">&amp;nbsp;</div>
                                </t>
                            </div>
                            <!-- Top comment -->
                            <t t-if="o.env['wua.parcel'].is_html_field_filled(o.file_top_comment)">
                                <div t-field="o.file_top_comment"/>
                            </t>
                            <div t-field="o.template_start_rendered"/>
                        </div>

                        <!-- Template end -->
                        <div name="template_end_rendered">
                            <div t-field="o.template_end_rendered"/>
                        </div>

                        <!-- Bottom comment -->
                        <t t-if="o.env['wua.parcel'].is_html_field_filled(o.file_bottom_comment)">
                            <div t-field="o.file_bottom_comment"/>
                        </t>

                    </div> <!-- end page -->
                </t>
            </t>
        </t>
    </template>

</odoo>
