<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="res_letter_report_document_letter" inherit_id="crm_lettermgmt.res_letter_report_document">

        <xpath expr="//div[@name='title']" position="before">
            <t t-set="report_style" t-value="o.env['ir.values'].get_default('wua.configuration', 'reports_style')"/>
        </xpath>

        <xpath expr="//t[@t-call='report.external_layout']" position="attributes">
            <attribute name="t-call">base_wua_report.wua_external_layout</attribute>
        </xpath>

        <xpath expr="//div[@name='registry_main_data_title']" position="replace">
            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;" name="registry_main_data_title">
                <t t-if="report_style == 'light'">
                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                        <div style="float: left; width: 32px;"><span class="fa fa-lettermgmt-inout"/></div>
                        <div style="float: left; display: inline;"><strong>Main&amp;nbsp;Data</strong></div>
                    </div>
                </t>
                <t t-else="">
                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                        <div style="float: left; width: 32px;"><span class="fa fa-lettermgmt-inout"/></div>
                        <div style="float: left; display: inline;"><strong>Main&amp;nbsp;Data</strong></div>
                    </div>
                </t>
            </div>
        </xpath>

        <xpath expr="//div[@name='registry_addicional_data_title']" position="replace">
            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;" name="registry_addicional_data_title">
                <t t-if="report_style == 'light'">
                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                        <div style="float: left; width: 32px;"><span class="fa fa-lettermgmt-inout"/></div>
                        <div style="float: left; display: inline;"><strong>Additional&amp;nbsp;Data</strong></div>
                    </div>
                </t>
                <t t-else="">
                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                        <div style="float: left; width: 32px;"><span class="fa fa-lettermgmt-inout"/></div>
                        <div style="float: left; display: inline;"><strong>Additional&amp;nbsp;Data</strong></div>
                    </div>
                </t>
            </div>
        </xpath>

        <xpath expr="//div[@name='notes_title']" position="replace">
            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;" name="notes_title">
                <t t-if="report_style == 'light'">
                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                        <div style="float: left; width: 32px;"><span class="fa fa-file"/></div>
                        <div style="float: left; display: inline;"><strong>Delivery&amp;nbsp;Notes</strong></div>
                    </div>
                </t>
                <t t-else="">
                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                        <div style="float: left; width: 32px;"><span class="fa fa-file"/></div>
                        <div style="float: left; display: inline;"><strong>Delivery&amp;nbsp;Notes</strong></div>
                    </div>
                </t>
            </div>
        </xpath>

        <xpath expr="//div[@name='attachments_title']" position="replace">
            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;" name="attachments_title">
            <t t-if="report_style == 'light'">
                <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                <div style="float: left; width: 32px;"><span class="fa fa-paperclip"/></div>
                <div style="float: left; display: inline;"><strong>Attachments</strong></div>
                </div>
            </t>
            <t t-else="">
                <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                <div style="float: left; width: 32px;"><span class="fa fa-paperclip"/></div>
                <div style="float: left; display: inline;"><strong>Attachments</strong></div>
                </div>
            </t>
            </div>
        </xpath>

    </template>

    <template id="res_letter_report_document_file" inherit_id="crm_filemgmt.res_letter_report_document">

        <xpath expr="//div[@name='file_title']" position="replace">
            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;" name="file_title">
                <t t-if="report_style == 'light'">
                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                        <div style="float: left; width: 32px;"><span class="fa fa-filemgmt-files"/></div>
                        <div style="float: left; display: inline;"><strong>File_</strong></div>
                    </div>
                </t>
                <t t-else="">
                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                        <div style="float: left; width: 32px;"><span class="fa fa-filemgmt-files"/></div>
                        <div style="float: left; display: inline;"><strong>File_</strong></div>
                    </div>
                </t>
            </div>
        </xpath>

    </template>

</odoo>