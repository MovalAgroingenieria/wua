<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <report
        id="res_file_category_report_custom"
        string="Custom report"
        model="res.file"
        report_type="qweb-pdf"
        file="wua_crm_filemgmt.category_report_custom_document"
        name="wua_crm_filemgmt.category_report_custom_document"
        paperformat="base_wua_report.paperformat_wua_reports"
        menu="False"/>

    <template id="wua_crm_filemgmt.category_report_custom_document">
        <t t-call="report.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="base_wua_report.wua_external_layout">
                    <div class="page">

                        <!-- Vars -->
                        <t t-set="report_style" t-value="o.env['ir.values'].get_default('wua.configuration', 'reports_style')"/>

                        <!-- Template start -->
                        <div name="template_start_rendered">
                            <div t-field="o.template_start_rendered"/>
                        </div>

                        <!-- Template end -->
                        <div name="template_end_rendered">
                            <div t-field="o.template_end_rendered"/>
                        </div>

                    </div> <!-- end page -->
                </t>
            </t>
        </t>
    </template>

</odoo>
