<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_file_view_form" model="ir.ui.view">
        <field name="name">Files (form view)</field>
        <field name="model">res.file</field>
        <field name="inherit_id" ref="crm_filemgmt.res_file_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='attachments']" position="before">
                <page name="parcellink_page" string="Parcel Links">
                    <header>
                        <button name="action_get_partner_parcels" type="object" class="btn btn-link"
                            attrs="{'invisible': ['|',('state','=','03_closed'),('is_blocked','=',True)]}"
                            string="Get parcels" icon="fa-moval-parcel" style="margin-top:2px; margin-bottom:2px;"
                            groups="crm_filemgmt.group_file_manager"/>
                    </header>
                    <field name="parcellink_ids"
                        attrs="{'readonly':['|',('state','=','03_closed'),('is_blocked','=',True)]}"
                        context="{'tree_view_ref': 'wua_crm_filemgmt.res_file_parcellink_view_tree'}"/>
                </page>
            </xpath>
        </field>
    </record>

    <record id="res_file_view_kanban" model="ir.ui.view">
        <field name="name">Files (kanban view)</field>
        <field name="model">res.file</field>
        <field name="inherit_id" ref="crm_filemgmt.res_file_view_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='has_registres']" position="after">
                <field name="has_parcellinks"/>
            </xpath>
            <xpath expr="//t[@t-if='record.has_registres.raw_value']" position="after">
                <t t-if="record.has_parcellinks.raw_value">
                    <span style="float:right; margin-right:3%;" class="fa fa-moval-parcel o_button_icon"/>
                </t>
            </xpath>
        </field>
    </record>

    <record id="res_file_parcellink_view_form" model="ir.ui.view">
        <field name="name">File Parcellink (form view)</field>
        <field name="model">res.file.parcellink</field>
        <field name="arch" type="xml">
            <form duplicate="0">
                <sheet>
                    <group name="master_data">
                        <group>
                            <field name="parcel_id"/>
                            <field name="parcel_area_official"/>
                            <field name="parcel_rural_location_county"/>
                            <field name="parcel_cadastral_reference"/>
                        </group>
                        <group>
                            <field name="parcel_partner_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="res_file_parcellink_view_tree" model="ir.ui.view">
        <field name="name">File Parcellink (tree view)</field>
        <field name="model">res.file.parcellink</field>
        <field name="arch" type="xml">
            <tree class="o_res_file_parcellink_view_tree" editable="bottom">
                <field name="parcel_gis_viewer_link" invisible="1"/>
                <field name="parcel_cadastral_reference_link" invisible="1"/>
                <field name="parcel_id"/>
                <field name="parcel_area_official"/>
                <button name="action_see_gis_viewer"
                        type="object" class="oe_stat_button"
                        string="GIS Viewer (zoom to parcel)"
                        icon="fa-map-marker"
                        attrs="{'invisible': [('parcel_gis_viewer_link','=','')]}"/>
                <button name="action_see_cadastral_report"
                        type="object" class="oe_stat_button"
                        string="Cadastral Report"
                        icon="fa-cubes"
                        attrs="{'invisible': [('parcel_cadastral_reference_link','=','')]}"/>
                <field name="parcel_rural_location_county"/>
                <field name="parcel_cadastral_reference"/>
                <field name="parcel_partner_id"/>
            </tree>
        </field>
    </record>

    <record id="res_file_parcellink_of_parcel_view_tree" model="ir.ui.view">
        <field name="name">File Parcellink (tree view)</field>
        <field name="model">res.file.parcellink</field>
        <field name="arch" type="xml">
            <tree class="o_res_file_parcellink_of_parcel_view_tree" create="false" edit="false">
                <field name="file_id"/>
                <field name="subject"/>
            </tree>
        </field>
    </record>

    <record id="res_file_parcellink_view_search" model="ir.ui.view">
        <field name="name">File Parcellink (search view)</field>
        <field name="model">res.file.parcellink</field>
        <field name="arch" type="xml">
            <search>
                <field name="file_id"/>
            </search>
        </field>
    </record>

    <record id="wua_generate_files_parcel_shp" model="ir.actions.server">
        <field name="name">Generate Parcel SHP</field>
        <field name="model_id" ref="model_res_file"/>
        <field name="code">
            action =  env['res.file'].browse(context['active_ids']).action_generate_parcels_shp()
        </field>
    </record>

    <record id="wua_action_generate_file_parcel_shp" model="ir.values">
        <field name="name">Generate Parcel SHP</field>
        <field name="model">res.file</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('wua_generate_files_parcel_shp'))"/>
    </record>

</odoo>