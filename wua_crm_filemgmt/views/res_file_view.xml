<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- File views -->
    <record id="res_file_view_form" model="ir.ui.view">
        <field name="name">Files (form view)</field>
        <field name="model">res.file</field>
        <field name="inherit_id" ref="crm_filemgmt.res_file_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='master_data_fields']" position="inside">
                <field name="category_is_lease" invisible="1"/>
                <field name="category_is_trading" invisible="1"/>
                <field name="category_is_complaint" invisible="1"/>
                <field name="category_report_id_domain" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='category_id']" position="replace">
                <field name="category_id"
                       attrs="{'readonly':['|',('is_closing_stage','=', True),('is_blocked','=',True)]}"/>
                <field name="category_report_id" domain="category_report_id_domain"
                       attrs="{'readonly':['|',('is_closing_stage','=', True),('is_blocked','=',True)]}"/>
                <field name="leased_from"
                       attrs="{'readonly':['|',('is_closing_stage','=', True),('is_blocked','=',True)],
                               'invisible':[('category_is_lease', '=', False)],
                               'required':[('category_is_lease', '=', True)]}"/>
                <field name="leased_to"
                       attrs="{'readonly':['|',('is_closing_stage','=', True),('is_blocked','=',True)],
                               'invisible':[('category_is_lease', '=', False)],
                               'required':[('category_is_lease', '=', True)]}"/>
            </xpath>
            <xpath expr="//field[@name='partnerlink_ids']" position="replace">
                <field name="partnerlink_ids"
                       context="{'tree_view_ref': 'crm_filemgmt.res_file_partnerlink_view_tree'}"
                       attrs="{'readonly':['|',('is_closing_stage','=', True),('is_blocked','=',True)],
                               'invisible':['|','|',('category_is_lease', '=', True),
                                                    ('category_is_trading', '=', True),
                                                    ('category_is_complaint', '=', True)]}"/>
                <field name="partnerlink_lease_ids"
                       context="{'tree_view_ref': 'wua_crm_filemgmt.res_file_partnerlink_view_tree_lease'}"
                       attrs="{'readonly':['|',('is_closing_stage','=', True),('is_blocked','=',True)],
                               'invisible':[('category_is_lease', '=', False)]}"/>
                <field name="partnerlink_trading_ids"
                       context="{'tree_view_ref': 'wua_crm_filemgmt.res_file_partnerlink_view_tree_trading'}"
                       attrs="{'readonly':['|',('is_closing_stage','=', True),('is_blocked','=',True)],
                               'invisible':[('category_is_trading', '=', False)]}"/>
                <field name="partnerlink_complaint_ids"
                       context="{'tree_view_ref': 'wua_crm_filemgmt.res_file_partnerlink_view_tree_complaint'}"
                       attrs="{'readonly':['|',('is_closing_stage','=', True),('is_blocked','=',True)],
                               'invisible':[('category_is_complaint', '=', False)]}"/>
            </xpath>
            <xpath expr="//page[@name='file_comments']" position="before">
                <page name="parcellink_page" string="Parcel Links">
                    <header>
                        <button name="action_get_partner_parcels" type="object" class="btn btn-link"
                            attrs="{'invisible': ['|',('is_closing_stage','=', True),('is_blocked','=',True)]}"
                            string="Get parcels" icon="fa-moval-parcel" style="margin-top:2px; margin-bottom:2px;"
                            groups="crm_filemgmt.group_file_manager"/>
                    </header>
                    <field name="parcellink_ids"
                           context="{'tree_view_ref': 'wua_crm_filemgmt.res_file_parcellink_view_tree'}"
                           attrs="{'readonly':['|',('is_closing_stage','=', True),('is_blocked','=',True)]}"/>
                </page>
            </xpath>
            <xpath expr="//page[@name='attachments']" position="before">
                <page name="start_template_page" string="Template start">
                    <header>
                        <div class="text-right oe_edit_only">
                            <button name="action_get_start_template" type="object" class="btn btn-link"
                                attrs="{'invisible': ['|',('is_closing_stage','=', True),('is_blocked','=',True)]}"
                                string="Refresh" icon="fa-retweet" style="margin-top:2px; margin-bottom:2px;"
                                help="Copy start template from selected report."
                                groups="crm_filemgmt.group_file_manager"/>
                        </div>
                    </header>
                    <field name="template_start" attrs="{'readonly':['|',('is_closing_stage','=', True),('is_blocked','=',True)]}"/>
                </page>
                 <page name="end_template_page" string="Template end">
                    <header>
                        <div class="text-right oe_edit_only">
                            <button name="action_get_end_template" type="object" class="btn btn-link"
                                attrs="{'invisible': ['|',('is_closing_stage','=', True),('is_blocked','=',True)]}"
                                string="Refresh" icon="fa-retweet" style="margin-top:2px; margin-bottom:2px;"
                                help="Copy end template from selected report."
                                groups="crm_filemgmt.group_file_manager"/>
                        </div>
                    </header>
                    <field name="template_end" attrs="{'readonly':['|',('is_closing_stage','=', True),('is_blocked','=',True)]}"/>
                </page>
            </xpath>
        </field>
    </record>

    <record id="res_file_view_kanban" model="ir.ui.view">
        <field name="name">Files (kanban view)</field>
        <field name="model">res.file</field>
        <field name="inherit_id" ref="crm_filemgmt.res_file_view_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='has_registres']" position="after">
                <field name="has_parcellinks"/>
            </xpath>
            <xpath expr="//t[@t-if='record.has_registres.raw_value']" position="after">
                <t t-if="record.has_parcellinks.raw_value">
                    <span style="float:right; margin-right:3%;" class="fa fa-moval-parcel o_button_icon"/>
                </t>
            </xpath>
        </field>
    </record>

    <!-- Partner link views -->
    <record id="res_file_partnerlink_view_tree_lease" model="ir.ui.view">
        <field name="name">File Partnerlink (tree view)</field>
        <field name="model">res.file.partnerlink</field>
        <field name="arch" type="xml">
            <tree class="o_res_file_partnerlink_view_tree" editable="bottom">
                <field name="category_is_lease" invisible="1"/>
                <field name="partner_id"/>
                <field name="is_lessor" attrs="{'required':[('category_is_lease', '=', True)]}"/>
                <field name="is_tenant" attrs="{'required':[('category_is_lease', '=', True)]}"/>
                <field name="is_main"/>
            </tree>
        </field>
    </record>

    <record id="res_file_partnerlink_view_tree_trading" model="ir.ui.view">
        <field name="name">File Partnerlink (tree view)</field>
        <field name="model">res.file.partnerlink</field>
        <field name="arch" type="xml">
            <tree class="o_res_file_partnerlink_view_tree" editable="bottom">
                <field name="category_is_trading" invisible="1"/>
                <field name="partner_id"/>
                <field name="is_seller" attrs="{'required':[('category_is_trading', '=', True)]}"/>
                <field name="is_buyer" attrs="{'required':[('category_is_trading', '=', True)]}"/>
                <field name="is_main"/>
            </tree>
        </field>
    </record>

    <record id="res_file_partnerlink_view_tree_complaint" model="ir.ui.view">
        <field name="name">File Partnerlink (tree view)</field>
        <field name="model">res.file.partnerlink</field>
        <field name="arch" type="xml">
            <tree class="o_res_file_partnerlink_view_tree" editable="bottom">
                <field name="category_is_complaint" invisible="1"/>
                <field name="partner_id"/>
                <field name="is_complainant" attrs="{'required':[('category_is_complaint', '=', True)]}"/>
                <field name="is_denounced" attrs="{'required':[('category_is_complaint', '=', True)]}"/>
                <field name="is_main"/>
            </tree>
        </field>
    </record>

    <!-- Parcel link views -->
    <record id="res_file_parcellink_view_form" model="ir.ui.view">
        <field name="name">File Parcellink (form view)</field>
        <field name="model">res.file.parcellink</field>
        <field name="arch" type="xml">
            <form duplicate="0">
                <sheet>
                    <group name="master_data">
                        <group>
                            <field name="parcel_id"/>
                            <field name="parcel_area_official"/>
                            <field name="parcel_rural_location_county"/>
                            <field name="parcel_cadastral_reference"/>
                        </group>
                        <group>
                            <field name="parcel_partner_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="res_file_parcellink_view_tree" model="ir.ui.view">
        <field name="name">File Parcellink (tree view)</field>
        <field name="model">res.file.parcellink</field>
        <field name="arch" type="xml">
            <tree class="o_res_file_parcellink_view_tree" editable="bottom">
                <field name="parcel_gis_viewer_link" invisible="1"/>
                <field name="parcel_cadastral_reference_link" invisible="1"/>
                <field name="parcel_id"/>
                <field name="parcel_is_archived"/>
                <field name="parcel_area_official"/>
                <button name="action_see_gis_viewer"
                        type="object" class="oe_stat_button"
                        string="GIS Viewer (zoom to parcel)"
                        icon="fa-map-marker"
                        attrs="{'invisible': [('parcel_gis_viewer_link','=','')]}"/>
                <button name="action_see_cadastral_report"
                        type="object" class="oe_stat_button"
                        string="Cadastral Report"
                        icon="fa-cubes"
                        attrs="{'invisible': [('parcel_cadastral_reference_link','=','')]}"/>
                <field name="parcel_rural_location_county"/>
                <field name="parcel_cadastral_reference"/>
                <field name="parcel_partner_id"/>
            </tree>
        </field>
    </record>

    <record id="res_file_parcellink_of_parcel_view_tree" model="ir.ui.view">
        <field name="name">File Parcellink (tree view)</field>
        <field name="model">res.file.parcellink</field>
        <field name="arch" type="xml">
            <tree class="o_res_file_parcellink_of_parcel_view_tree" create="false" edit="false">
                <field name="category_id"/>
                <field name="file_id"/>
                <field name="subject"/>
            </tree>
        </field>
    </record>

    <record id="res_file_parcellink_view_search" model="ir.ui.view">
        <field name="name">File Parcellink (search view)</field>
        <field name="model">res.file.parcellink</field>
        <field name="arch" type="xml">
            <search>
                <field name="file_id"/>
                <field name="category_id"/>
            </search>
        </field>
    </record>

    <record id="res_file_technical_partnerlink_view_tree" model="ir.ui.view">
        <field name="name">File Partnerlink Technical(tree view)</field>
        <field name="model">res.file.partnerlink</field>
        <field name="arch" type="xml">
            <tree class="o_res_file_partnerlink_view_tree" editable="bottom" default_order="create_date desc">
                <field name="file_id"/>
                <field name="partner_id"/>
                <field name="is_main"/>
            </tree>
        </field>
    </record>

    <record id="res_file_technical_partnerlink_action" model="ir.actions.act_window">
        <field name="name">Partner Links Technical(low-level)</field>
        <field name="res_model">res.file.partnerlink</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="res_file_technical_partnerlink_view_tree"/>
    </record>

    <record id="wua_generate_files_parcel_shp" model="ir.actions.server">
        <field name="name">Generate Parcel SHP</field>
        <field name="model_id" ref="model_res_file"/>
        <field name="code">
            action =  env['res.file'].browse(context['active_ids']).action_generate_parcels_shp()
        </field>
    </record>

    <record id="wua_action_generate_file_parcel_shp" model="ir.values">
        <field name="name">Generate Parcel SHP</field>
        <field name="model">res.file</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('wua_generate_files_parcel_shp'))"/>
    </record>

    <record id="res_file_print_selected_report" model="ir.actions.server">
        <field name="name">Print report</field>
        <field name="model_id" ref="model_res_file"/>
        <field name="code">
            action =  env['res.file'].browse(context['active_ids']).action_print_selected_report()
        </field>
    </record>

    <record id="action_res_file_print_selected_report" model="ir.values">
        <field name="name">Print report</field>
        <field name="model">res.file</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('res_file_print_selected_report'))"/>
    </record>

    <menuitem id="res_file_technical_partnerlinks_menu"
              name="Partner Links"
              parent="technical_menu"
              action="res_file_technical_partnerlink_action"
              sequence="2"
              groups="base.group_system"/>

</odoo>