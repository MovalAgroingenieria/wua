<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_hydraulicsector_view_form" model="ir.ui.view">
        <field name="name">Hydraulic Sectors (form view)</field>
        <field name="model">wua.hydraulicsector</field>
        <field name="inherit_id" ref="base_wua_infrastructure.wua_hydraulicsector_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='buttons']" position="inside">
                <button name="action_get_hydraulicsector_tankconsumptions" class="oe_stat_button"
                    type="object" icon="fa-moval-watertank"
                    groups="base_wua.group_wua_user, base_wua.group_wua_portal_user">
                    <div class="o_form_field o_stat_info">
                        <span class="o_stat_text">Tank cons.</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
