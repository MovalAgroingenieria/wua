<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_tank_view_form" model="ir.ui.view">
        <field name="name">Tanks (form view)</field>
        <field name="model">wua.tank</field>
        <field name="arch" type="xml">
            <form duplicate="0">
                <sheet>
                    <field name="gis_viewer_link" invisible="1"/>
                    <field name="with_gis_tank" invisible="1"/>
                    <div name="buttons" class="oe_button_box">
                        <button name="action_see_tankconsumptions" class="oe_stat_button"
                            type="object" icon="fa-moval-watertank" groups="base_wua.group_wua_user">
                            <div class="o_form_field o_stat_info">
                                <span class="o_stat_text">Tank consumptions</span>
                            </div>
                        </button>
                        <button name="action_see_gis_viewer" type="object"
                            class="oe_stat_button" string="GIS Viewer" icon="fa-map-marker"
                            attrs="{'invisible': ['|',('gis_viewer_link','=',False), ('with_gis_tank','=',False)]}"/>
                    </div>
                    <group name="master_data">
                        <group name="master_data_fields">
                            <field name="hydraulicsector_id"/>
                            <field name="name"/>
                            <field name="description"/>
                        </group>
                    </group>
                    <group name="slave_data">
                        <notebook name="slave_data_notebook">
                            <page name="notes_page" string="Notes">
                                <field name="notes"/>
                            </page>
                        </notebook>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="wua_tank_view_tree" model="ir.ui.view">
        <field name="name">Tanks (tree view)</field>
        <field name="model">wua.tank</field>
        <field name="arch" type="xml">
            <tree class="o_base_wua_pressurized_irritation_tank_view_tree">
                <field name="gis_viewer_link" invisible="1"/>
                <field name="with_gis_tank" invisible="1"/>
                <field name="name"/>
                <button name="action_see_gis_viewer"
                        type="object" class="oe_stat_button"
                        string="GIS Viewer (zoom to point)"
                        icon="fa-map-marker"
                        attrs="{'invisible': ['|',('gis_viewer_link','=',False),('with_gis_tank','=',False)]}"/>
                <field name="hydraulicsector_id"/>
                <field name="description"/>
            </tree>
        </field>
    </record>

    <record id="wua_tank_view_search" model="ir.ui.view">
        <field name="name">Tanks (search view)</field>
        <field name="model">wua.tank</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="hydraulicsector_id"/>
                <field name="description"/>
                <group expand="0" string="Group By">
                    <filter string="Hydraulic Sector" name="hydraulic_sector"
                        context="{'group_by':'hydraulicsector_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="wua_tank_action" model="ir.actions.act_window">
        <field name="name">Tanks</field>
        <field name="res_model">wua.tank</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids"
         eval="[(5, 0),
                (0, 0, {'view_mode': 'tree',
                        'view_id': ref('wua_tank_view_tree')}),
                (0, 0, {'view_mode': 'form',
                        'view_id': ref('wua_tank_view_form')})]"/>
        <field name="search_view_id" ref="wua_tank_view_search"/>
    </record>

    <menuitem id="tank_menu"
              name="Tanks"
              parent="base_wua_infrastructure.base_wua_infrastructure_pressurized_irrigation_menu"
              sequence="6"
              action="wua_tank_action"
              groups="base_wua.group_wua_user"/>

</odoo>