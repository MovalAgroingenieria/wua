<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_flowmeter_view_form" model="ir.ui.view">
        <field name="name">Flowmeters (form view)</field>
        <field name="model">wua.flowmeter</field>
        <field name="arch" type="xml">
            <form duplicate="0">
                <sheet>
                    <field name="gis_viewer_link" invisible="1"/>
                    <field name="with_gis_flowmeter" invisible="1"/>
                    <field name="connected_to_intake" invisible="1"/>
                    <div name="buttons" class="oe_button_box">
                        <field name="active" invisible="1"/>
                        <button name="toggle_active"
                                type="object"
                                class="oe_stat_button"
                                confirm="Are you sure you want to toggle visibility?"
                                icon="fa-archive">
                                <field name="active"
                                 widget="boolean_button"
                                 options='{"terminology": "archive"}'/>
                        </button>
                        <button name="action_see_gis_viewer" type="object"
                            class="oe_stat_button" string="GIS Viewer" icon="fa-map-marker"
                            attrs="{'invisible': ['|',('gis_viewer_link','=',False), ('with_gis_flowmeter','=',False)]}"/>
                    </div>
                    <group name="master_data">
                        <group name="master_data_left">
                            <field name="name"/>
                            <field name="description"/>
                            <field name="state"/>
                            <field name="type"/>
                            <field name="nominal_diameter"/>
                            <field name="serial_number"/>
                            <field name="flowmeter_brand"/>
                            <field name="flowmeter_model"/>
                            <field name="installation_date"/>
                            <field name="nominal_water_flow"/>
                            <field name="flow_direction"/>
                            <field name="bidirectional_flow_1_def" attrs="{'invisible': [('flow_direction','!=', 'bidirectional')],
                                                                           'required': [('flow_direction','=', 'bidirectional')]}"/>
                            <field name="bidirectional_flow_2_def" attrs="{'invisible': [('flow_direction','!=', 'bidirectional')],
                                                                           'required': [('flow_direction','=', 'bidirectional')]}"/>
                        </group>
                        <group name="master_data_right">
                            <field name="intake_id" attrs="{'invisible': [('connected_to_intake','!=', True)]}"/>
                        </group>
                    </group>
                    <group name="slave_data">
                        <notebook name="slave_data_notebook">
                            <page name="notes_page" string="Notes">
                                <field name="notes"/>
                            </page>
                        </notebook>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="wua_flowmeter_view_tree" model="ir.ui.view">
        <field name="name">Flowmeters (tree view)</field>
        <field name="model">wua.flowmeter</field>
        <field name="arch" type="xml">
            <tree class="o_base_wua_infrastructure_primary_flowmeters_view_tree">
                <field name="gis_viewer_link" invisible="1"/>
                <field name="with_gis_flowmeter" invisible="1"/>
                <field name="name"/>
                <field name="description"/>
                <button name="action_see_gis_viewer"
                        type="object" class="oe_stat_button"
                        string="GIS Viewer (zoom to point)"
                        icon="fa-map-marker"
                        attrs="{'invisible': ['|',('gis_viewer_link','=',False),('with_gis_flowmeter','=',False)]}"/>
                <field name="type"/>
                <field name="nominal_water_flow" string="Water (m3/hour)"/>
                <field name="connected_to_intake"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="wua_flowmeter_view_search" model="ir.ui.view">
        <field name="name">Flowmeters (search view)</field>
        <field name="model">wua.flowmeter</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter string="Connected to intake: Yes" name="connected_intake_yes" domain="[('connected_to_intake','=', True)]"/>
                <filter string="Connected to intake: No" name="connected_intake_no" domain="[('connected_to_intake','=', False)]"/>
                <separator/>
                <filter string="Woltmann" name="woltmann" domain="[('type','=','woltmann')]"/>
                <filter string="Electromagnetic" name="electromagnetic" domain="[('type','=','electromagnetic')]"/>
                <filter string="Ultrasonic" name="ultrasonic" domain="[('type','=','ultrasonic')]"/>
                <filter string="Titrator" name="titrator" domain="[('type','=','titrator')]"/>
                <filter string="Level Probe" name="levelprobe" domain="[('type','=','levelprobe')]"/>
                <filter string="Doppler-Effect Ultrasonic" name="ultrasonicdoppler" domain="[('type','=','ultrasonicdoppler')]"/>
                <filter string="Other" name="undefine" domain="[('type','=','undefine')]"/>
                <separator/>
                <filter string="Active" name="active" domain="[('state','=','active')]"/>
                <filter string="Stored" name="stored" domain="[('state','=','stored')]"/>
                <filter string="Discarted" name="discarted" domain="[('state','=','discarted')]"/>
                <group expand="0" string="Group By">
                    <filter string="Intake" name="intake" context="{'group_by':'intake_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="wua_flowmeter_action" model="ir.actions.act_window">
        <field name="name">Flowmeters</field>
        <field name="res_model">wua.flowmeter</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="wua_flowmeter_view_tree"/>
        <field name="search_view_id" ref="wua_flowmeter_view_search"/>
    </record>

    <menuitem
        name="Flowmeters"
        id="wua_flowmeter_menu"
        parent="base_wua_infrastructure.base_wua_infrastructure_primary_menu"
        sequence="11"
        action="wua_flowmeter_action"/>

</odoo>