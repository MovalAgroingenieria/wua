<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <record id="wua_controlhydricmovement_of_quota_view_tree" model="ir.ui.view">
        <field name="name">Control Hydric-Movements of a quota (tree view)</field>
        <field name="model">wua.controlhydricmovement</field>
        <field name="arch" type="xml">
            <tree class="o_base_wua_quota_management_with_provisional_quota_sorted_controlhydricmovement_of_quota_view_tree"
                  colors="orangered:is_consumption==True;royalblue:is_consumption==False"
                  create="false" edit="false" delete="false">
                <field name="is_consumption" invisible="1"/>
                <button type="object" class="oe_stat_button"
                        icon="fa-arrow-right"
                        attrs="{'invisible':
                                [('is_consumption','=',True)],
                                'readonly':'1'}"/>
                <field name="event_time"
                       string="Date" widget="date"/>
                <field name="description"/>
                <field name="accounting_volume"
                       string="Value (m³)" sum="Total Volume (m³)"/>
                <button type="object" class="oe_stat_button"
                        icon="fa-arrow-right"
                        attrs="{'invisible':
                                [('is_consumption','=',False)],
                                'readonly':'1'}"/>
            </tree>
        </field>
    </record>
    
</odoo>