<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Wua partner infrastrucure report (continuation of wua partner report) -->
    <template id="wua_partner_infrastructure_report_document" inherit_id="base_wua.wua_partner_report_document">
        <xpath expr="//div[@name='wua_partnerlinks_ids']" position="after">
            <div name="wua_irrigationpoint_ids" style="margin-top: 20px;">

                <!-- Determine number of IG and WC points -->
                <t t-set="pressure_type" t-value="0"/>
                <t t-set="gravity_type" t-value="0"/>
                <t t-foreach="o.partnerlink_ids" t-as="p">
                    <t t-foreach="p.parcel_id.irrigationpoint_ids" t-as="ip">
                        <t t-if="ip.type == 'WC'">
                            <t t-set="pressure_type" t-value="pressure_type + 1"/>
                        </t>
                        <t t-elif="ip.type == 'IG'">
                            <t t-set="gravity_type" t-value="gravity_type + 1"/>
                        </t>
                    </t>
                </t>

                <!-- Show Pressure irrigation points if any -->
                <t t-if="pressure_type != 0">
                    <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                        <t t-if="report_style == 'light'">
                            <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                <div style="float: left; width: 32px;"><span class="fa fa-moval-infra"/></div>
                                <div style="float: left; display: inline;"><strong>Water&amp;nbsp;connection&amp;nbsp;points</strong></div>
                           </div>
                        </t>
                        <t t-else="">
                            <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                <div style="float: left; width: 32px;"><span class="fa fa-moval-infra"/></div>
                                <div style="float: left; display: inline;"><strong>Water&amp;nbsp;connection&amp;nbsp;points</strong></div>
                            </div>
                        </t>
                    </div>
                    <table class="table table-condensed" style="margin-top: 2px;">
                        <thead>
                            <tr>
                                <th class="text-center" name="pression_parcel">Parcel</th>
                                <th name="pression_waterconnection">Water Connection</th>
                                <th name="pression_irrigation_shed">Irrigation Shed</th>
                                <th class="text-center" name="pression_hidraulicsector">Hydraulic Sector</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="o.partnerlink_ids" t-as="p">
                                <tr t-foreach="p.parcel_id.irrigationpoint_ids" t-as="ip">
                                    <t t-if="ip.type == 'WC'">
                                        <td class="text-center" name="pression_parcel"><span t-field="p.parcel_id"/></td>
                                        <td name="pression_waterconnection"><span t-field="ip.waterconnection_id"/></td>
                                        <td name="pression_irrigation_shed"><span t-field="ip.irrigationshed_id"/></td>
                                        <td class="text-center" name="pression_hidraulicsector"><span t-field="ip.hydraulicsector_id"/></td>
                                    </t>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>

                <!-- Show Gravity irrigation points if any -->
                <t t-if="gravity_type != 0">
                    <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                        <t t-if="report_style == 'light'">
                            <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                <div style="float: left; width: 32px;"><span class="fa fa-moval-infra"/></div>
                                <div style="float: left; display: inline;"><strong>Irrigation&amp;nbsp;gates</strong></div>
                           </div>
                        </t>
                        <t t-else="">
                            <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                <div style="float: left; width: 32px;"><span class="fa fa-moval-infra"/></div>
                                <div style="float: left; display: inline;"><strong>Irrigation&amp;nbsp;gates</strong></div>
                            </div>
                        </t>
                    </div>
                    <table class="table table-condensed" style="margin-top: 2px;">
                        <thead>
                            <tr>
                                <th name="gravity_parcel">Parcel</th>
                                <th name="gravity_irrigationgate">Irrigation gate</th>
                                <th name="gravity_irrigationditch">Irrigation ditch</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="o.partnerlink_ids" t-as="p">
                                <tr t-foreach="p.parcel_id.irrigationpoint_ids" t-as="ip">
                                    <t t-if="ip.type == 'IG'">
                                        <td name="gravity_parcel"><span t-field="p.parcel_id"/></td>
                                        <td name="gravity_irrigationgate"><span t-field="ip.irrigationgate_id"/></td>
                                        <td name="gravity_irrigationditch"><span t-field="ip.irrigationditch_id"/></td>
                                    </t>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>

            </div>
        </xpath>
    </template>

</odoo>
