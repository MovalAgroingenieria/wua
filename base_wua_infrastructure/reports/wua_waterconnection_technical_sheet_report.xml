<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <report id="wua_waterconnection_technical_sheet_report"
        string="Technical sheet"
        model="wua.waterconnection"
        report_type="qweb-pdf"
        file="base_wua_infrastructure.wua_waterconnection_technical_sheet_report_document"
        name="base_wua_infrastructure.wua_waterconnection_technical_sheet_report_document"
        paperformat="base_wua_report.paperformat_wua_reports"/>

    <template id="wua_waterconnection_technical_sheet_report_document">
        <t t-call="report.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="base_wua_report.wua_external_layout">
                    <div class="page">

                        <!-- Vars -->
                        <t t-set="report_style" t-value="o.env['ir.values'].get_default('wua.configuration', 'reports_style')"/>
                        <t t-set="area_measurement_type" t-value="o.env['ir.values'].get_default('wua.configuration', 'area_measurement_type')"/>
                        <t t-set="area_measurement_name" t-value="o.env['ir.values'].get_default('wua.configuration', 'area_measurement_name') or ''"/>

                        <!-- SECTION: Waterconnection Data -->
                        <div name="toma_section" style="margin-bottom: 16px;">

                            <!-- Section header -->
                            <div class="row h4 mb4" style="padding-bottom: 4px;">
                                <t t-if="report_style == 'light'">
                                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;"><span class="fa fa-moval-infra"/></div>
                                        <div style="float: left; display: inline;"><strong>Waterconnection Data</strong></div>
                                    </div>
                                </t>
                                <t t-else="">
                                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;"><span class="fa fa-moval-infra"/></div>
                                        <div style="float: left; display: inline;"><strong>Waterconnection Data</strong></div>
                                    </div>
                                </t>
                            </div>

                            <!-- Three-column layout: photo | main fields | description + extra -->
                            <div style="display: table; width: 100%; margin-top: 8px;">

                                <!-- Col 1: Photo (only rendered when image exists) -->
                                <t t-if="o.image">
                                    <div name="toma_photo_col" style="display: table-cell; width: 22%; vertical-align: middle; text-align: center; padding-right: 10px; border-right: 1px solid lightgrey;">
                                        <img t-att-src="'data:image/png;base64,' + o.image"
                                             style="max-width: 160px; max-height: 160px; padding: 2px;"/>
                                    </div>
                                </t>

                                <!-- Col 2: Identifier, sector, shed, position -->
                                <div name="toma_col_left" style="display: table-cell; vertical-align: top; padding: 0 12px; border-right: 1px solid lightgrey;">
                                    <table name="toma_table_left" class="table-condensed" style="width: 100%;">
                                        <tbody name="toma_tbody_left">
                                            <tr name="tr_name">
                                                <td style="width: 50%;"><span>Identifier:</span></td>
                                                <td class="text-right">
                                                    <t t-if="o.name"><span t-field="o.name"/></t>
                                                </td>
                                            </tr>
                                            <tr name="tr_hydraulicsector">
                                                <td><span>Hydraulic Sector:</span></td>
                                                <td class="text-right">
                                                    <t t-if="o.hydraulicsector_id">
                                                        <span t-field="o.hydraulicsector_id"/>
                                                    </t>
                                                </td>
                                            </tr>
                                            <tr name="tr_irrigationshed">
                                                <td><span>Irrigation Shed:</span></td>
                                                <td class="text-right">
                                                    <t t-if="o.irrigationshed_id">
                                                        <span t-field="o.irrigationshed_id"/>
                                                    </t>
                                                </td>
                                            </tr>
                                            <tr name="tr_position">
                                                <td><span>Position:</span></td>
                                                <td class="text-right">
                                                    <t t-if="o.position">
                                                        <span t-field="o.position"/>
                                                    </t>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>

                                <!-- Col 3: Description + extra fields injected by child modules -->
                                <div name="toma_col_right" style="display: table-cell; vertical-align: top; padding-left: 12px;">
                                    <table name="toma_table_right" class="table-condensed" style="width: 100%;">
                                        <tbody name="toma_tbody_right">
                                            <tr name="tr_description">
                                                <td style="width: 50%;"><span>Description:</span></td>
                                                <td class="text-right">
                                                    <t t-if="o.description">
                                                        <span t-field="o.description"/>
                                                    </t>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>

                            </div>
                        </div>

                        <!-- Placeholder for counter section (filled by base_wua_pressurized_irrigation) -->
                        <div name="watermeter_section_placeholder"/>

                        <!-- SECTION: Supplied Parcels -->
                        <div name="parcelas_section" style="margin-top: 16px;">

                            <!-- Section header -->
                            <div class="row h4 mb4" style="padding-bottom: 4px;">
                                <t t-if="report_style == 'light'">
                                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;"><span class="fa fa-list"/></div>
                                        <div style="float: left; display: inline;"><strong>Supplied Parcels</strong></div>
                                    </div>
                                </t>
                                <t t-else="">
                                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;"><span class="fa fa-list"/></div>
                                        <div style="float: left; display: inline;"><strong>Supplied Parcels</strong></div>
                                    </div>
                                </t>
                            </div>

                            <!-- Parcels table -->
                            <t t-if="o.irrigationpointwc_ids">
                                <table name="parcelas_table" class="table table-condensed table-striped" style="margin-top: 4px; width: 100%;">
                                    <thead>
                                        <tr>
                                            <th name="th_parcel">Parcel</th>
                                            <th name="th_cadastral">Cadastral Ref.</th>
                                            <th name="th_area">Area
                                                <t t-if="area_measurement_type == 1 and area_measurement_name">
                                                    (<span t-esc="area_measurement_name"/>)
                                                </t>
                                                <t t-else="">(ha)</t>
                                            </th>
                                            <th name="th_irrigationshed">Irrigation Shed</th>
                                            <th name="th_hydraulicsector">Hydraulic Sector</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="o.irrigationpointwc_ids" t-as="ip">
                                            <tr>
                                                <td name="td_parcel"><span t-esc="ip.parcel_id.name or ''"/></td>
                                                <td name="td_cadastral"><span t-esc="ip.parcel_id.cadastral_reference or ''"/></td>
                                                <td name="td_area"><span t-esc="'%.4f' % (ip.parcel_id.area_official or 0.0)"/></td>
                                                <td name="td_irrigationshed"><span t-esc="o.irrigationshed_id.name or ''"/></td>
                                                <td name="td_hydraulicsector"><span t-esc="o.hydraulicsector_id.name or ''"/></td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </t>
                            <t t-else="">
                                <div class="text-center" style="margin-top: 8px;">
                                    <span>(This connection has no associated supplied parcels)</span>
                                </div>
                            </t>

                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
