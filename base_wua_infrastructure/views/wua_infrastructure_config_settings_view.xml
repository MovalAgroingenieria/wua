<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_infrastructure_config_settings_view_form" model="ir.ui.view">
        <field name="name">Parameters</field>
        <field name="model">wua.infrastructure.configuration</field>
        <field name="arch" type="xml">
            <form string="Infrastructure Settings" class="oe_form_configuration">
                <header>
                    <button string="Apply" type="object" name="execute"
                     class="oe_highlight"/>
                    <button string="Cancel" type="object" name="cancel"
                     class="oe_link"/>
                </header>
                <group string="Irrigation Model">
                    <field name="irrigation_model_type" widget="radio"/>
                </group>
                <group string="GIS Settings" name="gis_settings_group">
                    <field name="url_gis_googlemaps"/>
                    <field name="url_gis_viewer_irrigationshed_param"/>
                    <field name="url_gis_viewer_waterconnection_param"/>
                    <field name="url_gis_viewer_irrigationditch_param"/>
                </group>
            </form>
        </field>
    </record>

    <record id="wua_infrastructure_configuration_action"
            model="ir.actions.act_window">
        <field name="name">Configure Infrastructure</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">wua.infrastructure.configuration</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
    </record>

    <menuitem id="base_wua_infrastructure_configuration_menu"
              name="Configuration"
              parent="base_wua_infrastructure_menu"
              sequence="1001"
              groups="base_wua.group_wua_user"/>

    <menuitem id="wua_infrastructure_configuration_menu"
              name="Parameters"
              parent="base_wua_infrastructure_configuration_menu"
              action="wua_infrastructure_configuration_action"
              sequence="1"
              groups="base.group_system"/>

</odoo>
