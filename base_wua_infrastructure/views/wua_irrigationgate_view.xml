<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_irrigationgate_view_form" model="ir.ui.view">
        <field name="name">Irrigation Gates (form view)</field>
        <field name="model">wua.irrigationgate</field>
        <field name="arch" type="xml">
            <form duplicate="0">
                <sheet>
                    <div name="buttons" class="oe_button_box">
                        <field name="gis_googlemaps_link" invisible="1"/>
                        <button name="action_see_gis_googlemaps"
                                type="object"
                                class="oe_stat_button"
                                string="Google Maps"
                                icon="fa-globe"
                                attrs="{'invisible':
                                        [('gis_googlemaps_link','=',False)]}"/>
                    </div>
                    <group name="master_data" col="9">
                        <group name="master_image" colspan="3">
                            <field name="image" widget="image" class="oe_img_259_160"/>
                        </group>
                        <group name="master_fields" colspan="6" col="4">
                            <field name="irrigationditch_id" colspan="4"/>
                            <field name="name"/>
                            <field name="delay_time"/>
                            <field name="hydraulic_order"/>
                            <newline/>
                            <field name="gis_viewer_x"/>
                            <field name="gis_viewer_y"/>
                            <field name="to_main_pipe"/>
                            <newline/>
                            <field name="with_flowdivider"/>
                            <field name="flowdivider_id"
                                   domain="[('irrigationditch_id', '=', irrigationditch_id)]"
                                   attrs="{'invisible': [('with_flowdivider','=',False)]}"/>
                            <field name="description" colspan="4"/>
                            <field name="number_of_parcels"/>
                            <field name="total_affected_area_official"/>
                        </group> 
                    </group>
                    <group name="slave_data" groups="base_wua.group_wua_user">
                        <notebook name="slave_data_notebook">
                            <page name="parcels_page" string="Parcels">
                                <field name="irrigationpoint_ids">
                                    <tree create="false" edit="false" delete="false"
                                        class="o_base_wua_infrastructure_irrigationpoint_parcels_view_tree_notebook">
                                        <field name="parcel_cadastral_reference_link"
                                               invisible="1"/>
                                        <field name="parcel_street_view_link"
                                               invisible="1"/>
                                        <field name="parcel_gis_viewer_link"
                                               invisible="1"/>
                                        <field name="parcel_id"/>
                                        <field name="parcel_area_official"/>
                                        <button name="action_see_gis_viewer"
                                                type="object" class="oe_stat_button"
                                                string="GIS Viewer (zoom to parcel)"
                                                icon="fa-map-marker"
                                                attrs="{'invisible': [('parcel_gis_viewer_link','=','')]}"/>
                                        <button name="action_see_cadastral_report"
                                                type="object" class="oe_stat_button"
                                                string="Cadastral Report"
                                                icon="fa-cubes"
                                                attrs="{'invisible': [('parcel_cadastral_reference_link','=','')]}"/>
                                        <field name="parcel_rural_location_county"/>
                                        <field name="parcel_cadastral_reference"/>                                        
                                        <field name="parcel_cadastral_polygon"/>
                                        <field name="parcel_cadastral_parcel"/>
                                        <button name="action_see_street_view"
                                                type="object" class="oe_stat_button"
                                                string="Street View"
                                                icon="fa-street-view"
                                                attrs="{'invisible': [('parcel_street_view_link','=','')]}"/>
                                    </tree>
                                </field>
                            </page>
                            <page name="notes_page" string="Notes">
                                <field name="notes"/>
                            </page>
                        </notebook>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="wua_irrigationgate_view_tree" model="ir.ui.view">
        <field name="name">Irrigation Gates (tree view)</field>
        <field name="model">wua.irrigationgate</field>
        <field name="arch" type="xml">
            <tree class="o_base_wua_infrastructure_irrigationgate_view_tree">
                <field name="gis_googlemaps_link" invisible="1"/>
                <field name="name"/>
                <field name="irrigationditch_id"/>
                <button name="action_see_gis_googlemaps"
                        type="object" class="oe_stat_button"
                        string="Google Maps (zoom to point)"
                        icon="fa-globe"
                        attrs="{'invisible': [('gis_googlemaps_link','=','')]}"/>                
                <field name="description"/>                
                <field name="hydraulic_order"/>
                <field name="delay_time"/>
                <field name="total_affected_area_official"/>
                <field name="number_of_parcels"/>
            </tree>
        </field>
    </record>

    <record id="wua_irrigationgate_view_search" model="ir.ui.view">
        <field name="name">Irrigation Gates (search view)</field>
        <field name="model">wua.irrigationgate</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="description"/>
                <field name="irrigationditch_id"/>
                <filter string="Connected to main pipe" name="tomainpipe"
                 domain="[('to_main_pipe','=',True)]"/>                
                <filter string="With flow divider" name="withflowdivider"
                 domain="[('with_flowdivider','=',True)]"/>                
                <group expand="0" string="Group By">
                    <filter string="Irrigation Ditch"
                     name="irrigation_ditch"
                     context="{'group_by':'irrigationditch_id'}"/>
                    <filter string="Flow Divider"
                     name="flow_divider"
                     context="{'group_by':'flowdivider_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="wua_irrigationgate_view_kanban" model="ir.ui.view">
        <field name="name">Irrigation Gates (kanban view)</field>
        <field name="model">wua.irrigationgate</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="description"/>
                <field name="irrigationditch_id"/>
                <field name="image"/>
                <field name="gis_googlemaps_link"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <t t-if="record.image.raw_value">
                                    <img t-att-src="kanban_image('wua.irrigationgate', 'image', record.id.value)"/>
                                </t>
                                <div style="margin-top:10px">
                                  <t t-if="record.gis_googlemaps_link.raw_value"><a type="button"><button name="action_see_gis_googlemaps" type="object" class="oe_stat_button"><span><i class="fa fa-globe"></i></span></button></a></t>
                                </div>                                
                            </div>                            
                            <div class="oe_kanban_details">
                                <strong><field name="irrigationditch_id"/></strong>
                                <br/>
                                <strong><field name="name"/></strong>
                                <ul>
                                    <li t-if="record.hydraulic_order.raw_value" class="o_text_overflow">Hydraulic order: <field name="hydraulic_order"/></li>
                                    <br/>
                                    <li t-if="record.description.raw_value" class="o_text_overflow"><field name="description"/></li>
                                    <li t-if="record.total_affected_area_official" class="o_text_overflow">Area: <field name="total_affected_area_official"/></li>
                                    <br/>
                                    <li t-if="record.number_of_parcels.raw_value" class="o_text_overflow">Parcels: <field name="number_of_parcels"/></li>                                    
                                    <br/>
                                </ul>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="wua_irrigationgate_action" model="ir.actions.act_window">
        <field name="name">Irrigation Gates</field>
        <field name="res_model">wua.irrigationgate</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="view_id" ref="wua_irrigationgate_view_tree"/>
        <field name="search_view_id"
         ref="wua_irrigationgate_view_search"/>
        <field name="context">{'search_default_irrigation_ditch': 1}</field>
    </record>

    <!-- Three following records: for set explicit view order. -->

    <record id="wua_irrigationgate_action_tree_view"
            model="ir.actions.act_window.view">
        <field name="sequence" eval="0"/>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="wua_irrigationgate_view_tree"/>
        <field name="act_window_id" ref="wua_irrigationgate_action"/>
    </record>

    <record id="wua_irrigationgate_action_kanban_view"
            model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="wua_irrigationgate_view_kanban"/>
        <field name="act_window_id" ref="wua_irrigationgate_action"/>
    </record>

    <record id="wua_irrigationgate_action_form_view"
            model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="wua_irrigationgate_view_form"/>
        <field name="act_window_id" ref="wua_irrigationgate_action"/>
    </record>
    
    <menuitem id="wua_irrigationgate_menu"
              name="Irrigation Gates"
              parent="base_wua_infrastructure_gravityfed_irrigation_menu"
              action="wua_irrigationgate_action"
              sequence="3"/>

</odoo>