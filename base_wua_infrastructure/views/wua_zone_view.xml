<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_zone_view_form" model="ir.ui.view">
        <field name="name">Zones (form view)</field>
        <field name="model">wua.zone</field>
        <field name="arch" type="xml">
            <form duplicate="0">
                <field name="id" invisible="1"/>
                <field name="hydraulicsector_ids" invisible="1"/>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_get_hydraulicsectors"
                                type="object" class="oe_stat_button"
                                icon="fa-sitemap"
                                attrs="{'invisible': [('hydraulicsector_ids','=',[])]}">
                            <div class="o_form_field o_stat_info">
                                <span class="o_stat_text">Sectors</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name" string="Zone:"/>
                        <h1>
                             <field name="name"
                                    style="margin-top:5px"/>
                        </h1>
                        <div>
                            <label for="zone_code"/>
                            <field name="zone_code"
                                   style="width:100px"
                                   attrs="{'readonly': [('id','>',0)]}"/>
                        </div>
                    </div>
                    <div name="notes">
                        <div name="notes_title"
                            style="text-align:center;">
                            <span style="font-weight:bold;">
                            N O T E S
                            </span>
                        </div>
                        <hr/>
                        <field name="notes" nolabel="1"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="wua_zone_view_tree" model="ir.ui.view">
        <field name="name">Zones (tree view)</field>
        <field name="model">wua.zone</field>
        <field name="arch" type="xml">
            <tree class="o_base_wua_infrastructure_zone_view_tree">
                <field name="zone_code"/>
                <field name="name"/>
                <field name="number_of_hydraulicsectors" string="Sectors"/>
            </tree>
        </field>
    </record>

    <record id="wua_zone_view_search" model="ir.ui.view">
        <field name="name">Zones (search view)</field>
        <field name="model">wua.zone</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="wua_zone_action"
            model="ir.actions.act_window">
        <field name="name">Zones</field>
        <field name="res_model">wua.zone</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>        
        <field name="view_ids"
         eval="[(5, 0),
                (0, 0, {'view_mode': 'tree',
                        'view_id': ref('wua_zone_view_tree')}),
                (0, 0, {'view_mode': 'form',
                        'view_id': ref('wua_zone_view_form')})]"/>
        <field name="search_view_id" ref="wua_zone_view_search"/>
    </record>

    <menuitem id="wua_zone_menu"
        name="Zones"
        parent="base_wua_infrastructure_pressurized_irrigation_menu"
        sequence="0"
        action="wua_zone_action"
        groups="base_wua.group_wua_user"/>

</odoo>