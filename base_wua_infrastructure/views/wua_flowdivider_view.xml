<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_flowdivider_view_form" model="ir.ui.view">
        <field name="name">Flow Dividers (form view)</field>
        <field name="model">wua.flowdivider</field>
        <field name="arch" type="xml">
            <form duplicate="0">
                <sheet>
                    <div name="buttons" class="oe_button_box">
                        <field name="gis_googlemaps_link" invisible="1"/>
                        <button name="action_see_gis_googlemaps"
                                type="object"
                                class="oe_stat_button"
                                string="Google Maps"
                                icon="fa-globe"
                                attrs="{'invisible':
                                        [('gis_googlemaps_link','=',False)]}"/>
                    </div>                
                    <group name="master_data" col="9">
                        <group name="master_image" colspan="3">
                            <field name="image" widget="image" class="oe_img_259_160"/>
                        </group>
                        <group name="master_fields" colspan="6" col="4">
                            <field name="irrigationditch_id" colspan="4"/>
                            <field name="name"/>
                            <field name="delay_time"/>
                            <field name="drainage_coefficient"/>
                            <newline/>
                            <field name="gis_viewer_x"/>
                            <field name="gis_viewer_y"/>
                            <field name="description" colspan="4"/>
                            <field name="number_of_irrigationgates"/>
                            <newline/>
                            <field name="initial_hydraulic_order"
                                   attrs="{'invisible':
                                           [('number_of_irrigationgates','=',0)]}"/>
                            <field name="final_hydraulic_order"
                                   attrs="{'invisible':
                                           [('number_of_irrigationgates','=',0)]}"/>
                        </group> 
                    </group>
                    <group name="slave_data">
                        <notebook name="slave_data_notebook">
                            <page name="irrigationgates_page" string="Irrigation Gates">
                                <field name="irrigationgate_ids">                                
                                    <tree class="o_base_wua_infrastructure_irrigationgate_view_tree_notebook"
                                     create="false" edit="false" delete="false">
                                        <field name="gis_googlemaps_link" invisible="1"/>
                                        <field name="name"/>
                                        <button name="action_see_gis_googlemaps"
                                                type="object" class="oe_stat_button"
                                                string="Google Maps (zoom to point)"
                                                icon="fa-map-marker"
                                                attrs="{'invisible': [('gis_googlemaps_link','=','')]}"/>
                                        <field name="description"/>
                                        <field name="hydraulic_order"/>                                        
                                        <field name="total_affected_area_official"/>
                                        <field name="number_of_parcels"/>
                                    </tree>
                                </field>
                            </page>                        
                            <page name="notes_page" string="Notes">
                                <field name="notes"/>
                            </page>
                        </notebook>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="wua_flowdivider_view_tree" model="ir.ui.view">
        <field name="name">Flow Dividers (tree view)</field>
        <field name="model">wua.flowdivider</field>
        <field name="arch" type="xml">
            <tree class="o_base_wua_infrastructure_flowdivider_view_tree">
                <field name="gis_googlemaps_link" invisible="1"/>
                <field name="name"/>
                <field name="irrigationditch_id"/>
                <button name="action_see_gis_googlemaps"
                        type="object" class="oe_stat_button"
                        string="Google Maps (zoom to point)"
                        icon="fa-globe"
                        attrs="{'invisible': [('gis_googlemaps_link','=','')]}"/>                
                <field name="description"/>
                <field name="number_of_irrigationgates"/>                
                <field name="initial_hydraulic_order"/>
                <field name="final_hydraulic_order"/>
                <field name="delay_time"/>
            </tree>
        </field>
    </record>

    <record id="wua_flowdivider_view_search" model="ir.ui.view">
        <field name="name">Flow Dividers (search view)</field>
        <field name="model">wua.flowdivider</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="description"/>
                <field name="irrigationditch_id"/>
                <group expand="0" string="Group By">
                    <filter string="Irrigation Ditch"
                     name="irrigation_ditch"
                     context="{'group_by':'irrigationditch_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="wua_flowdivider_view_kanban" model="ir.ui.view">
        <field name="name">Flow Dividers (kanban view)</field>
        <field name="model">wua.flowdivider</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="description"/>
                <field name="irrigationditch_id"/>
                <field name="image"/>
                <field name="gis_googlemaps_link"/>
                <field name="number_of_irrigationgates"/>
                <field name="initial_hydraulic_order"/>
                <field name="final_hydraulic_order"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <t t-if="record.image.raw_value">
                                    <img t-att-src="kanban_image('wua.flowdivider', 'image', record.id.value)"/>
                                </t>
                                <div style="margin-top:10px">
                                  <t t-if="record.gis_googlemaps_link.raw_value"><a type="button"><button name="action_see_gis_googlemaps" type="object" class="oe_stat_button"><span><i class="fa fa-globe"></i></span></button></a></t>
                                </div>                                
                            </div>                            
                            <div class="oe_kanban_details">
                                <strong><field name="irrigationditch_id"/></strong>
                                <br/>
                                <strong><field name="name"/></strong>
                                <ul>
                                    <li class="o_text_overflow">Irrigation Gates: <field name="number_of_irrigationgates"/></li>
                                    <li t-if="record.description.raw_value" class="o_text_overflow"><field name="description"/></li>
                                    <br/>
                                    <li t-if="record.number_of_irrigationgates.raw_value" class="o_text_overflow">Hydraulic Order Range: [<field name="initial_hydraulic_order"/>, <field name="final_hydraulic_order"/>]</li>
                                </ul>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="wua_flowdivider_action" model="ir.actions.act_window">
        <field name="name">Flow Dividers</field>
        <field name="res_model">wua.flowdivider</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="view_id" ref="wua_flowdivider_view_tree"/>
        <field name="search_view_id"
         ref="wua_flowdivider_view_search"/>
    </record>

    <menuitem id="wua_flowdivider_menu"
              name="Flow Dividers"
              parent="base_wua_infrastructure_gravityfed_irrigation_menu"
              action="wua_flowdivider_action"
              sequence="2"
              groups="base_wua.group_wua_user"/>

</odoo>