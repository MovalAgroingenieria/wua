<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form view -->
    <record id="wua_irrigationstretch_view_form" model="ir.ui.view">
        <field name="name">wua.irrigationstretch.form</field>
        <field name="model">wua.irrigationstretch</field>
        <field name="arch" type="xml">
            <form string="Irrigation Stretch">
                <sheet>
                    <div name="buttons" class="oe_button_box">
                        <field name="gis_viewer_link" invisible="1"/>
                        <field name="with_gis_irrigationstretch" invisible="1"/>
                        <button name="action_see_gis_viewer"
                                type="object"
                                class="oe_stat_button"
                                string="GIS Viewer"
                                icon="fa-map-marker"
                                attrs="{'invisible':
                                        ['|',('gis_viewer_link','=',False),
                                        ('with_gis_irrigationstretch','=',False)]}"/>
                    </div>
                    <group col="2">
                        <group>
                            <field name="name"/>
                            <field name="type"/>
                            <field name="channel_section_width"
                                   attrs="{'invisible': [('type', '!=', 'gravity')]}"/>
                            <field name="waterpipe_id"
                                   attrs="{'invisible': [('type','!=','pressure')]}"/>
                            <field name="length_meters"
                                   attrs="{'invisible': [('type', '!=', 'pressure')]}"/>
                            <field name="channel_section_height"
                                   attrs="{'invisible': [('type', '!=', 'gravity')]}"/>
                            <field name="is_channel_covered"
                                   attrs="{'invisible': [('type', '!=', 'gravity')]}"/>
                            <field name="tag"
                                   attrs="{'invisible': [('type', '!=', 'pressure')]}"/>
                            <field name="material"
                                   attrs="{'invisible': [('type', '!=', 'pressure')]}"/>
                            <field name="manufacturer"
                                   attrs="{'invisible': [('type', '!=', 'pressure')]}"/>
                            <field name="installation_date"
                                   attrs="{'invisible': [('type', '!=', 'pressure')]}"/>
                        </group>

                        <group>
                            <field name="irrigationditch_id"
                                   attrs="{'invisible': [('type', '!=', 'gravity')]}"/>
                            <field name="description"
                                   attrs="{'invisible': [('type', '!=', 'pressure')]}"/>
                            <field name="nominal_diameter"
                                   attrs="{'invisible': [('type', '!=', 'pressure')]}"/>
                            <field name="external_diameter"
                                   attrs="{'invisible': [('type', '!=', 'pressure')]}"/>
                            <field name="nominal_pressure"
                                   attrs="{'invisible': [('type', '!=', 'pressure')]}"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Notes">
                            <group>
                                <field name="notes"/>
                            </group>
                        </page>
                        <page string="Observations">
                            <group>
                                <field name="observations"/>
                            </group>
                        </page>
                        <page name="page_photos" string="Photos">
                            <group name="photos" col="4">
                                <field name="photo_01"
                                       widget="image"
                                       class="oe_img_259_160"/>
                                <field name="photo_02"
                                       widget="image"
                                       class="oe_img_259_160"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="wua_irrigationstretch_gravity_view_tree" model="ir.ui.view">
        <field name="name">wua.irrigationstretch.tree.gravity</field>
        <field name="model">wua.irrigationstretch</field>
        <field name="arch" type="xml">
            <tree string="Gravity Stretches">
                <field name="name"/>
                <field name="channel_section_width"/>
                <field name="channel_section_height"/>
                <field name="is_channel_covered"/>
            </tree>
        </field>
    </record>

    <record id="wua_irrigationstretch_pressure_view_tree" model="ir.ui.view">
        <field name="name">wua.irrigationstretch.tree.pressure</field>
        <field name="model">wua.irrigationstretch</field>
        <field name="arch" type="xml">
            <tree string="Pressure Stretches">
                <field name="name"/>
                <field name="length_meters"/>
                <field name="material"/>
                <field name="nominal_diameter"/>
                <field name="external_diameter"/>
            </tree>
        </field>
    </record>

    <record id="wua_irrigationstretch_view_search" model="ir.ui.view">
        <field name="name">wua.irrigationstretch.search</field>
        <field name="model">wua.irrigationstretch</field>
        <field name="arch" type="xml">
            <search string="Search Irrigation Stretches">
                <field name="name"/>
                <field name="type"/>
                <field name="material" attrs="{'invisible': [('type', '!=', 'pressure')]}"/>
                <field name="is_channel_covered" attrs="{'invisible': [('type', '!=', 'gravity')]}"/>
            </search>
        </field>
    </record>

    <record id="action_wua_irrigationstretch_pressure" model="ir.actions.act_window">
        <field name="name">Pressure Stretches</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">wua.irrigationstretch</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="wua_irrigationstretch_pressure_view_tree"/>
        <field name="domain">[('type', '=', 'pressure')]</field>
        <field name="context">{'default_type': 'pressure'}</field>
    </record>

    <record id="action_wua_irrigationstretch_gravity" model="ir.actions.act_window">
        <field name="name">Gravity Stretches</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">wua.irrigationstretch</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="wua_irrigationstretch_gravity_view_tree"/>
        <field name="domain">[('type', '=', 'gravity')]</field>
        <field name="context">{'default_type': 'gravity'}</field>
    </record>

    <menuitem id="wua_irrigationstretch_pressure_menu"
              name="Irrigation Stretches"
              parent="base_wua_infrastructure.base_wua_infrastructure_pressurized_irrigation_menu"
              action="action_wua_irrigationstretch_pressure"
              sequence="4"
              groups="base_wua.group_wua_user"/>

    <menuitem id="wua_irrigationstretch_gravity_menu"
              name="Irrigation Stretches"
              parent="base_wua_infrastructure.base_wua_infrastructure_gravityfed_irrigation_menu"
              action="action_wua_irrigationstretch_gravity"
              sequence="2"
              groups="base_wua.group_wua_user"/>

</odoo>
