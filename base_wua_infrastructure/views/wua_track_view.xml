<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="wua_track_view_tree" model="ir.ui.view">
        <field name="name">wua.track.tree</field>
        <field name="model">wua.track</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="gis_viewer_link" invisible="1"/>
                <field name="with_gis_track" invisible="1"/>
                <button name="action_see_gis_viewer"
                        type="object"
                        class="oe_stat_button"
                        string="GIS Viewer"
                        icon="fa-map-marker"
                        attrs="{'invisible': ['|', ('gis_viewer_link', '=', False), ('with_gis_track', '=', False)]}"/>
                <field name="cadastral_code"/>
                <field name="municipality_id"/>
                <field name="owned"/>
                <field name="classification"/>
            </tree>
        </field>
    </record>

    <record id="wua_track_view_form" model="ir.ui.view">
        <field name="name">wua.track.form</field>
        <field name="model">wua.track</field>
        <field name="arch" type="xml">
            <form string="Track">
                <sheet>
                    <div name="buttons" class="oe_button_box">
                        <field name="with_gis_track" invisible="1"/>
                        <field name="gis_viewer_link" invisible="1"/>
                        <button name="action_see_gis_viewer"
                                type="object"
                                class="oe_stat_button"
                                string="GIS Viewer"
                                icon="fa-map-marker"
                                attrs="{'invisible': ['|', ('gis_viewer_link', '=', False), ('with_gis_track', '=', False)]}"/>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="cadastral_code"/>
                            <field name="municipality_id"/>
                            <field name="owned"/>
                        </group>
                        <group>
                            <field name="width"/>
                            <field name="classification"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="wua_track_view_search" model="ir.ui.view">
        <field name="name">wua.track.search</field>
        <field name="model">wua.track</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="cadastral_code"/>
                <field name="municipality_id"/>
                <filter string="Owned" name="owned" domain="[('owned', '=', True)]"/>
                <filter string="With GIS Track" name="with_gis_track" domain="[('with_gis_track', '=', True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Municipality" name="group_by_municipality" context="{'group_by': 'municipality_id'}"/>
                    <filter string="Classification" name="group_by_classification" context="{'group_by': 'classification'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="wua_track_action" model="ir.actions.act_window">
        <field name="name">Tracks</field>
        <field name="res_model">wua.track</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="wua_track_view_tree"/>
        <field name="search_view_id" ref="wua_track_view_search"/>
    </record>

    <menuitem
        name="Tracks"
        id="wua_track_menu"
        parent="base_wua_infrastructure_primary_menu"
        sequence="50"
        action="wua_track_action"/>
</odoo>
