<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record model="mail.template"
                id="email_template_waterconnection_technical_sheet">
            <field name="name">Waterconnection Technical Sheet</field>
            <field name="model_id" ref="model_wua_waterconnection"/>
            <field name="subject">${ctx.get('subject', object.name)}</field>
            <field name="email_to">${ctx.get('partner_email', '')}</field>
            <field name="lang">${object.partner_id.lang or 'es_ES'}</field>
            <field name="auto_delete">True</field>
            <field name="report_template"
                   ref="wua_waterconnection_technical_sheet_report"/>
            <field name="report_name">technical_sheet_${(object.name or '').replace('/', '_')}</field>
            <field name="body_html">
                <![CDATA[
                <p>Dear ${ctx.get('partner_name', '')},</p>
                <p>Attached is the technical data sheet for waterconnection <strong>${object.name}</strong>.</p>
                ]]>
            </field>
        </record>
    </data>
</odoo>
