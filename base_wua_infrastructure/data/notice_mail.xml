<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record model="mail.template" id="email_template_waterconnection_notice">
            <field name="name">Waterconnection Notice Mail</field>
            <field name="model_id" ref="model_wua_waterconnection"/>
            <field name="subject"> ${ctx.get('shared_title')} - ${object.name}</field>
            <!--<field name="email_from">${(object.user_id.email_formatted or user.email_formatted) | safe}</field>-->
            <field name="email_to">${ctx.partner_email}</field>
            <field name="lang">${object.partner_id.lang or 'es_ES'}</field>
            <field name="auto_delete">True</field>
            <field name="body_html">
                <![CDATA[
                <p> ${ctx.get('shared_text')}</p>
                ]]>
            </field>
        </record>
    </data>

</odoo>
