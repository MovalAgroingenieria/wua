<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="hr.menu_hr_root" model="ir.ui.menu">
            <field name="groups_id" eval="[(3,ref('base.group_user')),(4,ref('base_wua.group_wua_user'))]"/>
        </record>

        <record id="rule_res_partner_waterconnection_group_wua_portal_user" model="ir.rule">
            <field name="name">Rule for Wua Portal User on partner waterconnections</field>
            <field name="model_id" ref="model_res_partner_waterconnection"/>
            <field name="domain_force">
                ['|', ('partner_id','=',user.partner_id.id),
                        ('partner_id.child_ids','=',user.partner_id.id)]
            </field>
            <field name="groups" eval="[(4, ref('base_wua.group_wua_portal_user'))]"/>
        </record>

    </data>
</odoo>