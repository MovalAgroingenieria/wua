<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_irrigation_config_settings_view_form" model="ir.ui.view">
        <field name="name">Parameters</field>
        <field name="model">wua.irrigation.configuration</field>
        <field name="inherit_id"
               ref="wua_remotecontrol_rest_batchline_irriweb.wua_irrigation_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='php_frame_type_programacion_height']"
                   position="after">
                <field name="php_frame_type_solicitudcuba"
                 attrs="{'invisible':[('enable_remotecontrol','=',False)],
                         'readonly':[('php_frame_enabled','=',False)]}"/>
                <field name="php_frame_type_solicitudcuba_width"
                 attrs="{'invisible':[('enable_remotecontrol','=',False)],
                         'readonly':[('php_frame_enabled','=',False)]}"/>
                <field name="php_frame_type_solicitudcuba_height"
                 attrs="{'invisible':[('enable_remotecontrol','=',False)],
                         'readonly':[('php_frame_enabled','=',False)]}"/>
            </xpath>
        </field>
    </record>

</odoo>