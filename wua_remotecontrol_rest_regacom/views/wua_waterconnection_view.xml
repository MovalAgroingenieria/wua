<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_waterconnection_view_form" model="ir.ui.view">
        <field name="name">wua.waterconnection.form.regacom</field>
        <field name="model">wua.waterconnection</field>
        <field name="inherit_id" ref="base_wua_remotecontrol_rest.wua_waterconnection_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='telecontrol_associated']" position="after">
                <field name="regacom_position"
                       attrs="{'invisible': [('telecontrol_associated', '!=', 'regacom')],
                               'required': [('telecontrol_associated', '=', 'regacom')]}"/>
            </xpath>
        </field>
    </record>

</odoo>
