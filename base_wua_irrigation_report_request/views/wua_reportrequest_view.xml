<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_reportrequest_view_form" model="ir.ui.view">
        <field name="name">Report Requests (form view)</field>
        <field name="model">wua.reportrequest</field>
        <field name="arch" type="xml">
            <form duplicate="0">
                <field name="id" invisible="1"/>
                <field name="cancelled" invisible="1"/>
                <field name="is_portal_user" invisible="1"/>
                <field name="credit_overdue" invisible="1"/>
                <field name="mapped_to_irrigationreport" invisible="1"/>
                <header>
                    <button name="validate_reportrequest" type="object" class="oe_highlight"
                            string="Validate"
                            attrs="{'invisible': ['|','|',('id','=',False),('state','=','validated'),('cancelled','=',True)]}"
                            groups="base_wua.group_wua_manager"/>
                    <button name="reset_reportrequest" type="object" class="oe_highlight"
                            string="To draft"
                            attrs="{'invisible': ['|',('id','=',False),('state','=','draft')]}"
                            groups="base_wua.group_wua_manager"
                            confirm="The reset will erase the Irrigation Report. Are you sure you want to continue?"/>
                    <button name="cancel_reportrequest" type="object" class="oe_link"
                            string="Cancel"
                            attrs="{'invisible': ['|','|',('id','=',False),('state','=','validated'),('cancelled','=',True)]}"
                            groups="base_wua.group_wua_manager"
                            confirm="Are you sure you want to cancel this request?"/>
                    <button name="reactivate_reportrequest" type="object" class="oe_highlight"
                            string="Reactivate"
                            attrs="{'invisible': ['|',('state','=','validate'),('cancelled','=',False)]}"
                            groups="base_wua.group_wua_manager"/>
                    <div name="reportrequest_cancelled" style="display: inline-block;color:red;padding-top: 5px;padding-bottom: 5px;padding-left: 10px;"
                         attrs="{'invisible':[('cancelled','=',False)]}">C A N C E L L E D
                    </div>
                    <div name="warning_signature" class="oe_edit_only" style="display: inline-block;color:red;padding-top:10px;"
                         attrs="{'invisible':['|','|',('is_portal_user', '=', False),('signature_image', '!=', False),('state', '=', 'validated')]}">
                         NOTICE: It will be necessary to sign
                    </div>
                    <div name="hascreditoverdue"
                         style="display: inline-block;color:red;padding-top: 5px;padding-bottom: 5px;padding-left: 10px;"
                         attrs="{'invisible':[('credit_overdue','&lt;=',0.0)]}">
                        ( CREDIT OVERDUE )
                    </div>
                    <field name="state" widget="statusbar" statusbar_visible="draft,validated"/>
                </header>
                <sheet>
                     <group name="master_data">
                        <group name="master_data_left">
                            <field name="partner_id"
                                   options="{'no_quick_create':True,'no_create_edit':True}"
                                   attrs="{'readonly': ['|','|',('id', '>', 0),('cancelled','=',True),('is_portal_user','=',True)]}"/>
                            <field name="parcel_id"
                                   options="{'no_quick_create':True,'no_create_edit':True}"
                                   attrs="{'readonly': ['|','|',('id', '>', 0),('state','=','validated'),('cancelled','=',True)]}"/>
                        </group>
                        <group name="master_data_right">
                            <field name="request_date" attrs="{'readonly': ['|','|',('id', '>', 0),('state','=','validated'),('cancelled','=',True)]}"/>
                            <field name="agriculturalseason_id"/>
                            <field name="product_id" domain="[('categ_id.productcategory_code','=',11)]"
                                attrs="{'readonly': ['|',('state','=','validated'),('cancelled','=',True)]}"/>
                            <field name="intake_id" domain="[('product_id','=', product_id)]"
                                attrs="{'invisible': [('product_id','&lt;=', 0)],
                                        'readonly': [('mapped_to_irrigationreport', '=', True)]
                                       }"/>
                            <field name="hours" style="width:100px" digits="[32, 2]" widget="float_time"
                                attrs="{'readonly': ['|',('state','=','validated'),('cancelled','=',True)]}"/>
                            <field name="volume" style="width:100px"
                                attrs="{'readonly': ['|',('state','=','validated'),('cancelled','=',True)]}"/>
                            <field name="irrigationreport_id" attrs="{
                                'invisible': [('state','=','draft')],
                                'readonly': ['|','|',('state','=','validated'),('cancelled','=',True),('is_portal_user','=',True)]}"/>
                        </group>
                    </group>
                    <group name="slave_data">
                        <notebook name="slave_data_notebook">
                            <page name="notes_page" string="Notes">
                                <field name="notes" widget="html" attrs="{'readonly': [('cancelled','=',True)]}"/>
                                <div class="oe_edit_only">
                                    (*) The notes will be printed in Report request and Irrigation report
                                </div>
                            </page>
                            <page name="signature_page" string="Signature">
                                <field name="signature_image" widget="signature" attrs="{'readonly': [('cancelled','=',True)]}"/>
                            </page>
                        </notebook>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread" groups="base_wua.group_wua_user"/>
                </div>
            </form>
        </field>
    </record>

    <record id="wua_reportrequest_view_tree" model="ir.ui.view">
        <field name="name">Report Requests (tree view)</field>
        <field name="model">wua.reportrequest</field>
        <field name="arch" type="xml">
            <tree class="o_base_wua_reportrequest_reportrequest_view_tree" colors="silver:cancelled == True;">
                <field name="cancelled" invisible="1"/>
                <field name="agriculturalseason_id"/>
                <field name="request_date"/>
                <field name="partner_id"/>
                <field name="parcel_id"/>
                <field name="product_id"/>
                <field name="hours" digits="[32, 2]" widget="float_time"/>
                <field name="volume"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="wua_reportrequest_view_search" model="ir.ui.view">
        <field name="name">Report Requests (search view)</field>
        <field name="model">wua.reportrequest</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <field name="parcel_id"/>
                <filter name="active_agriculturalseason" string="Active Agricultural Season"
                        domain="[('of_active_agriculturalseason','=',True)]"/>
                <separator/>
                <filter name="mapped_to_irrigation_report_true" string="Mapped to irrigation report: Yes"
                        domain="[('mapped_to_irrigationreport','=',True)]"/>
                <filter name="mapped_to_irrigation_report_false" string="Mapped to irrigation report: No"
                        domain="[('mapped_to_irrigationreport','=',False)]"/>
                <separator/>
                <filter name="is_cancelled" string="Cancelled"
                        domain="[('cancelled','=',True)]"/>
                <group expand="0" string="Group By">
                    <filter name="product" string="Product"
                            context="{'group_by':'product_id'}"/>
                    <filter name="partner" string="Partner"
                            context="{'group_by':'partner_id'}"/>
                    <filter name="parcel" string="Parcel"
                            context="{'group_by':'parcel_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="wua_reportrequest_view_calendar" model="ir.ui.view">
            <field name="name">Report Requests (calendar view)</field>
            <field name="model">wua.reportrequest</field>
            <field name="arch" type="xml">
                <calendar string="Report Request" color="partner_id"
                          date_start="request_date"
                          mode="month"
                          quick_add="False">
                    <field name="calendar_display_name"/>
                </calendar>
            </field>
        </record>

    <record id="wua_reportrequest_view_pivot" model="ir.ui.view" >
        <field name="name">Report Requests (pivot view)</field>
        <field name="model">wua.reportrequest</field>
        <field name="arch" type="xml">
            <pivot string="Report Requests" display_quantity="true">
                <field name="volume" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Actions -->
    <record id="wua_reportrequest_action" model="ir.actions.act_window">
        <field name="name">Report Requests</field>
        <field name="res_model">wua.reportrequest</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form,pivot,calendar</field>
        <field name="view_id" ref="wua_reportrequest_view_tree"/>
        <field name="search_view_id" ref="wua_reportrequest_view_search"/>
        <field name="context">
            {'search_default_active_agriculturalseason': 1}
        </field>
    </record>

    <record id="wua_validate_reportrequests" model="ir.actions.server">
        <field name="name">Validate</field>
        <field name="model_id" ref="model_wua_reportrequest"/>
        <field name="state">code</field>
        <field name="code">
            if context.get('active_ids'):
                action = env['wua.reportrequest'].validate_reportrequests(context['active_ids'])
        </field>
    </record>

    <record id="wua_action_validate_reportrequests" model="ir.values">
        <field name="name">Validate</field>
        <field name="model">wua.reportrequest</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('wua_validate_reportrequests'))"/>
    </record>

    <record id="wua_reset_reportrequests" model="ir.actions.server">
        <field name="name">Reset</field>
        <field name="model_id" ref="model_wua_reportrequest"/>
        <field name="state">code</field>
        <field name="code">
            if context.get('active_ids'):
                action = env['wua.reportrequest'].reset_reportrequests(context['active_ids'])
        </field>
    </record>

    <record id="wua_action_reset_reportrequests" model="ir.values">
        <field name="name">Reset</field>
        <field name="model">wua.reportrequest</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('wua_reset_reportrequests'))"/>
    </record>

    <record id="wua_cancel_reportrequests" model="ir.actions.server">
        <field name="name">Cancel</field>
        <field name="model_id" ref="model_wua_reportrequest"/>
        <field name="state">code</field>
        <field name="code">
            if context.get('active_ids'):
                action = env['wua.reportrequest'].cancel_reportrequests(context['active_ids'])
        </field>
    </record>

    <record id="wua_action_cancel_reportrequests" model="ir.values">
        <field name="name">Cancel</field>
        <field name="model">wua.reportrequest</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('wua_cancel_reportrequests'))"/>
    </record>

    <record id="wua_reactivate_reportrequests" model="ir.actions.server">
        <field name="name">Reactivate</field>
        <field name="model_id" ref="model_wua_reportrequest"/>
        <field name="state">code</field>
        <field name="code">
            if context.get('active_ids'):
                action = env['wua.reportrequest'].reactivate_reportrequests(context['active_ids'])
        </field>
    </record>

    <record id="wua_action_reactivate_reportrequests" model="ir.values">
        <field name="name">Reactivate</field>
        <field name="model">wua.reportrequest</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('wua_reactivate_reportrequests'))"/>
    </record>

    <!-- Menu entries -->
    <!-- Overwrite original to change position -->
    <menuitem name="Reports" id="base_wua_irrigation_report.base_wua_irrigationreport_menu"
        parent="base_wua_irrigation_report.base_wua_irrigation_report_menu" sequence="3"
        action="base_wua_irrigation_report.wua_irrigationreport_action"/>

    <menuitem name="Report Requests" id="reportrequest_menu"
        parent="base_wua_irrigation_report.base_wua_irrigation_report_menu" sequence="2"
        action="wua_reportrequest_action"/>

</odoo>
