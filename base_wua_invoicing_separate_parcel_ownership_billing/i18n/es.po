#. module: base_wua_invoicing_separate_parcel_ownership_billing
#: code:addons/base_wua_invoicing_separate_parcel_ownership_billing/models/wua_parcel.py:131
#, python-format
msgid "Separate parcel billing: It is mandatory to enter a valid mandate of the only partner that pays the ownership costs."
msgstr "Facturación separada de parcelas: Es obligatorio indicar un mandado validado que pertenezca al socio (único) que se haga cargo de los gastos por superficie aplicables al propietario."

#. module: base_wua_invoicing_separate_parcel_ownership_billing
#: code:addons/base_wua_invoicing_separate_parcel_ownership_billing/models/account_banking_mandate.py:21
#, python-format
msgid "Separate parcel billing: The mandate must be a valid mandate, because there are some parcels associated with this mandate (ownership costs)."
msgstr "Facturación separada de parcelas: El mandato debe ser obligatoriamente un mandato válido, ya que hay parcelas asociadas a este mandato (facturación separada por gastos por superficie aplicables al propietario)."

#. module: base_wua_invoicing_separate_parcel_ownership_billing
#: code:addons/base_wua_invoicing_separate_parcel_ownership_billing/models/wua_parcel.py:116
#, python-format
msgid "Separate parcel billing: there can be no more one payer for the ownership costs."
msgstr "Facturación separada de parcelas: No se permite que haya más de un socio a cargo de gastos distintos de superficie aplicables al propietario."

#. module: base_wua_invoicing_separate_parcel_ownership_billing
#: model:ir.model.fields,field_description:base_wua_invoicing_separate_parcel_ownership_billing.field_wua_parcel_ownershipcosts_potentially_billable
msgid "With a single payer for ownership costs"
msgstr "Con un único socio para los gastos por superficie aplicables al propietario"
