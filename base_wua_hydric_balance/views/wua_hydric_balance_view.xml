        </field>
    </record>

    <record id="action_add_output_to_values" model="ir.values">
        <field name="name">Add to Output</field>
        <field name="model">wua.hydric.balance.output.line</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('action_add_to_output'))"/>
    </record>

    <record id="action_remove_output_from_values" model="ir.values">
        <field name="name">Remove from Output</field>
        <field name="model">wua.hydric.balance.output.line</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('action_remove_from_output'))"/>
    </record>

    <record id="action_add_variation_to_values" model="ir.values">
        <field name="name">Add to Variation</field>
        <field name="model">wua.hydric.balance.variation.line</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('action_add_to_variation'))"/>
    </record>

    <record id="action_remove_variation_from_values" model="ir.values">
        <field name="name">Remove from Variation</field>
        <field name="model">wua.hydric.balance.variation.line</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('action_remove_from_variation'))"/>
    </record>

    <record id="action_wua_hydric_balance" model="ir.actions.act_window">
        <field name="name">Balances Hídricos</field>
        <field name="res_model">wua.hydric.balance</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_wua_hydric_balance_tree"/>
    </record>

    <menuitem id="menu_wua_hydric_balance" name="Balances" parent="hydric_balance_menu" action="action_wua_hydric_balance"/>
</odoo>