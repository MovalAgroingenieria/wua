    </record>

    <record id="action_remove_from_output" model="ir.actions.server">
        <field name="name">Remove from Output</field>
        <field name="model_id" ref="model_wua_hydric_balance_output_line"/>
        <field name="state">code</field>
        <field name="code">
            if context.get('active_ids'):
                action = env['wua.hydric.balance.output.line'].browse(context['active_ids']).remove_from_output()
