<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_file_view_form" model="ir.ui.view">
        <field name="name">Files (form view)</field>
        <field name="model">res.file</field>
        <field name="inherit_id" ref="wua_crm_filemgmt.res_file_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_get_file_registers']" position="after">
                <field name="gis_viewer_link" invisible="1"/>
                <field name="has_parcellinks" invisible="1"/>
                    <button name="action_see_gis_viewer"
                        type="object"
                        class="oe_stat_button"
                        string="GIS Viewer"
                        icon="fa-map-marker"
                        attrs="{'invisible':
                                ['|',('gis_viewer_link','=',False),
                                    ('has_parcellinks','=',False)]}"
                        groups="base_wua.group_wua_user,
                                base_wua.group_wua_portal_user"/>
            </xpath>
            <xpath expr="//group[@name='slave_data']" position="after">
                <templates>
                    <t t-name="gisviewer">
                         <field name="has_parcellinks" invisible="1"/>
                         <div id="gisviewer_file"
                              attrs="{'invisible':
                                      [('has_parcellinks','=',False)]}">
                             <field name="html_gisviewer_frame" widget="html"/>
                         </div>
                    </t>
                </templates>
            </xpath>
        </field>
    </record>

    <record id="res_file_view_tree" model="ir.ui.view">
        <field name="name">Files (tree view)</field>
        <field name="model">res.file</field>
        <field name="inherit_id" ref="crm_filemgmt.res_file_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="gis_viewer_link" invisible="1"/>
                <field name="has_parcellinks" invisible="1"/>
                <button name="action_see_gis_viewer"
                    type="object" class="oe_stat_button"
                    string="GIS Viewer (zoom to parcels)"
                    icon="fa-map-marker"
                    attrs="{'invisible':
                            ['|',('gis_viewer_link','=',False),
                                 ('has_parcellinks','=',False)]}"/>
            </xpath>
        </field>
    </record>



</odoo>