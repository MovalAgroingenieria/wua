<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="wua_processingcentre_view_form" model="ir.ui.view">
    <field name="name">WUA Processing Centre (form view)</field>
    <field name="model">wua.processingcentre</field>
    <field name="arch" type="xml">
      <form string="Processing Centre">
        <sheet>
          <div name="buttons" class="oe_button_box">
            <field name="with_gis_processing_centre" invisible="1"/>
            <field name="gis_viewer_link" invisible="1"/>
              <button name="action_see_gis_viewer"
                      type="object"
                      class="oe_stat_button"
                      string="GIS Viewer"
                      icon="fa-map-marker"
                      attrs="{'invisible':
                            ['|',('gis_viewer_link','=',False),
                            ('with_gis_processing_centre','=',False)]}"/>
          </div>
          <group>
            <field name="name"/>
            <field name="type"/>
            <field name="capacity"/>
            <field name="number_of_transformers"/>
            <field name="transformer_type"/>
            <field name="installation_year"/>
          </group>
          <notebook>
            <page string="Notes">
              <field name="notes"/>
            </page>
            <page string="Technical Characteristics">
              <field name="technical_characteristics"/>
            </page>
            <page name="page_photos" string="Photos">
              <group name="photos" col="4">
                  <field name="photo_01"
                         widget="image"
                         class="oe_img_259_160"/>
                  <field name="photo_02"
                         widget="image"
                         class="oe_img_259_160"/>
              </group>
          </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="wua_processingcentre_view_tree" model="ir.ui.view">
    <field name="name">WUA Processing Centre (tree view)</field>
    <field name="model">wua.processingcentre</field>
    <field name="arch" type="xml">
      <tree string="Processing Centres">
        <field name="name"/>
        <field name="gis_viewer_link" invisible="1"/>
        <field name="with_gis_processing_centre" invisible="1"/>
                <button name="action_see_gis_viewer"
                        type="object" class="oe_stat_button"
                        string="GIS Viewer (zoom to point)"
                        icon="fa-map-marker"
                        attrs="{'invisible': ['|',('gis_viewer_link','=',False),
                               ('with_gis_processing_centre','=',False)]}"/>
        <field name="type"/>
        <field name="capacity"/>
        <field name="number_of_transformers"/>
        <field name="transformer_type"/>
        <field name="installation_year"/>
        <field name="with_measurement_devices"/>
      </tree>
    </field>
  </record>

  <record id="wua_processingcentre_view_search" model="ir.ui.view">
    <field name="name">WUA Processing Centre (search view)</field>
    <field name="model">wua.processingcentre</field>
    <field name="arch" type="xml">
      <search>
        <field name="name"/>
        <field name="type"/>
        <field name="transformer_type"/>
        <filter string="With Measurement Devices" name="with_measurement_devices" domain="[('with_measurement_devices','=',True)]"/>
        <filter string="With GIS Processing Centre" name="with_gis_processing_centre" domain="[('with_gis_processing_centre','=',True)]"/>
        <group expand="0" string="Group By">
          <filter string="Type" name="group_type" context="{'group_by': 'type'}"/>
          <filter string="Transformer Type" name="group_transformer_type" context="{'group_by': 'transformer_type'}"/>
          <filter string="Installation Year" name="group_installation_year" context="{'group_by': 'installation_year'}"/>
        </group>
      </search>
    </field>
  </record>

</odoo>
