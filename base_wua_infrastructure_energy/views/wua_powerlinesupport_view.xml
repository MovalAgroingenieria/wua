<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="wua_powerlinesupport_view_tree" model="ir.ui.view">
        <field name="name">wua.powerlinesupport.tree</field>
        <field name="model">wua.powerlinesupport</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="gis_viewer_link" invisible="1"/>
                <field name="with_gis_powerlinesupport" invisible="1"/>
                <button name="action_see_gis_viewer"
                        type="object" class="oe_stat_button"
                        string="GIS Viewer (zoom to point)"
                        icon="fa-map-marker"
                        attrs="{'invisible': ['|',('gis_viewer_link','=',False),
                               ('with_gis_powerlinesupport','=',False)]}"/>
                <field name="tipology"/>
                <field name="wire_support"/>
                <field name="bird_friendly"/>
                <field name="construction_date"/>
                <field name="material"/>
                <field name="insulator_type"/>
                <field name="singular_points"/>
            </tree>
        </field>
    </record>

    <record id="wua_powerlinesupport_view_form" model="ir.ui.view">
        <field name="name">wua.powerlinesupport.form</field>
        <field name="model">wua.powerlinesupport</field>
        <field name="arch" type="xml">
            <form string="Power Line Support">
                <sheet>
                    <div name="buttons" class="oe_button_box">
                        <field name="with_gis_powerlinesupport" invisible="1"/>
                        <field name="gis_viewer_link" invisible="1"/>
                        <button name="action_see_gis_viewer"
                                type="object"
                                class="oe_stat_button"
                                string="GIS Viewer"
                                icon="fa-map-marker"
                                attrs="{'invisible':
                                      ['|',('gis_viewer_link','=',False),
                                      ('with_gis_powerlinesupport','=',False)]}"/>
                    </div>
                        <group>
                        <group>
                            <field name="name"/>
                            <field name="tipology"/>
                            <field name="wire_support"/>
                            <field name="bird_friendly"/>
                            <field name="construction_date"/>
                        </group>

                        <group>
                            <field name="useful_height"/>
                            <field name="material"/>
                            <field name="insulator_type"/>
                            <field name="singular_points"/>
                            <field name="bypass"/>
                            <field name="anticlimb_device"/>
                            <field name="danger_signage"/>
                            <field name="have_license_plate"/>
                            <field name="license_plate"
                                   attrs="{'invisible': [('have_license_plate','=',False)]}"/>
                        </group>
                    </group>
                        <notebook>
                        <page string="Technical Characteristics">
                            <field name="technical_characteristics"/>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                        <page name="page_photos" string="Photos">
                            <group name="photos" col="4">
                                <field name="photo_01"
                                       widget="image"
                                       class="oe_img_259_160"/>
                                <field name="photo_02"
                                       widget="image"
                                       class="oe_img_259_160"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>


    <record id="wua_powerlinesupport_view_search" model="ir.ui.view">
        <field name="name">wua.powerlinesupport.search</field>
        <field name="model">wua.powerlinesupport</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="tipology"/>
                <field name="material"/>
                <field name="insulator_type"/>
                <filter string="Bird Friendly" name="bird_friendly" domain="[('bird_friendly', '=', True)]"/>
                <filter string="With License Plate" name="have_license_plate" domain="[('have_license_plate', '=', True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Material" name="group_by_material" context="{'group_by': 'material'}"/>
                    <filter string="Insulator Type" name="group_by_insulator" context="{'group_by': 'insulator_type'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
