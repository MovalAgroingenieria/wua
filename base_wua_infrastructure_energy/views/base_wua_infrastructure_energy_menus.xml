<odoo>
    <record id="wua_processingcentre_action" model="ir.actions.act_window">
        <field name="name">Processing Centres</field>
        <field name="res_model">wua.processingcentre</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="wua_powerline_action" model="ir.actions.act_window">
        <field name="name">Power Lines</field>
        <field name="res_model">wua.powerline</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="wua_powerlinesupport_action" model="ir.actions.act_window">
        <field name="name">Power Line Supports</field>
        <field name="res_model">wua.powerlinesupport</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem
        name="Processing Centres"
        id="wua_processingcentre_menu"
        parent="base_wua_infrastructure.base_wua_infrastructure_primary_menu"
        sequence="70"
        action="wua_processingcentre_action"/>

    <menuitem
        name="Power Lines"
        id="wua_powerline_menu"
        parent="base_wua_infrastructure.base_wua_infrastructure_primary_menu"
        sequence="71"
        action="wua_powerline_action"/>

    <menuitem
        name="Power Line Supports"
        id="wua_powerlinesupport_menu"
        parent="base_wua_infrastructure.base_wua_infrastructure_primary_menu"
        sequence="72"
        action="wua_powerlinesupport_action"/>

</odoo>