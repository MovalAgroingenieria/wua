<odoo>
    <record id="wua_processing_centre_action" model="ir.actions.act_window">
        <field name="name">Processing Centres</field>
        <field name="res_model">wua.processing.centre</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="wua_power_line_action" model="ir.actions.act_window">
        <field name="name">Power Lines</field>
        <field name="res_model">wua.power.line</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="wua_power_line_support_action" model="ir.actions.act_window">
        <field name="name">Power Line Supports</field>
        <field name="res_model">wua.power.line.support</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem
        name="Processing Centres"
        id="wua_processing_centre_menu"
        parent="base_wua_infrastructure.base_wua_infrastructure_primary_menu"
        sequence="12"
        action="wua_processing_centre_action"/>

    <menuitem
        name="Power Lines"
        id="wua_power_line_menu"
        parent="base_wua_infrastructure.base_wua_infrastructure_primary_menu"
        sequence="13"
        action="wua_power_line_action"/>

    <menuitem
        name="Power Line Supports"
        id="wua_power_line_support_menu"
        parent="base_wua_infrastructure.base_wua_infrastructure_primary_menu"
        sequence="14"
        action="wua_power_line_support_action"/>

</odoo>