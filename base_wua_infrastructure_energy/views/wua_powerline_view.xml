<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_powerline_view_tree" model="ir.ui.view">
        <field name="name">wua.powerline.tree</field>
        <field name="model">wua.powerline</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="gis_viewer_link" invisible="1"/>
                <field name="with_gis_powerline" invisible="1"/>
                <button name="action_see_gis_viewer"
                        type="object" class="oe_stat_button"
                        string="GIS Viewer (zoom to point)"
                        icon="fa-map-marker"
                        attrs="{'invisible': ['|',('gis_viewer_link','=',False),
                               ('with_gis_powerline','=',False)]}"/>
                <field name="rated_voltage"/>
                <field name="type"/>
                <field name="length"/>
                <field name="construction_date"/>
                <field name="critical_crossings"/>
                <field name="bird_friendly"/>
            </tree>
        </field>
    </record>

    <record id="wua_powerline_view_form" model="ir.ui.view">
        <field name="name">wua.powerline.form</field>
        <field name="model">wua.powerline</field>
        <field name="arch" type="xml">
            <form string="Power Line">
                <sheet>
                    <div name="buttons" class="oe_button_box">
                        <field name="with_gis_powerline" invisible="1"/>
                        <field name="gis_viewer_link" invisible="1"/>
                        <button name="action_see_gis_viewer"
                                type="object"
                                class="oe_stat_button"
                                string="GIS Viewer"
                                icon="fa-map-marker"
                                attrs="{'invisible':
                                      ['|',('gis_viewer_link','=',False),
                                      ('with_gis_powerline','=',False)]}"/>
                    </div>
                    <group name="master_data">
                        <group name="master_data_left">
                            <field name="name"/>
                            <field name="rated_voltage"/>
                            <field name="type"/>
                            <field name="length"/>
                            <field name="construction_date"/>
                            <field name="critical_crossings"/>
                            <field name="bird_friendly"/>
                            <field name="electricitypoint_id"/>
                        </group>
                        <group name="master_data_right">
                            <field name="image" widget="image" class="oe_img_259_160"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Technical Characteristics">
                            <field name="technical_characteristics"/>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="wua_powerline_view_search" model="ir.ui.view">
        <field name="name">wua.powerline.search</field>
        <field name="model">wua.powerline</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="type"/>
                <field name="critical_crossings"/>
                <filter string="Bird Friendly" name="bird_friendly" domain="[('bird_friendly', '=', True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Type" name="group_by_type" context="{'group_by': 'type'}"/>
                    <filter string="Critical Crossings" name="group_by_crossings" context="{'group_by': 'critical_crossings'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>