<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_flowreading_view_form" model="ir.ui.view">
        <field name="name">Flowreadings (form view)</field>
        <field name="model">wua.flowreading</field>
        <field name="inherit_id" ref="base_wua_irrigation_measurement.wua_flowreading_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='intakeconsumption_id']" position="after">
                <field name="is_field_reading" invisible="1"/>
                <field name="readingperiod_id" attrs="{'invisible':[('is_field_reading','=',False)]}"/>
                <field name="watermeter_reader_id" attrs="{'invisible':[('is_field_reading','=',False)]}"/>
            </xpath>
            <xpath expr="//page[@name='notes_page']" position="after">
                <page name="reading_img" string="Reading Image">
                    <group name="reading_img_group">
                        <field name="reading_img" widget="image" class="oe_img_259_160"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="wua_flowreading_view_search" model="ir.ui.view">
        <field name="name">Flowreadings (search view)</field>
        <field name="model">wua.flowreading</field>
        <field name="inherit_id" ref="base_wua_irrigation_measurement.wua_flowreading_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='intake_id']" position="after">
                <field name="readingperiod_id"/>
                <field name="watermeter_reader_id"/>
            </xpath>
            <xpath expr="//filter[@name='intake']" position="after">
                <filter string="Reading Period"
                 name="readingperiod"
                 context="{'group_by':'readingperiod_id'}"/>
                <filter string="Watermeter Reader"
                 name="watermeterreaderid"
                 context="{'group_by':'watermeter_reader_id'}"/>
            </xpath>
            <xpath expr="//filter[@name='readingintakeno']" position="after">
                <separator/>
                  <filter string="Is Field Reading: Yes" name="isfieldreadingyes"
                   domain="[('is_field_reading','=',True)]"/>
                  <filter string="Is Field Reading: No" name="isfieldreadingno"
                   domain="[('is_field_reading','=',False)]"/>
                <separator/>
            </xpath>
        </field>
    </record>

</odoo>
