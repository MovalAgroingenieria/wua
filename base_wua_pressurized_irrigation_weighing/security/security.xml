<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="rule_wua_weighing_group_wua_portal_user" model="ir.rule">
      <field name="name">Rule for Wua Portal User on subparcel weighings</field>
      <field name="model_id" ref="model_wua_weighing"/>
      <field name="domain_force">
          ['|', ('partner_id','=',user.partner_id.id),
                ('partner_id.child_ids','=',user.partner_id.id)]
      </field>
      <field name="groups" eval="[(4, ref('base_wua.group_wua_portal_user'))]"/>
  </record>

  <record id="rule_wua_weighing_enrolledsubparcel_group_wua_portal_user" model="ir.rule">
      <field name="name">Rule for Wua Portal User on accumulated subparcel weighings</field>
      <field name="model_id" ref="model_wua_weighing_enrolledsubparcel"/>
      <field name="domain_force">
          ['|', ('partner_id','=',user.partner_id.id),
                ('partner_id.child_ids','=',user.partner_id.id)]
      </field>
      <field name="groups" eval="[(4, ref('base_wua.group_wua_portal_user'))]"/>
  </record>

</odoo>
