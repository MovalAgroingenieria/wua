<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="wua_agriculturalseason_view_form" model="ir.ui.view">
      <field name="name">Agricultural Seasons (form view)</field>
      <field name="model">wua.agriculturalseason</field>
      <field name="inherit_id" ref="base_wua_pressurized_irrigation.wua_agriculturalseason_view_form"/>
      <field name="arch" type="xml">
          <xpath expr="//field[@name='description']" position="before">
              <field name="active_agriculturalseason"/>
          </xpath>
      </field>
  </record>

</odoo>
