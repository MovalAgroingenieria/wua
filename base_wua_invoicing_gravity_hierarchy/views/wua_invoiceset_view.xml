<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <record id="wua_invoiceset_line_parcel_view_tree" model="ir.ui.view" >
        <field name="name">Invoice-set line for parcels (tree view)</field>
        <field name="model">wua.invoiceset.line.parcel</field>
        <field name="inherit_id" ref="base_wua_invoicing.wua_invoiceset_line_parcel_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='irrigationditch_id']" position="after">
                <field name="irrigationditch_01_id"/>
                <field name="irrigationditch_02_id"/>
                <field name="drainageditch_id"/>
                <field name="drainageditch_01_id"/>
                <field name="drainageditch_02_id"/>
            </xpath>
        </field>
    </record>

    <record id="wua_invoiceset_line_parcel_view_search" model="ir.ui.view" >
        <field name="name">Invoice-set line for parcels (search view)</field>
        <field name="model">wua.invoiceset.line.parcel</field>
        <field name="inherit_id" ref="base_wua_invoicing.wua_invoiceset_line_parcel_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='irrigationditch_id']" position="after">
                <field name="irrigationditch_01_id"/>
                <field name="irrigationditch_02_id"/>
                <field name="drainageditch_id"/>
                <field name="drainageditch_01_id"/>
                <field name="drainageditch_02_id"/>
            </xpath>
            <xpath expr="//filter[@name='irrigationditch']" position="after">
                <filter string="Ditch level 1" name="ditchlevel1" context="{'group_by':'irrigationditch_01_id'}"/>
                <filter string="Ditch level 2" name="ditchlevel2" context="{'group_by':'irrigationditch_02_id'}"/>
                <filter string="Drainage ditch" name="drainageditch" context="{'group_by':'drainageditch_id'}"/>
                <filter string="Drainage ditch level 1" name="drainageditchlevel1" context="{'group_by':'drainageditch_01_id'}"/>
                <filter string="Drainage ditch level 2" name="drainageditchlevel2" context="{'group_by':'drainageditch_02_id'}"/>
            </xpath>
        </field>
    </record>

</odoo>