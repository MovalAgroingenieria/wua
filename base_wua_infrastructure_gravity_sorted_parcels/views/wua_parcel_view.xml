<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form view -->
    <record id="wua_parcel_view_form" model="ir.ui.view">
        <field name="name">Parcels (form view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id" ref="base_wua_infrastructure_gravity_hierarchy.wua_parcel_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='allow_multiple_waterings']" position="after">
                <field name="hydraulic_order"/>
            </xpath>
        </field>
    </record>

    <record id="wua_parcel_view_tree" model="ir.ui.view">
        <field name="name">Parcels (tree view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id"
               ref="base_wua_invoicing.wua_parcel_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="hydraulic_order"/>
            </xpath>
        </field>
    </record>


</odoo>