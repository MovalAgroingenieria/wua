<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form" model="ir.ui.view">
        <field name="name">Partners (form view)</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base_wua.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <field name="registered_cropplan" invisible="1"/>
                <field name="exists_active_agriculturalseason" invisible="1"/>
                <header>
                    <div name="cropplanregistered"
                         style="display: inline-block;color:black;padding-top: 5px;padding-bottom: 5px;padding-left: 10px;"
                         attrs="{'invisible':['|',('registered_cropplan','=',False),('exists_active_agriculturalseason','=',False)]}">
                        ( CROP PLAN REGISTERED )
                    </div>
                    <div name="cropplannotregistered"
                         style="display: inline-block;color:red;padding-top: 5px;padding-bottom: 5px;padding-left: 10px;"
                         attrs="{'invisible':['|',('registered_cropplan','=',True),('exists_active_agriculturalseason','=',False)]}">
                        ( CROP PLAN NOT REGISTERED )
                    </div>
                </header>
            </xpath>
            <xpath expr="//button[@name='action_see_gis_viewer']"
                   position="before">
                <button name="action_see_enrolledsubparcels"
                    attrs="{'invisible':[('number_of_enrolledsubparcels','=',0)]}"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-book"
                    groups="base_wua.group_wua_user,
                            base_wua.group_wua_portal_user">
                    <div class="o_form_field o_stat_info">
                        <span class="o_stat_value">
                            <field name="number_of_enrolledsubparcels"/>
                        </span>                    
                        <span class="o_stat_text">
                            enrollments
                        </span>
                    </div>
                </button>
            </xpath>            
            <xpath expr="//field[@name='number_of_votes']" position="after">
                <field name="cropplan_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_partner_tree" model="ir.ui.view" >
        <field name="name">Partners (tree view)</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base_wua.view_partner_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='parcel_lessee_area']"
                   position="after">
                <field name="registered_cropplan" string="Registered Crop Plan"/>
            </xpath>
        </field>
    </record>

    <record id="view_partner_search" model="ir.ui.view" >
        <field name="name">Partners (search view)</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base_wua.view_partner_search"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='inactive']" position="before">
                <filter string="Registered Crop Plan: Yes" name="registeredcropplanyes"
                 domain="[('registered_cropplan','=',True)]"/>
                <filter string="Registered Crop Plan: No" name="registeredcropplanno"
                 domain="[('registered_cropplan','=',False)]"/>
                <separator/>                 
            </xpath>
        </field>
    </record>

</odoo>