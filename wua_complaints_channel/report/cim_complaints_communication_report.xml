<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Parent module: cim_complaints_channel -->
    <!-- Reports to modify:
            report_cim_complaint_communication
    -->

    <!-- Paperformat modifications -->
    <record id="cim_complaints_channel.action_cim_complaint_communication_report" model="ir.actions.report.xml">
        <field name="paperformat_id" ref="base_wua_report.paperformat_wua_reports"/>
    </record>

    <!-- Header and footer modifications -->
    <template id="report_cim_complaint_communication_external_layout_wua_modifications" inherit_id="cim_complaints_channel.report_cim_complaint_communication_external_layout">

        <xpath expr="//t[@t-call='cim_complaints_channel.report_cim_complaint_communication_external_layout_header']" position="attributes">
            <attribute name="t-call">base_wua_report.external_layout_header</attribute>
        </xpath>

        <xpath expr="//t[@t-call='cim_complaints_channel.report_cim_complaint_communication_external_layout_footer']" position="attributes">
            <attribute name="t-call">base_wua_report.external_layout_footer</attribute>
        </xpath>

    </template>

    <template id="report_cim_complaint_communication_document_wua_modifications" inherit_id="cim_complaints_channel.report_cim_complaint_communication_document">

        <xpath expr="//div[@name='section_complaint_data']" position="before">
            <t t-set="report_style" t-value="request.env['ir.values'].get_default('wua.configuration', 'reports_style')"/>
            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                <t t-if="report_style == 'light'">
                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                        <div style="float: left; width: 32px;"><span class="fa fa-inbox"/></div>
                        <div style="float: left; display: inline;">
                            <strong>Communication&amp;nbsp;<t t-esc="o.communication_number"/>&amp;nbsp;-&amp;nbsp;<t t-esc="o.name"/></strong>
                        </div>
                    </div>
                </t>
                <t t-else="">
                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                        <div style="float: left; width: 32px;"><span class="fa fa-inbox"/></div>
                        <div style="float: left; display: inline;">
                            <strong>Communication&amp;nbsp;<t t-esc="o.communication_number"/>&amp;nbsp;-&amp;nbsp;<t t-esc="o.name"/></strong>
                        </div>
                    </div>
                </t>
            </div>
        </xpath>

        <xpath expr="//div[@name='div_complaint_title']" position="replace">
            <div name="div_complaint_title" class="col-xs-3"><strong>Complaint: </strong></div>
        </xpath>

        <xpath expr="//div[@name='div_issue_title']" position="replace">
            <div name="div_issue_title" class="col-xs-3"><strong>Issue: </strong></div>
        </xpath>

        <xpath expr="//div[@name='div_source_title']" position="replace">
            <div name="div_source_title" class="col-xs-3"><strong>Source: </strong></div>
        </xpath>

        <xpath expr="//div[@name='div_communication_data']" position="replace">
            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                <t t-if="report_style == 'light'">
                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                        <div style="float: left; width: 32px;"><span class="fa fa-file-text-o"/></div>
                        <div style="float: left; display: inline;">
                            <strong>Communication&amp;nbsp;Data</strong>
                        </div>
                    </div>
                </t>
                <t t-else="">
                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                        <div style="float: left; width: 32px;"><span class="fa fa-file-text-o"/></div>
                        <div style="float: left; display: inline;">
                            <strong>Communication&amp;nbsp;Data</strong>
                        </div>
                    </div>
                </t>
            </div>
            <div class="col-xs-12">
                <br/>
            </div>
            <div class="col-xs-12">
                <span name="span_description" t-field="o.description"/>
            </div>
        </xpath>

    </template>
</odoo>