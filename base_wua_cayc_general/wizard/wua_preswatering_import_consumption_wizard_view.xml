<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="import_consumption_wizard_view_form"
            model="ir.ui.view">
        <field name="name">wua.preswatering.import.consumption.wizard.form</field>
        <field name="model">wua.preswatering.import.consumption.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Consumption from JSON File">
                <script>
                    $(document).ready(function(){
                        $('.modal-dialog').css({'width': '640px'});
                    });
                </script>
                <group>
                    <field name="preswatering_id" invisible="1"/>
                    <field name="json_filename" invisible="1"/>
                    <field name="json_file" filename="json_filename"/>
                </group>
                <footer>
                    <button name="action_import_consumptions"
                            type="object"
                            string="Import"
                            class="btn-primary"/>
                    <button string="Cancel" special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>