#. module: base_wua_cayc_general
#: model:mail.template,body_html:base_wua_cayc_general.wua_preswatering_parent_partner_email_template
msgid "\n"
"                \n"
"                    <p>Dear <strong>${object.display_name}</strong>,</p>\n"
"                    <p>Below is the summary of the watering requests for your associated partners for <strong>${ctx['tomorrow_str']}</strong>:</p>\n"
"                    <table border=\"1\" style=\"width: 100%; border-collapse: collapse; text-align: left;\">\n"
"                        <thead>\n"
"                            <tr style=\"background-color: #f2f2f2;\">\n"
"                                <th style=\"padding: 8px;\"></th>\n"
"                                <th style=\"padding: 8px;\"></th>\n"
"                                <th style=\"padding: 8px;\"></th>\n"
"                                <th style=\"padding: 8px;\"></th>\n"
"                                <th style=\"padding: 8px;\">${ctx['yesterday_str']}</th>\n"
"                                <th style=\"padding: 8px;\">${ctx['tomorrow_str']}</th>\n"
"                                <th style=\"padding: 8px;\"></th>\n"
"                            </tr>\n"
"                            <tr style=\"background-color: #f2f2f2;\">\n"
"                                <th style=\"padding: 8px;\">N.</th>\n"
"                                <th style=\"padding: 8px;\">Partner</th>\n"
"                                <th style=\"padding: 8px;\">Hectares (ha)</th>\n"
"                                <th style=\"padding: 8px;\">Water Connection</th>\n"
"                                <th style=\"padding: 8px;\">Issued</th>\n"
"                                <th style=\"padding: 8px;\">Requested</th>\n"
"                                <th style=\"padding: 8px;\">Modified</th>\n"
"                            </tr>\n"
"                        </thead>\n"
"                        <tbody>\n"
"                            % for consumption in ctx['data']['consumptions']:\n"
"                                <tr style=\"background-color: ${'#cce5ff' if consumption.get('nominal_flow_ls', 0) > 0 else 'white'};\">\n"
"                                    <td style=\"padding: 8px;\">${consumption.get('partner_code', '-')}</td>\n"
"                                    <td style=\"padding: 8px;\">${consumption.get('partner_name', '-')}</td>\n"
"                                    <td style=\"padding: 8px;\">\n"
"                                        ${\"{:,.2f}\".format(consumption.get('total_affected_area_official_hec', 0.0)).replace(\",\", \"X\").replace(\".\", \",\").replace(\"X\", \".\")}\n"
"                                    </td>\n"
"                                    <td style=\"padding: 8px;\">${consumption.get('water_connection', '-')}</td>\n"
"                                    <td style=\"padding: 8px;\">\n"
"                                        ${\"{:,.0f}\".format(consumption.get('nominal_flow_issued_ls', 0)).replace(\",\", \"X\").replace(\".\", \",\").replace(\"X\", \".\")}\n"
"                                    </td>\n"
"                                    <td style=\"padding: 8px;\">\n"
"                                        ${\"{:,.0f}\".format(consumption.get('nominal_flow_ls', 0)).replace(\",\", \"X\").replace(\".\", \",\").replace(\"X\", \".\")}\n"
"                                    </td>\n"
"                                    <td style=\"padding: 8px; color: ${'red' if consumption.get('modified', False) else '#555'};\">\n"
"                                        ${'True' if consumption.get('modified', False) else 'False'}\n"
"                                    </td>\n"
"                                </tr>\n"
"                            % endfor\n"
"                        </tbody>\n"
"                    </table>\n"
"                \n"
"            "
msgstr "\n"
"                \n"
"                    <p>Estimado/a <strong>${object.display_name}</strong>,</p>\n"
"                    <p>A continuación se muestra el resumen de las solicitudes de riego de sus socios asociados para el día <strong>${ctx['tomorrow_str']}</strong>:</p>\n"
"                    <table border=\"1\" style=\"width: 100%; border-collapse: collapse; text-align: left;\">\n"
"                        <thead>\n"
"                            <tr style=\"background-color: #f2f2f2;\">\n"
"                                <th style=\"padding: 8px;\"></th>\n"
"                                <th style=\"padding: 8px;\"></th>\n"
"                                <th style=\"padding: 8px;\"></th>\n"
"                                <th style=\"padding: 8px;\"></th>\n"
"                                <th style=\"padding: 8px;\">${ctx['yesterday_str']}</th>\n"
"                                <th style=\"padding: 8px;\">${ctx['tomorrow_str']}</th>\n"
"                                <th style=\"padding: 8px;\"></th>\n"
"                            </tr>\n"
"                            <tr style=\"background-color: #f2f2f2;\">\n"
"                                <th style=\"padding: 8px;\">N.</th>\n"
"                                <th style=\"padding: 8px;\">Socio</th>\n"
"                                <th style=\"padding: 8px;\">Hectáreas (ha)</th>\n"
"                                <th style=\"padding: 8px;\">Toma</th>\n"
"                                <th style=\"padding: 8px;\">Servido</th>\n"
"                                <th style=\"padding: 8px;\">Pedido</th>\n"
"                                <th style=\"padding: 8px;\">Modificado</th>\n"
"                            </tr>\n"
"                        </thead>\n"
"                        <tbody>\n"
"                            % for consumption in ctx['data']['consumptions']:\n"
"                                <tr style=\"background-color: ${'#cce5ff' if consumption.get('nominal_flow_ls', 0) > 0 else 'white'};\">\n"
"                                    <td style=\"padding: 8px;\">${consumption.get('partner_code', '-')}</td>\n"
"                                    <td style=\"padding: 8px;\">${consumption.get('partner_name', '-')}</td>\n"
"                                    <td style=\"padding: 8px;\">\n"
"                                        ${\"{:,.2f}\".format(consumption.get('total_affected_area_official_hec', 0.0)).replace(\",\", \"X\").replace(\".\", \",\").replace(\"X\", \".\")}\n"
"                                    </td>\n"
"                                    <td style=\"padding: 8px;\">${consumption.get('water_connection', '-')}</td>\n"
"                                    <td style=\"padding: 8px;\">\n"
"                                        ${\"{:,.0f}\".format(consumption.get('nominal_flow_issued_ls', 0)).replace(\",\", \"X\").replace(\".\", \",\").replace(\"X\", \".\")}\n"
"                                    </td>\n"
"                                    <td style=\"padding: 8px;\">\n"
"                                        ${\"{:,.0f}\".format(consumption.get('nominal_flow_ls', 0)).replace(\",\", \"X\").replace(\".\", \",\").replace(\"X\", \".\")}\n"
"                                    </td>\n"
"                                    <td style=\"padding: 8px; color: ${'red' if consumption.get('modified', False) else '#555'};\">\n"
"                                        ${'Sí' if consumption.get('modified', False) else 'No'}\n"
"                                    </td>\n"
"                                </tr>\n"
"                            % endfor\n"
"                        </tbody>\n"
"                    </table>\n"
"                \n"
"            "

