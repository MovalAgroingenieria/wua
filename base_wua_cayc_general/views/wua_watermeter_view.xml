<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_watermeter_view_form" model="ir.ui.view">
        <field name="name">Water Meters (form view)</field>
        <field name="model">wua.watermeter</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation.wua_watermeter_view_form"/>
        <field name="arch" type="xml">
          <xpath expr="//field[@name='nominal_water_flow']" position="after">
            <field name="maximum_nominal_flow"/>
          </xpath>
          <xpath expr="//page[@name='notes_page']" position="before">
              <page name="modules_page"
                string="Modules">
                  <field name="watermeter_module_ids">
                      <tree editable="bottom">
                          <field name="position"/>
                          <field name="module_flow"/>
                      </tree>
                  </field>
              </page>
          </xpath>
        </field>
    </record>

    <record id="wua_watermeter_view_tree" model="ir.ui.view">
        <field name="name">Water Meters (tree view)</field>
        <field name="model">wua.watermeter</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation.wua_watermeter_view_tree"/>
        <field name="arch" type="xml">
            <field name="nominal_water_flow" position="after">
                <field name="maximum_nominal_flow"/>
            </field>
        </field>
    </record>

    <record id="wua_watermeter_module_view_tree" model="ir.ui.view">
      <field name="name">Watermeter Modules (tree view)</field>
      <field name="model">wua.watermeter.module</field>
      <field name="arch" type="xml">
          <tree class="o_base_wua_cayc_general_watermeters_modules_view_tree"
                editable="bottom">
              <field name="name" string="Identifier"/>
              <field name="watermeter_id"/>
              <field name="position"/>
              <field name="module_flow"/>
          </tree>
      </field>
    </record>

    <record id="wua_watermeter_module_view_search" model="ir.ui.view">
        <field name="name">Watermeter Modules (search view)</field>
      <field name="model">wua.watermeter.module</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="watermeter_id"/>
                <group expand="0" string="Group By">
                    <filter string="Water Meter"
                     name="watermeter"
                     context="{'group_by':'watermeter_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="wua_technical_watermeter_module_action" model="ir.actions.act_window">
        <field name="name">Watermeter Modules</field>
        <field name="res_model">wua.watermeter.module</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="wua_watermeter_module_view_tree"/>
        <field name="search_view_id" ref="wua_watermeter_module_view_search"/>
    </record>

    <menuitem id="wua_technical_watermeter_module_menu"
              name="Watermeter Modules"
              parent="wua_structure_irrigation.base_wua_irrigation_technical_menu"
              action="wua_technical_watermeter_module_action"
              sequence="30"/>

</odoo>
