<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_waterconnection_view_form" model="ir.ui.view">
        <field name="name">Water Connection (form view)</field>
        <field name="model">wua.waterconnection</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation.wua_waterconnection_view_form"/>
        <field name="arch" type="xml">
          <xpath expr="//field[@name='with_cultivation']" position="after">
            <field name="from_san_salvador_pumping"/>
            <field name="from_san_salvador_gravity"/>
            <field name="from_san_salvador_esplus"/>
          </xpath>
        </field>
    </record>

</odoo>
