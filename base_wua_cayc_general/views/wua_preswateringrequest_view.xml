<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="base_wua_pressurized_irrigation_request.wua_preswateringrequest_menu" model="ir.ui.menu">
        <field name="sequence">3</field>
    </record>

    <record id="wua_preswateringrequest_view_form" model="ir.ui.view">
        <field name="name">Pres Watering Requests (form view)</field>
        <field name="model">wua.preswateringrequest</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation_request.wua_preswateringrequest_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='nominal_flow_ls']" position="after">
                <field name="maximum_nominal_flow"/>
            </xpath>
            <xpath expr="//field[@name='watering_duration']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='preswateringperiod_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='is_recurrence']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='recurrence_end_date']" position="attributes">
                <attribute name="invisible">1</attribute>
                <attribute name="required">0</attribute>
            </xpath>
            <xpath expr="//field[@name='recurrence_interval']" position="attributes">
                <attribute name="invisible">1</attribute>
                <attribute name="required">0</attribute>
            </xpath>
            <xpath expr="//field[@name='initial_hour']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="domain">[('is_primary', '=', True)]</attribute>
            </xpath>
            <xpath expr="//field[@name='notes_user']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//span[@name='span_notes_user']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='change_state_draft']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='change_state_validated']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//group[@name='master_data_right']" position="inside">
                <field name="partner_parcel_owner_area"/>
            </xpath>
        </field>
    </record>

</odoo>