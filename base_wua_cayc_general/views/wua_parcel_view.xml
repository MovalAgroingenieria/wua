<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_parcel_view_form_inherit_infrastructure_pressurized_hierarchy" model="ir.ui.view" >
        <field name="name">Parcels (form view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id" ref="base_wua_infrastructure_pressurized_hierarchy.wua_parcel_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='waterpipe_id']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="wua_parcel_view_form_inherit_crop_planning" model="ir.ui.view" >
        <field name="name">Parcels (form view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id" ref="base_wua_crop_planning.wua_parcel_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='cropplan_id']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='permanent']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="wua_parcel_view_form" model="ir.ui.view" >
        <field name="name">Parcels (form view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id" ref="base_wua_cayc.wua_parcel_view_form"/>
        <field name="arch" type="xml">
            <!-- Invisible Field fot primary and secondary parcels -->
            <xpath expr="//field[@name='area_intersected_perimeter_static']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='irrigationditch_id']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='with_watering_shift']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='tag_ids']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='pressurized_irrigation_right']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='gravityfed_irrigation_right']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='with_irrigation_worker']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='with_waterreservoir']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='rurallocation_id']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='with_cultivationplan']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='farmproperty_id']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='elev_min']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='elev_ave']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='elev_max']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='with_pumping']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='street_view_active']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='leased_parcel']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='leased_parcel']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='leased_from']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='leased_to']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//page[@name='subparcels']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <!-- Invisible elements for primary parcels -->
            <xpath expr="//field[@name='cadastral_sector']"
                   position="attributes">
                <attribute name="attrs">{'invisible': [('is_primary', '=', True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='cadastral_polygon']"
                   position="attributes">
                <attribute name="attrs">{'invisible': [('is_primary', '=', True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='cadastral_parcel']"
                   position="attributes">
                <attribute name="attrs">{'invisible': [('is_primary', '=', True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='cadastral_subparcel']"
                   position="attributes">
                <attribute name="attrs">{'invisible': [('is_primary', '=', True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='cadastral_reference']"
                   position="attributes">
                <attribute name="attrs">{'invisible': [('is_primary', '=', True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='area_cadaster']"
                   position="attributes">
                <attribute name="attrs">{'invisible': [('is_primary', '=', True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='hydraulic_infrastructure_type']"
                   position="attributes">
                <attribute name="attrs">{'invisible': [('is_primary', '=', True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='intake_id']"
                   position="attributes">
                <attribute name="attrs">{'invisible': [('is_primary', '=', True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='hydraulicsector_id']"
                   position="attributes">
                <attribute name="attrs">{'invisible': [('is_primary', '=', True)]}</attribute>
            </xpath>
            <xpath expr="//button[@name='action_see_cadastral_report']"
                   position="attributes">
                <attribute name="attrs">{'invisible': [('is_primary', '=', True)]}</attribute>
            </xpath>
            <xpath expr="//button[@name='action_see_gravconsumptions']"
                   position="attributes">
                <attribute name="attrs">{'invisible': [('is_primary', '=', True)]}</attribute>
            </xpath>
            <xpath expr="//page[@name='parcel_classes']"
                   position="attributes">
                <attribute name="attrs">{'invisible': [('is_primary', '=', True)]}</attribute>
            </xpath>
            <!-- Invisible elements for secondary parcels -->
            <xpath expr="//field[@name='with_votes']"
                   position="attributes">
                <attribute name="attrs">{'invisible': [('is_primary', '=', False)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='supply_suspended']"
                   position="attributes">
                <attribute name="attrs">{'invisible': [('is_primary', '=', False)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='is_billable_water']"
                   position="attributes">
                <attribute name="attrs">{'invisible': [('is_primary', '=', False)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='is_billable_expenses']"
                   position="attributes">
                <attribute name="attrs">{'invisible': [('is_primary', '=', False)]}</attribute>
            </xpath>
            <xpath expr="//page[@name='concessions']"
                   position="attributes">
                <attribute name="attrs">{'invisible': [('is_primary', '=', False)]}</attribute>
            </xpath>
            <xpath expr="//page[@name='irrigation_supplies']"
                   position="attributes">
                <attribute name="attrs">{'invisible': [('is_primary', '=', False)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='cadastral_sector']"
                   position="before">
                <field name="is_primary" colspan="4"/>
                <div colspan="4"/>
                <field name="wuabase_id" colspan="8" options="{'no_quick_create': True, 'no_create_edit': True}"/>
                <field name="class_sharer" colspan="8"/>
            </xpath>
            <xpath expr="//field[@name='county_id']"
                   position="before">
                <field name="partner_type" readonly="1"
                    style="width:300px"/>
                <br/>
            </xpath>
        </field>
    </record>

    <record id="wua_parcel_view_tree" model="ir.ui.view">
        <field name="name">Parcels (tree view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id" ref="base_wua_cayc.wua_parcel_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="wuabase_id"/>
            </xpath>
            <xpath expr="//field[@name='number_of_subparcels']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="wua_parcel_view_tree_inherit_crop_planning" model="ir.ui.view">
        <field name="name">Parcels (tree view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id" ref="base_wua_crop_planning.wua_parcel_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='registered_cropplan']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="wua_parcel_view_search" model="ir.ui.view">
        <field name="name">Parcels (search view)</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id" ref="base_wua_infrastructure.wua_parcel_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='hydraulicsector_id']" position="before">
                <field name="wuabase_id"/>
                <field name="octroi_id"/>
                <field name="waterchannel_id"/>
            </xpath>
            <xpath expr="//filter[@name='hydraulic_infrastructure_type_0']" position="before">
                <filter string="Primary Parcel" name="primaryparcel"
                    domain="[('is_primary','=',True)]"/>
                <filter string="CHE Parcel" name="cheparcel"
                    domain="[('is_primary','=',False)]"/>
                <separator/>
            </xpath>
            <xpath expr="//filter[@name='hydraulicsector']" position="before">
                <filter string="WUA Base"
                     name="wuabase_id"
                     context="{'group_by':'wuabase_id'}"/>
                <filter string="Partner Type"
                     name="partner_type"
                     context="{'group_by':'partner_type'}"/>
                <filter string="Octroi"
                     name="octroi_id"
                     context="{'group_by':'octroi_id'}"/>
                <filter string="Waterchannel"
                     name="waterchannel_id"
                     context="{'group_by':'waterchannel_id'}"/>
            </xpath>
        </field>
    </record>

    <record id="wua_parcel_class_view_form" model="ir.ui.view" >
        <field name="name">Parcel classes (form view)</field>
        <field name="model">wua.parcel.class</field>
        <field name="inherit_id" ref="base_wua_cayc.wua_parcel_class_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='parcel_id']"
                   position="before">
                <field name="wuabase_id"/>
            </xpath>
            <xpath expr="//field[@name='area_gis']"
                   position="after">
                <field name="intake_id"/>
                <field name="octroi_id"/>
                <field name="waterchannel_id"/>
            </xpath>
        </field>
    </record>

    <record id="wua_parcel_class_view_tree" model="ir.ui.view" >
        <field name="name">Parcel classes (tree view)</field>
        <field name="model">wua.parcel.class</field>
        <field name="inherit_id" ref="base_wua_cayc.wua_parcel_class_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='parcel_id']"
                   position="before">
                <field name="wuabase_id"/>
            </xpath>
            <xpath expr="//field[@name='class_sharer']"
                   position="after">
                <field name="intake_id"/>
                <field name="octroi_id"/>
                <field name="waterchannel_id"/>
            </xpath>
        </field>
    </record>

    <record id="wua_technical_parcel_class_view_tree" model="ir.ui.view" >
        <field name="name">Parcel classes (form view)</field>
        <field name="model">wua.parcel.class</field>
        <field name="inherit_id" ref="base_wua_cayc.wua_technical_parcel_class_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='parcel_id']"
                   position="before">
                <field name="wuabase_id"/>
            </xpath>
            <xpath expr="//field[@name='class_sharer']"
                   position="after">
                <field name="intake_id"/>
                <field name="octroi_id"/>
                <field name="waterchannel_id"/>
            </xpath>
        </field>
    </record>

    <record id="wua_parcel_class_view_search" model="ir.ui.view">
        <field name="name">Parcels (search view)</field>
        <field name="model">wua.parcel.class</field>
        <field name="inherit_id" ref="base_wua_cayc.wua_parcel_class_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='parcel_id']" position="before">
                <field name="wuabase_id"/>
            </xpath>
            <xpath expr="//filter[@name='parcel_id']" position="before">
                <filter string="WUA Base"
                     name="wuabase_id"
                     context="{'group_by':'wuabase_id'}"/>
            </xpath>
            <xpath expr="//filter[@name='class_sharer']" position="after">
                <filter string="Intake"
                     name="intake_id"
                     context="{'group_by':'intake_id'}"/>
                <filter string="Octroi"
                     name="octroi_id"
                     context="{'group_by':'octro_id'}"/>
                <filter string="Waterchannel"
                     name="waterchannel_id"
                     context="{'group_by':'waterchannel_id'}"/>
            </xpath>
        </field>
    </record>

    <record id="wua_parcel_primary_action" model="ir.actions.act_window">
        <field name="name">Parcels Primary</field>
        <field name="res_model">wua.parcel</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form,pivot</field>
        <field name="view_id" ref="base_wua.wua_parcel_view_tree"/>
        <field name="domain">[('is_primary', '=', True)]</field>
        <field name="search_view_id" ref="wua_parcel_view_search"/>
        <field name="context">{'is_primary_parcel': True}</field>
    </record>

    <record id="wua_parcel_che_action" model="ir.actions.act_window">
        <field name="name">Parcels CHE</field>
        <field name="res_model">wua.parcel</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form,pivot</field>
        <field name="view_id" ref="base_wua.wua_parcel_view_tree"/>
        <field name="domain">[('is_primary', '=', False)]</field>
        <field name="search_view_id" ref="wua_parcel_view_search"/>
        <field name="context">{'is_primary_parcel': False}</field>
    </record>

    <menuitem id="base_wua.wua_parcel_menu"
              name="Parcels Primary"
              parent="base_wua.base_wua_census_landparcels_menu"
              action="wua_parcel_primary_action"
              sequence="10"/>

    <menuitem id="wua_parcel_che_menu"
              name="Parcels CHE"
              parent="base_wua.base_wua_census_landparcels_menu"
              action="wua_parcel_che_action"
              sequence="11"/>

    <menuitem id="base_wua.wua_subparcel_menu"
              name="Subparcels"
              parent="base_wua.base_wua_census_landparcels_menu"
              action="base_wua.wua_subparcel_action"
              groups="base.group_no_one"/>

</odoo>
