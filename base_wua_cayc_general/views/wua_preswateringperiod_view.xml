<odoo>

    <record id="base_wua_pressurized_irrigation_request.wua_preswateringperiod_menu" model="ir.ui.menu">
        <field name="sequence">2</field>
    </record>

    <record id="wua_preswateringperiod_view_form" model="ir.ui.view">
        <field name="name">wua.preswateringperiod.form</field>
        <field name="model">wua.preswateringperiod</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation_request.wua_preswateringperiod_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='description']" position="before">
                <field name="proration"/>
                <field name="zones_united"/>
                <field name="rebombed_flow_ls"/>
                <field name="by_gravity_outlet"/>
                <field name="by_pumping"/>
                <field name="by_surplus"/>
            </xpath>
        </field>
    </record>

</odoo>