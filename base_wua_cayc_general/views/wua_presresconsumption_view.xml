<odoo>

    <record id="base_wua_pressurized_irrigation_request.wua_presresconsumption_menu" model="ir.ui.menu">
        <field name="sequence">5</field>
    </record>

    <record id="wua_presresconsumption_view_tree" model="ir.ui.view">
        <field name="name">wua.presresconsumption.tree</field>
        <field name="model">wua.presresconsumption</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation_request.wua_presresconsumption_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='watering_duration']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='initial_hour']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='waterconnection_id']" position="after">
                <field name="siemens_id"/>
            </xpath>
        </field>
    </record>


    <record id="wua_presresconsumption_view_pivot" model="ir.ui.view">
        <field name="name">wua.presresconsumption.pivot</field>
        <field name="model">wua.presresconsumption</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation_request.wua_presresconsumption_view_pivot"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='watering_duration']" position="replace">
            </xpath>
            <xpath expr="//field[@name='watering_volume']" position="replace">
            </xpath>
            <xpath expr="//field[@name='total_affected_area_official_hec']" position="replace">
                <field name="nominal_flow_ls" type="measure"/>
                <field name="nominal_flow_ls_granted" type="measure"/>
                <field name="nominal_flow_ls_issued" type="measure"/>
                <field name="request_time" interval="day" type="row"/>
            </xpath>
        </field>
    </record>

    <record id="wua_presresconsumption_view_form" model="ir.ui.view">
        <field name="name">wua.presresconsumption.form</field>
        <field name="model">wua.presresconsumption</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation_request.wua_presresconsumption_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="attributes">
                <attribute name="edit">1</attribute>
            </xpath>
            <xpath expr="//field[@name='nominal_flow_ls_issued']" position="attributes">
                <attribute name="readonly">0</attribute>
            </xpath>
            <xpath expr="//field[@name='waterconnection_id']" position="after">
                <field name="siemens_id"/>
            </xpath>
        </field>
    </record>

</odoo>