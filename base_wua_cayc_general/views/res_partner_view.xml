<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Hide consumption button  -->
    <record id="view_partner_form_inherit_gravity_irrigation" model="ir.ui.view">
        <field name="name">Partners (form view)</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base_wua_gravity_irrigation.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_see_gravity_consumptions']" position="attributes">
                <attribute name="attrs">{'invisible': [('is_primary', '=', True)]}</attribute>
            </xpath>
        </field>
    </record>

    <!-- Hide cropplan data  -->
    <record id="view_partner_form_inherit_infrastructure" model="ir.ui.view">
        <field name="name">Partners (form view)</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base_wua_infrastructure.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='%(base_wua_infrastructure.res_partner_irrigationpoints_action)d']" position="attributes">
                <attribute name="attrs">{'invisible': [('is_primary', '=', True)]}</attribute>
            </xpath>
        </field>
    </record>

    <!-- Hide cropplan data  -->
    <record id="view_partner_form_inherit_cropplan" model="ir.ui.view">
        <field name="name">Partners (form view)</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base_wua_crop_planning.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='cropplan_id']" position="attributes">
                <attribute name="attrs">{'invisible': [('is_primary', '=', True)]}</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_partner_tree_inherit_cropplan" model="ir.ui.view">
        <field name="name">Partners (form view)</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base_wua_crop_planning.view_partner_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='registered_cropplan']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_partner_form" model="ir.ui.view">
        <field name="name">Partners (form view)</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base_wua.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="style">width:400px</attribute>
            </xpath>
            <xpath expr="//field[@name='apply_second_partner_coding']" position="after">
                <field name="is_primary" invisible="1"/>
                <field name="partner_type" attrs="{'invisible': [('is_primary', '=', False)], 'required': [('is_primary', '=', True)]}" />
                <field name="wuabase_id" class="oe_read_only" style="width: 220px;"/>
                <div name="is_primary_secondary"
                    class="oe_read_only text-center"
                    colspan="2"
                    style="display: inline-block; padding-top: 5px;padding-bottom: 5px;padding-left: 10px;">
                    <strong attrs="{'invisible': [('is_primary', '=', False)]}">( PRIMARY PARTNER )</strong>
                    <strong attrs="{'invisible': [('is_primary', '=', True)]}">( CHE PARTNER )</strong>
                </div>
            </xpath>
            <xpath expr="//field[@name='website']" position="after">
                <field name="octroi_id"  attrs="{'invisible': [('is_primary', '=', False)]}"/>
                <field name="zone_id"  attrs="{'invisible': [('is_primary', '=', False)]}"/>
                <field name="is_independent"  attrs="{'invisible': [('is_primary', '=', False)]}"/>
                <field name="parent_partner_id"  attrs="{'invisible': ['|', ('is_primary', '=', False), ('is_independent', '=', True)]}"/>
            </xpath>
            <xpath expr="//field[@name='number_of_votes']" position="after">
                <field name="concession_as_volume" style="width:120px" attrs="{'invisible': [('partner_type', 'not in', ['02_IND', '03_WSP'])]}"/>
                <field name="concession_as_power" style="width:120px" attrs="{'invisible': [('partner_type', 'not in', ['04_HEL'])]}"/>
            </xpath>
            <xpath expr="//button[@name='toggle_active']" position="after">
                <button name="action_see_secondary_parcels"
                        string="Secondary parcels"
                        attrs="{'invisible':[('is_primary','=',False)]}"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-moval-parcel"
                        groups="base_wua.group_wua_user,
                                base_wua.group_wua_portal_user"/>
            </xpath>
            <!-- Hide fields, buttons and pages on primary partners -->
            <xpath expr="//field[@name='gender']"  position="attributes">
                <attribute name="attrs">{'invisible': [('is_primary', '=', True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='birthdate']" position="attributes">
                <attribute name="attrs">{'invisible': [('is_primary', '=', True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='name_alias']" position="attributes">
                <attribute name="attrs">{'invisible': [('is_primary', '=', True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='is_owner']" position="attributes">
                <attribute name="attrs">{'invisible': [('is_primary', '=', True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='is_lessee']" position="attributes">
                <attribute name="attrs">{'invisible': [('is_primary', '=', True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='is_payer']" position="attributes">
                <attribute name="attrs">{'invisible': [('is_primary', '=', True)]}</attribute>
            </xpath>
            <xpath expr="//page[@name='quotas']" position="attributes">
                <attribute name="attrs">{'invisible': [('is_primary', '=', True)]}</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_partner_tree" model="ir.ui.view">
        <field name="name">Partners (tree view)</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base_wua.view_partner_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vat']" position="before">
                <field name="partner_type"/>
                <field name="octroi_id"/>
                <field name="zone_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_partner_search" model="ir.ui.view">
        <field name="name">Partners (search view)</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base_wua_cayc.view_partner_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='category_id']" position="before">
                <field name="wuabase_id"/>
            </xpath>
            <xpath expr="//filter[@name='isacompany']" position="before">
                <filter string="Primary Entity"
                     name="wuabase_id"
                     context="{'group_by':'wuabase_id'}"/>
                <filter string="Partner Type"
                     name="partner_type"
                     context="{'group_by':'partner_type'}"/>
                <filter string="Octroi"
                     name="octroi_id"
                     context="{'group_by':'octroi_id'}"/>
                <filter string="Zone"
                    name="zone_id"
                    context="{'group_by':'zone_id'}"/>
                <filter string="Parent Partner"
                    name="parent_partner_id"
                    context="{'group_by':'parent_partner_id'}"/>
            </xpath>
            <xpath expr="//filter[@name='partnermappedno']" position="after">
                <separator/>
                <filter string="Is Independent: Yes"
                    name="isindependentyes"
                    domain="[('is_independent','=', True)]"/>
                <filter string="Is Independent: No"
                    name="isindependentno"
                    domain="[('is_independent','=', False)]"/>
            </xpath>
            <xpath expr="//filter[@name='partnermappedyes']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//filter[@name='partnermappedno']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="res_partner_primary_action" model="ir.actions.act_window">
        <field name="name">Partners Primary</field>
        <field name="res_model">res.partner</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="view_id" ref="base_wua.view_partner_tree"/>
        <field name="domain">[('is_wua_partner','=',True), ('is_primary', '=', True)]</field>
        <field name="search_view_id" ref="view_partner_search"/>
        <field name="context">{'wua':'1','default_is_wua_partner':True, 'is_primary_partner': True}</field>
    </record>

    <record id="res_partner_che_action" model="ir.actions.act_window">
        <field name="name">Partners CHE</field>
        <field name="res_model">res.partner</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="view_id" ref="base_wua.view_partner_tree"/>
        <field name="domain">[('is_wua_partner','=',True), ('is_primary', '=', False)]</field>
        <field name="search_view_id" ref="view_partner_search"/>
        <field name="context">{'wua':'1','default_is_wua_partner':True, 'is_primary_partner': False, 'create': False, 'edit': False, 'delete': False}</field>
    </record>

    <menuitem id="base_wua.res_partner_menu"
              name="Partners Primary"
              parent="base_wua.base_wua_census_partners_menu"
              action="res_partner_primary_action"
              sequence="1"/>

    <menuitem id="res_partner_che_menu"
              name="Partners CHE"
              parent="base_wua.base_wua_census_partners_menu"
              action="res_partner_che_action"
              groups="base_wua.group_wua_user"
              sequence="1"/>

</odoo>