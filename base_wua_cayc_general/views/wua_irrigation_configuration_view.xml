<odoo>

    <record id="wua_irrigation_config_settings_view_form" model="ir.ui.view">
        <field name="name">wua.irrigation.config.settings.form</field>
        <field name="model">wua.irrigation.configuration</field>
        <field name="inherit_id" ref="base_wua_pressurized_irrigation_request.wua_irrigation_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='lock_modification_hours']" position="after">
                <field name="independent_lock_modification_hours"/>
            </xpath>
        </field>
    </record>

</odoo>