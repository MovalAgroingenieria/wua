<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="base_wua_pressurized_irrigation_request.wua_preswatering_menu" model="ir.ui.menu">
        <field name="sequence">4</field>
    </record>

    <record id="action_open_import_consumption_wizard"
            model="ir.actions.act_window">
        <field name="name">Import SINEMA JSON</field>
        <field name="res_model">wua.preswatering.import.consumption.wizard</field>
        <field name="view_type">form</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="wua_preswatering_view_form" model="ir.ui.view">
        <field name="name">wua.preswatering.form</field>
        <field name="model">wua.preswatering</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation_request.wua_preswatering_view_form"/>
        <field name="arch" type="xml">
        <xpath expr="//button[@name='issue_presresconsumptions']" position="after">
            <button name="%(action_open_import_consumption_wizard)d"
                    string="Import Consumption from JSON File"
                    type="action"
                    class="btn-primary"
                    attrs="{'invisible':
                            ['|', ('state', '=', '01_draft'),
                                ('presresconsumptions_issued', '=', True)]}"
                    groups="base_wua.group_wua_manager"
                    context="{'default_preswatering_id': active_id}"/>
        </xpath>
            <xpath expr="//field[@name='description']" position="before">
                <field name="proration"/>
                <field name="zones_united"/>
                <field name="by_gravity_outlet"/>
                <field name="by_pumping"/>
                <field name="by_surplus"/>
                <field name="rebombed_flow_ls"/>
            </xpath>
            <xpath expr="//field[@name='condition_line_ids']/tree/field[@name='check_value']" position="after">
                <field name="specific_proration" string='Original %' readonly="1"/>
                <field name="result_value_first_proration" readonly="1"/>
                <field name="proration_factor_used" readonly="1"/>
            </xpath>
        </field>
    </record>

    <record id="wua_preswatering_condition_view_form" model="ir.ui.view">
        <field name="name">Preswatering Conditions (form view)</field>
        <field name="model">wua.preswatering.condition</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation_request.wua_preswatering_condition_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='is_mandatory']" position="after">
                <field name="apply_second_proration"/>
                <field name="max_iterations"/>
                <field name="tolerance"/>
                <field name="iteration_step"/>
            </xpath>
        </field>
    </record>

</odoo>