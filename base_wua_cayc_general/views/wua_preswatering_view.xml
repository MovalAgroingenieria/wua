<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="base_wua_pressurized_irrigation_request.wua_preswatering_menu" model="ir.ui.menu">
        <field name="sequence">4</field>
    </record>

    <record id="wua_preswatering_view_form" model="ir.ui.view">
        <field name="name">wua.preswatering.form</field>
        <field name="model">wua.preswatering</field>
        <field name="inherit_id"
               ref="base_wua_pressurized_irrigation_request.wua_preswatering_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='description']" position="before">
                <field name="proration"/>
                <field name="zones_united"/>
                <field name="by_gravity_outlet"/>
                <field name="by_pumping"/>
                <field name="by_surplus"/>
                <field name="rebombed_flow_ls"/>
            </xpath>
        </field>
    </record>

</odoo>