<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="0">

        <record id="group_make_invisible" model="res.groups">
            <field name="name">Invisible</field>
        </record>

        <record id="group_wua_octroi_user" model="res.groups">
            <field name="name">Octroi User</field>
            <field name="category_id"
                ref="base.module_category_water_users_associations"/>
        </record>

        <record id="rule_wua_parcel_group_wua_portal_user_inherited" model="ir.rule">
            <field name="name">Rule for Wua Portal User on parcels (Inherited)</field>
            <field name="model_id" ref="model_wua_parcel"/>
            <field name="domain_force">
                ['|',
                '|',
                ('partnerlink_ids.partner_id', '=', user.partner_id.id),
                ('partnerlink_ids.partner_id', 'parent_of', user.partner_id.id),
                '|',
                ('wuabase_id', '=', user.partner_id.wuabase_id.id),
                ('wuabase_id', '=', user.partner_id.parent_id.wuabase_id.id)]
            </field>
            <field name="groups" eval="[(4, ref('base_wua.group_wua_portal_user'))]"/>
        </record>

        <record id="rule_wua_parcel_class_partnerlink" model="ir.rule">
            <field name="name">Rule for Partner to see Parcel Class of Parcels they are Partnerlink</field>
            <field name="model_id" ref="model_wua_parcel_class"/>
            <field name="domain_force">
                ['|',
                 '|',
                 ('parcel_id.partnerlink_ids.partner_id', '=', user.partner_id.id),
                 ('parcel_id.partnerlink_ids.partner_id', 'parent_of', user.partner_id.id),
                 '|',
                 ('wuabase_id', '=', user.partner_id.wuabase_id.id),
                 ('wuabase_id', '=', user.partner_id.parent_id.wuabase_id.id)]
            </field>
            <field name="groups" eval="[(4, ref('base_wua.group_wua_portal_user'))]"/>
        </record>

        <!-- Ensure can only see partners from his octroi -->
        <record id="rule_res_partner_group_wua_octroi_user" model="ir.rule">
            <field name="name">Rule for Octroi User on Partners</field>
            <field name="model_id" ref="model_res_partner"/>
            <field name="domain_force">
                [('octroi_id', '=', user.octroi_id.id),]
            </field>
            <field name="groups" eval="[(4, ref('base_wua_cayc_general.group_wua_octroi_user'))]"/>
        </record>

        <!-- Ensure can only edit, delete and create  preswateringrequest of
             the partners from his octroi  -->
        <record id="rule_wua_preswateringrequest_group_wua_octroi_user" model="ir.rule">
            <field name="name">Rule for Octroi User on Preswatering Request</field>
            <field name="model_id" ref="model_wua_preswateringrequest"/>
            <field name="domain_force">
                ['|',
                 ('partner_id.octroi_id', '=', user.octroi_id.id),
                 ('partner_id', '=', False),]
            </field>
            <field name="groups" eval="[(4, ref('base_wua_cayc_general.group_wua_octroi_user'))]"/>
        </record>

        <!-- Ensure can only edit, delete and create  presresconsumptions of
             the partners from his octroi  -->
        <record id="rule_wua_presresconsumption_group_wua_octroi_user" model="ir.rule">
            <field name="name">Rule for Octroi User on Presresconsumption</field>
            <field name="model_id" ref="model_wua_presresconsumption"/>
            <field name="domain_force">
                ['|',
                 ('partner_id.octroi_id', '=', user.octroi_id.id),
                 ('partner_id', '=', False),]
            </field>
            <field name="groups" eval="[(4, ref('base_wua_cayc_general.group_wua_octroi_user'))]"/>
        </record>

    </data>

</odoo>
