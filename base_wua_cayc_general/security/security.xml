<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="0">

        <record id="group_make_invisible" model="res.groups">
            <field name="name">Invisible</field>
        </record>

        <record id="rule_wua_parcel_group_wua_portal_user_inherited" model="ir.rule">
            <field name="name">Rule for Wua Portal User on parcels (Inherited)</field>
            <field name="model_id" ref="model_wua_parcel"/>
            <field name="domain_force">
                ['|',
                '|',
                ('partnerlink_ids.partner_id', '=', user.partner_id.id),
                ('partnerlink_ids.partner_id', 'parent_of', user.partner_id.id),
                '|',
                ('wuabase_id', '=', user.partner_id.wuabase_id.id),
                ('wuabase_id', '=', user.partner_id.parent_id.wuabase_id.id)]
            </field>
            <field name="groups" eval="[(4, ref('base_wua.group_wua_portal_user'))]"/>
        </record>

        <record id="rule_wua_parcel_class_partnerlink" model="ir.rule">
            <field name="name">Rule for Partner to see Parcel Class of Parcels they are Partnerlink</field>
            <field name="model_id" ref="model_wua_parcel_class"/>
            <field name="domain_force">
                ['|',
                 '|',
                 ('parcel_id.partnerlink_ids.partner_id', '=', user.partner_id.id),
                 ('parcel_id.partnerlink_ids.partner_id', 'parent_of', user.partner_id.id),
                 '|',
                 ('wuabase_id', '=', user.partner_id.wuabase_id.id),
                 ('wuabase_id', '=', user.partner_id.parent_id.wuabase_id.id)]
            </field>
            <field name="groups" eval="[(4, ref('base_wua.group_wua_portal_user'))]"/>
        </record>

    </data>

</odoo>
