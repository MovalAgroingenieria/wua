<?xml version="1.0" encoding="utf-8"?>
<odoo>


   <template id="wua_partner_report_document" inherit_id="base_wua.wua_partner_report_document">
        <!-- Hide parcel class if parcel primary -->
        <xpath expr="//tr[@name='tr_number_of_votes']" position="after">
            <tr name="tr_partner_type">
                <td><span>Partner type:</span></td>
                <td class="text-right">
                    <t t-if="o.is_primary">
                        <span>Primary</span>
                    </t>
                    <t t-else="">
                        <span>CHE</span>
                    </t>
                </td>
            </tr>
            <tr t-if="not o.is_primary" name="tr_wuabase">
                <td><span>Base WUA:</span></td>
                <td class="text-right">
                    <span t-field="o.wuabase_id"/>
                </td>
            </tr>
        </xpath>
    </template>

</odoo>
