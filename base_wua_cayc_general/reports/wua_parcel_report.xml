<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="wua_parcel_report_document" inherit_id="base_wua_cayc.wua_parcel_report_document">
        <!-- Hide parcel class if parcel primary -->
        <xpath expr="//div[@name='classes_data']" position="attributes">
            <attribute name="t-if">not o.is_primary</attribute>
        </xpath>
    </template>

</odoo>
