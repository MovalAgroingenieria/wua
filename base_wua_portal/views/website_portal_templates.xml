<odoo>
    <data>
        <template id="portal_my_home_menu_wua" name="Portal layout : wua menu entries" inherit_id="website_portal_sale.portal_my_home_menu_sale" priority="925">
            <xpath expr="//ul[contains(@class,'o_portal_submenu')]" position="attributes">
                <attribute name="style">display: flex; flex-direction: row; flex-wrap: wrap;</attribute>
            </xpath>
            <xpath expr="//ul[contains(@class,'o_portal_submenu')]" position="inside">
                <li style="order: 2;">
                    <a name="parcels_menu" href="/my/parcels">Parcels</a>
                </li>
            </xpath>
            <xpath expr="//li[a[@href='/my/quotes']]" position="attributes">
                <attribute name="style">display: none;</attribute>
            </xpath>
            <xpath expr="//li[a[@href='/my/orders']]" position="attributes">
                <attribute name="style">display: none;</attribute>
            </xpath>
            <xpath expr="//div[@id='o_my_sidebar']" position="attributes">
                <attribute name="t-if">default_url != '/my/parcels'</attribute>
            </xpath>
            <xpath expr="//div[@id='o_my_sidebar']//div[@class='o_my_details']//div[@t-field='user.partner_id']" position="attributes">
                <attribute name="style">display: none;</attribute>
            </xpath>
            <xpath expr="//div[@id='o_my_sidebar']//div[@class='o_my_details']" position="inside">
            <a t-attf-href="/my/report"
               target="_blank">
                <div t-field="user.partner_id" t-options='{"widget": "contact", "fields": ["email", "phone", "address", "name"]}'/>
                <div class="mt8" t-if="user.partner_id.vat">
                    <t t-set="vat_no_prefix" t-value="user.partner_id.vat[2:]"/>
                    <span t-esc="vat_no_prefix"/>
                </div>
            </a>

            <div class="col-md-12 text-center mt-auto">
                <a name="gis_viewer_link" t-att-href="gis_viewer_link" target="_blank" class="btn oe_stat_button">
                    <div class="fa fa-fw fa-map-marker o_button_icon"></div>
                        View in Map
                </a>
            </div>
            </xpath>
        </template>
        <template id="portal_my_home_wua" inherit_id="website_portal_sale.portal_my_home_sale" name="Hide Quotes and Orders">
            <xpath expr="//div[contains(@class,'o_my_home_content')]" position="attributes">
                <attribute name="style">display: flex; flex-direction: column;</attribute>
            </xpath>
            <xpath expr="//div[contains(@class,'o_my_home_content')]" position="inside">
                <h3 name="parcels_home_header" class="page-header" style="order: 2;">
                    <a href="/my/parcels">
                    <i class="fa fa-fw fa-moval-parcel"></i>
                        Your Parcels
                        <small class="ml8">
                            <t t-if="parcel_count">
                                <span class='badge pull-right'><t t-esc="parcel_count"/></span>
                            </t>
                            <t t-if="not parcel_count">
                                There are currently no parcels for your account.
                            </t>
                        </small>
                    </a>
                </h3>
            </xpath>
            <xpath expr="//h3[a[@href='/my/quotes']]" position="attributes">
                <attribute name="style">display: none;</attribute>
            </xpath>
            <xpath expr="//h3[a[@href='/my/orders']]" position="attributes">
                <attribute name="style">display: none;</attribute>
            </xpath>
            <xpath expr="//h3[a[@href='/my/invoices']]" position="attributes">
                <attribute name="style">display: none;</attribute>
            </xpath>
            <xpath expr="//h3[a[@href='/my/invoices']]" position="after">
                <h3 class="page-header" style="order: 1;">
                    <a href="/my/invoices">
                        <i class="fa fa-fw fa-pencil-square-o"></i>
                        Your Invoices and Payments
                        <small class="ml8">
                            <t t-if="invoice_count">
                                <span class='badge pull-right'><t t-esc="invoice_count"/></span>
                            </t>
                            <t t-if="not invoice_count">
                                There are currently no invoices for your account.
                            </t>
                        </small>
                    </a>
                </h3>
            </xpath>
        </template>
        <template id="custom_my_account_details" inherit_id="website_portal.details">
            <xpath expr="//div[@id='wrap']/div[@class='container']/h1" position="replace">
                <h1>Partner Details</h1>
            </xpath>
            <xpath expr="//form[@action='/my/account']/div[@class='row o_website_portal_details']/div[@class='col-md-8']/div[@class='row']" position="inside">
                    <div class="form-group col-lg-6">
                        <label class="control-label">Number of Votes</label>
                        <div>
                            <span t-esc="partner.number_of_votes"/>
                        </div>
                    </div>
                    <div class="clearfix"/>
                    <h1 class="form-group col-lg-12">Partner roles</h1>
                    <div class="form-group col-lg-4 text-center">
                        <label class="control-label">Is Owner</label>
                        <div>
                            <input type="checkbox" t-att-checked="partner.is_owner" disabled="disabled"/>
                        </div>
                    </div>
                    <div class="form-group col-lg-4 text-center">
                        <label class="control-label">Is Lessee</label>
                        <div>
                            <input type="checkbox" t-att-checked="partner.is_lessee" disabled="disabled"/>
                        </div>
                    </div>
                    <div class="form-group col-lg-4 text-center">
                        <label class="control-label">Is Payer</label>
                        <div>
                            <input type="checkbox" t-att-checked="partner.is_payer" disabled="disabled"/>
                        </div>
                    </div>
                    <h1 class="form-group col-lg-12">Bank Data</h1>
                    <div  class="form-group col-lg-6">
                        <label class="control-label">Customer Payment Mode</label>
                        <div>
                            <span t-esc="partner.customer_payment_mode_id.name"/>
                        </div>
                    </div>
                    <h3 class="form-group col-lg-12">Bank Accounts</h3>
                    <div class="form-group col-lg-12">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Bank Name</th>
                                    <th>Account Number</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-if="partner.bank_ids">
                                    <t t-foreach="partner.bank_ids" t-as="bank">
                                        <tr>
                                            <td><t t-esc="bank.bank_id.name"/></td>
                                            <td><t t-esc="bank.acc_number"/></td>
                                        </tr>
                                    </t>
                                </t>
                                <t t-if="not partner.bank_ids">
                                    <tr>
                                        <td colspan="2">No bank accounts available</td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                    <!-- Banking Mandates
                    <h3 class="form-group col-lg-12">Banking Mandates</h3>
                    <div class="form-group col-lg-12">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Format</th>
                                    <th>Unique Mandate Reference</th>
                                    <th>Bank Account</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-if="mandates">
                                    <t t-foreach="mandates" t-as="mandate">
                                        <tr>
                                            <td><t t-esc="mandate.format"/></td>
                                            <td><t t-esc="mandate.unique_mandate_reference"/></td>
                                            <td><t t-esc="mandate.partner_bank_id.acc_number"/></td>
                                        </tr>
                                    </t>
                                </t>
                                <t t-if="not mandates">
                                    <tr>
                                        <td colspan="3">No banking mandates available</td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                    -->
            </xpath>
        </template>
        <template id="portal_my_parcels" name="My Parcels">
            <t t-call="website.layout">
                <div class="container mt16">
                    <div class="navbar navbar-default">
                        <div class="navbar-header">
                            <button type="button" class="navbar-toggle" data-toggle="collapse" data-target="#oe-help-navbar-collapse">
                                <span class="sr-only">Toggle navigation</span>
                                <span class="icon-bar"></span>
                                <span class="icon-bar"></span>
                            </button>
                            <a class="navbar-brand" href="/my/home">
                                My Account
                            </a>
                        </div>
                        <div class="collapse navbar-collapse" id="oe-help-navbar-collapse">
                            <ul class="nav navbar-nav o_portal_submenu">
                                <li>
                                    <a href="/my/invoices">Facturas</a>
                                </li>
                                <li>
                                    <a href="/my/parcels">Parcelas</a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div id="wrap">
                    <div class="container mb64">
                        <div class="col-md-12">
                            <h3 class="page-header">Your Parcels</h3>
                            <form action="/my/parcels" method="get" class="mb-3">
                                <div class="row">
                                    <div class="col-md-2">
                                        <select id="search_field" name="search_field" class="form-control">
                                            <option value="name" t-att-selected="'name' == search_field">Parcel #</option>
                                            <t t-if="has_extra_code">
                                                <option value="extra_code" t-att-selected="'extra_code' == search_field">Extra Code</option>
                                            </t>
                                            <option value="cadastral_reference" t-att-selected="'cadastral_reference' == search_field">Cadastral Reference</option>
                                            <option value="concession" t-att-selected="'concession' == search_field">Concessions</option>
                                        </select>
                                    </div>
                                    <div class="col-md-8">
                                        <input type="text" name="search" class="form-control" placeholder="Search parcels..."
                                            t-att-value="search_query or ''"/>
                                    </div>
                                    <div class="col-md-2">
                                        <button type="submit" class="btn btn-primary btn-block">Search</button>
                                    </div>
                                </div>
                            </form>
                            <t t-if="not parcels">
                                <p>There are currently no parcels for your account.</p>
                            </t>
                            <t t-if="parcels">
                                <table class="table table-hover o_my_status_table">
                                    <thead>
                                        <tr class="active">
                                            <th>Parcel #</th>
                                            <t t-if="has_extra_code">
                                                <th>Extra code</th>
                                            </t>
                                            <th>Cadastral Reference</th>
                                            <th>Concessions</th>
                                            <th>Profile</th>
                                            <th>Area Official</th>
                                            <th>Ownership Percentage</th>
                                        </tr>
                                    </thead>
                                    <t t-foreach="partnerlinks" t-as="parcel">
                                        <tr>
                                            <td>
                                                <a t-attf-href="/my/parcels/#{parcel.id}?#{keep_query()}">
                                                    <t t-esc="parcel.parcel_id.name"/>
                                                </a>
                                            </td>
                                            <t t-if="has_extra_code">
                                                <td><t t-esc="parcel.parcel_id.extra_code"/></td>
                                            </t>
                                            <td><t t-esc="parcel.parcel_id.cadastral_reference"/></td>
                                            <td>
                                                <t t-if="parcel.parcel_id.concession_ids">
                                                    <div>
                                                        <div t-foreach="parcel.parcel_id.concession_ids" t-as="concession">
                                                            <t t-esc="concession.name"/><br/>
                                                        </div>
                                                    </div>
                                                </t>
                                                <t t-if="not parcel.parcel_id.concession_ids">
                                                    <span>No concessions</span>
                                                </t>
                                            </td>
                                            <td>
                                                <t t-if="parcel.profile == 'O'"><span>Owner</span></t>
                                                <t t-if="parcel.profile == 'P'"><span>Payer</span></t>
                                                <t t-if="parcel.profile == 'L'"><span>Lessee</span></t>
                                            </td>
                                            <td><t t-esc="parcel.parcel_id.area_official"/></td>
                                            <td><t t-esc="parcel.ownership_percentage"/></td>
                                        </tr>
                                    </t>
                                </table>
                                <div t-if="pager" class="o_portal_pager text-center">
                                    <t t-call="website.pager"/>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>
            </t>
        </template>
        <template id="parcels_followup" name="Parcel">
            <t t-call="website.layout">
                <div id="wrap">
                    <div class="container">
                        <div class="oe_structure">
                            <div class="row">
                                <div class="col-sm-4">
                                    <ol class="breadcrumb mt8">
                                        <li><a href="/my/home"><i class="fa fa-home"/></a></li>
                                        <li>
                                            <a t-attf-href="/my/parcels">
                                                <t>My Parcels</t>
                                            </a>
                                        </li>
                                    </ol>
                                </div>
                            </div>
                            <div id="optional_placeholder"></div>
                            <div class="panel panel-default">
                                <div class="panel-heading">
                                    <div class="row">
                                        <div class="col-md-8">
                                            <h4>
                                                <t>Parcel</t>
                                                <a t-att-href="'/my/parcels/' + str(parcel.id) + '/report'">
                                                    <span t-esc="parcel.name"/>
                                                </a>
                                            </h4>
                                        </div>
                                    </div>
                                </div>
                                <div class="panel-body">
                                    <div class="row">
                                        <div class="col-md-4 d-flex flex-column justify-content-between">
                                            <div><strong>Cadastral Parcel:</strong> <span t-esc="parcel.cadastral_parcel"/></div>
                                            <br/>
                                            <div><strong>Cadastral Sector:</strong> <span t-field="parcel.cadastral_sector"/></div>
                                            <br/>
                                            <div><strong>Cadastral Polygon:</strong> <span t-field="parcel.cadastral_polygon"/></div>
                                            <br/>
                                            <div><strong>Cadastral Parcel:</strong> <span t-field="parcel.cadastral_parcel"/></div>
                                            <br/>
                                            <div><strong>Cadastral Subparcel:</strong> <span t-field="parcel.cadastral_subparcel"/></div>
                                            <br/>
                                            <div><strong>Cadastral Reference:</strong> <span t-field="parcel.cadastral_reference"/></div>
                                            <br/>
                                            <div><strong>Area (Cadaster):</strong> <span t-field="parcel.area_cadaster"/></div>
                                        </div>
                                        <div class="col-md-4 d-flex flex-column justify-content-between">
                                            <div><strong>County:</strong> <span t-esc="parcel.county_id.name"/></div>
                                            <br/>
                                            <div t-if="parcel.farmproperty_id"><strong>Farm Property:</strong> <span t-field="parcel.farmproperty_id"/></div>
                                            <div t-if="parcel.farmproperty_id"><br/></div>
                                            <div t-if="parcel.rurallocation_id"><strong>Rural Location:</strong> <span t-field="parcel.rurallocation_id"/></div>
                                            <div t-if="parcel.rurallocation_id"><br/></div>
                                            <div><strong>Area (Official):</strong> <span t-field="parcel.area_official"/></div>
                                            <br/>
                                            <div><strong>Area (GIS):</strong> <span t-field="parcel.area_gis"/></div>
                                            <br/>
                                            <div><strong>With Votes:</strong>
                                                <input type="checkbox" t-att-checked="parcel.with_votes" disabled="disabled"/>
                                            </div>
                                            <br/>
                                            <div><strong>Is Billable Expenses:</strong>
                                                <input type="checkbox" t-att-checked="parcel.is_billable_expenses" disabled="disabled"/>
                                            </div>
                                            <br/>
                                            <div><strong>Is Billable Water:</strong>
                                                <input type="checkbox" t-att-checked="parcel.is_billable_water" disabled="disabled"/>
                                            </div>

                                        </div>
                                        <div class="col-md-4 text-center">
                                            <div class="d-flex flex-column justify-content-between" style="height: 100%;">
                                                <div t-if="parcel.aerial_img">
                                                    <img t-att-src="'/web/image?model=wua.parcel&amp;id=' + str(parcel.id) + '&amp;field=aerial_img'" class="img-thumbnail" style="width:100%; max-width:300px;"/>
                                                </div>
                                                <div class="col-md-12 text-center mt-auto">
                                                    <a name="gis_url_button" t-if="gis_url" t-att-href="gis_url" target="_blank" class="btn oe_stat_button">
                                                        <div class="fa fa-fw fa-map-marker o_button_icon"></div>
                                                            View in Map
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div name="pages">
                                        <ul name="tabs_titles" class="nav nav-tabs" role="tablist">
                                            <li class="active"><a href="#partnerlinks" role="tab" data-toggle="tab">Partner Links</a></li>
                                            <li><a href="#subparcels" role="tab" data-toggle="tab">Subparcels</a></li>
                                            <li><a href="#concessions" role="tab" data-toggle="tab">Concessions</a></li>
                                        </ul>
                                        <div name="tabs_content" class="tab-content">
                                            <div class="tab-pane active" id="partnerlinks">
                                                <h4>Partner Links</h4>
                                                <table class="table table-hover">
                                                    <thead>
                                                        <tr>
                                                            <th>Partner</th>
                                                            <th>Profile</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <t t-if="parcel.partnerlink_ids">
                                                            <t t-foreach="parcel.partnerlink_ids" t-as="partnerlink">
                                                                <tr>
                                                                    <td><t t-esc="partnerlink.partner_id.name"/></td>
                                                                    <td>
                                                                        <t t-if="partnerlink.profile == 'O'"><span>Owner</span></t>
                                                                        <t t-if="partnerlink.profile == 'P'"><span>Payer</span></t>
                                                                        <t t-if="partnerlink.profile == 'L'"><span>Lessee</span></t>
                                                                    </td>
                                                                </tr>
                                                            </t>
                                                        </t>
                                                        <t t-if="not parcel.partnerlink_ids">
                                                            <tr>
                                                                <td colspan="2">No partner links available</td>
                                                            </tr>
                                                        </t>
                                                    </tbody>
                                                </table>
                                            </div>
                                            <div class="tab-pane" id="subparcels">
                                                <h4>Subparcels</h4>
                                                <table class="table table-hover">
                                                    <thead>
                                                        <tr>
                                                            <th>Type</th>
                                                            <th>Area Percentage</th>
                                                            <th>Area Official</th>
                                                            <th>Cultivation</th>
                                                            <th>Variety</th>
                                                            <th>Irrigation System</th>
                                                            <th>Production Method</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <t t-if="parcel.subparcel_ids">
                                                            <t t-foreach="parcel.subparcel_ids" t-as="subparcel">
                                                                <tr>
                                                                    <td><t t-esc="subparcel.subparceltype_id.display_name"/></td>
                                                                    <td><t t-esc="subparcel.area_perc"/></td>
                                                                    <td><t t-esc="subparcel.area_official"/></td>
                                                                    <td><t t-esc="subparcel.cultivation_id.display_name"/></td>
                                                                    <td><t t-esc="subparcel.cultivationvariety_id.display_name"/></td>
                                                                    <td><t t-esc="subparcel.irrigationsystem_id.display_name"/></td>
                                                                    <td><t t-esc="subparcel.productionmethod_id.display_name"/></td>
                                                                </tr>
                                                            </t>
                                                        </t>
                                                        <t t-if="not parcel.subparcel_ids">
                                                            <tr>
                                                                <td colspan="7">No subparcels available</td>
                                                            </tr>
                                                        </t>
                                                    </tbody>
                                                </table>
                                            </div>
                                            <div class="tab-pane" id="concessions">
                                                <h4>Concessions</h4>
                                                <table class="table table-hover">
                                                    <thead>
                                                        <tr>
                                                            <th>Name</th>
                                                            <th>Description</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <t t-if="parcel.concession_ids">
                                                            <t t-foreach="parcel.concession_ids" t-as="concession">
                                                                <tr>
                                                                    <td><t t-esc="concession.name"/></td>
                                                                    <td><t t-esc="concession.description"/></td>
                                                                </tr>
                                                            </t>
                                                        </t>
                                                        <t t-if="not parcel.concession_ids">
                                                            <tr>
                                                                <td colspan="2">No concessions available</td>
                                                            </tr>
                                                        </t>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </template>


    </data>
</odoo>