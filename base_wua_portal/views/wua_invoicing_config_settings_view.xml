<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_invoicing_config_settings_view_form" model="ir.ui.view">
        <field name="name">Parameters</field>
        <field name="model">wua.invoicing.configuration</field>
        <field name="inherit_id" ref="base_wua_invoicing.wua_invoicing_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='show_owners']" position="after">
                <field name="liquidation_on_portal"/>
            </xpath>
        </field>
    </record>
</odoo>
