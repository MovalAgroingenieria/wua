<odoo>
    <data>

        <template id="assets_frontend" inherit_id="website.assets_frontend">
            <xpath expr="." position="inside">
                <script type="text/javascript" src="/base_wua_portal/static/src/js/portal_invoices.js"/>
            </xpath>
        </template>
        <template id="portal_my_invoices" inherit_id="website_portal_sale.portal_my_invoices" name="My Invoices and Payments">
            <xpath expr="//h3[@class='page-header']" position="attributes">
                <attribute name="style">display: none;</attribute>
            </xpath>
            <xpath expr="//h3[@class='page-header']" position="after">
                <h3 class="page-header">
                    <t t-if="liquidation_on_portal">Your Liquidations</t>
                    <t t-else="">Your Invoices and Payments</t>
                </h3>
            </xpath>
            <xpath expr="//h3[@class='page-header']" position="before">
                <form action="/my/invoices" method="get" class="mb-3">
                    <div class="row">
                        <div class="col-md-2">
                            <select id="search_field" name="search_field" class="form-control">
                                <t t-if="liquidation_on_portal">
                                    <option value="name" t-att-selected="'name' == search_field">Liquidation #</option>
                                    <option value="invoiceset" t-att-selected="'invoiceset' == search_field">Liquidation Set</option>
                                    <option value="date_invoice" t-att-selected="'date_invoice' == search_field">Liquidation Date</option>
                                </t>
                                <t t-else="">
                                    <option value="name" t-att-selected="'name' == search_field">Invoice #</option>
                                    <option value="invoiceset" t-att-selected="'invoiceset' == search_field">Invoiceset</option>
                                    <option value="date_invoice" t-att-selected="'date_invoice' == search_field">Invoice Date</option>
                                </t>
                            </select>
                        </div>
                        <div class="col-md-8">
                            <input type="text" name="search" class="form-control" placeholder="Search..."
                                t-att-value="search_query or ''"/>
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-primary btn-block">Search</button>
                        </div>
                    </div>
                </form>
            </xpath>
            <xpath expr="//table[contains(@class, 'o_my_status_table')]" position="attributes">
                            <attribute name="t-if">False</attribute>
            </xpath>
            <xpath expr="//table[contains(@class, 'o_my_status_table')]" position="after">
                <form id="print_invoices_form" action="/my/invoices/pdf_multi" method="post">
                    <table class="table table-hover o_my_status_table">
                        <thead>
                            <tr class="active">
                                <th>
                                    <input type="checkbox" id="select_all" onclick="toggleCheckboxes(this)"/>
                                </th>
                                <t t-if="liquidation_on_portal">
                                    <th width="15%">Liquidation</th>
                                    <th width="12%">Liquidation Set</th>
                                    <th width="15%">Liquidation Date</th>
                                </t>
                                <t t-else="">
                                    <th width="15%">Invoice #</th>
                                    <th width="12%">Invoiceset</th>
                                    <th width="12%">Invoice Date</th>
                                </t>
                                <th width="12%">Due Date</th>
                                <th></th>
                                <th>Amount Due</th>
                                <th>Amount Total</th>
                            </tr>
                        </thead>
                        <t t-foreach="invoices" t-as="invoice">
                            <tr>
                                <td>
                                    <input type="checkbox" name="invoice_ids" t-att-value="invoice.id"/>
                                </td>
                                <td width="15%">
                                    <a t-att-href="'/my/invoices/pdf/'+str(invoice.id)" t-att-title="invoice.number">
                                        <t t-esc="invoice.number"/>
                                    </a>
                                </td>
                                <td width="12%">
                                    <span><t t-esc="invoice.invoiceset_id.description"/></span>
                                </td>
                                <td width="12%"><span t-field="invoice.date_invoice"/></td>
                                <td width="12%"><span t-field="invoice.date_due"/></td>
                                <td>
                                    <t t-if="invoice.state == 'open'">
                                        <span class="label label-info">
                                            <i class="fa fa-fw fa-clock-o"/> Waiting for Payment
                                        </span>
                                    </t>
                                    <t t-if="invoice.state == 'paid'">
                                        <span class="label label-default">
                                            <i class="fa fa-fw fa-check"/> Paid
                                        </span>
                                    </t>
                                    <t t-if="invoice.state == 'cancel'">
                                        <span class="label label-default">
                                            <i class="fa fa-fw fa-remove"/> Cancelled
                                        </span>
                                    </t>
                                </td>
                                <td>
                                    <span t-field="invoice.residual" t-options='{"widget": "monetary", "display_currency": invoice.currency_id}'/>
                                </td>
                                <td>
                                    <span t-field="invoice.amount_total" t-options='{"widget": "monetary", "display_currency": invoice.currency_id}'/>
                                </td>
                            </tr>
                        </t>
                    </table>
                    <button type="submit" id="print_btn" class="btn btn-primary mt-3">
                        Print Selected Invoices
                    </button>
                </form>
            </xpath>
        </template>

    </data>
</odoo>