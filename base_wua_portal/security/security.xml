<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="0">

        <record id="rule_wua_parcel_group_portal_user" model="ir.rule">
            <field name="name">Rule for Wua Portal User on parcels</field>
            <field name="model_id" ref="base_wua.model_wua_parcel"/>
            <field name="domain_force">
                ['|',
                 ('partnerlink_ids.partner_id','=',user.partner_id.id),
                 ('partnerlink_ids.partner_id','parent_of',user.partner_id.id)]
            </field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        </record>

        <record id="rule_wua_partnerlink_group_portal_user" model="ir.rule">
            <field name="name">Rule for Wua Portal User on partner links</field>
            <field name="model_id" ref="base_wua.model_wua_parcel_partnerlink"/>
            <field name="domain_force">
                ['|',
                 ('partner_id','=',user.partner_id.id),
                 ('partner_id','parent_of',user.partner_id.id)]
            </field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        </record>

    </data>


</odoo>