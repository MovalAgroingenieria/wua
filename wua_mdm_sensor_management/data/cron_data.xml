<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sensor_readings_refresh_cron" model="ir.cron">
        <field name="name">Refresh Sensor Readings Materialized Views</field>
        <field name="model">mdm.device.parcellink</field>
        <field name="function">cron_refresh_materialized_views</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="doall" eval="False"/>
        <field name="active" eval="False"/>
        <field name="nextcall" eval="(DateTime.now().replace(hour=0, minute=0, second=0, microsecond=0) + timedelta(days=1, hours=9)).strftime('%Y-%m-%d %H:%M:%S')"/>
        <field name="priority">5</field>
    </record>

</odoo>