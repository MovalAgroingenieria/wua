<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_infrastructure_config_settings_view_form" model="ir.ui.view">
        <field name="name">Parameters (Monitoring Infrastucture)</field>
        <field name="model">wua.infrastructure.configuration</field>
        <field name="inherit_id" ref="base_wua_infrastructure.wua_infrastructure_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[last()]" position="before">
                <group string="Monitoring Settings" style="width:60%;">
                    <group>
                        <field name="threshold_pump_flow"/>
                        <field name="threshold_pump_pressure"/>
                        <field name="threshold_pump_power"/>
                    </group>
                    <group>
                        <field name="limit_energy_efficiency_a"/>
                        <field name="limit_energy_efficiency_b"/>
                        <field name="limit_energy_efficiency_c"/>
                        <field name="limit_energy_efficiency_d"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

</odoo>