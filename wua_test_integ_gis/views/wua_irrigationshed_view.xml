<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_irrigationshed_view_form" model="ir.ui.view">
        <field name="name">Irrigation Sheds (form view)</field>
        <field name="model">wua.irrigationshed</field>
        <field name="inherit_id" ref="base_wua_infrastructure.wua_irrigationshed_view_form"/>        
        <field name="arch" type="xml">
            <xpath expr="//group[@name='slave_data']" position="after">
                <templates>
                    <t t-name="gisviewer">
                         <div id="gisviewer_shed">
                             <field name="html_gisviewer_frame" widget="html"/>
                         </div>
                    </t>
                </templates>            
            </xpath>        
        </field>
    </record>

</odoo>