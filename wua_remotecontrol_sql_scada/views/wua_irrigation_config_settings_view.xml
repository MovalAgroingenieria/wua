<?xml version="1.0" encoding="utf-8"?>
<odoo>

       <record id="wua_irrigation_config_settings_view_form_scada"
            model="ir.ui.view">
              <field name="name">Parameters (SCADA SQL)</field>
        <field name="model">wua.irrigation.configuration</field>
        <field name="inherit_id"
               ref="base_wua_remotecontrol_rest.wua_irrigation_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='remote_control']" position="after">
                <group name="remote_control_scada"
                       string="SCADA SQL - Connection Parameters"
                       attrs="{'invisible': [('enable_remotecontrol', '=', False)]}">
                    <field name="sql_server_scada" string="Server"
                           attrs="{'invisible': [('enable_remotecontrol', '=', False)]}"/>
                    <field name="sql_port_scada" string="Port"
                           attrs="{'invisible': [('enable_remotecontrol', '=', False)]}"/>
                    <field name="sql_database_scada" string="Database"
                           attrs="{'invisible': [('enable_remotecontrol', '=', False)]}"/>
                    <field name="sql_uid_scada" string="User ID"
                           attrs="{'invisible': [('enable_remotecontrol', '=', False)]}"/>
                    <field name="sql_pwd_scada" string="Password" password="True"
                           attrs="{'invisible': [('enable_remotecontrol', '=', False)]}"/>
                    <field name="import_from_readings_scada"
                           attrs="{'invisible': [('enable_remotecontrol', '=', False)]}"/>
                </group>
            </xpath>
        </field>
    </record>


</odoo>
