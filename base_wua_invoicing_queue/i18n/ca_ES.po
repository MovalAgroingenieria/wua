#. module: base_wua_invoicing_queue
#: code:addons/base_wua_invoicing_queue/models/wua_invoiceset.py:144
#, python-format
msgid "Invoice set calculation and validation have been enqueued and will run in the background. Follow the validation progress bar on this form."
msgstr "El càlcul i la validació del lot s'han posat en cua i s'executaran en segon pla. Seguiu la barra de progrés de validació en aquest formulari."

#. module: base_wua_invoicing_queue
#: code:addons/base_wua_invoicing_queue/models/wua_invoiceset.py:129
#, python-format
msgid "Invoice set calculation has been enqueued and will run in the background. Follow its progress in the Job Queue."
msgstr "El càlcul del lot s'ha posat en cua i s'executarà en segon pla. Seguiu el seu progrés a la cua de treballs."

#. module: base_wua_invoicing_queue
#: code:addons/base_wua_invoicing_queue/models/wua_invoiceset.py:162
#, python-format
msgid "Invoice validation has been enqueued and will run in the background. Follow the progress bar on this form."
msgstr "La validació de factures s'ha posat en cua i s'executarà en segon pla. Seguiu la barra de progrés en aquest formulari."

#. module: base_wua_invoicing_queue
#: model:ir.model.fields,help:base_wua_invoicing_queue.field_wua_invoiceset_validate_done
msgid "Invoices already validated, derived on read from a COUNT so the parallel workers never write to this record (no row lock)."
msgstr "Factures ja validades, calculades en lectura mitjançant un COUNT perquè els treballadors en paral·lel no escriguin mai en aquest registre (sense bloqueig de fila)."

#. module: base_wua_invoicing_queue
#: model:ir.model.fields,field_description:base_wua_invoicing_queue.field_wua_invoiceset_validate_total
msgid "Invoices to validate"
msgstr "Factures per validar"

#. module: base_wua_invoicing_queue
#: model:ir.model.fields,field_description:base_wua_invoicing_queue.field_wua_invoiceset_validate_done
msgid "Invoices validated"
msgstr "Factures validades"

#. module: base_wua_invoicing_queue
#: model:ir.model.fields,help:base_wua_invoicing_queue.field_wua_invoiceset_validate_progress
msgid "Percentage of invoices validated by the parallel jobs."
msgstr "Percentatge de factures validades pels treballs en paral·lel."

#. module: base_wua_invoicing_queue
#: model:ir.ui.view,arch_db:base_wua_invoicing_queue.wua_invoiceset_view_form_queue
msgid "The calculation and validation will run in the background. Continue?"
msgstr "El càlcul i la validació s'executaran en segon pla. Continuar?"

#. module: base_wua_invoicing_queue
#: model:ir.ui.view,arch_db:base_wua_invoicing_queue.wua_invoiceset_view_form_queue
