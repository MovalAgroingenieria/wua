<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wizard_cropunit_creation_summary_view_form" model="ir.ui.view">
        <field name="name">Crop Unit Creation Summary</field>
        <field name="model">wizard.cropunit.creation.summary</field>
        <field name="arch" type="xml">
            <form string="Crop Unit Creation Summary">
                <group>
                    <field name="message" nolabel="1" colspan="2"/>
                </group>
                <footer>
                    <button string="Close" type="object" name="action_close" class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
