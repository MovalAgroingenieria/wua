#. module: base_wua_hydric_estimation
#: model:mail.template,body_html:base_wua_hydric_estimation.email_template_irrigation_recommendation
msgid "\n"
"<div style=\"font-family: 'Lucida Grande', Ubuntu, Arial, Verdana, sans-serif; font-size: 12px; color: rgb(34, 34, 34); background-color: #FFF; \">\n"
"\n"
"    <p>\n"
"        % if object.partner_id:\n"
"        Dear ${object.partner_id.name or ''},\n"
"        % else:\n"
"        Dear Partner,\n"
"        % endif\n"
"    </p>\n"
"\n"
"    <p>\n"
"        % if object.cropunit_id and object.parcel_id:\n"
"        Here is a summary of the irrigation recommendation for the crop unit <strong>${object.cropunit_id.name or ''}</strong> belonging to parcel <strong>${object.parcel_id.name or ''}</strong>:\n"
"        % elif object.cropunit_id:\n"
"        Here is a summary of the irrigation recommendation for the crop unit <strong>${object.cropunit_id.name or ''}</strong>:\n"
"        % else:\n"
"        Here is a summary of your irrigation recommendation:\n"
"        % endif\n"
"    </p>\n"
"\n"
"    <table style=\"width: 100%; border-collapse: collapse; margin: 15px 0;\">\n"
"        % if object.recommendationperiod_id and object.recommendationperiod_id.initial_date and object.recommendationperiod_id.end_date:\n"
"        <tr>\n"
"            <td style=\"padding: 8px; font-weight: bold; width: 200px;\">Application Period:</td>\n"
"            <td style=\"padding: 8px;\">${object.recommendationperiod_id.initial_date or ''} - ${object.recommendationperiod_id.end_date or ''}</td>\n"
"        </tr>\n"
"        % endif\n"
"        % if object.cultivation_id:\n"
"        <tr style=\"background-color: #f5f5f5;\">\n"
"            <td style=\"padding: 8px; font-weight: bold; width: 200px;\">Cultivation:</td>\n"
"            <td style=\"padding: 8px;\">${object.cultivation_id.name or ''}</td>\n"
"        </tr>\n"
"        % endif\n"
"        <tr>\n"
"            <td style=\"padding: 8px; font-weight: bold; width: 200px;\">Dotation:</td>\n"
"            <td style=\"padding: 8px;\">${'{:.2f}'.format(object.gin or 0)} m³/ha</td>\n"
"        </tr>\n"
"        <tr style=\"background-color: #f5f5f5;\">\n"
"            <td style=\"padding: 8px; font-weight: bold; width: 200px;\">Recommended Volume:</td>\n"
"            <td style=\"padding: 8px;\">${'{:.2f}'.format(object.total_gin or 0)} m³</td>\n"
"        </tr>\n"
"    </table>\n"
"\n"
"    <p>For more details, please review the attached PDF report.</p>\n"
"\n"
"    <p>\n"
"        Best regards.<br/>\n"
"    </p>\n"
"</div>\n"
"        "
msgstr "\n"
"<div style=\"font-family: 'Lucida Grande', Ubuntu, Arial, Verdana, sans-serif; font-size: 12px; color: rgb(34, 34, 34); background-color: #FFF; \">\n"
"\n"
"    <p>\n"
"        % if object.partner_id:\n"
"        Benvolgut/da ${object.partner_id.name or ''},\n"
"        % else:\n"
"        Benvolgut/da soci/sòcia,\n"
"        % endif\n"
"    </p>\n"
"\n"
"    <p>\n"
"        % if object.cropunit_id and object.parcel_id:\n"
"        A continuació es mostra un resum de la recomanació de reg per a la unitat de cultiu <strong>${object.cropunit_id.name or ''}</strong> pertanyent a la parcel·la <strong>${object.parcel_id.name or ''}</strong>:\n"
"        % elif object.cropunit_id:\n"
"        A continuació es mostra un resum de la recomanació de reg per a la unitat de cultiu <strong>${object.cropunit_id.name or ''}</strong>:\n"
"        % else:\n"
"        A continuació es mostra un resum de la seva recomanació de reg:\n"
"        % endif\n"
"    </p>\n"
"\n"
"    <table style=\"width: 100%; border-collapse: collapse; margin: 15px 0;\">\n"
"        % if object.recommendationperiod_id and object.recommendationperiod_id.initial_date and object.recommendationperiod_id.end_date:\n"
"        <tr>\n"
"            <td style=\"padding: 8px; font-weight: bold; width: 200px;\">Període d'Aplicació:</td>\n"
"            <td style=\"padding: 8px;\">${object.recommendationperiod_id.initial_date or ''} - ${object.recommendationperiod_id.end_date or ''}</td>\n"
"        </tr>\n"
"        % endif\n"
"        % if object.cultivation_id:\n"
"        <tr style=\"background-color: #f5f5f5;\">\n"
"            <td style=\"padding: 8px; font-weight: bold; width: 200px;\">Cultiu:</td>\n"
"            <td style=\"padding: 8px;\">${object.cultivation_id.name or ''}</td>\n"
"        </tr>\n"
"        % endif\n"
"        <tr>\n"
"            <td style=\"padding: 8px; font-weight: bold; width: 200px;\">Dotació:</td>\n"
"            <td style=\"padding: 8px;\">${'{:.2f}'.format(object.gin or 0)} m³/ha</td>\n"
"        </tr>\n"
"        <tr style=\"background-color: #f5f5f5;\">\n"
"            <td style=\"padding: 8px; font-weight: bold; width: 200px;\">Volum Recomanat:</td>\n"
"            <td style=\"padding: 8px;\">${'{:.2f}'.format(object.total_gin or 0)} m³</td>\n"
"        </tr>\n"
"    </table>\n"
"\n"
"    <p>Per a més detalls, si us plau revisi l'informe PDF adjunt.</p>\n"
"\n"
"    <p>\n"
"        Atentament.<br/>\n"
"    </p>\n"
"</div>\n"
"        "

#. module: base_wua_hydric_estimation
#: model:mail.template,body_html:base_wua_hydric_estimation.email_template_calculation_notification
msgid "\n"
"<div style=\"font-family: 'Lucida Grande', Ubuntu, Arial, Verdana, sans-serif; font-size: 12px; color: rgb(34, 34, 34); background-color: #FFF; \">\n"
"\n"
"    <p>Dear Administrator,</p>\n"
"\n"
"    <p>The irrigation recommendations have been successfully calculated for the period:</p>\n"
"\n"
"    <table style=\"width: 100%; border-collapse: collapse; margin: 15px 0;\">\n"
"        <tr style=\"background-color: #f5f5f5;\">\n"
"            <td style=\"padding: 8px; font-weight: bold;\">Initial Date:</td>\n"
"            <td style=\"padding: 8px;\">${object.initial_date or ''}</td>\n"
"        </tr>\n"
"        <tr>\n"
"            <td style=\"padding: 8px; font-weight: bold;\">End Date:</td>\n"
"            <td style=\"padding: 8px;\">${object.end_date or ''}</td>\n"
"        </tr>\n"
"        <tr style=\"background-color: #f5f5f5;\">\n"
"            <td style=\"padding: 8px; font-weight: bold;\">Number of Recommendations:</td>\n"
"            <td style=\"padding: 8px;\">${len(object.hydricneed_ids)}</td>\n"
"        </tr>\n"
"        <tr>\n"
"            <td style=\"padding: 8px; font-weight: bold;\">Total Gross Irrigation Needs:</td>\n"
"            <td style=\"padding: 8px;\">${'{:.2f}'.format(object.sum_total_gin or 0)} m³</td>\n"
"        </tr>\n"
"    </table>\n"
"\n"
"    <p>You can access the recommendations from the system or send individual recommendations to partners.</p>\n"
"\n"
"</div>\n"
"        "
msgstr "\n"
"<div style=\"font-family: 'Lucida Grande', Ubuntu, Arial, Verdana, sans-serif; font-size: 12px; color: rgb(34, 34, 34); background-color: #FFF; \">\n"
"\n"
"    <p>Benvolgut/da administrador/a,</p>\n"
"\n"
"    <p>Les recomanacions de reg s'han calculat correctament per al període:</p>\n"
"\n"
"    <table style=\"width: 100%; border-collapse: collapse; margin: 15px 0;\">\n"
"        <tr style=\"background-color: #f5f5f5;\">\n"
"            <td style=\"padding: 8px; font-weight: bold;\">Data Inicial:</td>\n"
"            <td style=\"padding: 8px;\">${object.initial_date or ''}</td>\n"
"        </tr>\n"
"        <tr>\n"
"            <td style=\"padding: 8px; font-weight: bold;\">Data Final:</td>\n"
"            <td style=\"padding: 8px;\">${object.end_date or ''}</td>\n"
"        </tr>\n"
"        <tr style=\"background-color: #f5f5f5;\">\n"
"            <td style=\"padding: 8px; font-weight: bold;\">Nombre de Recomanacions:</td>\n"
"            <td style=\"padding: 8px;\">${len(object.hydricneed_ids)}</td>\n"
"        </tr>\n"
"        <tr>\n"
"            <td style=\"padding: 8px; font-weight: bold;\">Necessitats Hídriques Brutes Totals:</td>\n"
"            <td style=\"padding: 8px;\">${'{:.2f}'.format(object.sum_total_gin or 0)} m³</td>\n"
"        </tr>\n"
"    </table>\n"
"\n"
"    <p>Podeu accedir a les recomanacions des del sistema o enviar recomanacions individuals als socis.</p>\n"
"\n"
"</div>\n"
"        "

