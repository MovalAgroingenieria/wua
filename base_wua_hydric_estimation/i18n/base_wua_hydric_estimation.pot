#. module: base_wua_hydric_estimation
#: model:mail.template,body_html:base_wua_hydric_estimation.email_template_calculation_notification
msgid "\n"
"<div style=\"font-family: 'Lucida Grande', Ubuntu, Arial, Verdana, sans-serif; font-size: 12px; color: rgb(34, 34, 34); background-color: #FFF; \">\n"
"\n"
"    <p>Dear Administrator,</p>\n"
"\n"
"    <p>The irrigation recommendations have been successfully calculated for the control period:</p>\n"
"\n"
"    <table style=\"width: 100%; border-collapse: collapse; margin: 15px 0;\">\n"
"        <tr>\n"
"            <td style=\"padding: 8px; font-weight: bold; width: 200px;\">Control Period:</td>\n"
"            <td style=\"padding: 8px;\">${object.name}</td>\n"
"        </tr>\n"
"        <tr style=\"background-color: #f5f5f5;\">\n"
"            <td style=\"padding: 8px; font-weight: bold;\">Initial Date:</td>\n"
"            <td style=\"padding: 8px;\">${object.initial_date}</td>\n"
"        </tr>\n"
"        <tr>\n"
"            <td style=\"padding: 8px; font-weight: bold;\">End Date:</td>\n"
"            <td style=\"padding: 8px;\">${object.end_date}</td>\n"
"        </tr>\n"
"        <tr style=\"background-color: #f5f5f5;\">\n"
"            <td style=\"padding: 8px; font-weight: bold;\">Number of Recommendations:</td>\n"
"            <td style=\"padding: 8px;\">${object.number_of_hydricneeds}</td>\n"
"        </tr>\n"
"        <tr>\n"
"            <td style=\"padding: 8px; font-weight: bold;\">Total Gross Irrigation Needs:</td>\n"
"            <td style=\"padding: 8px;\">${'{:.2f}'.format(object.sum_total_gin or 0)} m³</td>\n"
"        </tr>\n"
"    </table>\n"
"\n"
"    <p>You can access the recommendations from the control period form or send individual recommendations to partners.</p>\n"
"\n"
"</div>\n"
"        "
msgstr ""

#. module: base_wua_hydric_estimation
#: model:mail.template,body_html:base_wua_hydric_estimation.email_template_irrigation_recommendation
msgid "\n"
"<div style=\"margin: 0px; padding: 0px;\">\n"
"    <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"        Dear ${object.partner_id.name or ''},\n"
"        <br/><br/>\n"
"        Please find attached the irrigation recommendation report for your crop unit <strong>${object.cropunit_id.name}</strong>.\n"
"        <br/><br/>\n"
"        <strong>Summary:</strong>\n"
"        <ul>\n"
"            <li>Parcel: ${object.parcel_id.name}</li>\n"
"            <li>Cultivation: ${object.cultivation_id.name}</li>\n"
"            <li>Application Period: ${object.initial_date} - ${object.end_date}</li>\n"
"            <li>Recommended Volume: ${object.total_gin} m³</li>\n"
"            <li>Dotation: ${object.gin} m³/ha</li>\n"
"        </ul>\n"
"        <br/>\n"
"        For more details, please review the attached PDF report.\n"
"        <br/><br/>\n"
"        Best regards,\n"
"        <br/>\n"
"        ${user.name}\n"
"    </p>\n"
"</div>\n"
"        "
msgstr ""

