<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <report id="wua_hydricneed_report"
            string="Irrigation Recommendation"
            model="wua.hydricneed"
            report_type="qweb-pdf"
            file="base_wua_hydric_estimation.wua_hydricneed_report_document"
            name="base_wua_hydric_estimation.wua_hydricneed_report_document"
            paperformat="base_wua_report.paperformat_wua_reports" />

    <template id="wua_hydricneed_report_document">
        <t t-call="report.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="base_wua_report.wua_external_layout">

                    <t t-set="report_style" t-value="o.env['ir.values'].get_default('wua.configuration', 'reports_style')" />

                    <div class="page">

                        <div name="printing_date" class="text-right" style="margin: 0px; padding: 0px;">
                            <span>Printing date: <strong><span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y')"/></strong></span>
                        </div>

                        <div name="title" class="text-center" style="font-size: 16px;">
                            <strong>Irrigation Recommendation Report</strong>
                        </div>

                        <div name="general_data">
                            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                <t t-if="report_style == 'light'">
                                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;">
                                            <span class="fa fa-leaf" />
                                        </div>
                                        <div style="float: left; display: inline;">
                                            <strong>General Data</strong>
                                        </div>
                                    </div>
                                </t>
                                <t t-else="">
                                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;">
                                            <span class="fa fa-leaf" />
                                        </div>
                                        <div style="float: left; display: inline;">
                                            <strong>General Data</strong>
                                        </div>
                                    </div>
                                </t>
                            </div>
                            <div class="row" style="margin-top: 4px;">
                                <div class="col-xs-6">
                                    <table style="width: 100%;">
                                        <tbody>
                                            <tr>
                                                <td style="width: 40%; padding: 2px 0;">Irrigation Partner:</td>
                                                <td class="text-right" style="padding: 2px 0;"><span t-field="o.partner_id.name"/></td>
                                            </tr>
                                            <tr>
                                                <td style="padding: 2px 0;">Parcel:</td>
                                                <td class="text-right" style="padding: 2px 0;"><span t-field="o.parcel_id.name"/></td>
                                            </tr>
                                            <tr>
                                                <td style="padding: 2px 0;">Crop Unit:</td>
                                                <td class="text-right" style="padding: 2px 0;"><span t-field="o.cropunit_id.name"/></td>
                                            </tr>
                                            <tr>
                                                <td style="padding: 2px 0;">Cultivation:</td>
                                                <td class="text-right" style="padding: 2px 0;"><span t-field="o.cultivation_id.name"/></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                                <div class="col-xs-6">
                                    <table style="width: 100%;">
                                        <tbody>
                                            <tr>
                                                <td style="width: 50%; padding: 2px 0;">Surface:</td>
                                                <td class="text-right" style="padding: 2px 0;"><span t-field="o.area_gis_ha"/> ha</td>
                                            </tr>
                                            <tr>
                                                <td style="padding: 2px 0;">Irrigation System:</td>
                                                <td class="text-right" style="padding: 2px 0;"><span t-field="o.cropunit_id.irrigationsystem_id.name"/></td>
                                            </tr>
                                            <tr>
                                                <td style="padding: 2px 0;">Agricultural Season:</td>
                                                <td class="text-right" style="padding: 2px 0;"><span t-field="o.agriculturalseason_id.description"/></td>
                                            </tr>
                                            <tr>
                                                <td style="padding: 2px 0;">Application Period:</td>
                                                <td class="text-right" style="padding: 2px 0;">
                                                    <strong>
                                                        <t t-if="o.recommendationperiod_id">
                                                            <span t-field="o.recommendationperiod_id.initial_date"/> - <span t-field="o.recommendationperiod_id.end_date"/>
                                                        </t>
                                                        <t t-else="">
                                                            <span t-field="o.initial_date"/> - <span t-field="o.end_date"/>
                                                        </t>
                                                    </strong>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <div name="agronomic_data">
                            <div class="row h4 mt16 mb4" style="padding-bottom: 4px;">
                                <t t-if="report_style == 'light'">
                                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;">
                                            <span class="fa fa-bar-chart" />
                                        </div>
                                        <div style="float: left; display: inline;">
                                            <strong>Agronomic Data</strong>
                                        </div>
                                    </div>
                                </t>
                                <t t-else="">
                                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;">
                                            <span class="fa fa-bar-chart" />
                                        </div>
                                        <div style="float: left; display: inline;">
                                            <strong>Agronomic Data</strong>
                                        </div>
                                    </div>
                                </t>
                            </div>
                            <div class="row" style="margin-top: 4px;">
                                <div class="col-xs-6">
                                    <table style="width: 100%;">
                                        <tbody>
                                            <tr>
                                                <td style="width: 60%; padding: 2px 0;">Mean NDVI:</td>
                                                <td class="text-right" style="padding: 2px 0;"><span t-field="o.mean_ndvi"/></td>
                                            </tr>
                                            <tr>
                                                <td style="padding: 2px 0;">Adjusted Kc:</td>
                                                <td class="text-right" style="padding: 2px 0;"><span t-field="o.kc"/></td>
                                            </tr>
                                            <tr>
                                                <td style="padding: 2px 0;">ET0 Period:</td>
                                                <td class="text-right" style="padding: 2px 0;"><span t-field="o.accumulated_et0"/> mm</td>
                                            </tr>
                                            <tr>
                                                <td style="padding: 2px 0;">ETc:</td>
                                                <td class="text-right" style="padding: 2px 0;"><span t-field="o.accumulated_etc"/> mm</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                                <div class="col-xs-6">
                                    <table style="width: 100%;">
                                        <tbody>
                                            <tr>
                                                <td style="width: 60%; padding: 2px 0;">Precipitation:</td>
                                                <td class="text-right" style="padding: 2px 0;"><span t-field="o.accumulated_pe"/> mm</td>
                                            </tr>
                                            <tr>
                                                <td style="padding: 2px 0;">Net Irrigation Needs:</td>
                                                <td class="text-right" style="padding: 2px 0;"><span t-field="o.nin"/> mm</td>
                                            </tr>
                                            <tr>
                                                <td style="padding: 2px 0;">Irrigation Efficiency:</td>
                                                <td class="text-right" style="padding: 2px 0;">
                                                    <span t-esc="'%.0f' % (o.standard_application_efficiency * 100)"/>%
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <div name="recommendation">
                            <div class="row h4 mt16 mb4" style="padding-bottom: 4px;">
                                <t t-if="report_style == 'light'">
                                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;">
                                            <span class="fa fa-moval-hydric-estimation" />
                                        </div>
                                        <div style="float: left; display: inline;">
                                            <strong>Irrigation Recommendation</strong>
                                        </div>
                                    </div>
                                </t>
                                <t t-else="">
                                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;">
                                            <span class="fa fa-moval-hydric-estimation" />
                                        </div>
                                        <div style="float: left; display: inline;">
                                            <strong>Irrigation Recommendation</strong>
                                        </div>
                                    </div>
                                </t>
                            </div>
                            <div class="row" style="margin-top: 4px;">
                                <div class="col-xs-12">
                                    <table style="width: 100%;">
                                        <tbody>
                                            <tr>
                                                <td style="width: 50%; padding: 2px 0;">Recommended Volume:</td>
                                                <td class="text-right" style="padding: 2px 0;">
                                                    <span t-field="o.total_gin"/> m³
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="padding: 2px 0;">Dotation:</td>
                                                <td class="text-right" style="padding: 2px 0;">
                                                    <span t-field="o.gin"/> m³/ha
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <div name="images_section">
                            <div class="row h4 mt16 mb4" style="padding-bottom: 4px;">
                                <t t-if="report_style == 'light'">
                                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;">
                                            <span class="fa fa-picture-o" />
                                        </div>
                                        <div style="float: left; display: inline;">
                                            <strong>Maps</strong>
                                        </div>
                                    </div>
                                </t>
                                <t t-else="">
                                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;">
                                            <span class="fa fa-picture-o" />
                                        </div>
                                        <div style="float: left; display: inline;">
                                            <strong>Maps</strong>
                                        </div>
                                    </div>
                                </t>
                            </div>

                            <t t-set="latest_ndvi" t-value="o.env['wua.cropunit.vegetationindex.ndvi'].search([('cropunit_id', '=', o.cropunit_id.id)], limit=1, order='data_date desc')"/>
                            <div class="row" style="margin-top: 4px;">
                                <div class="col-xs-6">
                                    <div style="text-align: center; margin-bottom: 4px;">
                                        <strong>NDVI Image</strong>
                                    </div>
                                    <div style="text-align: center;">
                                        <t t-if="latest_ndvi and latest_ndvi.vegetationindex_img">
                                            <img t-att-src="'data:image/png;base64,%s' % o.get_ndvi_with_cropunit_overlay(latest_ndvi)"
                                                 style="max-width: 100%; max-height: 280px; border: 2px solid #000;"/>
                                        </t>
                                        <t t-else="">
                                            <div style="height: 280px; border: 1px dashed #ccc; display: flex; align-items: center; justify-content: center;">
                                                <span style="color: #999;">No NDVI image available</span>
                                            </div>
                                        </t>
                                    </div>
                                </div>

                                <div class="col-xs-6">
                                    <div style="text-align: center; margin-bottom: 4px;">
                                        <strong>Aerial Image</strong>
                                    </div>
                                    <div style="text-align: center;">
                                        <t t-if="o.cropunit_id.aerial_image_shown">
                                            <img t-att-src="'data:image/png;base64,%s' % o.cropunit_id.aerial_image_shown"
                                                 style="max-width: 100%; max-height: 280px; border: 2px solid #000;"/>
                                        </t>
                                        <t t-else="">
                                            <div style="height: 280px; border: 1px dashed #ccc; display: flex; align-items: center; justify-content: center;">
                                                <span style="color: #999;">No aerial image available</span>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
