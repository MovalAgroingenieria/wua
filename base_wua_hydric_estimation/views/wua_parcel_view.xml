<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_parcel_view_form" model="ir.ui.view">
        <field name="name">wua.parcel.view.form.base_wua_hydric_estimation</field>
        <field name="model">wua.parcel</field>
        <field name="inherit_id" ref="base_wua.wua_parcel_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_see_gis_viewer']" position="after">
                <button name="action_get_hydricneeds"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-calculator">
                    <div class="o_form_field o_stat_info">
                        <span class="o_stat_text">
                            Recommen-
                        </span>
                        <span class="o_stat_text">
                            dations
                        </span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

</odoo>