<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_config_settings_view_form" model="ir.ui.view">
        <field name="name">Parameters</field>
        <field name="model">wua.configuration</field>
        <field name="inherit_id" ref="base_wua.wua_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[6]" position="after">
                 <group string="Irrigation Recommendations Settings">
                    <field name="default_standard_application_efficiency"
                           string="Application Efficiency (default)"
                           style="width:100px"/>
                    <field name="control_periodicity"
                           string="Control Periodicity (default)"
                           style="width:100px"/>
                    <field name="period_start_day"
                           string="Period Start Day"
                           style="width:100px"
                           attrs="{'invisible': [('control_periodicity', '!=', 7)]}"/>
                    <field name="automatic_calculation"
                           string="Automatic Calculation"
                           attrs="{'invisible': [('control_periodicity', '!=', 7)]}"/>
                    <field name="default_kc_ndvi_a"
                           string="Coefficient a for Kc (default)"
                           style="width:100px"/>
                    <field name="default_kc_ndvi_b"
                           string="Coefficient b for Kc (default)"
                           style="width:100px"/>
                    <field name="default_kc_ndvi_c"
                           string="Coefficient c for Kc (default)"
                           style="width:100px"/>
                    <field name="max_offset_alternative_ndvi"
                           string="Maximum offset for an alternative NDVI"
                           style="width:100px"/>
                    <field name="hydric_est_ndvi_model"
                           string="Hydric Estimation: NDVI Model"
                           style="width:250px"/>
                    <field name="hydric_est_et0_sensor_type"
                           string="Hydric Estimation: Sensor type for ET0"
                           style="width:250px"
                           options="{'no_create_edit':True}"/>
                    <field name="hydric_est_pe_sensor_type"
                           string="Hydric Estimation: Sensor type for Pe"
                           style="width:250px"
                           options="{'no_create_edit':True}"/>
                    <field name="kc_lower_saturation"
                           string="Kc: Lower saturation"
                           style="width:100px"/>
                    <field name="kc_upper_saturation"
                           string="Kc: Upper saturation"
                           style="width:100px"/>
                    <field name="notification_emails"
                           string="Notification emails"
                           placeholder="email1@example.com,email2@example.com"/>
                    <field name="aerial_image_wms"
                           string="Aerial Image: WMS Service"/>
                    <field name="aerial_image_layers"
                           string="Aerial Image: WMS Layers"/>
                    <field name="aerial_image_width"
                           string="Aerial Image: Width (pixels)"
                           style="width:100px"/>
                    <field name="aerial_image_height"
                           string="Aerial Image: Height (pixels)"
                           style="width:100px"/>
                    <field name="aerial_image_zoom"
                           string="Aerial Image: Zoom"
                           style="width:100px"/>
                    <field name="aerial_image_format"
                           string="Aerial Image: Format"
                           style="width:100px"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>