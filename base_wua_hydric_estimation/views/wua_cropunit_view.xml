<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_cropunit_view_form" model="ir.ui.view">
        <field name="name">wua.cropunit.view.form</field>
        <field name="model">wua.cropunit</field>
        <field name="arch" type="xml">
            <form duplicate="false">
                <field name="id" invisible="1"/>
                <field name="mapped_to_polygon" invisible="1"/>
                <field name="exists_current_recommendation" invisible="1"/>
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_get_hydric_estimations"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-calculator">
                            <div class="o_form_field o_stat_info">
                                <span class="o_stat_text">
                                    Recommen-
                                </span>
                                <span class="o_stat_text">
                                    dations
                                </span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title" colspan="2">
                        <field name="parcel_type" widget="radio"
                               options="{'horizontal': true}"
                               readonly="1"/>
                        <h2>
                            <field name="name"/>
                        </h2>
                        <field name="county_id"
                               readonly="1"/>
                    </div>
                    <group name="master_data_01"
                           attrs="{'invisible': ['|', ('id', '=', 0), ('mapped_to_polygon', '=', False)]}">
                        <group name="master_data_01_left">
                            <div name="section_aerial_img_content" colspan="2"
                                 class="text-center">
                                <div name="div_aerial_image"
                                     style="display:inline-block;">
                                    <field name="aerial_image_shown"
                                           widget="image"
                                           style="border-color:#696969;border-width:1px;border-style:solid"/>
                                </div>
                            </div>
                        </group>
                        <group name="master_data_02_right">
                            <field name="html_frame_googlemaps" widget="html" nolabel="1"/>
                        </group>
                    </group>
                    <group name="master_data_02" class="text-center">
                        <group name="master_data_02_left" class="text-left">
                            <div name="section_cropunit_data_title"
                                 colspan="2" class="text-center panel-body"
                                 style="background:#fbfbfb;border-color:#cccccc;border-width:1px;border-style:solid;height:50px;margin-bottom:20px;margin-left:1px;margin-right:4px">
                                <p>CROP UNIT DATA</p>
                            </div>
                            <field name="agriculturalseason_id"
                                   string="Agricultural Season"
                                   options="{'no_create_edit':True}"
                                   attrs="{'readonly': [('id', '>', 0)]}"/>
                            <field name="parcel_id"
                                   string="Parcel"
                                   style="width:250px"
                                   options="{'no_create_edit':True}"
                                   attrs="{'readonly': [('id', '>', 0)]}"/>
                            <field name="partner_id"
                                   string="Irrigation Partner"/>
                            <field name="cultivation_id"
                                   string="Cultivation"
                                   style="width:250px"
                                   options="{'no_create_edit':True}"/>
                            <field name="order_number"
                                   string="Order Number"
                                   style="width:100px"/>
                            <label for="initial_date"/>
                            <div>
                                <field name="initial_date" class="oe_inline"/>
                                <span class="oe_inline"> - </span>
                                <field name="end_date" class="oe_inline"/>
                            </div>
                            <field name="irrigationsystem_id"
                                   string="Irrigation System"
                                   style="width:250px"
                                   options="{'no_create_edit':True}"/>
                            <field name="standard_application_efficiency"
                                   string="Applic. Efficiency"
                                   style="width:100px"/>
                        </group>
                        <group name="master_data_02_right_no_recommendation"
                               attrs="{'invisible': [('exists_current_recommendation', '=', True)]}">
                            <div name="section_current_recommendation_title_no_recommendation"
                                 colspan="2" class="text-center panel-body"
                                 style="background:#fbfbfb;border-color:#cccccc;border-width:1px;border-style:solid;height:50px;margin-bottom:20px;margin-left:1px;margin-right:4px">
                                <p>CURRENT RECOMMENDATION</p>
                            </div>
                            <div name="no_recommendation"
                                 colspan="2" class="text-center">
                                <p>(No recommendations are available for the current date)</p>
                            </div>
                        </group>
                        <group name="master_data_02_right" class="text-left"
                               attrs="{'invisible': [('exists_current_recommendation', '=', False)]}">
                            <div name="section_current_recommendation_title"
                                 colspan="2" class="text-center panel-body"
                                 style="background:#fbfbfb;border-color:#cccccc;border-width:1px;border-style:solid;height:50px;margin-bottom:20px;margin-left:1px;margin-right:4px">
                                <p>CURRENT RECOMMENDATION</p>
                            </div>
                            <label for="current_controlperiod_initial_date"
                                   attrs="{'invisible': [('exists_current_recommendation', '=', False)]}"/>
                            <div attrs="{'invisible': [('exists_current_recommendation', '=', False)]}">
                                <field name="current_controlperiod_initial_date" class="oe_inline"/>
                                <span class="oe_inline"> - </span>
                                <field name="current_controlperiod_end_date" class="oe_inline"/>
                            </div>
                            <label for="current_controlperiod_et0"
                                   attrs="{'invisible': [('exists_current_recommendation', '=', False)]}"/>
                            <div attrs="{'invisible': [('exists_current_recommendation', '=', False)]}">
                                <field name="current_controlperiod_et0" class="oe_inline"/>
                                <span class="oe_inline"> mm, </span>
                                <field name="current_controlperiod_pe" class="oe_inline"/>
                                <span class="oe_inline"> mm</span>
                            </div>
                            <label for="current_controlperiod_kc"
                                   attrs="{'invisible': [('exists_current_recommendation', '=', False)]}"/>
                            <div attrs="{'invisible': [('exists_current_recommendation', '=', False)]}">
                                <span class="oe_inline">Kc(</span>
                                <field name="current_controlperiod_ndvi" class="oe_inline"/>
                                <span class="oe_inline">) = </span>
                                <field name="current_controlperiod_kc" class="oe_inline"/>
                            </div>
                            <!-- <label for="current_controlperiod_nin"
                                   attrs="{'invisible': [('exists_current_recommendation', '=', False)]}"/>
                            <div attrs="{'invisible': [('exists_current_recommendation', '=', False)]}">
                                <field name="current_controlperiod_nin" class="oe_inline"/>
                                <span class="oe_inline"> m³/ha</span>
                            </div> -->
                            <label for="current_controlperiod_gin"
                                   attrs="{'invisible': [('exists_current_recommendation', '=', False)]}"/>
                            <div attrs="{'invisible': [('exists_current_recommendation', '=', False)]}">
                                <field name="current_controlperiod_gin" class="oe_inline"/>
                                <span class="oe_inline"> m³/ha</span>
                            </div>
                            <label for="area_gis_ha"
                                   attrs="{'invisible': [('exists_current_recommendation', '=', False)]}"/>
                            <div attrs="{'invisible': [('exists_current_recommendation', '=', False)]}">
                                <field name="area_gis_ha" class="oe_inline"/>
                                <span class="oe_inline"> ha</span>
                            </div>
                            <div name="section_current_controlperiod_total_gin"
                                 colspan="2" class="text-center panel-body"
                                 style="border-color:#cccccc;border-width:1px;border-style:solid;height:50px;margin-top:15px;margin-left:25%;margin-right:25%"
                                 attrs="{'invisible': [('exists_current_recommendation', '=', False)]}">
                                <b><span class="oe_inline">Total = </span>
                                <field name="current_controlperiod_total_gin" class="oe_inline"/>
                                <span class="oe_inline"> m³</span></b>
                            </div>
                        </group>
                    </group>
                    <group name="slave_data">
                        <notebook name="slave_data_notebook">
                            <page name="page_notes" string="Notes">
                                <field name="notes"/>
                            </page>
                        </notebook>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"
                           widget="mail_followers" groups="base.group_user"/>
                    <field name="message_ids"
                           widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="wua_cropunit_view_tree" model="ir.ui.view">
        <field name="name">wua.cropunit.view.tree</field>
        <field name="model">wua.cropunit</field>
        <field name="arch" type="xml">
            <tree class="o_base_wua_hydric_estimation_cropunit_view_tree"
                  colors="green:state=='02_active';">
                <field name="name" string="Crop Unit"/>
                <field name="area_gis_ha" string="Area (ha)"/>
                <field name="parcel_id" string="Parcel"/>
                <field name="partner_id" string="Irrigation Partner"/>
                <field name="cultivation_id" string="Cultivation"/>
                <field name="order_number" string="Order N."/>
                <field name="initial_date" string="Initial date"/>
                <field name="end_date" string="End date"/>
                <field name="current_controlperiod_total_gin" string="Current Rec. (m³)"/>
                <field name="state" string="State"/>
            </tree>
        </field>
    </record>

    <record id="wua_cropunit_view_search" model="ir.ui.view">
        <field name="name">wua.cropunit.view.search</field>
        <field name="model">wua.cropunit</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Crop Unit"/>
                <field name="partner_id" string="Partner"/>
                <field name="cultivation_id" string="Cultivation"/>
                <field name="initial_date" string="Crop cycle initial date"/>
                <field name="end_date" string="Crop cycle end date"/>
                <field name="state" string="State"/>
                <filter string="Active agricultural season"
                        name="mapped_to_active_agriculturalseason_yes"
                        domain="[('mapped_to_active_agriculturalseason', '=', True)]"/>
                <separator/>
                <filter string="State: Not started"
                        name="state_not_started"
                        domain="[('state', '=', '01_not_started')]"/>
                <filter string="State: Active Crop"
                        name="state_active"
                        domain="[('state', '=', '02_active')]"/>
                <filter string="State: Finished"
                        name="state_closed"
                        domain="[('state', '=', '03_closed')]"/>
                <separator/>
                <filter name="mapped_to_polygon_yes"
                        string="With GIS link: Yes"
                        domain="[('mapped_to_polygon', '=', True)]"/>
                <filter name="mapped_to_polygon_no"
                        string="With GIS link: No"
                        domain="[('mapped_to_polygon', '!=', True)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Agricultural Season"
                            name="grouped_agriculturalseason"
                     context="{'group_by':'agriculturalseason_id'}"/>
                    <filter string="Partner"
                            name="grouped_partner"
                     context="{'group_by':'partner_id'}"/>
                    <filter string="Parcel"
                            name="grouped_parcel"
                     context="{'group_by':'parcel_id'}"/>
                    <filter string="Cultivation"
                            name="grouped_cultivation"
                     context="{'group_by':'cultivation_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="wua_cropunit_view_kanban" model="ir.ui.view">
        <field name="name">wua.cropunit.view.kanban</field>
        <field name="model">wua.cropunit</field>
        <field name="arch" type="xml">
            <kanban create="false"
                    group_create="false"
                    group_delete="false"
                    default_order="name">
                <field name="id"/>
                <field name="aerial_image_shown"/>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="area_gis_ha"/>
                <field name="cultivation_id"/>
                <field name="county_id"/>
                <field name="state_id"/>
                <field name="exists_current_recommendation"/>
                <field name="initial_date"/>
                <field name="end_date"/>
                <field name="current_controlperiod_total_gin"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_cropunit_kanban_image">
                                <t t-if="record.aerial_image_shown.raw_value">
                                    <img t-att-src="kanban_image('wua.cropunit', 'aerial_image_shown', record.id.raw_value)" alt="wua_cropunit" style="border-color:#696969;border-width:1px;border-style:solid"/>
                                </t>
                                <t t-else="">
                                    <img t-att-src="'/base_wua_hydric_estimation/static/src/img/avatar_cropunit.png'" width="150" alt="wua_cropunit_avatar" style="margin-top:40px"/>
                                </t>
                            </div>
                            <div class="oe_kanban_details" style="margin-top:10px">
                                <div class="text-center">
                                    <strong><field name="name"/></strong><br/>
                                    <strong>(<field name="state"/>)</strong>
                                </div>
                                <div class="container" style="margin-top:10px">
                                    <div name="div_content" class="row">
                                        <div name="div_content_01">
                                            <field name="partner_id"/>
                                        </div>
                                        <div name="div_content_02">
                                            <field name="cultivation_id"/>, <field name="area_gis_ha"/> ha
                                        </div>
                                        <div name="div_content_03">
                                            <field name="county_id"/> (<field name="state_id"/>)
                                        </div>
                                        <t t-if="record.exists_current_recommendation.value">
                                            <div name="div_content_04_01" style="margin-top:10px">
                                                <i class="fa fa-calculator fa-lg" style="margin-right:6px"/> <field name="initial_date"/> - <field name="end_date"/> : <strong><field name="current_controlperiod_total_gin"/> m³</strong>
                                            </div>
                                        </t>
                                        <t t-else="">
                                            <div name="div_content_04_02" style="margin-top:10px">
                                                <span>(no irrigation recommendations)</span>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="wua_cropunit_view_pivot" model="ir.ui.view">
        <field name="name">wua.cropunit.view.pivot</field>
        <field name="model">wua.cropunit</field>
        <field name="arch" type="xml">
            <pivot string="Agregated Values" display_quantity="true">
                <field name="partner_id" type="row"/>
                <field name="area_gis_ha" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="wua_cropunit_refresh_aerial_img" model="ir.actions.server">
        <field name="name">Refresh Aerial Image</field>
        <field name="model_id" ref="base_wua_hydric_estimation.model_wua_cropunit"/>
        <field name="code">
            action =  env['wua.cropunit'].browse(context['active_ids']).refresh_aerial_img()
        </field>
    </record>

    <record id="wua_cropunit_action_refresh_aerial_img" model="ir.values">
        <field name="name">Refresh Aerial Image</field>
        <field name="model">wua.cropunit</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('wua_cropunit_refresh_aerial_img'))"/>
    </record>

    <record id="wua_cropunit_action"
            model="ir.actions.act_window">
        <field name="name">Crop Units</field>
        <field name="res_model">wua.cropunit</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form,kanban,pivot</field>
        <field name="view_ids"
         eval="[(5, 0),
                (0, 0, {'view_mode': 'tree',
                        'view_id': ref('wua_cropunit_view_tree')}),
                (0, 0, {'view_mode': 'form',
                        'view_id': ref('wua_cropunit_view_form')}),
                (0, 0, {'view_mode': 'kanban',
                        'view_id': ref('wua_cropunit_view_kanban')}),
                (0, 0, {'view_mode': 'pivot',
                        'view_id': ref('wua_cropunit_view_pivot')})]"/>
        <field name="search_view_id" ref="wua_cropunit_view_search"/>
        <field name="context">
            {'search_default_mapped_to_active_agriculturalseason_yes': True}
        </field>
    </record>

    <menuitem id="wua_cropunit_menu"
              name="Crop Units"
              parent="base_wua.base_wua_census_landparcels_menu"
              action="wua_cropunit_action"
              sequence="25"/>

</odoo>