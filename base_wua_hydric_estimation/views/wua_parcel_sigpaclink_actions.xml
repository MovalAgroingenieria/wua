<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Server Action: Create Crop Units from Selected SIGPAC Enclosures -->
    <record id="wua_sigpaclink_create_cropunits" model="ir.actions.server">
        <field name="name">Create Crop Units from SIGPAC Enclosures</field>
        <field name="model_id" ref="base_wua_sigpac.model_wua_parcel_sigpaclink"/>
        <field name="state">code</field>
        <field name="code">
if context.get('active_ids'):
    action = env['wua.parcel.sigpaclink'].browse(context['active_ids']).action_create_cropunits_from_selected()
else:
    raise UserError('Please select at least one SIGPAC enclosure.')
        </field>
    </record>

    <record id="wua_sigpaclink_action_create_cropunits" model="ir.values">
        <field name="name">Create Crop Units from SIGPAC Enclosures</field>
        <field name="model">wua.parcel.sigpaclink</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('wua_sigpaclink_create_cropunits'))"/>
    </record>

</odoo>
