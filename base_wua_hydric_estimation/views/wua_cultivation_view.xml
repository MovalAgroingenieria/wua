<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_cultivation_view_form" model="ir.ui.view">
        <field name="name">wua.cultivation.view.form.base_wua_hydric_estimation</field>
        <field name="model">wua.cultivation</field>
        <field name="inherit_id" ref="base_wua.wua_cultivation_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='description']" position="after">
                <field name="cropfamily_id"
                       string="Crop Family"
                       style="width:250px"
                       options="{'no_create_edit':True}"/>
            </xpath>
        </field>
    </record>

    <record id="wua_cultivation_view_tree" model="ir.ui.view">
        <field name="name">wua.cultivation.view.tree.base_wua_hydric_estimation</field>
        <field name="model">wua.cultivation</field>
        <field name="inherit_id" ref="base_wua.wua_cultivation_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='number_of_varieties']" position="after">
                <field name="cropfamily_id" string="Crop Family"/>
            </xpath>
        </field>
    </record>

    <record id="wua_cultivation_view_search" model="ir.ui.view">
        <field name="name">wua.cultivation.view.search.base_wua_hydric_estimation</field>
        <field name="model">wua.cultivation</field>
        <field name="inherit_id" ref="base_wua.wua_cultivation_view_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="cropfamily_id" string="Crop Family"/>
                <group expand="0" string="Group By">
                    <filter string="Crop Family"
                     name="cropfamily"
                     context="{'group_by':'cropfamily_id'}"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>