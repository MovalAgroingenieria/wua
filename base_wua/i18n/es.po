#. module: base_wua
#: model:mail.template,body_html:base_wua.lease_near_end_leaser_partner_report_email_template
#: model:mail.template,body_html:base_wua.lease_near_end_partner_report_email_template
msgid "<p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"                    Dear Mr/Ms ${object.owner_id.name}.\n"
"\n"
"                    According to the information available to the ${object.partner_id.company_id.name|safe}. The lease of the parcel ${object.name} will end on ${object.days_until_lease_ends} days.\n"
"                </p>\n"
"                <br/>\n"
"                <p style=\"margin: 0px; padding: 0px;\">\n"
"                    If you want to regularize the available information, contact with ${object.partner_id.company_id.name|safe} via mail ${(object.partner_id.company_id.email or user.email)|safe} or phone ${(object.partner_id.company_id.phone)|safe}.\n"
"                </p>\n"
"                <br/>\n"
"                <p style=\"margin: 0px; padding: 0px;\">\n"
"                    In case of not receiving news, the lease will be terminated.\n"
"                </p>\n"
"                <br/>\n"
"                <p>\n"
"                    Receive a cordial greeting.\n"
"                </p>\n"
"            "
msgstr "<p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"                    Estimada/o Sra/Sr ${object.owner_id.name}.\n"
"\n"
"                    De acuerdo con la información disponible en ${object.partner_id.company_id.name|safe}. El arrendamiento de la parcela ${object.name} finalizará en ${object.days_until_lease_ends} días.\n"
"                </p>\n"
"                <br/>\n"
"                <p style=\"margin: 0px; padding: 0px;\">\n"
"                    Si desea regularizar la información disponible, contacte con ${object.partner_id.company_id.name|safe} a través del mail ${(object.partner_id.company_id.email or user.email)|safe} o del teléfono ${(object.partner_id.company_id.phone)|safe}.\n"
"                </p>\n"
"                <br/>\n"
"                <p style=\"margin: 0px; padding: 0px;\">\n"
"                    En caso de no recibir noticias, el arrendamiento se dará por finalizado.\n"
"                </p>\n"
"                <br/>\n"
"                <p>\n"
"                    Reciba un cordial saludo.\n"
"                </p>\n"
"            "

