<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="wua_cron_set_gis_fields_action" model="ir.cron">
            <field name="name">Set GIS fields</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="model">wua.parcel</field>
            <field name="function">set_gis_fields</field>
            <field name="args">()</field>
            <field name="active" eval="True"/>
            <!-- Set nextcall to 4 AM on the next day -->
            <field name="nextcall" eval="(DateTime.now() + relativedelta(days=1, hour=2, minute=0, second=0)).strftime('%Y-%m-%d %H:%M:%S')"/>
        </record>

    </data>

</odoo>
