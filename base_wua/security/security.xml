<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="0">

        <record id="group_wua_portal_user" model="res.groups">
            <field name="name">WUA Portal User</field>
            <field name="category_id"
                ref="base.module_category_water_users_associations"/>
            <field name="implied_ids"
                eval="[(4, ref('base.group_portal'))]"/>
            <field name="is_portal">True</field>
        </record>

        <record id="group_wua_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id"
                ref="base.module_category_water_users_associations"/>
            <field name="implied_ids"
                eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_wua_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id"
                ref="base.module_category_water_users_associations"/>
            <field name="implied_ids"
                eval="[(4, ref('group_wua_user'))]"/>
            <field name="users"
                eval="[(4, ref('base.user_root'))]"/>
        </record>

    </data>

    <data noupdate="0">

        <record id="portal.access_ir_attachment_portal" model="ir.model.access">
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>

