<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Wua partner report (droplist menu) -->
    <report
        id="wua_partner_report"
        string="Wua partner report"
        model="res.partner"
        report_type="qweb-pdf"
        file="base_wua.wua_partner_report_document"
        name="base_wua.wua_partner_report_document"
        paperformat="base_wua_report.paperformat_wua_reports"/>

    <!-- Wua partner report -->
    <template id="wua_partner_report_document">
        <t t-call="report.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="base_wua_report.wua_external_layout">
                    <div class="page">

                        <!-- Vars -->
                        <t t-set="report_style" t-value="request.env['ir.values'].get_default('wua.configuration', 'reports_style')"/>

                        <!-- Partner data -->
                        <div name="wua_partner_data">
                            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                <t t-if="report_style == 'light'">
                                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;"><span class="fa fa-user"/></div>
                                        <div style="float: left; display: inline;"><strong>Partner</strong></div>
                                   </div>
                                </t>
                                <t t-else="">
                                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                        <div style="float: left; width: 32px;"><span class="fa fa-user"/></div>
                                        <div style="float: left; display: inline;"><strong>Partner</strong></div>
                                    </div>
                                </t>
                            </div>
                            <div class="row" style="margin-top: 4px;">
                                <div class="col-xs-12" style="display: table;">
                                    <div style="width: 50%; display: table-cell;">
                                        <t t-if="o.name">
                                            <strong><span t-field="o.name"/></strong>
                                            <t t-if="o.vat"><span>(NIF:&amp;nbsp;<span t-field="o.vat"/>)</span></t>
                                        <br/>
                                        </t>
                                        <t t-if="o.street_type_show or o.street or o.street_num or o.street2">
                                            <t t-if="o.street_type_show"><span t-field="o.street_type_show"/></t>
                                            <t t-if="o.street"><span t-field="o.street"/></t>
                                            <t t-if="o.street_num"><span t-field="o.street_num"/></t>
                                            <t t-if="o.street2"><span t-field="o.street2"/></t>
                                            <br/>
                                        </t>
                                        <t t-if="o.city or o.zip">
                                            <t t-if="o.city"><span t-field="o.city"/></t>
                                            <t t-if="o.zip"><span>-&amp;nbsp;</span><span t-field="o.zip"/></t>
                                            <br/>
                                        </t>
                                        <t t-if="o.state_id or o.country_id">
                                            <t t-if="o.state_id"><span t-field="o.state_id"/></t>
                                            <t t-if="o.country_id"><span>-&amp;nbsp;</span><span t-field="o.country_id"></span></t>
                                            <br/>
                                        </t>
                                        <t t-if="o.phones or o.phone or o.mobile">
                                            <t t-if="o.phones"><span t-field="o.phones"/></t>
                                            <t t-else="">
                                                <t t-if="o.phone"><span t-field="o.phone"/></t>
                                                <t t-if="o.mobile"><span t-field="o.mobile"/></t>
                                            </t>
                                            <br/>
                                        </t>
                                        <t t-if="o.email"><span t-field="o.email"/><br/></t>
                                        <t t-if="o.bank_ids">
                                            <t t-foreach="o.bank_ids" t-as="bank_acc">
                                                <t t-if="bank_acc.acc_number">
                                                    <t t-set="hidden_acc_number" t-value="bank_acc.acc_number[:24] + ' XXXX'"/>
                                                    <span t-esc="hidden_acc_number"/>
                                                </t>
                                                <t t-if="bank_acc.bank_name">
                                                    <span>-</span>
                                                    <span t-field="bank_acc.bank_name"></span>
                                                </t>
                                                <br/>
                                            </t>
                                        </t>
                                    </div>
                                    <div style="display: table-cell; padding-left: 32px;">
                                        <div>&amp;nbsp;</div>
                                        <table style="width: 100%;">
                                            <tbody>
                                                <tr>
                                                    <td><span>Wua partner code:</span></td>
                                                    <td class="text-right"><span t-field="o.partner_code"/></td>
                                                </tr>
                                                <tr name="tr_number_of_votes">
                                                    <td><span>Number of votes:</span></td>
                                                    <td class="text-right"><span t-field="o.number_of_votes"/></td>
                                                </tr>
                                                <tr>
                                                    <td><span>Number of parcels:</span></td>
                                                    <td class="text-right"><span t-field="o.parcel_number"/></td>
                                                </tr>
                                                <tr>
                                                    <td><span>Total area:</span></td>
                                                    <td class="text-right" style="padding: 0 0 0 28px;">
                                                        <span t-field="o.parcel_total_area"/>
                                                        <t t-if="o.partnerlink_ids">
                                                            <t t-set="measurement_unit" t-value="o.partnerlink_ids[0].parcel_id._compute_area_measurement_name()"/>
                                                            <span><t t-esc="measurement_unit"/></span>
                                                        </t>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Parcels data -->
                        <div name="wua_partnerlinks_ids" style="margin-top: 20px;">
                            <t t-if="o.partnerlink_ids">
                                <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                    <t t-if="report_style == 'light'">
                                        <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                            <div style="float: left; width: 32px;"><span class="fa fa-moval-parcel"/></div>
                                            <div style="float: left; display: inline;"><strong>Parcels</strong></div>
                                       </div>
                                    </t>
                                    <t t-else="">
                                        <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                            <div style="float: left; width: 32px;"><span class="fa fa-moval-parcel"/></div>
                                            <div style="float: left; display: inline;"><strong>Parcels</strong></div>
                                        </div>
                                    </t>
                                </div>
                                <table class="table table-striped" style="margin-top: 2px;">
                                    <thead>
                                        <tr>
                                            <th width="20%" class="text-center">Parcel</th>
                                            <th width="18%" class="text-center" name="th_cadastral_reference_name">Cadastral reference</th>
                                            <th width="12%" class="text-right">Area (<t t-esc="measurement_unit"/>)</th>
                                            <th width="10%" name="th_irrigation_partner_name" class="text-center">Irrigation partner</th>
                                            <th width="12%" class="text-center" name="th_profile_name">Profile</th>
                                            <th width="10%" name="th_ownership_name" class="text-right">Ownership (%)</th>
                                            <th width="9%" name="th_water_name" class="text-right">Water (%)</th>
                                            <th width="9%" name="th_costs_name" class="text-right">Costs (%)</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="o.partnerlink_ids" t-as="p" style="page-break-inside: avoid;">
                                            <td class="text-center"><span t-field="p.parcel_id"/></td>
                                            <td class="text-center" name="td_cadastral_reference_name"><span t-field="p.parcel_id.cadastral_reference"/></td>
                                            <td class="text-right"><span t-field="p.area_official"/></td>
                                            <td name="td_irrigation_partner_name" class="text-center">
                                                <t t-if="p.irrigation_partner == True"><span>Yes</span></t>
                                                <t t-else=""><span>No</span></t>
                                            </td>
                                            <td class="text-center" name="td_profile_name" ><span t-field="p.profile"/></td>
                                            <td name="td_ownership_name" class="text-right"><span t-field="p.ownership_percentage"/></td>
                                            <td name="td_water_name" class="text-right"><span t-field="p.water_costs_percentage"/></td>
                                            <td name="td_costs_name" class="text-right"><span t-field="p.other_costs_percentage"/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </t>
                        </div>

                        <!--
                         If base_wua_infrastructure module is installed this report continues
                         with wua_partner_infrastructure_report_document
                        -->

                        <!-- Info -->
                        <div name="info" style="page-break-inside: avoid">
                            <t t-set="informative_clauses" t-value="request.env['ir.values'].get_default('wua.configuration', 'reports_informative_clauses')"/>
    
                            <t t-if="informative_clauses and consent != True">
                                <div name="info_div" style="margin-top: 20px;">
                                    <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                        <t t-if="report_style == 'light'">
                                            <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                                <div style="float: left; width: 32px;"><span class="fa fa-info-circle"/></div>
                                                <div style="float: left; display: inline;"><strong>Information</strong></div>
                                           </div>
                                        </t>
                                        <t t-else="">
                                            <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                                <div style="float: left; width: 32px;"><span class="fa fa-info-circle"/></div>
                                                <div style="float: left; display: inline;"><strong>Information</strong></div>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                                <t t-if="informative_clauses">
                                    <div name="informative_clause_div">
                                        <span t-raw="informative_clauses"/>
                                    </div>
                                </t>
                            </t>
                        </div>

                        <!-- Consent -->
                        <div name="info" style="page-break-inside: avoid">
                            <t t-set="consent_clauses" t-value="request.env['ir.values'].get_default('wua.configuration', 'reports_consent_clauses')"/>
                            <t t-if="consent_clauses and consent == True">
                                <div name="info_div" style="margin-top: 20px;">
                                    <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
                                        <t t-if="report_style == 'light'">
                                            <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                                                <div style="float: left; width: 32px;"><span class="fa fa-check-square-o"/></div>
                                                <div style="float: left; display: inline;"><strong>Consent</strong></div>
                                           </div>
                                        </t>
                                        <t t-else="">
                                            <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                                                <div style="float: left; width: 32px;"><span class="fa fa-check-square-o"/></div>
                                                <div style="float: left; display: inline;"><strong>Consent</strong></div>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                                <t t-if="consent_clauses">
                                    <div name="consent_clause_div">
                                        <span t-raw="consent_clauses"/>
                                    </div>
                                </t>
                            </t>
                        </div>

                        <!-- Force new page -->
                        <p style="page-break-after:always;"/>

                        <!-- Parcels aerial images  -->
                        <div name="wua_parcel_aerial_images">
                            <t t-if="o.partnerlink_ids">
                                <t t-foreach="o.partnerlink_ids" t-as="p">
                                    <div style="width: 48%; float: left; display: table; border: 1px solid black; margin: 1.5% 0.5%; page-break-inside: avoid;">
                                        <div name="parcel_data" style="border-bottom: 1px solid black; padding: 2%;">
                                            <table style="width: 100%;">
                                                <tbody>
                                                    <tr>
                                                        <td>
                                                            <strong>Parcel</strong>
                                                            <t t-if="p.parcel_id.aerial_img_date">
                                                                <span>(image of <span t-field="p.parcel_id.aerial_img_date" t-options="{'format': 'MMMM YYYY'}"></span>)</span>
                                                            </t>
                                                        </td>
                                                        <td class="text-right"><span t-field="p.parcel_id"/></td>
                                                    </tr>
                                                    <tr>
                                                        <td><strong>Cadastral reference</strong></td>
                                                        <td class="text-right"><span t-field="p.cadastral_reference"/></td>
                                                    </tr>
                                                    <tr>
                                                        <td><strong>Area</strong></td>
                                                        <td class="text-right">
                                                            <span t-field="p.area_official"/>
                                                            <span><t t-esc="measurement_unit"/></span>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                        <div name="parcel_aerial_image" class="text-center">
                                            <t t-if="p.parcel_id.aerial_img">
                                                <img t-attf-src="data:image/png;base64, #{p.parcel_id.aerial_img}" style="max-width: 408px; max-height: 408px;"/>
                                            </t>
                                            <t t-else="">
                                                <div class="text-center text-muted" style="width: 408px; height: 408px; padding-top: 40%;">
                                                    Aerial image not found
                                                </div>
                                            </t>
                                        </div>
                                    </div>
                                </t>
                            </t>
                        </div>

                    </div><!-- end page -->
                </t>
            </t>
        </t>
    </template>

</odoo>
