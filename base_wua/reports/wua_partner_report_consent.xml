<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Wua partner report consent (droplist menu) -->
    <report
        id="wua_partner_report_consent"
        string="Wua partner report (consent)"
        model="res.partner"
        report_type="qweb-pdf"
        file="base_wua.wua_partner_report_document_consent"
        name="base_wua.wua_partner_report_document_consent"
        paperformat="base_wua_report.paperformat_wua_reports"
        menu="False"
        groups="base_wua.group_wua_user"/>/>

    <!-- Wua partner report consent -->
    <template id="wua_partner_report_document_consent">
        <t t-set="consent" t-value="True"/>
        <t t-call="base_wua.wua_partner_report_document"/>
    </template>

</odoo>
