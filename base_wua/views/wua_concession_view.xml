<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_concession_view_form" model="ir.ui.view">
        <field name="name">Water Concessions (form view)</field>
        <field name="model">wua.concession</field>
        <field name="arch" type="xml">
            <form duplicate="0">
                <group name="master_data">
                    <group name="master_data_left">
                        <field name="name" style="width:350px"/>
                        <field name="associated_file" style="width:350px"/>
                    </group>
                    <group name="master_data_right">
                        <field name="annual_volume" style="width:350px"/>
                        <field name="surface" style="width:350px"/>
                        <field name="flow" style="width:350px"/>
                    </group>
                    <field name="description" style="width:100%"/>
                </group>
                <group name="slave_data">
                    <notebook name="slave_data_notebook">
                        <page name="notes_page" string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </group>
            </form>
        </field>
    </record>

    <record id="wua_concession_view_tree" model="ir.ui.view">
        <field name="name">Water Concessions (tree view)</field>
        <field name="model">wua.concession</field>
        <field name="arch" type="xml">
            <tree class="o_base_wua_concession_view_tree">
                <field name="name"/>
                <field name="description"/>
            </tree>
        </field>
    </record>

    <record id="wua_concession_view_search" model="ir.ui.view">
        <field name="name">Water Concessions (search view)</field>
        <field name="model">wua.concession</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="description"/>
            </search>
        </field>
    </record>

    <record id="wua_concession_action" model="ir.actions.act_window">
        <field name="name">Water Concessions</field>
        <field name="res_model">wua.concession</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="wua_concession_view_tree"/>
        <field name="search_view_id"
         ref="wua_concession_view_search"/>
    </record>

    <menuitem id="wua_concession_menu"
              name="Water Concessions"
              parent="base_wua_census_configuration_menu"
              action="wua_concession_action"
              sequence="5"/>

</odoo>