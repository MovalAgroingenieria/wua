<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ter_parcel_view_form" model="ir.ui.view">
        <field name="name">ter.parcel.view.form</field>
        <field name="model">ter.parcel</field>
        <field name="inherit_id" ref="base_ter.ter_parcel_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='page_partnerlinks']" position="after">
                <page name="wua_parcel_options" string="Options">
                    <group name="wua_parcel_options_group">
                        <group name="wua_parcel_options_left">
                            <field name="mandatory_concessions"/>
                        </group>
                        <group name="wua_parcel_options_right">
                        </group>
                    </group>
                </page>
                <page name="page_concessionlinks" string="Concessions">
                    <field name="concessionlink_ids" nolabel="1">
                        <tree editable="bottom">
                            <field name="concession_id"/>
                            <field name="name"/>
                            <field name="notes"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>