<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_cultivation_subparcel_action" model="ir.actions.act_window">
        <field name="name">Subparcel Cultivations</field>
        <field name="res_model">wua.parcel.subparcel</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="base_wua.wua_parcel_subparcel_view_tree"/>
        <field name="search_view_id" ref="base_wua.wua_parcel_subparcel_view_search"/>
        <field name="domain">[("cultivation_id","=",context.get('active_id'))]</field>
        <field name="context">{'remove_master_field':'1'}</field>
    </record>

    <record id="wua_cultivation_view_form" model="ir.ui.view">
        <field name="name">Cultivations (form view)</field>
        <field name="model">wua.cultivation</field>
        <field name="arch" type="xml">
            <form duplicate="0">
                <div name="buttons" class="oe_button_box">
                    <button name="toggle_active"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-archive"
                            confirm="Are you sure you want to toggle visibility?"
                            groups="base_wua.group_wua_user">
                            <field name="active"
                                   widget="boolean_button"
                                   options='{"terminology": "archive"}'/>
                    </button>
                    <button name="%(wua_cultivation_subparcel_action)d"
                            type="action"
                            class="oe_stat_button"
                            icon="fa-moval-subparcel"
                            groups="base_wua.group_wua_user">
                            <div class="o_form_field o_stat_info">
                                <span class="o_stat_text">Subparcels</span>
                            </div>
                    </button>
                </div>
                <group name="master_data">
                    <field name="name" style="width:250px"/>
                    <field name="description" style="width:100%%"/>
                </group>
                <group name="slave_data">
                    <notebook name="slave_data_notebook">
                        <page name="varieities_page" string="Varieties">
                            <field name="variety_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="description"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </group>
            </form>
        </field>
    </record>

    <record id="wua_cultivation_view_tree" model="ir.ui.view">
        <field name="name">Cultivations (tree view)</field>
        <field name="model">wua.cultivation</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="description"/>
                <field name="number_of_varieties"/>
            </tree>
        </field>
    </record>

    <record id="wua_cultivation_view_search" model="ir.ui.view">
        <field name="name">Cultivations (search view)</field>
        <field name="model">wua.cultivation</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="description"/>
                <filter name="inactive"
                        string="Archived"
                        domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="wua_cultivation_action" model="ir.actions.act_window">
        <field name="name">Cultivations</field>
        <field name="res_model">wua.cultivation</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="wua_cultivation_view_tree"/>
        <field name="search_view_id"
         ref="wua_cultivation_view_search"/>
    </record>

    <menuitem id="wua_cultivation_menu"
              name="Cultivations"
              parent="base_wua_census_configuration_menu"
              action="wua_cultivation_action"
              sequence="8"/>

</odoo>