<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_partner_partnerlink_action" model="ir.actions.act_window">
        <field name="name">Parcels</field>
        <field name="res_model">wua.parcel.partnerlink</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="base_wua.wua_parcel_partnerlink_view_tree"/>
        <field name="search_view_id" ref="base_wua.wua_parcel_partnerlink_view_search"/>
        <field name="domain">[("partner_id","=",context.get('active_id'))]</field>
        <field name="context">{'remove_master_field':'1'}</field>
    </record>

    <record id="view_partner_form" model="ir.ui.view">
        <field name="name">Partners (form view)</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="attributes">
                <attribute name="duplicate">0</attribute>
            </xpath>
            <xpath expr="//sheet" position="before">
                <header>
                </header>
            </xpath>
            <xpath expr="//button[@name='toggle_active']" position="attributes">
                <attribute name="groups">base_wua.group_wua_user</attribute>
                <attribute name="confirm">Are you sure you want to toggle visibility?</attribute>
            </xpath>
            <xpath expr="//button[@name='toggle_active']" position="after">
                <field name="is_wua_partner" invisible="1"/>
                <field name="gis_viewer_link" invisible="1"/>
            </xpath>
            <xpath expr="//button[@name='toggle_active']" position="after">
                <button name="%(res_partner_partnerlink_action)d"
                        attrs="{'invisible':[('is_wua_partner','=',False)]}"
                        type="action"
                        class="oe_stat_button"
                        icon="fa-moval-parcel"
                        groups="base_wua.group_wua_user,
                                base_wua.group_wua_portal_user">
                        <div class="o_form_field o_stat_info">
                            <span class="o_stat_value">
                                <field name="parcel_total_area"/> (<field name="parcel_number"/>)
                            </span>
                            <span class="o_stat_text">
                                area (parcels)
                            </span>
                        </div>
                </button>
                <br/>
                <button name="action_see_gis_viewer"
                        attrs="{'invisible':['|',('is_wua_partner','=',False),
                                                 ('gis_viewer_link','=',False)]}"
                        type="object"
                        class="oe_stat_button"
                        string="GIS Viewer"
                        icon="fa-map-marker"
                        groups="base_wua.group_wua_user,
                                base_wua.group_wua_portal_user"/>
                <button name="action_see_partner_mail_messages"
                        attrs="{'invisible':[('is_wua_partner','=',False)]}"
                        type="object"
                        class="oe_stat_button"
                        string="Emails_"
                        icon="fa-envelope"
                        groups="base_wua.group_wua_user, base_wua.group_wua_portal_user"/>
            </xpath>
            <xpath expr="//h1//field[@name='name']/.." position="after">
                <group attrs="{'invisible':[('is_wua_partner','=',False)]}">
                    <field name="partner_code"/>
                    <field name="apply_second_partner_coding"
                           class="oe_edit_only"/>
                </group>
            </xpath>
            <xpath expr="//field[@name='parent_id']" position="attributes">
                <attribute name="invisible">True</attribute>
            </xpath>
            <xpath expr="//field[@name='website']" position="after">
                <field name="number_of_votes" readonly="1"
                 attrs="{'invisible':[('is_wua_partner','=',False)]}"/>
            </xpath>
            <xpath expr="//field[@name='category_id']" position="replace">
                <field name="category_id" widget="many2many_tags"
                 placeholder="Tags..." options="{'no_create_edit': False}"/>
            </xpath>
            <xpath expr="//field[@name='function']" position="attributes">
                <attribute name="attrs">
                    {'invisible':[('is_wua_partner','=',True)]}
                </attribute>
            </xpath>
            <xpath expr="//field[@name='title']" position="attributes">
                <attribute name="attrs">
                    {'invisible':[('is_wua_partner','=',True)]}
                </attribute>
            </xpath>
            <xpath expr="//field[@name='lang']" position="after">
                <field name = "tz"
                 attrs="{'invisible':[('is_wua_partner','=',False)]}"/>
                <field name="gender"
                 attrs="{'invisible':[('is_wua_partner','=',False)]}"/>
                <field name="birthdate"
                 attrs="{'invisible':[('is_wua_partner','=',False)]}"/>
                <field name="name_alias"
                 attrs="{'invisible':[('is_wua_partner','=',False)]}"/>
                <field name="is_owner" readonly="1"
                 attrs="{'invisible':[('is_wua_partner','=',False)]}"/>
                <field name="is_lessee" readonly="1"
                 attrs="{'invisible':[('is_wua_partner','=',False)]}"/>
                <field name="is_payer" readonly="1"
                 attrs="{'invisible':[('is_wua_partner','=',False)]}"/>
            </xpath>
            <xpath expr="//group[@name='sale']//field[@name='customer']"
             position="attributes">
                <attribute name="readonly">True</attribute>
            </xpath>
            <xpath expr="//group[@name='sale']" position="attributes">
                <attribute name="attrs">
                    {'invisible':[('is_wua_partner','=',False)]}
                </attribute>
            </xpath>
            <xpath expr="//page[@name='internal_notes']"
                   position="attributes">
                <attribute name="groups">base_wua.group_wua_user</attribute>
            </xpath>
            <xpath expr="//page[@name='sales_purchases']"
                   position="attributes">
                <attribute name="groups">base_wua.group_wua_user</attribute>
            </xpath>
            <notebook>
                <page name="quotas" string="Quotas"
                      attrs="{'invisible':[('is_wua_partner','=',False)]}"
                      groups="base_wua.group_wua_user">
                </page>
            </notebook>
            <xpath expr="//field[@name='child_ids']//form//field[@name='title']" position="before">
                <field name="vat_wua_legalrep" string="TIN"/>
            </xpath>
            <xpath expr="//img[@t-att-src='_s + &quot;/base/static/src/img/money.png&quot;']" position="after">
                <img t-if="record.type.raw_value === 'wua_legalrep'" t-att-src='"/base_wua/static/img/lawyer.png"'/>
            </xpath>
            <xpath expr="//field[@name='child_ids']//kanban//templates//t//div//div//t//t" position="attributes">
                <attribute name="t-if">record.type.raw_value !== &apos;invoice&apos; &amp;&amp; record.type.raw_value !== &apos;delivery&apos;  &amp;&amp; record.type.raw_value !== &apos;wua_legalrep&apos;</attribute>
            </xpath>
            <xpath expr="//div[@t-if='record.fax.raw_value']" position="after">
                <div t-if="record.type.raw_value === 'wua_legalrep'">LEGAL REPRESENTATIVE</div>
            </xpath>
            <xpath expr="//notebook[1]" position="before">
                <field name="with_notes" invisible="1"/>
                <field name="show_notes_conf" invisible="1"/>
                <div name="hasnotes"
                     style="display: inline-block;color:red;padding-top: 5px;padding-bottom: 5px;padding-left: 10px;"
                     attrs="{'invisible': ['|', ('with_notes', '=', False), ('show_notes_conf', '=', False)]}">
                     <strong>( NOTES PRESENT )</strong>
                </div>
            </xpath>
        </field>
    </record>

    <record id="view_emails_partner_info_form" model="ir.ui.view">
        <field name="name">Partners (form view, without messages for WUA portal users)</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="mail.view_emails_partner_info_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='message_ids']"
                   position="attributes">
                <attribute name="groups">base.group_user</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_partner_tree" model="ir.ui.view" >
        <field name="name">Partners (tree view)</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="class">
                    o_base_wua_partner_view_tree
                </attribute>
            </xpath>
            <xpath expr="//field[@name='display_name']" position="before">
                <field name="name_alias" invisible="1"/>
                <field name="partner_code"/>
            </xpath>
            <xpath expr="//field[@name='phone']" position="attributes">
                <attribute name="invisible">True</attribute>
            </xpath>
            <xpath expr="//field[@name='email']" position="attributes">
                <attribute name="invisible">True</attribute>
            </xpath>
            <xpath expr="//field[@name='email']" position="after">
                <field name="vat"/>
                <field name="gis_viewer_link" invisible="1"/>
                <field name="company_type" invisible="1"/>
                <button name="action_see_gis_viewer"
                        type="object" class="oe_stat_button"
                        string="GIS Viewer (zoom to parcels)"
                        icon="fa-map-marker"
                        attrs="{'invisible': [('gis_viewer_link','=','')]}"/>
                <field name="phones"/>
                <field name="number_of_votes"/>
                <field name="parcel_owner_number"/>
                <field name="parcel_owner_area"/>
                <field name="parcel_lessee_number"/>
                <field name="parcel_lessee_area"/>
                <field name="comment" invisible="1"/>
                <button type="object" class="oe_stat_button"
                        icon="fa-user"
                        attrs="{'invisible':
                                [('company_type','=','company')],
                                'readonly':
                                [('company_type','=','person')]}"/>
                <button type="object" class="oe_read_only"
                        icon="fa-building"
                        attrs="{'invisible':
                                [('company_type','=','person')],
                                'readonly':
                                [('company_type','=','company')]}"/>
            </xpath>
        </field>
    </record>

    <record id="view_partner_search" model="ir.ui.view">
        <field name="name">Partners (search view)</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_code"/>
                <field name="display_name"/>
                <field name="name_alias"/>
                <field name="category_id"/>
                <filter string="Persons" name="notiscompany"
                 domain="[('is_company','=',False)]"/>
                <filter string="Companies" name="iscompany"
                 domain="[('is_company','=',True)]"/>
                <separator/>
                <filter string="Owner" name="isowner"
                 domain="[('is_owner','=',True)]"/>
                <filter string="Lessee" name="islessee"
                 domain="[('is_lessee','=',True)]"/>
                <filter string="Payer" name="ispayer"
                 domain="[('is_payer','=',True)]"/>
                <separator/>
                <filter string="With legal representative" name="with_legalrep_yes"
                 domain="[('with_legalrep','=',True)]"/>
                <separator/>
                <filter string="With notes" name="with_notes" domain="[('with_notes','=',True)]" />
                <separator/>
                <filter string="Archived" name="inactive"
                 domain="[('active','=',False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Is a company (marked)"
                     name="isacompany"
                     context="{'group_by':'is_company'}"/>
                    <filter string="City"
                     name="city"
                     context="{'group_by':'city'}"/>
                    <filter string="Totals"
                     name="totals"
                     context="{'group_by':'is_wua_partner'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="res_partner_action" model="ir.actions.act_window">
        <field name="name">Partners</field>
        <field name="res_model">res.partner</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="view_id" ref="view_partner_tree"/>
        <field name="domain">[("is_wua_partner","=",True)]</field>
        <field name="search_view_id" ref="view_partner_search"/>
        <field name="context">{'wua':'1','default_is_wua_partner':True}</field>
    </record>

    <record id="wua_generate_partner_parcel_shp" model="ir.actions.server">
        <field name="name">Generate Parcel SHP</field>
        <field name="model_id" ref="base_wua.model_res_partner"/>
        <field name="code">
            action =  env['res.partner'].browse(context['active_ids']).action_generate_parcel_shp()
        </field>
    </record>

    <record id="wua_action_generate_partner_parcel_shp" model="ir.values">
        <field name="name">Generate Parcel SHP</field>
        <field name="model">res.partner</field>
        <field name="key">action</field>
        <field name="key2">client_action_multi</field>
        <field name="value" eval="'ir.actions.server,' + str(ref('wua_generate_partner_parcel_shp'))"/>
    </record>

    <record id="res_partnertag_action" model="ir.actions.act_window">
        <field name="name">Partner Tags</field>
        <field name="res_model">res.partner.category</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="wua_partnerlink_action" model="ir.actions.act_window">
        <field name="name">Partner Links</field>
        <field name="res_model">wua.parcel.partnerlink</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="wua_parcel_partnerlink_view_tree"/>
        <field name="search_view_id" ref="wua_parcel_partnerlink_view_search"/>
    </record>

    <record id="base.action_partner_customer_form" model="ir.actions.act_window">
        <field name="name">Customers</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.partner</field>
        <field name="view_type">form</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="domain">[]</field>
        <field name="context">{'default_customer':1, 'search_default_customer':1}</field>
        <field name="filter" eval="True"/>
        <field name="search_view_id" ref="base.view_res_partner_filter"/>
        <field name="help" type="html">
          <p class="oe_view_nocontent_create">
            Click to add a contact in your address book.
          </p><p>
            Odoo helps you easily track all activities related to
            a customer: discussions, history of business opportunities,
            documents, etc.
          </p>
        </field>
    </record>

    <record id="base.action_partner_supplier_form" model="ir.actions.act_window">
        <field name="name">Vendors</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.partner</field>
        <field name="view_type">form</field>
        <field name="domain">[]</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="context">{'search_default_supplier': 1,'default_customer': 0,'default_supplier': 1}</field>
        <field name="search_view_id" ref="base.view_res_partner_filter"/>
        <field name="filter" eval="True"/>
        <field name="help" type="html">
          <p class="oe_view_nocontent_create">
            Click to add a contact in your address book.
          </p><p>
            Odoo helps you easily track all activities related to
            a supplier: discussions, history of purchases,
            documents, etc.
          </p>
        </field>
    </record>

    <menuitem id="base_wua_census_partners_menu"
              name="Partners"
              parent="base_wua_census_menu"
              sequence="1"
              groups="group_wua_user,group_wua_portal_user"/>

    <menuitem id="res_partner_menu"
              name="Partners"
              parent="base_wua_census_partners_menu"
              action="res_partner_action"
              sequence="1"/>

    <menuitem id="res_partnertag_menu"
              name="Partner Tags"
              parent="base_wua_census_configuration_menu"
              action="res_partnertag_action"
              sequence="21"/>

    <!-- <menuitem id="wua_partnerlink_menu"
              name="Partner Links"
              parent="base_wua_census_partners_menu"
              action="wua_partnerlink_action"
              sequence="2"/> -->

</odoo>