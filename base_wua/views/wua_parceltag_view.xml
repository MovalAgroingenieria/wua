<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_parceltag_view_form" model="ir.ui.view">
        <field name="name">Parcel Tags (form view)</field>
        <field name="model">wua.parceltag</field>
        <field name="arch" type="xml">
            <form duplicate="0">
                <group name="master_data">
                    <field name="name" style="width:200px"/>
                    <field name="description"/>
                    <field name="color"/>
                </group>
                <group name="slave_data">
                    <notebook name="slave_data_notebook">
                        <page name="notes_page" string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </group>
            </form>
        </field>
    </record>

    <record id="wua_parceltag_view_tree" model="ir.ui.view">
        <field name="name">Parcel Tags (tree view)</field>
        <field name="model">wua.parceltag</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="description"/>
                <field name="color"/>
            </tree>
        </field>
    </record>

    <record id="wua_parceltag_view_search" model="ir.ui.view">
        <field name="name">Parcel Tags (search view)</field>
        <field name="model">wua.parceltag</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="wua_parceltag_action" model="ir.actions.act_window">
        <field name="name">Parcel Tags</field>
        <field name="res_model">wua.parceltag</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="wua_parceltag_view_tree"/>
        <field name="search_view_id"
         ref="wua_parceltag_view_search"/>
    </record>

    <menuitem id="wua_parceltag_menu"
              name="Parcel Tags"
              parent="base_wua_census_configuration_menu"
              action="wua_parceltag_action"
              sequence="20"/>

</odoo>