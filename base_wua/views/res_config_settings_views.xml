<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.base</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="10"/>
        <field name="inherit_id" ref="base_ter.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='gisviewer_settings']" position="after">
                <h2>Water Users Association: Basic Settings</h2>
                <div class="row mt16 o_settings_container" name="wua_basic_settings">
                    <div id="div_mandatory_concessions_default"
                        class="col-12 col-lg-12 o_setting_box">
                        <div class="o_setting_left_pane">
                            <field name="concessions_mandatory_default_parcels"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="concessions_mandatory_default_parcels"/>
                            <div class="text-muted">
                                If checked, the concession will be mandatory in parcels
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

</odoo>