<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wizard_set_vat_view_form" model="ir.ui.view">
        <field name="name">Wizard to set a Partner Code</field>
        <field name="model">wizard.set.partner.code</field>
        <field name="arch" type="xml">
            <form string="Data of a VAT">
                <script>
                    $(document).ready(function(){
                        $('.modal-dialog').css({'width': '300px'});
                    });
                </script>
                <div style="text-align:center">
                    <h4>Please, insert the new partner_code </h4>
                </div>
                <group name="group_partner_code_data">
                    <field name="partner_code" colspan="2" nolabel="1"
                           string="Partner Code"/>
                </group>
                <footer>
                    <button name="set_partner_code"
                            type="object"
                            string="Apply"
                            class="btn-primary"/>
                    <button string="Cancel"
                            class="btn-default"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <act_window id="action_set_partner_code"
        name="Change Code"
        res_model="wizard.set.partner.code"
        src_model="res.partner"
        view_mode="form"
        target="new"
        groups="group_wua_manager"/>
</odoo>