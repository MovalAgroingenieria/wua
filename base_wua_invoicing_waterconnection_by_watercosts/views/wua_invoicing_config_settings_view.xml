<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wua_invoicing_config_settings_view_form" model="ir.ui.view">
        <field name="name">Parameters</field>
        <field name="model">wua.invoicing.configuration</field>
        <field name="inherit_id"
               ref="base_wua_invoicing.wua_invoicing_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='group_detail_lines_of_wc_if_same_payer']"
                   position="after">
                <field name="invoicing_of_wc_with_factor"/>
            </xpath>
            <xpath expr="//group[@name='group_invoicing_intakes']"
                   position="after">
                <group string="Water connections (by water costs) – calculation">
                    <field name="product_category_water_costs"/>
                    <field name="log_progress_wc_max_step"/>
                    <field name="log_progress_wc_divisor"/>
                    <field name="invoice_line_quantity_precision"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>