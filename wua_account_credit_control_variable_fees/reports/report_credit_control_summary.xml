<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_credit_control_summary_document_variable_fees_part_wua"
        inherit_id="account_credit_control.report_credit_control_summary_document">

        <xpath expr="//th[@name='invoice_number']" position="after">
            <th name="invoiceset_id_variable_fees_wua">Invoiceset</th>
        </xpath>

        <xpath expr="//t[@name='invoice_number_2']" position="after">
            <td name="td_invoiceset_id_variable_fees_wua">
                <t name="tif_linvoiceset" t-if="l.invoiceset_id">
                    <span t-field="l.invoiceset_id.description"/>
                </t>
            </td>
        </xpath>

        <xpath expr="//table[@id='summary_table_with_variable_fees']/tbody/tr" position="attributes">
            <attribute name="t-foreach">lines.filtered(lambda x: x.included_in_variable_fees)</attribute>
        </xpath>

    </template>

</odoo>
