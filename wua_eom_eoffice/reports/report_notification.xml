<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="notification_report" inherit_id="eom_eoffice.notification_report">
        <xpath expr="//t[@t-call='report.external_layout']" position="attributes">
            <attribute name="t-call">base_wua_report.wua_external_layout</attribute>
        </xpath>
    </template>

    <template id="notification_report_document" inherit_id="eom_eoffice.notification_report_document">
        <xpath expr="//t[@t-set='user_lang']" position="before">
            <t t-set="report_style" t-value="o.env['ir.values'].get_default('wua.configuration', 'reports_style')"/>
        </xpath>

        <xpath expr="//div[@name='notification_title']" position="replace">
            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;" name="registry_main_data_title">
                <t t-if="report_style == 'light'">
                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                        <div style="float: left; width: 32px;"><span class="fa fa-authdnie-eoffice"/></div>
                        <div style="float: left; display: inline;"><strong>Notification</strong></div>
                        <div style="float: right; display: inline;"><strong><span t-field="o.name"/></strong></div>
                    </div>
                </t>
                <t t-else="">
                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                        <div style="float: left; width: 32px;"><span class="fa fa-authdnie-eoffice"/></div>
                        <div style="float: left; display: inline;"><strong>Notification</strong></div>
                        <div style="float: right; display: inline;"><strong><span t-field="o.name"/></strong></div>
                    </div>
                </t>
            </div>
        </xpath>

        <xpath expr="//div[@name='issue_title']" position="replace">
            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;" name="registry_main_data_title">
                <t t-if="report_style == 'light'">
                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                        <div style="float: left; width: 32px;"><span class="fa fa-file"/></div>
                        <div style="float: left; display: inline;"><strong>Issue</strong></div>
                    </div>
                </t>
                <t t-else="">
                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                        <div style="float: left; width: 32px;"><span class="fa fa-file"/></div>
                        <div style="float: left; display: inline;"><strong>Issue</strong></div>
                    </div>
                </t>
            </div>
        </xpath>

        <xpath expr="//div[@name='text_title']" position="replace">
            <div class="row h4 mt28 mb4" style="padding-bottom: 4px;" name="registry_main_data_title">
                <t t-if="report_style == 'light'">
                    <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid; padding: 1px 16px;">
                        <div style="float: left; width: 32px;"><span class="fa fa-file-text"/></div>
                        <div style="float: left; display: inline;"><strong>Text</strong></div>
                    </div>
                </t>
                <t t-else="">
                    <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
                        <div style="float: left; width: 32px;"><span class="fa fa-file-text"/></div>
                        <div style="float: left; display: inline;"><strong>Text</strong></div>
                    </div>
                </t>
            </div>
        </xpath>

    </template>

</odoo>