<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <template id="report_electronic_file_form_layout" inherit_id="eom_eoffice.report_electronic_file_form">
    <xpath expr="//t[@t-call='report.external_layout']" position="attributes">
      <attribute name="t-call">base_wua_report.wua_external_layout</attribute>
    </xpath>
  </template>

  <template id="report_electronic_file_form_styled"
            inherit_id="eom_eoffice.report_electronic_file_form_document"
            name="Electronic File Form Styled">

    <xpath expr="/t/div[@class='row'][1]" position="before">
      <t t-set="report_style" t-value="o.env['ir.values'].get_default('wua.configuration', 'reports_style')"/>
    </xpath>

    <xpath expr="/t/div[@class='row'][1]" position="replace">
      <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
        <t t-if="report_style == 'light'">
          <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid black; padding: 1px 16px;">
            <div style="float: left; width: 32px;"><span class="fa fa-folder-open"/></div>
            <div style="float: left; display: inline;">
              <strong>Electronic File:</strong>
              <span t-esc="o.name"/>
            </div>
          </div>
        </t>
        <t t-else="">
          <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
            <div style="float: left; width: 32px;"><span class="fa fa-folder-open"/></div>
            <div style="float: left; display: inline;">
              <strong>Electronic File:</strong>
              <span t-esc="o.name"/>
            </div>
          </div>
        </t>
      </div>
    </xpath>

    <xpath expr="//hr" position="replace"/>

    <xpath expr='//t[@t-if="o.type == &#39;01_generic_instance&#39;"]/div[1]' position="replace">
      <div style="margin-top:12px;">
        <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
          <t t-if="report_style == 'light'">
            <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid black; padding: 1px 16px;">
              <div style="float: left; width: 32px;"><span class="fa fa-info-circle"/></div>
              <div style="float: left; display: inline;"><strong>Exposition</strong></div>
            </div>
          </t>
          <t t-else="">
            <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
              <div style="float: left; width: 32px;"><span class="fa fa-info-circle"/></div>
              <div style="float: left; display: inline;"><strong>Exposition</strong></div>
            </div>
          </t>
        </div>
        <p><span t-esc="o.exposition"/></p>
      </div>
    </xpath>

    <xpath expr='//t[@t-if="o.type == &#39;01_generic_instance&#39;"]/div[2]' position="replace">
      <div style="margin-top:12px;">
        <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
          <t t-if="report_style == 'light'">
            <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid black; padding: 1px 16px;">
              <div style="float: left; width: 32px;"><span class="fa fa-hand-paper-o"/></div>
              <div style="float: left; display: inline;"><strong>Request</strong></div>
            </div>
          </t>
          <t t-else="">
            <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
              <div style="float: left; width: 32px;"><span class="fa fa-hand-paper-o"/></div>
              <div style="float: left; display: inline;"><strong>Request</strong></div>
            </div>
          </t>
        </div>
        <p><span t-esc="o.request"/></p>
      </div>
    </xpath>

    <xpath expr="//t[@t-if=&quot;o.type == '01_generic_instance'&quot;]/following-sibling::t[@t-else='']/div" position="replace">
      <div style="margin-top:12px;">
        <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
          <t t-if="report_style == 'light'">
            <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid black; padding: 1px 16px;">
              <div style="float: left; width: 32px;"><span class="fa fa-lightbulb-o"/></div>
              <div style="float: left; display: inline;"><strong>Suggestion</strong></div>
            </div>
          </t>
          <t t-else="">
            <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
              <div style="float: left; width: 32px;"><span class="fa fa-lightbulb-o"/></div>
              <div style="float: left; display: inline;"><strong>Suggestion</strong></div>
            </div>
          </t>
        </div>
        <p><span t-esc="o.suggestion"/></p>
      </div>
    </xpath>

    <xpath expr="//t[@t-if='o.resolution']/div" position="replace">
      <div style="margin-top:12px;">
        <div class="row h4 mt28 mb4" style="padding-bottom: 4px;">
          <t t-if="report_style == 'light'">
            <div class="col-xs-12 theme-report-color" style="border-bottom: 1px solid black; padding: 1px 16px;">
              <div style="float: left; width: 32px;"><span class="fa fa-gavel"/></div>
              <div style="float: left; display: inline;"><strong>Resolution</strong></div>
            </div>
          </t>
          <t t-else="">
            <div class="col-xs-12 bg-theme-report-color" style="color: white; padding: 1px 16px;">
              <div style="float: left; width: 32px;"><span class="fa fa-gavel"/></div>
              <div style="float: left; display: inline;"><strong>Resolution</strong></div>
            </div>
          </t>
        </div>
        <p><span t-esc="o.resolution"/></p>
      </div>
    </xpath>

  </template>
</odoo>
